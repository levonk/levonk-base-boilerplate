        let error = {{ crate_name | capitalize | replace('_', '') }}Error::validation("field", "message");
        assert!(matches!(error, {{ crate_name | capitalize | replace('_', '') }}Error::Validation { .. }));
        assert_eq!(error.category(), "validation");
