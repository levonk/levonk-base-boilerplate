validate:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "✅ Validating {{ package_name | default('typescript-package') }}..."
    
    # Run all validation checks
    just typecheck
    just lint
    just test
    
    echo "✅ Validation complete"

