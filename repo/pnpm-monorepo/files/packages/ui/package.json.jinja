{
  "name": "ui",
  "version": "0.1.0",
  "private": true,
  "description": "Shared UI components",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "dependencies": {
    "react": "*",
    "react-dom": "*",
    "@{{ monorepo_name }}/utils": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "*",
    "@types/react-dom": "*",
    "typescript": "*",
    "tsup": "*",
    "vitest": ">=4.1.0"
  },
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./types/*": "./src/types/*.ts"
  }
}
