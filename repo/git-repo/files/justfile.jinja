# Git repository specific implementations
bootstrap-internal:
    #!/usr/bin/env bash
    # Internal bootstrap logic called by devbox init_hook
    if ! command -v nix >/dev/null 2>&1; then
      echo "[bootstrap] Installing Nix..."
      curl -L https://nixos.org/nix/install | sh -s -- --daemon --yes
      echo "[bootstrap] Nix installed. Please restart your shell and run 'just bootstrap' again."
      exit 0
    fi
    if ! command -v direnv >/dev/null 2>&1; then
      echo "[bootstrap] Installing direnv via Nix..."
      nix profile add nixpkgs#direnv --extra-experimental-features "nix-command flakes"
      echo "[bootstrap] direnv installed."
    fi
    if ! command -v devbox >/dev/null 2>&1; then
      echo "[bootstrap] Installing devbox via Nix..."
      nix profile add nixpkgs#devbox --extra-experimental-features "nix-command flakes"
      echo "[bootstrap] devbox installed."
    fi
    if ! command -v just >/dev/null 2>&1; then
      echo "[bootstrap] Installing just via Nix..."
      nix profile add nixpkgs#just --extra-experimental-features "nix-command flakes"
      echo "[bootstrap] just installed."
    fi
    if [ -f "{{REPO_ROOT}}/.envrc" ]; then
      direnv allow "{{REPO_ROOT}}"
    fi
    echo "[bootstrap] Project bootstrap complete!"

