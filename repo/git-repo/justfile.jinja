# Git repository specific targets
init-repo:
    @echo "🔧 Initializing git repository..."
    git init
    @echo "✅ Git repository initialized"

setup-remote:
    @echo "🔧 Setting up remote repository..."
    @echo "TODO: Add remote setup logic for {{ project_name }}"
    
create-gh-pages:
    @echo "📄 Creating gh-pages branch..."
    @if ! git rev-parse --verify gh-pages >/dev/null 2>&1; then
        @git checkout --orphan gh-pages
        @git rm -rf . 2>/dev/null || true
        @echo "# {{ project_name }} Documentation" > README.md
        @git add README.md
        @git commit -m "Initial gh-pages commit"
        @git checkout main 2>/dev/null || git checkout -b main
        @echo "✅ gh-pages branch created"
    else
        @echo "ℹ️  gh-pages branch already exists"
    fi

check-git-hooks:
    @echo "🔍 Checking git hooks..."
    @if [ -d .git/hooks ]; then
        @find .git/hooks -name "*" -type f -exec echo "  - {}" \;
        @echo "✅ Git hooks found"
    else
        @echo "⚠️  No git hooks found"
    fi

check-gitignore:
    @echo "🔍 Checking .gitignore..."
    @if [ -f .gitignore ]; then
        @echo "✅ .gitignore found"
        @wc -l .gitignore
    else
        @echo "⚠️  No .gitignore found"
    fi
