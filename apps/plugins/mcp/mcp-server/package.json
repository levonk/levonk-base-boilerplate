{
  "name": "__APP_NAME__-mcp-server",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "build": "turbo run build",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@job-aide/mcp-server-kit": "workspace:*"
  },
  "devDependencies": {
    "@job-aide/tools-lint-eslint-config": "workspace:*",
    "@types/node": "*",
    "eslint": "*",
    "typescript": "*",
    "vitest": "*",
    "@antfu/ni": "*"
  },
  "modeline": "/* vim: set ft=json: */",
  "packageManager": "pnpm@*",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "*"
    },
    "packageManager": {
      "version": "*",
      "name": "pnpm"
    }
  },
  "engines": {
    "node": "*",
    "pnpm": "*"
  }
}
