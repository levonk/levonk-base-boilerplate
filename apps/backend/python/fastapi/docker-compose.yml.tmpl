version: "3.9"

services:
  {{ service_name | replace(" ", "-") | lower }}:
    build:
      context: .
      dockerfile: Dockerfile
    environment:
      - PUID=${PUID:-1000}
      - PGID=${PGID:-1000}
      - TZ=${TZ:-America/Los_Angeles}
      - NODE_ENV=production
      - PORT={{ port }}
    ports:
      - "{{ port }}:{{ port }}"
    restart: unless-stopped
