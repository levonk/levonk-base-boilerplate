{
  "name": "{{ package_name }}",
  "version": "0.0.1",
  "sha-version": "$Id$",
  "private": true,
  "description": "{{ description }}",
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "portless {{ package_name }} next dev --turbopack",
    "watchmode": "node --watch-path=. --watch-extensions=ts,tsx,js,jsx,json --eval 'console.log(\"Node watchmode active. Monitoring for changes...\")'",
    "build": "next build",
    "optimize-images": "node scripts/optimize-images.ts",
    "yakbak:record": "node scripts/yakbak-proxy.mjs",
    "yakbak:replay": "YAKBAK_NO_RECORD=1 node scripts/yakbak-proxy.mjs",
    "start": "next start",
    "export": "next build && next export",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf dist .next",
    "clean:hard": "rm -rf dist .next node_modules",
    "test": "vitest run",
    "test:performance": "vitest run --project performance",
    "test:integration": "vitest run --project integration",
    "test:e2e:requirements": "vitest run --project e2e-requirements",
    "test:e2e:usecases": "vitest run --project e2e-usecases",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:setup": "npx tsx lib/db/setup.ts",
    "db:seed": "npx tsx lib/db/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "next": "*",
    "@job-aide/tools-platform-next-config": "workspace:*",
    "@antfu/ni": "*",
    "react": "*",
    "better-auth": "^1.1.1",
    "@better-auth/drizzle-adapter": "^1.5.0-beta.9",
    "bcryptjs": "*",
    "better-all": "*",
    "class-variance-authority": "*",
    "clsx": "*",
    "dotenv": "*",
    "drizzle-kit": "*",
    "jose": "*",
    "lucide-react": "*",
    "only-allow": "*",
    "postgres": "*",
    "radix-ui": "*",
    "server-only": "*",
    "stripe": "*",
    "swr": "*",
    "tailwind-merge": "*",
    "tailwindcss": "*",
    "tw-animate-css": "*",
    "typescript": "*",
    "zod": "*"
  },
  "devDependencies": {
    "@antfu/ni": "*",
    "@browserbasehq/stagehand": "*",
    "@job-aide/tools-lint-eslint-config": "workspace:*",
    "@job-aide/tools-css-config": "workspace:*",
    "@tailwindcss/postcss": "*",
    "@testing-library/react": "*",
    "@testing-library/jest-dom": "*",
    "@testing-library/user-event": "*",
    "@tobilu/qmd": "*",
    "@types/node": "*",
    "@types/react": "*",
    "@types/react-dom": "*",
    "autoprefixer": "*",
    "boneyard-js": "*",
    "eslint": "*",
    "eslint-config-next": "*",
    "fallow": "*",
    "globby": "*",
    "imagemin": "*",
    "imagemin-mozjpeg": "*",
    "imagemin-pngquant": "*",
    "imagemin-webp": "*",
    "jsdom": "*",
    "modern-errors": "*",
    "modern-errors-beautiful": "*",
    "modern-errors-bugs": "*",
    "modern-errors-clean": "*",
    "modern-errors-cli": "*",
    "modern-errors-process": "*",
    "modern-errors-serialize": "*",
    "modern-errors-winston": "*",
    "only-allow": "*",
    "portless": "*",
    "postcss": "*",
    "skillman": "*",
    "skills-detector": "*",
    "tailwindcss": "*",
    "typescript": "*",
    "vitest": "*",
    "yakbak": "*"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "*"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "*"
    }
  },
  "engines": {
    "node": "*",
    "pnpm": "*"
  },
  "packageManager": "pnpm@*",
  "modeline": "/* vim: set ft=json: */"
}
