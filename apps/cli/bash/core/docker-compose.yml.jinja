version: '3.8'

services:
  cli:
    build: .
    image: {{ project_slug }}:latest
    entrypoint: ["/bin/bash", "/app/{{ project_slug }}.sh"]
    user: "1000:1000"
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    read_only: true
    tmpfs:
      - /tmp
    volumes:
      - .:/app:ro
    command: ["--help"]
