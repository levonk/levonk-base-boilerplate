from {{ project_slug }}.security import SecurityManager, mask_sensitive_data, is_sensitive_key
from {{ project_slug }}.resource import ResourceMonitor, get_resource_monitor
from unittest.mock import patch, MagicMock
import pytest


def test_security_manager_creation():
    """Test security manager can be created."""
    manager = SecurityManager()
    assert manager is not None


def test_mask_sensitive_data():
    """Test sensitive data masking."""
    data = "my_secret_password"
    masked = mask_sensitive_data(data)
    assert masked is not None
    assert data not in masked
    assert "*" in masked


def test_mask_short_data():
    """Test masking of short data."""
    data = "abc"
    masked = mask_sensitive_data(data)
    assert masked is not None
    assert len(masked) == len(data)


def test_mask_empty_data():
    """Test masking of empty data."""
    data = ""
    masked = mask_sensitive_data(data)
    assert masked == ""


def test_is_sensitive_key():
    """Test sensitive key detection."""
    assert is_sensitive_key("password") is True
    assert is_sensitive_key("api_key") is True
    assert is_sensitive_key("secret") is True
    assert is_sensitive_key("token") is True
    assert is_sensitive_key("username") is False
    assert is_sensitive_key("name") is False


def test_is_sensitive_key_case_insensitive():
    """Test sensitive key detection is case-insensitive."""
    assert is_sensitive_key("PASSWORD") is True
    assert is_sensitive_key("Api_Key") is True
    assert is_sensitive_key("SECRET") is True


