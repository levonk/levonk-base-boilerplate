def test_store_credential_fallback():
    """Test credential storage fallback when keyring unavailable."""
    with patch('{{ project_slug }}.security.SecurityManager._check_keyring_available', return_value=False):
        manager = SecurityManager()
        # This should use fallback (environment variable)
        result = manager.store_credential("test_service", "test_user", "test_pass")
        # Result depends on keyring availability
        assert isinstance(result, bool)


def test_get_credential_fallback():
    """Test credential retrieval fallback when keyring unavailable."""
    with patch('{{ project_slug }}.security.SecurityManager._check_keyring_available', return_value=False):
        manager = SecurityManager()
        # This should use fallback (environment variable)
        credential = manager.get_credential("test_service", "test_user")
        # Returns None if not found
        assert credential is None or isinstance(credential, str)


def test_delete_credential():
    """Test credential deletion."""
