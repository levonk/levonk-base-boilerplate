# Tests for structured error formatting
def test_structured_error_to_dict():
    """Test StructuredError to_dict conversion."""
    error = StructuredError("Test error", "Fix it", "ERR001", {"key": "value"})
    result = error.to_dict()

    assert result["error"] is True
    assert result["description"] == "Test error"
    assert result["suggestion"] == "Fix it"
    assert result["error_code"] == "ERR001"
    assert result["context"] == {"key": "value"}


def test_format_structured_error():
    """Test structured error formatting."""
