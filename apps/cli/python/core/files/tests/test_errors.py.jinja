# Tests for error translation and sanitization
def test_sanitize_error_message():
    """Test error message sanitization."""
    message = "pip install failed at 0x1234"
    result = sanitize_error_message(message)

    assert "pip" not in result
    assert "0x1234" not in result


def test_sanitize_dependency_name():
    """Test dependency name sanitization."""
    assert sanitize_dependency_name("pip") == "package manager"
    assert sanitize_dependency_name("npm") == "package manager"
    assert sanitize_dependency_name("requests") == "HTTP library"


def test_sanitize_path():
    """Test path sanitization."""
    path = "/usr/lib/python3.9/site-packages/requests/__init__.py"
    result = sanitize_path(path)

    assert "site-packages" not in result
    assert "<internal>" in result


def test_extract_actionable_suggestion():
    """Test actionable suggestion extraction."""
    error = FileNotFoundError("File not found")
    suggestion = extract_actionable_suggestion(error)

    assert "file path" in suggestion.lower()


def test_translate_error():
    """Test error translation."""
    error = FileNotFoundError("File not found: /tmp/test.txt")
    result = translate_error(error)

    assert result["error"] is True
    assert result["error_type"] == "FileNotFoundError"
    assert result["suggestion"]
    assert "File not found" in result["description"]


def test_translate_subprocess_error():
    """Test subprocess error translation."""
    result = translate_subprocess_error(
        returncode=1,
        stdout="",
        stderr="Command failed",
        command=["pip", "install", "requests"]
    )

    assert result["error"] is True
    assert result["returncode"] == 1
    assert "pip" not in str(result.get("command", ""))


# Tests for exit codes
def test_exit_code_constants():
    """Test exit code constants."""
    assert EXIT_SUCCESS == 0
    assert EXIT_ERROR == 1
    assert EXIT_USAGE == 2


def test_exit_code_get_description():
    """Test exit code description."""
    assert ExitCode.get_description(0) == "Success"
    assert ExitCode.get_description(1) == "Error"
    assert ExitCode.get_description(2) == "Usage error"


def test_determine_exit_code_success():
    """Test exit code determination for success."""
    result = {"status": "success"}
    assert determine_exit_code(result) == EXIT_SUCCESS


def test_determine_exit_code_noop():
    """Test exit code determination for no-op."""
    result = {"status": "noop"}
    assert determine_exit_code(result) == EXIT_SUCCESS


def test_determine_exit_code_error():
    """Test exit code determination for error."""
    result = {"error": True, "error_type": "GENERIC_ERROR"}
    assert determine_exit_code(result) == EXIT_ERROR


def test_determine_exit_code_usage():
    """Test exit code determination for usage error."""
    result = {"error": True, "error_type": "VALIDATION_ERROR"}
    assert determine_exit_code(result) == EXIT_USAGE


def test_determine_exit_code_from_exception():
    """Test exit code determination from exception."""
    error = ValueError("Invalid value")
    assert determine_exit_code_from_exception(error) == EXIT_USAGE


def test_determine_exit_code_from_subprocess():
    """Test exit code determination from subprocess."""
    assert determine_exit_code_from_subprocess(0) == EXIT_SUCCESS
    assert determine_exit_code_from_subprocess(1) == EXIT_ERROR
    assert determine_exit_code_from_subprocess(2) == EXIT_USAGE
    assert determine_exit_code_from_subprocess(127) == EXIT_USAGE


def test_should_exit_with_error():
    """Test should_exit_with_error."""
    assert should_exit_with_error({"status": "success"}) is False
    assert should_exit_with_error({"error": True}) is True


def test_format_exit_message():
    """Test exit message formatting."""
    result = {"error": True, "description": "Test", "suggestion": "Fix it"}
    message = format_exit_message(result, EXIT_ERROR)

    assert "Error" in message
    assert "Test" in message


def test_exit_with_code():
    """Test exit_with_code function."""
    result = {"status": "success"}
    exit_code = exit_with_code(result, show_message=False)

    assert exit_code == EXIT_SUCCESS
