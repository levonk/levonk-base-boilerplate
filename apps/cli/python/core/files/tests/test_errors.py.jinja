from {{ project_slug }}.errors import (
    format_error,
    format_file_reference_vscode,
    format_file_reference_standard,
    format_url,
    format_file_not_found_error,
    format_permission_denied_error,
    format_validation_error,
    format_network_error,
    format_config_error
)
from pathlib import Path
import pytest


def test_error_format():
    """Test error message format."""
    result = format_error("Test error", "Try this fix")
    assert result == "ERROR: Test error - Try this fix"


def test_file_reference_vscode():
    """Test VSCode-compatible file reference format."""
    file_path = Path("/tmp/test.txt")
    result = format_file_reference_vscode(file_path, line=10, column=5)
    assert "file:///" in result
    assert ":10" in result
    assert ":5" in result


def test_file_reference_standard():
    """Test standard file reference format."""
    file_path = Path("/tmp/test.txt")
    result = format_file_reference_standard(file_path, line=10, column=5)
    assert "/tmp/test.txt" in result
    assert ":10" in result
    assert ":5" in result


def test_url_formatting():
    """Test URL formatting."""
    result = format_url("https://example.com")
    assert result == "https://example.com"


def test_file_not_found_error():
    """Test file not found error formatting."""
    file_path = Path("/tmp/nonexistent.txt")
    result = format_file_not_found_error(file_path)
    assert "ERROR:" in result
    assert "File not found" in result
    assert "Check the file path" in result


def test_permission_denied_error():
    """Test permission denied error formatting."""
    file_path = Path("/tmp/no_perms.txt")
    result = format_permission_denied_error(file_path)
    assert "ERROR:" in result
    assert "Permission denied" in result
    assert "Check file permissions" in result


def test_validation_error():
    """Test validation error formatting."""
    result = format_validation_error("port", "abc", "Must be a number")
    assert "ERROR:" in result
    assert "Validation failed" in result
    assert "port" in result


def test_network_error():
    """Test network error formatting."""
    result = format_network_error("https://example.com", "Connection timeout")
    assert "ERROR:" in result
    assert "Network error" in result


def test_config_error():
    """Test config error formatting."""
    config_path = Path("/tmp/config.yaml")
    result = format_config_error(config_path, "Invalid YAML")
    assert "ERROR:" in result
    assert "Configuration error" in result
