from typer.testing import CliRunner
from {{ project_slug }}.__main__ import app
from {{ project_slug }}.completion import (
    install_completion,
    uninstall_completion,
    install_all_completions,
    uninstall_all_completions,
    generate_completion_script,
    get_completion_dir
)
