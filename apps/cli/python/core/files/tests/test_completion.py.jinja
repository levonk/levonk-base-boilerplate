def test_generate_invalid_shell():
    """Test invalid shell raises error."""
    try:
        generate_completion_script("invalid", app)
        assert False, "Should have raised ValueError"
    except ValueError as e:
        assert "Unsupported shell" in str(e)


def test_install_all_completions():
    """Test install all completions."""
    results = install_all_completions(app, force=True)
    assert "bash" in results
    assert "zsh" in results
    assert "fish" in results
    assert "man_page" in results


def test_get_completion_dir():
    """Test completion directory resolution."""
    completion_dir = get_completion_dir()
    assert completion_dir is not None
    assert completion_dir.exists()


def test_install_all_completions_old():
    """Test installing all shell completions (old signature for compatibility)."""
    results = install_all_completions(force=True)
    assert "bash" in results
    assert "zsh" in results
    assert "fish" in results
    # At least one should succeed
    assert any(results.values())


def test_uninstall_all_completions():
    """Test uninstalling all shell completions."""
    results = uninstall_all_completions()
    assert "bash" in results
    assert "zsh" in results
    assert "fish" in results


def test_generate_man_page():
    """Test man page generation."""
    man_content = generate_man_page()
    assert man_content is not None
    assert len(man_content) > 0
    assert "{{ project_slug }}" in man_content
    assert "{{ description }}" in man_content
    assert "NAME" in man_content
    assert "SYNOPSIS" in man_content
    assert "DESCRIPTION" in man_content
    assert "OPTIONS" in man_content


def test_get_man_page_dir():
    """Test man page directory resolution."""
    man_dir = get_man_page_dir()
    assert man_dir is not None
    assert man_dir.exists()


def test_install_man_page():
    """Test man page installation."""
    result = install_man_page(force=True)
    assert result is True


def test_uninstall_man_page():
    """Test man page uninstallation."""
    result = uninstall_man_page()
    assert result is True


def test_man_flag():
    """Test --man flag displays man page."""
    result = runner.invoke(app, ["--man"])
    assert result.exit_code == 0
    assert "{{ project_slug }}" in result.stdout
    assert "NAME" in result.stdout
