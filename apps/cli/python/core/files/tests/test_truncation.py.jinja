class TestApplyTruncation:
    """Test apply_truncation helper function."""
    
    def test_apply_truncation_string(self):
        """Test apply_truncation on string."""
        result = apply_truncation("0123456789abcdef", limit=10, full_output=False)
        
        assert isinstance(result, dict)
        assert result["truncated"] is True
    
    def test_apply_truncation_string_full(self):
        """Test apply_truncation on string with full_output=True."""
        result = apply_truncation("0123456789abcdef", limit=10, full_output=True)
        
        assert result == "0123456789abcdef"
    
    def test_apply_truncation_dict(self):
        """Test apply_truncation on dict."""
        data = {"description": "0123456789abcdef"}
        result = apply_truncation(data, limit=10, full_output=False)
        
        assert isinstance(result["description"], dict)
        assert result["description"]["truncated"] is True
    
    def test_apply_truncation_list(self):
        """Test apply_truncation on list."""
        data = ["0123456789abcdef", "short"]
        result = apply_truncation(data, limit=10, full_output=False)
        
        assert isinstance(result[0], dict)
        assert result[0]["truncated"] is True
        assert result[1] == "short"


class TestTruncationEdgeCases:
    """Test edge cases for truncation."""
    
    def test_unicode_text(self):
        """Test truncation with unicode characters."""
        truncator = Truncator(limit=10)
        text = "Hello 世界 🌍"
        result = truncator.truncate(text)
        
        # Unicode characters should be handled correctly
        assert result.original_length == len(text)
    
    def test_very_long_text(self):
        """Test truncation of very long text."""
        truncator = Truncator(limit=1000)
        text = "a" * 10000
        result = truncator.truncate(text)
        
        assert result.was_truncated is True
        assert result.truncated_length == 1000
        assert result.original_length == 10000
    
    def test_zero_limit(self):
        """Test truncation with zero limit."""
        truncator = Truncator(limit=0)
        text = "test"
        result = truncator.truncate(text)
        
        # With zero limit, should still show ellipsis
        assert result.was_truncated is True
    
    def test_multiline_text(self):
        """Test truncation of multiline text."""
        truncator = Truncator(limit=20)
        text = "line1\nline2\nline3\nline4"
        result = truncator.truncate(text)
        
        assert result.was_truncated is True
        assert "\n" in result.truncated_text or len(result.truncated_text) <= 20
