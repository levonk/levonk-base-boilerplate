def test_generate_suggestions_for_process_empty():
    """Test generating suggestions for empty results."""
    output = {
        "results": [],
    }
    
    suggestions = generate_suggestions_for_process(output)
    
    assert len(suggestions) > 0
    assert any("create" in s.command for s in suggestions)


def test_generate_suggestions_for_process_with_results():
    """Test generating suggestions with results."""
    output = {
        "results": [{"source": "test.txt"}],
    }
    
    suggestions = generate_suggestions_for_process(output)
    
    assert len(suggestions) > 0
    assert any("view" in s.command for s in suggestions)


def test_rank_suggestions():
    """Test ranking suggestions by relevance."""
    suggestions = [
        Suggestion("cmd1", "desc1", relevance=1),
        Suggestion("cmd2", "desc2", relevance=3),
        Suggestion("cmd3", "desc3", relevance=2),
    ]
    
    ranked = rank_suggestions(suggestions)
    
    assert ranked[0].relevance == 3
    assert ranked[1].relevance == 2
    assert ranked[2].relevance == 1


def test_limit_suggestions():
    """Test limiting suggestions count."""
    suggestions = [
        Suggestion(f"cmd{i}", f"desc{i}", relevance=i)
        for i in range(10)
    ]
    
    limited = limit_suggestions(suggestions, max_count=4)
    
    assert len(limited) == 4


def test_format_suggestions_toon():
    """Test formatting suggestions in TOON."""
    suggestions = [
        Suggestion("test command", "test description", relevance=3),
    ]
    
    toon = format_suggestions_toon(suggestions)
    
    assert "help[" in toon
    assert "test command" in toon
    assert "test description" in toon


def test_format_suggestions_toon_empty():
    """Test formatting empty suggestions in TOON."""
    toon = format_suggestions_toon([])
    
    assert toon == ""


