# vim: set ft=python :
"""Tests for contextual disclosure with next steps suggestions."""

import pytest
from {{project_slug}}.suggestions import (
    Suggestion,
    generate_suggestions_for_noargs,
    generate_suggestions_for_process,
    rank_suggestions,
    limit_suggestions,
    format_suggestions_toon,
    get_contextual_suggestions,
    format_suggestions,
)


def test_suggestion_creation():
    """Test creating a suggestion."""
    suggestion = Suggestion("test command", "test description", relevance=3)
    
    assert suggestion.command == "test command"
    assert suggestion.description == "test description"
    assert suggestion.relevance == 3


def test_suggestion_to_dict():
    """Test converting suggestion to dictionary."""
    suggestion = Suggestion("test command", "test description", relevance=3)
    result = suggestion.to_dict()
    
    assert result["command"] == "test command"
    assert result["description"] == "test description"
    assert "relevance" not in result  # relevance not included in dict


def test_generate_suggestions_for_noargs_git_repo():
    """Test generating suggestions for git repository."""
    context = {
        "exists": True,
        "is_dir": True,
        "is_git_repo": True,
        "has_files": True,
    }
    
    suggestions = generate_suggestions_for_noargs(context)
    
    assert len(suggestions) > 0
    assert any("git-status" in s.command for s in suggestions)


