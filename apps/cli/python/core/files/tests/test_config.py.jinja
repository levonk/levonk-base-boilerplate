    def test_full_config_precedence_chain(self):
        """Test full precedence: CLI args > env vars > local > user > defaults."""
        {% if include_advanced_config %}
        import os
        import tempfile

        with tempfile.TemporaryDirectory() as temp_dir:
            # Create user config
            user_config_path = Path(temp_dir) / "user_config.toml"
            user_config_path.write_text("""
version = 1
log_level = "debug"
color = "never"
""")

            # Create local config
            local_config_path = Path(temp_dir) / "local_config.toml"
            local_config_path.write_text("""
version = 1
log_level = "info"
color = "always"
""")

            # Set environment variable
            os.environ["{{ project_slug | upper | replace('-', '_') }}_LOG_LEVEL"] = "warn"

            try:
                # Initialize logger before creating ConfigManager
                from {{ project_slug }}.logging import configure_logging, get_logger
                configure_logging(name="{{ project_slug }}", quiet=True)

                manager = ConfigManager()
                manager._load_defaults()  # log_level = "info", color = "auto"

                # Load user config (should override defaults)
                manager._load_from_file(user_config_path, ConfigSource.USER)
                assert manager.config.log_level == "debug"
                assert manager.config.color == "never"

                # Load local config (should override user)
                manager._load_from_file(local_config_path, ConfigSource.LOCAL)
                assert manager.config.log_level == "info"
                assert manager.config.color == "always"

                # Load environment (should override local)
                manager._load_environment()
                assert manager.config.log_level == "warn"
                assert manager.config.color == "always"  # Not set in env, stays from local

                # Simulate CLI arg (should override env)
                # CLI sets both log_level and color to override all previous sources
                manager._merge_config(ConfigModel(log_level="error", color="always"), ConfigSource.COMMAND_LINE)
                assert manager.config.log_level == "error"
                assert manager.config.color == "always"

            finally:
                if "{{ project_slug | upper | replace('-', '_') }}_LOG_LEVEL" in os.environ:
                    del os.environ["{{ project_slug | upper | replace('-', '_') }}_LOG_LEVEL"]
        {% else %}
        # Skip test if advanced config not enabled
        pytest.skip("Advanced config not enabled")
        {% endif %}
