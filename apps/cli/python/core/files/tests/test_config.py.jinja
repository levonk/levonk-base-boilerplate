    def test_merge_config(self):
        """Test configuration merging with precedence."""
        manager = ConfigManager()
        new_config = ConfigModel(log_level="debug", color="never")
        manager._merge_config(new_config, ConfigSource.USER)
        assert manager.config.log_level == "debug"
        assert manager.config.color == "never"
        # Default values should remain
        assert manager.config.output_format == "text"

