class TestConfigModel:
    """Test ConfigModel validation."""

    def test_default_config(self):
        """Test default configuration values."""
        config = ConfigModel()
        assert config.version == 1
        assert config.mode == "agent"
        assert config.default_format == "toon"
        assert config.truncation_limit == 1000
        assert config.fields_default == []
        assert config.log_level == "info"
        assert config.color == "auto"
        assert config.output_format == "text"
        assert config.quiet is False
        assert config.max_concurrent == 4
        assert config.timeout == 30
        assert config.experimental is False

    def test_invalid_log_level(self):
        """Test validation rejects invalid log level."""
        with pytest.raises(ValueError) as exc_info:
            ConfigModel(log_level="invalid")
        assert "Invalid log_level" in str(exc_info.value)

    def test_invalid_color(self):
        """Test validation rejects invalid color mode."""
        with pytest.raises(ValueError) as exc_info:
            ConfigModel(color="invalid")
        assert "Invalid color mode" in str(exc_info.value)

    def test_invalid_output_format(self):
        """Test validation rejects invalid output format."""
        with pytest.raises(ValueError) as exc_info:
            ConfigModel(output_format="invalid")
        assert "Invalid output_format" in str(exc_info.value)

    def test_invalid_max_concurrent(self):
        """Test validation rejects zero max_concurrent."""
        with pytest.raises(ValueError) as exc_info:
            ConfigModel(max_concurrent=0)
        assert "max_concurrent must be greater than 0" in str(exc_info.value)

    def test_invalid_timeout(self):
        """Test validation rejects zero timeout."""
        with pytest.raises(ValueError) as exc_info:
            ConfigModel(timeout=0)
        assert "timeout must be greater than 0" in str(exc_info.value)

    def test_invalid_mode(self):
        """Test validation rejects invalid mode."""
        with pytest.raises(ValueError) as exc_info:
            ConfigModel(mode="invalid")
        assert "Invalid mode" in str(exc_info.value)

    def test_invalid_default_format(self):
        """Test validation rejects invalid default_format."""
        with pytest.raises(ValueError) as exc_info:
            ConfigModel(default_format="invalid")
        assert "Invalid default_format" in str(exc_info.value)

    def test_invalid_truncation_limit(self):
        """Test validation rejects zero truncation_limit."""
        with pytest.raises(ValueError) as exc_info:
            ConfigModel(truncation_limit=0)
        assert "truncation_limit must be greater than 0" in str(exc_info.value)


