    def test_parse_toml_config(self):
        """Test parsing TOML configuration."""
        toml_content = """
version = 1
log_level = "debug"
color = "never"
output_format = "json"
quiet = true
max_concurrent = 8
timeout = 60
experimental = true
"""
        with tempfile.NamedTemporaryFile(mode='w', suffix='.toml', delete=False) as f:
            f.write(toml_content)
            temp_path = Path(f.name)

        try:
            manager = ConfigManager()
            config = manager._parse_config(toml_content, temp_path)
            assert config.log_level == "debug"
            assert config.color == "never"
            assert config.output_format == "json"
            assert config.quiet is True
            assert config.max_concurrent == 8
            assert config.timeout == 60
            assert config.experimental is True
        finally:
            temp_path.unlink()

    def test_parse_toml_config_with_agent_mode(self):
        """Test parsing TOML configuration with agent mode settings."""
        toml_content = """
version = 1
mode = "human"
default_format = "json"
truncation_limit = 500
fields_default = ["id", "name", "status"]
log_level = "debug"
color = "never"
"""
        with tempfile.NamedTemporaryFile(mode='w', suffix='.toml', delete=False) as f:
            f.write(toml_content)
            temp_path = Path(f.name)

        try:
            manager = ConfigManager()
            config = manager._parse_config(toml_content, temp_path)
            assert config.mode == "human"
            assert config.default_format == "json"
            assert config.truncation_limit == 500
            assert config.fields_default == ["id", "name", "status"]
            assert config.log_level == "debug"
            assert config.color == "never"
        finally:
            temp_path.unlink()

    def test_parse_invalid_toml(self):
        """Test parsing invalid TOML raises error."""
        invalid_toml = "invalid [ toml content"
