    def test_migrate_config(self):
        """Test configuration migration with backup."""
        with tempfile.TemporaryDirectory() as temp_dir:
            config_path = Path(temp_dir) / "config.toml"

            # Write old version config
            old_content = """
version = 0
log_level = "debug"
"""
            config_path.write_text(old_content)

            old_config = ConfigModel(version=0, log_level="debug")
            manager = ConfigManager()
            manager._migrate_config(config_path, old_config)

            # Check backup was created
            backup_path = config_path.with_suffix(".toml.bak")
            assert backup_path.exists()

            # Check new config has updated version
            new_content = config_path.read_text()
            assert "version = 1" in new_content

            # Clean up
            backup_path.unlink()

    def test_migrate_config_agent_mode(self):
        """Test configuration migration adds agent mode settings."""
        with tempfile.TemporaryDirectory() as temp_dir:
            config_path = Path(temp_dir) / "config.toml"

            # Write old version config without agent mode settings
            old_content = """
version = 0
log_level = "debug"
color = "never"
"""
            config_path.write_text(old_content)

            old_config = ConfigModel(version=0, log_level="debug", color="never")
            manager = ConfigManager()
            manager._migrate_config(config_path, old_config)

            # Check backup was created
            backup_path = config_path.with_suffix(".toml.bak")
            assert backup_path.exists()

            # Check new config has agent mode settings with defaults
            new_content = config_path.read_text()
            assert "version = 1" in new_content
            assert "mode = \"agent\"" in new_content
            assert "default_format = \"toon\"" in new_content
            assert "truncation_limit = 1000" in new_content

            # Clean up
            backup_path.unlink()

