def test_detect_log_format_tty():
    """Test format auto-detection returns human for TTY."""
    # This test depends on the environment
    format_type = detect_log_format()
    assert format_type in ["human", "json"]


def test_detect_log_format_non_tty():
    """Test format auto-detection returns json for non-TTY."""
    # Mock non-TTY environment
    original_stdout = sys.stdout
    original_stderr = sys.stderr

    class MockStream:
        def isatty(self):
            return False

    sys.stdout = MockStream()
    sys.stderr = MockStream()

    try:
        format_type = detect_log_format()
        assert format_type == "json"
    finally:
        sys.stdout = original_stdout
        sys.stderr = original_stderr


def test_resolve_log_level_env_var():
    """Test log level resolution with environment variable."""
    os.environ["LOG_LEVEL"] = "DEBUG"
