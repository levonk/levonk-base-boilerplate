import signal
import pytest


def test_handle_sighup_sets_reload_flag():
    """Test SIGHUP handler sets reload flag."""
    import {{ project_slug }}.__main__ as main_module
    main_module._config_needs_reload = False

    from {{ project_slug }}.__main__ import handle_sighup
    handle_sighup(signal.SIGHUP, None)

    assert main_module._config_needs_reload is True


def test_reload_config_returns_true():
    """Test reload_config returns True on success."""
    from {{ project_slug }}.__main__ import reload_config
    result = reload_config()
    assert result is True


def test_reload_config_clears_flag():
    """Test reload_config clears the reload flag."""
    import {{ project_slug }}.__main__ as main_module
    main_module._config_needs_reload = True

    from {{ project_slug }}.__main__ import reload_config
    reload_config()

    assert main_module._config_needs_reload is False
