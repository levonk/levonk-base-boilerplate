def test_exit_code_constants():
    """Test all exit code constants are defined."""
    from {{ project_slug }}.__main__ import (
        EXIT_SUCCESS,
        EXIT_ERROR,
        EXIT_USAGE,
        EXIT_NETWORK_ERROR,
        EXIT_VALIDATION_ERROR,
        EXIT_FILE_NOT_FOUND,
        EXIT_PERMISSION_DENIED,
        EXIT_SIGINT
    )
    assert EXIT_SUCCESS == 0
    assert EXIT_ERROR == 1
    assert EXIT_USAGE == 2
    assert EXIT_NETWORK_ERROR == 3
    assert EXIT_VALIDATION_ERROR == 4
    assert EXIT_FILE_NOT_FOUND == 5
    assert EXIT_PERMISSION_DENIED == 6
    assert EXIT_SIGINT == 130

