def test_stdin_processing():
    result = runner.invoke(app, ["-", "--json"], input="test content")
    assert result.exit_code == 0
    assert "stdin" in result.stdout
    assert "processed" in result.stdout

def test_json_output_format():
    """Test JSON output format is valid JSON."""
    result = runner.invoke(app, ["-", "--json"], input="test content")
    assert result.exit_code == 0
    import json
    data = json.loads(result.stdout)
    assert isinstance(data, list)
    assert len(data) > 0
    assert "source" in data[0]

def test_human_output_format():
    """Test human output format is readable text."""
    result = runner.invoke(app, ["-"], input="test content")
    assert result.exit_code == 0
    # Human output should not be JSON
    import json
    try:
        json.loads(result.stdout)
        assert False, "Human output should not be valid JSON"
    except json.JSONDecodeError:
        # Expected - human output is not JSON
        pass

def test_file_processing(tmp_path):
    f = tmp_path / "test.txt"
    f.write_text("content")

    result = runner.invoke(app, [str(f), "--json"])
    assert result.exit_code == 0
    assert str(f) in result.stdout

def test_globbing_pattern(tmp_path):
    """Test globbing pattern with *.txt."""
    (tmp_path / "file1.txt").write_text("content1")
    (tmp_path / "file2.txt").write_text("content2")

    result = runner.invoke(app, [str(tmp_path / "*.txt"), "--json", "--quiet"])
    assert result.exit_code == 0

def test_recursive_globbing(tmp_path):
    """Test recursive globbing with **/* pattern."""
    subdir = tmp_path / "subdir"
    subdir.mkdir()
    (tmp_path / "file1.txt").write_text("content1")
    (subdir / "file2.txt").write_text("content2")

    result = runner.invoke(app, [str(tmp_path / "**/*.txt"), "--json", "--quiet"])
    assert result.exit_code == 0

def test_globbing_no_matches(tmp_path):
    """Test globbing pattern with no matches."""
    result = runner.invoke(app, [str(tmp_path / "*.txt"), "--quiet"])
    # Should exit with success even if no files found (warning logged)
    assert result.exit_code in (0, 5)

