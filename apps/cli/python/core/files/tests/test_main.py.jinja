def test_exit_code_file_not_found(tmp_path):
    """Test exit code for file not found error."""
    nonexistent = tmp_path / "nonexistent.txt"
    result = runner.invoke(app, [str(nonexistent)])
    assert result.exit_code == 5  # EXIT_FILE_NOT_FOUND

def test_exit_code_permission_denied(tmp_path):
    """Test exit code for permission denied error."""
    # Create a file with no read permissions
    f = tmp_path / "no_perms.txt"
    f.write_text("content")
    f.chmod(0o000)

    result = runner.invoke(app, [str(f)])
    # Should exit with permission denied code (6) or error (1) depending on OS
    assert result.exit_code in (1, 6)

