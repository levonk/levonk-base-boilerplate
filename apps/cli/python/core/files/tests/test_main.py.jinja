def test_debug_flag():
    """Test --debug flag enables debug logging."""
    result = runner.invoke(app, ["-", "--debug"], input="test content")
    assert result.exit_code == 0
    # Debug flag should be accepted without error

def test_debug_vs_verbose():
    """Test that debug provides more detailed output than verbose."""
    # Debug should enable DEBUG level logging
    # Verbose should enable INFO level logging
    # This test verifies the flags are accepted and don't conflict
    result_debug = runner.invoke(app, ["-", "--debug"], input="test content")
    result_verbose = runner.invoke(app, ["-", "--verbose"], input="test content")
    assert result_debug.exit_code == 0
    assert result_verbose.exit_code == 0

def test_verbose_flag():
    """Test --verbose flag enables verbose logging."""
    result = runner.invoke(app, ["-", "--verbose"], input="test content")
    assert result.exit_code == 0
    # Verbose flag should be accepted without error

def test_exit_code_file_not_found(tmp_path):
    """Test exit code for file not found error."""
    nonexistent = tmp_path / "nonexistent.txt"
    result = runner.invoke(app, [str(nonexistent)])
    assert result.exit_code == 5  # EXIT_FILE_NOT_FOUND

def test_exit_code_permission_denied(tmp_path):
    """Test exit code for permission denied error."""
    # Create a file with no read permissions
    f = tmp_path / "no_perms.txt"
    f.write_text("content")
    f.chmod(0o000)

    result = runner.invoke(app, [str(f)])
    # Should exit with permission denied code (6) or error (1) depending on OS
    assert result.exit_code in (1, 6)

