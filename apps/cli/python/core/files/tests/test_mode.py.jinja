from {{ project_slug }}.mode import (
    Mode, DetectionMethod, is_tty, detect_agent_session,
    detect_agent_parent_process, auto_detect_mode, get_mode_from_env,
    get_mode_from_config, determine_mode, is_agent_mode, is_human_mode
)
import pytest
import os


def test_mode_enum():
    """Test Mode enum values."""
    assert Mode.AGENT.value == "agent"
    assert Mode.HUMAN.value == "human"


def test_detection_method_enum():
    """Test DetectionMethod enum values."""
    assert DetectionMethod.AUTO_DETECT.value == "auto_detect"
    assert DetectionMethod.CLI_FLAG.value == "cli_flag"
    assert DetectionMethod.ENV_VAR.value == "env_var"
    assert DetectionMethod.CONFIG.value == "config"


def test_is_tty():
    """Test TTY detection."""
    result = is_tty()
    assert isinstance(result, bool)


def test_detect_agent_session():
    """Test agent session detection via environment variables."""
    result = detect_agent_session()
    assert isinstance(result, bool)


def test_detect_agent_session_with_env():
    """Test agent session detection with CLAUDE_SESSION set."""
    original = os.environ.get("CLAUDE_SESSION")
    try:
        os.environ["CLAUDE_SESSION"] = "1"
        result = detect_agent_session()
        assert result is True
    finally:
        if original is None:
            os.environ.pop("CLAUDE_SESSION", None)
        else:
            os.environ["CLAUDE_SESSION"] = original


def test_detect_agent_parent_process():
    """Test agent parent process detection."""
    result = detect_agent_parent_process()
    assert isinstance(result, bool)


def test_auto_detect_mode():
    """Test automatic mode detection."""
    mode = auto_detect_mode()
    assert isinstance(mode, Mode)
    assert mode in [Mode.AGENT, Mode.HUMAN]


def test_get_mode_from_env():
    """Test getting mode from environment variable."""
