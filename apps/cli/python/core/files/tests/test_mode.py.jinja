def test_determine_mode_precedence():
    """Test mode determination precedence chain."""
    env_var = "{{ project_slug|upper|replace('-', '_') }}_MODE"
    original = os.environ.get(env_var)
    try:
        os.environ[env_var] = "human"
        # CLI flag should override env var
        mode, method = determine_mode(cli_flag=Mode.AGENT)
        assert mode == Mode.AGENT
        assert method == DetectionMethod.CLI_FLAG
    finally:
        if original is None:
            os.environ.pop(env_var, None)
        else:
            os.environ[env_var] = original


def test_is_agent_mode():
    """Test checking if mode is agent mode."""
    assert is_agent_mode(Mode.AGENT) is True
    assert is_agent_mode(Mode.HUMAN) is False


def test_is_human_mode():
    """Test checking if mode is human mode."""
    assert is_human_mode(Mode.HUMAN) is True
    assert is_human_mode(Mode.AGENT) is False
