def test_operation_execute_create_noop():
    """Test operation execution with no-op (state already exists)."""
    def execute_func():
        return {"status": "created"}
    
    def check_state_func():
        return {"status": "already_exists"}
    
    op = Operation(
        name="test_create",
        op_type=OperationType.CREATE,
        execute_func=execute_func,
        check_state_func=check_state_func
    )
    
    result = op.execute(desired_state={"status": "already_exists"})
    
    assert result["status"] == "noop"
    assert "already in desired state" in result["message"]


def test_operation_execute_create_actual():
    """Test operation execution with actual create."""
    def execute_func():
        return {"status": "created"}
    
    def check_state_func():
        return {"status": "not_exists"}
    
    op = Operation(
        name="test_create",
        op_type=OperationType.CREATE,
        execute_func=execute_func,
        check_state_func=check_state_func
    )
    
    result = op.execute(desired_state={"status": "created"})
    
    assert result["status"] == "success"
    assert "completed successfully" in result["message"]


