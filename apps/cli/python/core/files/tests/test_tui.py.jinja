from {{ project_slug }}.tui import CLIArguments, launch_tui, confirm_execution
import pytest


def test_cli_arguments_creation():
    """Test CLIArguments dataclass creation."""
    args = CLIArguments(
        inputs=["file.txt"],
        config="/path/to/config",
        json_output=True,
        quiet=False
    )
    assert args.inputs == ["file.txt"]
    assert args.config == "/path/to/config"
    assert args.json_output is True
    assert args.quiet is False


def test_launch_tui():
    """Test TUI launch function."""
    args = CLIArguments(inputs=["file.txt"])
    result = launch_tui(args)
    assert isinstance(result, CLIArguments)
    # Placeholder implementation returns args unchanged
    assert result.inputs == args.inputs


