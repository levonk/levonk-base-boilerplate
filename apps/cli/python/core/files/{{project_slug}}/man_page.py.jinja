'''
    return man_content


def get_man_page_dir() -> Path:
    """
    Get the platform-specific man page directory.

    Returns:
        Path to man page directory
    """
    # Use platform-specific man page directory
    man_dir = Path(user_data_dir("man", appauthor="{{ project_slug }}")) / "man1"
    man_dir.mkdir(parents=True, exist_ok=True)
    return man_dir


def install_man_page(force: bool = False) -> bool:
    """
    Install man page to platform-specific location.

    Args:
        force: If True, overwrite existing man page

    Returns:
        True if installation succeeded, False otherwise
    """
    try:
        man_dir = get_man_page_dir()
        man_content = generate_man_page()
        man_file = man_dir / "{{ project_slug }}.1"

        # Check if file exists
        if man_file.exists() and not force:
            logger.warn(f"Man page already exists: {man_file}", module="man")
            logger.warn("Use --force to overwrite", module="man")
            return False

        # Write man page
        man_file.write_text(man_content)
        logger.info(f"Installed man page to {man_file}", module="man")
        logger.info("Add man page directory to MANPATH or copy to system man path", module="man")
        return True

    except Exception as e:
        logger.error(f"Failed to install man page: {e}", module="man")
        return False


def uninstall_man_page() -> bool:
    """
    Uninstall man page from platform-specific location.

    Returns:
        True if uninstallation succeeded, False otherwise
    """
    try:
        man_dir = get_man_page_dir()
        man_file = man_dir / "{{ project_slug }}.1"

        # Check if file exists
        if not man_file.exists():
            logger.warn(f"Man page not found: {man_file}", module="man")
            return False

        # Remove man page
        man_file.unlink()
        logger.info(f"Removed man page from {man_file}", module="man")
        return True

    except Exception as e:
        logger.error(f"Failed to uninstall man page: {e}", module="man")
        return False


def print_man_page() -> None:
    """Print man page content to stdout."""
    try:
        man_content = generate_man_page()
        print(man_content)
    except Exception as e:
        logger.error(f"Failed to generate man page: {e}", module="man")
