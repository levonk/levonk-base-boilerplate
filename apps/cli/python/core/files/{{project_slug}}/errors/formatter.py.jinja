"""Structured error formatting for CLI output.

This module provides utilities for formatting errors in a structured format
that goes to stdout (not stderr) in the same format as normal output.
Errors include what went wrong and actionable suggestions.
"""

from typing import Any, Dict, Optional


class StructuredError:
    """Represents a structured error with description and suggestion."""
    
    def __init__(
        self,
        description: str,
        suggestion: str,
        error_code: Optional[str] = None,
        context: Optional[Dict[str, Any]] = None
    ):
        """Initialize a structured error.
        
        Args:
            description: What went wrong
            suggestion: Actionable suggestion to fix the error
            error_code: Optional error code for programmatic handling
            context: Optional additional context about the error
        """
        self.description = description
        self.suggestion = suggestion
        self.error_code = error_code
        self.context = context or {}
    
    def to_dict(self) -> Dict[str, Any]:
        """Convert error to dictionary format.
        
        Returns:
            Dictionary representation of the error
        """
        result = {
            "error": True,
            "description": self.description,
            "suggestion": self.suggestion
        }
        
        if self.error_code:
            result["error_code"] = self.error_code
        
        if self.context:
            result["context"] = self.context
        
        return result


def format_structured_error(
    description: str,
    suggestion: str,
    error_code: Optional[str] = None,
    context: Optional[Dict[str, Any]] = None
) -> Dict[str, Any]:
    """Format an error in structured format for stdout.
    
    This function formats errors in the same structured format as normal
    output, ensuring consistency for agent mode parsing.
    
    Args:
        description: What went wrong
        suggestion: Actionable suggestion to fix the error
        error_code: Optional error code for programmatic handling
        context: Optional additional context about the error
        
    Returns:
        Structured error dictionary
    """
    error = StructuredError(description, suggestion, error_code, context)
    return error.to_dict()


def format_validation_error(
    field: str,
    value: str,
    reason: str,
    suggestion: Optional[str] = None
) -> Dict[str, Any]:
    """Format a validation error in structured format.
    
    Args:
        field: The field that failed validation
        value: The invalid value
        reason: The reason for validation failure
        suggestion: Optional specific suggestion (auto-generated if not provided)
        
    Returns:
        Structured error dictionary
    """
    if suggestion is None:
        suggestion = f"Provide a valid value for {field}"
    
    return format_structured_error(
        description=f"Validation failed for {field}: {value}",
        suggestion=f"{reason}. {suggestion}",
        error_code="VALIDATION_ERROR",
        context={"field": field, "value": value, "reason": reason}
    )


def format_missing_required_error(
    field: str,
    suggestion: Optional[str] = None
) -> Dict[str, Any]:
    """Format a missing required field error in structured format.
    
    Args:
        field: The missing required field
        suggestion: Optional specific suggestion (auto-generated if not provided)
        
    Returns:
        Structured error dictionary
    """
    if suggestion is None:
        suggestion = f"Provide the required --{field} flag"
    
    return format_structured_error(
        description=f"Missing required field: {field}",
        suggestion=suggestion,
        error_code="MISSING_REQUIRED",
        context={"field": field}
    )


