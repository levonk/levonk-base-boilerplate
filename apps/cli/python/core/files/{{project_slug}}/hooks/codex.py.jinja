"""Codex hook installation.

This module provides utilities for installing session hooks for Codex.
"""

from pathlib import Path
from typing import Dict, Any, Optional
from {{project_slug}}.hooks.installer import (
    install_hook,
    uninstall_hook,
    get_current_executable,
)


def get_codex_hook_path() -> Path:
    """Get the path to Codex's session-end hook.
    
    Returns:
        Path to the hook file
    """
    # Codex stores hooks in ~/.codex/hooks/
    home = Path.home()
    hooks_dir = home / ".codex" / "hooks"
    return hooks_dir / "session-end"


def generate_codex_hook_content(executable_path: str) -> str:
    """Generate Codex session-end hook content.
    
    Args:
        executable_path: Path to the CLI executable
        
    Returns:
        Hook script content
    """
    return f"""#!/bin/bash
# Codex session-end hook
# Generated by {{ project_slug }}

# Run session context command
{executable_path} session-context
"""


def install_codex_hook(executable_path: Optional[str] = None) -> Dict[str, Any]:
    """Install Codex session-end hook.
    
    Args:
        executable_path: Optional path to CLI executable. Auto-detected if None.
        
    Returns:
        Result dictionary with status and details
    """
    if executable_path is None:
        executable_path = get_current_executable()
    
    hook_path = get_codex_hook_path()
    hook_content = generate_codex_hook_content(executable_path)
    
    return install_hook(hook_path, hook_content, executable_path)


def uninstall_codex_hook() -> Dict[str, Any]:
    """Uninstall Codex session-end hook.
    
    Returns:
        Result dictionary with status and details
    """
    hook_path = get_codex_hook_path()
    return uninstall_hook(hook_path)
