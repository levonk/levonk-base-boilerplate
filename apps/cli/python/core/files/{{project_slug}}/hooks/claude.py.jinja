"""Claude Code hook installation.

This module provides utilities for installing session hooks for Claude Code.
"""

from pathlib import Path
from typing import Dict, Any, Optional
from {{project_slug}}.hooks.installer import (
    install_hook,
    uninstall_hook,
    get_current_executable,
)


def get_claude_hook_path() -> Path:
    """Get the path to Claude Code's session-end hook.
    
    Returns:
        Path to the hook file
    """
    # Claude Code stores hooks in ~/.claude/hooks/
    home = Path.home()
    hooks_dir = home / ".claude" / "hooks"
    return hooks_dir / "session-end"


def generate_claude_hook_content(executable_path: str) -> str:
    """Generate Claude Code session-end hook content.
    
    Args:
        executable_path: Path to the CLI executable
        
    Returns:
        Hook script content
    """
    return f"""#!/bin/bash
# Claude Code session-end hook
# Generated by {{ project_slug }}

# Run session context command
{executable_path} session-context
"""


def install_claude_hook(executable_path: Optional[str] = None) -> Dict[str, Any]:
    """Install Claude Code session-end hook.
    
    Args:
        executable_path: Optional path to CLI executable. Auto-detected if None.
        
    Returns:
        Result dictionary with status and details
    """
    if executable_path is None:
        executable_path = get_current_executable()
    
    hook_path = get_claude_hook_path()
    hook_content = generate_claude_hook_content(executable_path)
    
    return install_hook(hook_path, hook_content, executable_path)


def uninstall_claude_hook() -> Dict[str, Any]:
    """Uninstall Claude Code session-end hook.
    
    Returns:
        Result dictionary with status and details
    """
    hook_path = get_claude_hook_path()
    return uninstall_hook(hook_path)
