# vim: set ft=python :
import sys
import signal
import glob
import json
from pathlib import Path
from typing import List, Optional
import typer
from rich.console import Console
from platformdirs import user_config_dir

from {{ project_slug }}.logging import configure_logging, get_logger
from {{ project_slug }}.completion import install_all_completions, uninstall_all_completions
from {{ project_slug }}.errors import format_file_not_found_error, format_permission_denied_error
{% if include_advanced_config %}
from {{ project_slug }}.config import ConfigManager, get_config_manager
{% endif %}

# Version constant
VERSION = "0.1.0"

# Exit code constants
EXIT_SUCCESS = 0
EXIT_ERROR = 1
EXIT_USAGE = 2
EXIT_NETWORK_ERROR = 3
EXIT_VALIDATION_ERROR = 4
EXIT_FILE_NOT_FOUND = 5
EXIT_PERMISSION_DENIED = 6
EXIT_SIGINT = 130

app = typer.Typer(
    no_args_is_help=True,
    add_completion=False,
    rich_markup_mode="rich"
)
console = Console(stderr=True)  # Default to stderr for console output

# Global logger instance
logger = None


def cleanup(signum, frame):
    """Handle SIGINT gracefully."""
    if logger:
        logger.fatal("Aborted by user")
    console.print("[bold red]\nAborted! Cleaning up...[/bold red]")
    sys.exit(EXIT_SIGINT)


signal.signal(signal.SIGINT, cleanup)


def version_callback(value: bool):
    """Show version and exit."""
    if value:
        console.print(f"{{ project_slug }} {VERSION}")
        raise typer.Exit()


def usage_callback(value: bool):
    """Show usage and exit."""
    if value:
        ctx = typer.get_current_context()
        console.print(ctx.get_help())
        raise typer.Exit()


def process_content(content: str, source: str, module: str = "processor"):
    """
    Dummy processing function. Replace with actual logic.
    """
    if logger:
        logger.debug(f"Processing content from {source} (length: {len(content)})", module=module)
    # Return processed data
    return {"source": source, "length": len(content), "status": "processed"}


@app.command()
def process(
    inputs: Optional[List[str]] = typer.Argument(None, help="Input files or glob patterns. Use '-' for stdin."),
    config: Path = typer.Option(None, envvar="{{ project_slug | upper | replace('-', '_') }}_CONFIG", help="Path to config file"),
    json_output: bool = typer.Option(False, "--json", help="Output results as JSON to stdout"),
    quiet: bool = typer.Option(False, "--quiet", "-q", help="Suppress all log output"),
    verbose: bool = typer.Option(False, "--verbose", "-v", help="Enable verbose logging"),
    debug: bool = typer.Option(False, "--debug", help="Enable detailed debugging output"),
    color: str = typer.Option("auto", "--color", help="Color mode: auto, always, or never"),
    install: bool = typer.Option(False, "--install", help="Install shell completions and initialize config"),
    uninstall: bool = typer.Option(False, "--uninstall", help="Uninstall shell completions and cleanup"),
    force: bool = typer.Option(False, "--force", help="Force overwrite during install"),
    version: bool = typer.Option(False, "--version", callback=version_callback, help="Show version and exit"),
    usage: bool = typer.Option(False, "--usage", callback=usage_callback, help="Show usage information and exit"),
):
    """
    {{ description }}

    Examples:
        {{ project_slug }} file.txt
        {{ project_slug }} "**/*.txt"
        cat file.txt | {{ project_slug }} -
    """
    global logger

    # Configure logging based on flags
    configure_logging(
        name="{{ project_slug }}",
        quiet=quiet,
        verbose=verbose,
        debug=debug,
        color=color
    )
    logger = get_logger()

    # Handle install/uninstall flags
    if install:
        logger.info("Installing shell completions...", module="install")
        results = install_all_completions(force=force)
        success_count = sum(1 for v in results.values() if v)
        logger.info(f"Installed {success_count}/{len(results)} completion scripts", module="install")

        {% if include_advanced_config %}
        # Initialize config during install
        try:
            config_manager = get_config_manager()
            config = config_manager.initialize_config()
            logger.info(f"Initialized config at {config}", module="install")
        except Exception as e:
            logger.warn(f"Could not initialize config: {e}", module="install")
        {% endif %}

        sys.exit(EXIT_SUCCESS)

    if uninstall:
        logger.info("Uninstalling shell completions...", module="install")
        results = uninstall_all_completions()
        success_count = sum(1 for v in results.values() if v)
        logger.info(f"Removed {success_count}/{len(results)} completion scripts", module="install")
        sys.exit(EXIT_SUCCESS)

    {% if include_advanced_config %}
    # Load configuration with precedence
    config_manager = get_config_manager()

    # Initialize config file if it doesn't exist
    if not config:
        try:
            config = config_manager.initialize_config()
        except Exception as e:
            if not quiet:
                logger.warn(f"Could not initialize config: {e}", module="config")

    # Load from specified config file if provided
    if config and config.exists():
        try:
            from {{ project_slug }}.config import ConfigSource
            config_manager._load_from_file(config, ConfigSource.USER)
        except Exception as e:
            if not quiet:
                logger.error(f"Failed to load config from {config}: {e}", module="config")

    # Validate configuration
    validation_errors = config_manager.validate()
    if validation_errors:
        if not quiet:
            logger.error("Configuration validation errors:", module="config")
            for error in validation_errors:
                logger.error(f"  - {error}", module="config")

    if not quiet:
        logger.info(f"Configuration loaded from {len(config_manager.sources)} sources", module="config")
    {% else %}
    # XDG Config Resolution (legacy)
    if not config:
        config = Path(user_config_dir("{{ project_slug }}")) / "config.toml"

    if not quiet:
        logger.info(f"Reading config from {config}", module="config")
    {% endif %}

    files_to_process = []
    read_from_stdin = False

    # Input Strategy
    if inputs:
        for inp in inputs:
            if inp == "-":
                read_from_stdin = True
            else:
                # Glob expansion
                matches = glob.glob(inp, recursive=True)
                if not matches:
                    # Maybe it's a new file or specific path that doesn't exist yet?
                    # For processing, we usually expect existence.
                    if not quiet:
                        logger.warn(f"No files found for pattern '{inp}'", module="input")
                files_to_process.extend(matches)
    elif not sys.stdin.isatty():
        # Implicit stdin if piped and no args
        read_from_stdin = True
    else:
        # No input provided and TTY -> Show help
        ctx = typer.get_current_context()
        console.print(ctx.get_help())
        sys.exit(EXIT_USAGE)

    results = []

    # Process Stdin
    if read_from_stdin:
        content = sys.stdin.read()
        results.append(process_content(content, "stdin"))

    # Process Files
    for file_path in files_to_process:
        try:
            with open(file_path, 'r', encoding='utf-8') as f:
                content = f.read()
                results.append(process_content(content, file_path))
        except FileNotFoundError:
            if not quiet:
                logger.error(format_file_not_found_error(Path(file_path)), module="io")
            sys.exit(EXIT_FILE_NOT_FOUND)
        except PermissionError:
            if not quiet:
                logger.error(format_permission_denied_error(Path(file_path)), module="io")
            sys.exit(EXIT_PERMISSION_DENIED)
        except Exception as e:
            if not quiet:
                logger.error(f"Error reading {file_path}: {e}", module="io")
            sys.exit(EXIT_ERROR)

    # Output Strategy
    if json_output:
        print(json.dumps(results, indent=2))
    else:
        # Human readable output logic here
        for res in results:
            console.print(f"[green]✓[/green] Processed {res['source']}")


if __name__ == "__main__":
    app()
