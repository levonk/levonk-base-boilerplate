# vim: set ft=python :
import sys
import signal
import glob
import json
from pathlib import Path
from typing import List, Optional
import typer
from rich.console import Console
from platformdirs import user_config_dir

from {{ project_slug }}.logging import configure_logging, get_logger

# Version constant
VERSION = "0.1.0"

app = typer.Typer(
    no_args_is_help=True,
    add_completion=False,
    rich_markup_mode="rich"
)
console = Console(stderr=True)  # Default to stderr for console output

# Global logger instance
logger = None


def cleanup(signum, frame):
    """Handle SIGINT gracefully."""
    if logger:
        logger.fatal("Aborted by user")
    console.print("[bold red]\nAborted! Cleaning up...[/bold red]")
    sys.exit(130)


signal.signal(signal.SIGINT, cleanup)


def version_callback(value: bool):
    """Show version and exit."""
    if value:
        console.print(f"{{ project_slug }} {VERSION}")
        raise typer.Exit()


def usage_callback(value: bool):
    """Show usage and exit."""
    if value:
        ctx = typer.get_current_context()
        console.print(ctx.get_help())
        raise typer.Exit()


def process_content(content: str, source: str, module: str = "processor"):
    """
    Dummy processing function. Replace with actual logic.
    """
    if logger:
        logger.debug(f"Processing content from {source} (length: {len(content)})", module=module)
    # Return processed data
    return {"source": source, "length": len(content), "status": "processed"}


@app.command()
def process(
    inputs: Optional[List[str]] = typer.Argument(None, help="Input files or glob patterns. Use '-' for stdin."),
    config: Path = typer.Option(None, envvar="{{ project_slug | upper | replace('-', '_') }}_CONFIG", help="Path to config file"),
    json_output: bool = typer.Option(False, "--json", help="Output results as JSON to stdout"),
    quiet: bool = typer.Option(False, "--quiet", "-q", help="Suppress all log output"),
    verbose: bool = typer.Option(False, "--verbose", "-v", help="Enable verbose (debug) logging"),
    nocolor: bool = typer.Option(False, "--nocolor", help="Disable colored output"),
    version: bool = typer.Option(False, "--version", callback=version_callback, help="Show version and exit"),
    usage: bool = typer.Option(False, "--usage", callback=usage_callback, help="Show usage information and exit"),
):
    """
    {{ description }}

    Examples:
        {{ project_slug }} file.txt
        {{ project_slug }} "**/*.txt"
        cat file.txt | {{ project_slug }} -
    """
    global logger
    
    # Configure logging based on flags
    configure_logging(
        name="{{ project_slug }}",
        quiet=quiet,
        verbose=verbose,
        nocolor=nocolor
    )
    logger = get_logger()
    
    # XDG Config Resolution
    if not config:
        config = Path(user_config_dir("{{ project_slug }}")) / "config.toml"

    if not quiet:
        logger.info(f"Reading config from {config}", module="config")

    files_to_process = []
    read_from_stdin = False

    # Input Strategy
    if inputs:
        for inp in inputs:
            if inp == "-":
                read_from_stdin = True
            else:
                # Glob expansion
                matches = glob.glob(inp, recursive=True)
                if not matches:
                    # Maybe it's a new file or specific path that doesn't exist yet?
                    # For processing, we usually expect existence.
                    if not quiet:
                        logger.warn(f"No files found for pattern '{inp}'", module="input")
                files_to_process.extend(matches)
    elif not sys.stdin.isatty():
        # Implicit stdin if piped and no args
        read_from_stdin = True
    else:
        # No input provided and TTY -> Show help
        ctx = typer.get_current_context()
        console.print(ctx.get_help())
        sys.exit(1)

    results = []

    # Process Stdin
    if read_from_stdin:
        content = sys.stdin.read()
        results.append(process_content(content, "stdin"))

    # Process Files
    for file_path in files_to_process:
        try:
            with open(file_path, 'r', encoding='utf-8') as f:
                content = f.read()
                results.append(process_content(content, file_path))
        except Exception as e:
            if not quiet:
                logger.error(f"Error reading {file_path}: {e}", module="io")

    # Output Strategy
    if json_output:
        print(json.dumps(results, indent=2))
    else:
        # Human readable output logic here
        for res in results:
            console.print(f"[green]✓[/green] Processed {res['source']}")


if __name__ == "__main__":
    app()
