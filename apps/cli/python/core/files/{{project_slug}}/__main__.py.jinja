import sys
import signal
import glob
import json
from pathlib import Path
from typing import List, Optional
import typer
from rich.console import Console
from platformdirs import user_config_dir

from {{ project_slug }}.logging import configure_logging, get_logger
from {{ project_slug }}.completion import install_all_completions, uninstall_all_completions
from {{ project_slug }}.errors import format_file_not_found_error, format_permission_denied_error
from {{ project_slug }}.progress import progress_bar
from {{ project_slug }}.daemon import get_daemon_manager
from {{ project_slug }}.man_page import print_man_page
{% if include_tui %}
from {{ project_slug }}.tui import CLIArguments, launch_tui, confirm_execution
{% endif %}
{% if include_advanced_config %}
from {{ project_slug }}.config import ConfigManager, get_config_manager
{% endif %}

# Version constant
VERSION = "0.1.0"

# Exit code constants
EXIT_SUCCESS = 0
EXIT_ERROR = 1
EXIT_USAGE = 2
EXIT_NETWORK_ERROR = 3
EXIT_VALIDATION_ERROR = 4
EXIT_FILE_NOT_FOUND = 5
EXIT_PERMISSION_DENIED = 6
EXIT_SIGINT = 130

app = typer.Typer(
    no_args_is_help=True,
    add_completion=False,
    rich_markup_mode="rich"
)
console = Console(stderr=True)  # Default to stderr for console output

# Global logger instance
logger = None


def cleanup(signum, frame):
    """Handle SIGINT gracefully."""
    if logger:
        logger.fatal("Aborted by user")
    console.print("[bold red]\nAborted! Cleaning up...[/bold red]")
    sys.exit(EXIT_SIGINT)


signal.signal(signal.SIGINT, cleanup)


def version_callback(value: bool):
    """Show version and exit."""
    if value:
        console.print(f"{{ project_slug }} {VERSION}")
        raise typer.Exit()


def usage_callback(value: bool):
    """Show usage and exit."""
    if value:
        ctx = typer.get_current_context()
        console.print(ctx.get_help())
        raise typer.Exit()


def process_content(content: str, source: str, module: str = "processor"):
    """
    Dummy processing function. Replace with actual logic.
    """
    if logger:
        logger.debug(f"Processing content from {source} (length: {len(content)})", module=module)
    # Return processed data
    return {"source": source, "length": len(content), "status": "processed"}


def confirm_destructive_action(action: str, force: bool = False) -> bool:
    """
    Prompt user for confirmation before destructive operations.

    Args:
        action: Description of the destructive action
        force: If True, bypass confirmation (use --force flag)

    Returns:
        True if action should proceed, False otherwise
    """
    if force:
        return True

    response = input(f"{action} Continue? [y/N] ")
    return response.lower() == 'y'


@app.command()
def process(
    inputs: Optional[List[str]] = typer.Argument(None, help="Input files or glob patterns. Use '-' for stdin."),
    config: Path = typer.Option(None, envvar="{{ project_slug | upper | replace('-', '_') }}_CONFIG", help="Path to config file"),
    json_output: bool = typer.Option(False, "--json", help="Output results as JSON to stdout"),
    quiet: bool = typer.Option(False, "--quiet", "-q", help="Suppress all log output"),
    verbose: bool = typer.Option(False, "--verbose", "-v", help="Enable verbose logging"),
    debug: bool = typer.Option(False, "--debug", help="Enable detailed debugging output"),
    color: str = typer.Option("auto", "--color", help="Color mode: auto, always, or never"),
    install: bool = typer.Option(False, "--install", help="Install shell completions and initialize config"),
    uninstall: bool = typer.Option(False, "--uninstall", help="Uninstall shell completions and cleanup"),
{% if include_tui %}
    interactive: bool = typer.Option(False, "--interactive", "--tui", help="Launch TUI mode for interactive configuration"),
{% endif %}
    dry_run: bool = typer.Option(False, "--dry-run", help="Preview changes without executing"),
    force: bool = typer.Option(False, "--force", help="Force overwrite during install and bypass confirmation prompts"),
    daemon: bool = typer.Option(False, "--daemon", help="Run in daemon mode (background process)"),
    no_daemon: bool = typer.Option(False, "--no-daemon", help="Force synchronous operation (no daemon)"),
    list_jobs: bool = typer.Option(False, "--list-jobs", help="List background jobs"),
    cancel_job: Optional[str] = typer.Option(None, "--cancel-job", help="Cancel a specific background job by ID"),
    man: bool = typer.Option(False, "--man", help="Display man page"),
    version: bool = typer.Option(False, "--version", callback=version_callback, help="Show version and exit"),
    usage: bool = typer.Option(False, "--usage", callback=usage_callback, help="Show usage information and exit"),
):
    """
    {{ description }}

    Examples:
        {{ project_slug }} file.txt
        {{ project_slug }} "**/*.txt"
        cat file.txt | {{ project_slug }} -
    """
    global logger

    # Configure logging based on flags
    configure_logging(
        name="{{ project_slug }}",
        quiet=quiet,
        verbose=verbose,
        debug=debug,
        color=color
    )
    logger = get_logger()

    # Handle daemon-related flags
    daemon_manager = get_daemon_manager()

    if list_jobs:
        jobs = daemon_manager.list_jobs()
        if not quiet:
            logger.info(f"Background jobs: {len(jobs)}", module="daemon")
            for job in jobs:
                logger.info(f"  - {job}", module="daemon")
        sys.exit(EXIT_SUCCESS)

    if cancel_job:
        if daemon_manager.cancel_job(cancel_job):
            if not quiet:
                logger.info(f"Cancelled job {cancel_job}", module="daemon")
            sys.exit(EXIT_SUCCESS)
        else:
            if not quiet:
                logger.error(f"Failed to cancel job {cancel_job}", module="daemon")
            sys.exit(EXIT_ERROR)

    if daemon:
        if not daemon_manager.is_platform_supported():
            if not quiet:
                logger.error(daemon_manager.get_platform_fallback_message(), module="daemon")
            sys.exit(EXIT_ERROR)

        if not quiet:
            logger.info("Starting daemon mode...", module="daemon")
        pid = daemon_manager.start_daemon()
        if pid:
            if not quiet:
                logger.info(f"Daemon started with PID {pid}", module="daemon")
            sys.exit(EXIT_SUCCESS)
        else:
            if not quiet:
                logger.error("Failed to start daemon", module="daemon")
            sys.exit(EXIT_ERROR)

    if no_daemon:
        # Force synchronous mode
        if not quiet:
            logger.info("Running in synchronous mode (--no-daemon)", module="daemon")

    if man:
        print_man_page()
        sys.exit(EXIT_SUCCESS)

{% if include_tui %}
    # Handle TUI mode
    if interactive:
        args = CLIArguments(
            inputs=inputs,
            config=str(config) if config else None,
            json_output=json_output,
            quiet=quiet,
            verbose=verbose,
            debug=debug,
            color=color,
            install=install,
            uninstall=uninstall,
            force=force
        )
        modified_args = launch_tui(args)

        # Update variables from TUI
        inputs = modified_args.inputs
        config = Path(modified_args.config) if modified_args.config else None
        json_output = modified_args.json_output
        quiet = modified_args.quiet
        verbose = modified_args.verbose
        debug = modified_args.debug
        color = modified_args.color
        install = modified_args.install
        uninstall = modified_args.uninstall
        force = modified_args.force

        # Confirm execution
        if not confirm_execution(modified_args):
            logger.info("Execution cancelled by user", module="tui")
            sys.exit(EXIT_SUCCESS)
{% endif %}

    # Handle dry-run mode
    if dry_run:
        logger.info("DRY RUN: Previewing changes without execution", module="dry-run")
        # Show what would be done
        if install:
            logger.info("Would install shell completions", module="dry-run")
        if uninstall:
            logger.info("Would uninstall shell completions", module="dry-run")
        if inputs:
            logger.info(f"Would process {len(inputs)} input(s)", module="dry-run")
        sys.exit(EXIT_SUCCESS)

    # Handle install/uninstall flags
    if install:
        if not confirm_destructive_action("This will install shell completions.", force):
            logger.info("Install cancelled by user", module="install")
            sys.exit(EXIT_SUCCESS)
        logger.info("Installing shell completions...", module="install")
        results = install_all_completions(force=force)
        success_count = sum(1 for v in results.values() if v)
        logger.info(f"Installed {success_count}/{len(results)} completion scripts", module="install")

        {% if include_advanced_config %}
        # Initialize config during install
        try:
            config_manager = get_config_manager()
            config = config_manager.initialize_config()
            logger.info(f"Initialized config at {config}", module="install")
        except Exception as e:
            logger.warn(f"Could not initialize config: {e}", module="install")
        {% endif %}

        sys.exit(EXIT_SUCCESS)

    if uninstall:
        if not confirm_destructive_action("This will uninstall shell completions.", force):
            logger.info("Uninstall cancelled by user", module="install")
            sys.exit(EXIT_SUCCESS)
        logger.info("Uninstalling shell completions...", module="install")
        results = uninstall_all_completions()
        success_count = sum(1 for v in results.values() if v)
        logger.info(f"Removed {success_count}/{len(results)} completion scripts", module="install")
        sys.exit(EXIT_SUCCESS)

    {% if include_advanced_config %}
    # Load configuration with precedence
    config_manager = get_config_manager()

    # Initialize config file if it doesn't exist
    if not config:
        try:
            config = config_manager.initialize_config()
        except Exception as e:
            if not quiet:
                logger.warn(f"Could not initialize config: {e}", module="config")

    # Load from specified config file if provided
    if config and config.exists():
        try:
            from {{ project_slug }}.config import ConfigSource
            config_manager._load_from_file(config, ConfigSource.USER)
        except Exception as e:
            if not quiet:
                logger.error(f"Failed to load config from {config}: {e}", module="config")

    # Validate configuration
    validation_errors = config_manager.validate()
    if validation_errors:
        if not quiet:
            logger.error("Configuration validation errors:", module="config")
            for error in validation_errors:
                logger.error(f"  - {error}", module="config")

    if not quiet:
        logger.info(f"Configuration loaded from {len(config_manager.sources)} sources", module="config")
    {% else %}
    # XDG Config Resolution (legacy)
    if not config:
        config = Path(user_config_dir("{{ project_slug }}")) / "config.toml"

    if not quiet:
        logger.info(f"Reading config from {config}", module="config")
    {% endif %}

    files_to_process = []
    read_from_stdin = False

    # Input Strategy
    if inputs:
        for inp in inputs:
            if inp == "-":
                read_from_stdin = True
            else:
                # Glob expansion
                matches = glob.glob(inp, recursive=True)
                if not matches:
                    # Maybe it's a new file or specific path that doesn't exist yet?
                    # For processing, we usually expect existence.
                    if not quiet:
                        logger.warn(f"No files found for pattern '{inp}'", module="input")
                files_to_process.extend(matches)
    elif not sys.stdin.isatty():
        # Implicit stdin if piped and no args
        read_from_stdin = True
    else:
        # No input provided and TTY -> Show help
        ctx = typer.get_current_context()
        console.print(ctx.get_help())
        sys.exit(EXIT_USAGE)

    results = []

    # Process Stdin
    if read_from_stdin:
        content = sys.stdin.read()
        results.append(process_content(content, "stdin"))

    # Process Files with progress indicator
    if files_to_process:
        with progress_bar("Processing files", quiet=quiet) as progress:
            if progress:
                task = progress.add_task("Processing files", total=len(files_to_process))

            for i, file_path in enumerate(files_to_process):
                try:
                    with open(file_path, 'r', encoding='utf-8') as f:
                        content = f.read()
                        results.append(process_content(content, file_path))
                except FileNotFoundError:
                    if not quiet:
                        logger.error(format_file_not_found_error(Path(file_path)), module="io")
                    sys.exit(EXIT_FILE_NOT_FOUND)
                except PermissionError:
                    if not quiet:
                        logger.error(format_permission_denied_error(Path(file_path)), module="io")
                    sys.exit(EXIT_PERMISSION_DENIED)
                except Exception as e:
                    if not quiet:
                        logger.error(f"Error reading {file_path}: {e}", module="io")
                    sys.exit(EXIT_ERROR)

                if progress:
                    progress.update(task, advance=1)

    # Output Strategy
    if json_output:
        print(json.dumps(results, indent=2))
    else:
        # Human readable output logic here
        for res in results:
            console.print(f"[green]✓[/green] Processed {res['source']}")


if __name__ == "__main__":
    app()
