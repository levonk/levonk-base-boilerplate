{
  "name": "{{ project_name | default('python-cli-app') }}",
  "version": "0.1.0",
  "description": "{{ project_description | default('A Python CLI application') }}",
  "shell": {
    "init": [
      "echo '🐍 Setting up {{ project_name | default('python-cli-app') }} development environment...'"
    ],
    "scripts": {
      "build": "uv run python -m build",
      "install": "uv pip install -e .",
      "install-dev": "uv pip install -e \".[dev]\"",
      "test": "uv run pytest",
      "test-coverage": "uv run pytest --cov={{ project_slug | default(project_name | lower | replace(' ', '_')) }} --cov-report=html",
      "lint": "uv run ruff check .",
      "format": "uv run ruff format .",
      "format-check": "uv run ruff format --check .",
      "run": "uv run python -m {{ project_slug | default(project_name | lower | replace(' ', '_')) }}",
      "dev": "uv run watchfiles \"python -m {{ project_slug | default(project_name | lower | replace(' ', '_')) }}\" src",
      "clean": "rm -rf build dist *.egg-info",
      "docs": "uv run mkdocs serve",
      "type-check": "uv run mypy {{ project_slug | default(project_name | lower | replace(' ', '_')) }}",
      "check": "uv run ruff check . && uv run mypy {{ project_slug | default(project_name | lower | replace(' ', '_')) }}"
    }
  },
  "packages": {
    "nixpkgs#uv": "",
    {% if include_requests %}
    "nixpkgs#python311Packages.requests": "",
    {% endif %}
    {% if include_click %}
    "nixpkgs#python311Packages.click": "",
    {% endif %}
    {% if include_sqlalchemy %}
    "nixpkgs#python311Packages.sqlalchemy": "",
    {% endif %}
    {% if include_async %}
    "nixpkgs#python311Packages.aiohttp": "",
    "nixpkgs#python311Packages.asyncio": "",
    {% endif %}
    {% if include_pandas %}
    "nixpkgs#python311Packages.pandas": "",
    {% endif %}
    {% if include_numpy %}
    "nixpkgs#python311Packages.numpy": "",
    {% endif %}
    {% if include_openssl %}
    "nixpkgs#openssl": "",
    "nixpkgs#openssl.dev": "",
    {% endif %}
    {% if include_postgres %}
    "nixpkgs#python311Packages.psycopg2": "",
    "nixpkgs#postgresql": "",
    {% endif %}
    {% if include_sqlite %}
    "nixpkgs#python311Packages.sqlite3": "",
    {% endif %}
  },
  "env": {
    "PYTHONPATH": "{{ pythonpath | default('.') }}",
    "PYTHONPATH_DEV": "{{ pythonpath_dev | default('.:./tests') }}",
    {% if include_async %}
    "PYTHONASYNCIODEBUG": "1",
    {% endif %}
    {% if include_postgres %}
    "DATABASE_URL": "postgresql://localhost/{{ project_name | default('python-cli-app') }}",
    {% endif %}
    {% if include_sqlite %}
    "DATABASE_URL": "sqlite:./{{ project_name | default('python-cli-app') }}.db",
    {% endif %}
    {% if include_development %}
    "FLASK_ENV": "development",
    "FLASK_DEBUG": "1",
    {% endif %}
  },
  "hooks": {
    "on_create": [
      "uv sync --group dev"
    ]
  }
}
