{
  "name": "{{ project_slug }}",
  "version": "1.0.0",
  "description": "{{ description }} - A production-ready TypeScript CLI tool following CLI Tool Standards ADR compliance",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "{{ project_slug }}": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "lint": "eslint src/**/*.ts",
    "preinstall": "npx -y only-allow pnpm"
  },
  "keywords": [
    "cli",
    "typescript",
    "command-line",
    "tool",
    "automation"
  ],
  "author": "{{ author_name }}",
  "license": "{{ license }}",
  "homepage": "{{ homepage }}",
  "repository": {
    "type": "git",
    "url": "{{ repository_url }}"
  },
  "bugs": {
    "url": "{{ issues_url }}"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^11.0.0",
    "glob": "^10.0.0",
    "ink": "^4.4.1",
    "ink-select-input": "^5.0.0",
    "ink-text-input": "^5.0.0",
    "react": "^18.2.0",
    "supports-color": "^9.4.0",
    "zod": "^3.22.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^9.0.0",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/cli-progress": "^3.11.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0",
    "vitest": ">=4.1.0"
  },
  "engines": {
    "node": "*"
  }
}
