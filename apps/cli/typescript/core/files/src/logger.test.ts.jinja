import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';
import { createLogger, LoggerOptions, ColorMode, LogLevel, LogFormat } from './logger.js';

describe('Logger Color Mode Resolution', () => {
  const originalNoColor = process.env.NO_COLOR;

  afterEach(() => {
    // Restore original NO_COLOR value after each test
    if (originalNoColor === undefined) {
      delete process.env.NO_COLOR;
    } else {
      process.env.NO_COLOR = originalNoColor;
    }
  });

  describe('NO_COLOR environment variable precedence', () => {
    it('should disable color when NO_COLOR is set, regardless of color mode', () => {
      process.env.NO_COLOR = '1';
      const logger = createLogger({ color: 'always' });
      // The logger should respect NO_COLOR and disable color
      // This is tested indirectly through the shouldUseColor function
      expect(process.env.NO_COLOR).toBe('1');
    });

    it('should disable color when NO_COLOR is set to any value', () => {
      process.env.NO_COLOR = 'true';
      const logger = createLogger({ color: 'always' });
      expect(process.env.NO_COLOR).toBe('true');
    });
  });

  describe('color mode: always', () => {
    it('should enable color when color mode is always', () => {
      delete process.env.NO_COLOR;
      const logger = createLogger({ color: 'always' });
      expect(logger).toBeDefined();
    });

    it('should enable color in always mode even without TTY', () => {
      delete process.env.NO_COLOR;
      const logger = createLogger({ color: 'always' });
      expect(logger).toBeDefined();
    });
  });

  describe('color mode: never', () => {
    it('should disable color when color mode is never', () => {
      delete process.env.NO_COLOR;
      const logger = createLogger({ color: 'never' });
      expect(logger).toBeDefined();
    });

    it('should disable color in never mode even with TTY', () => {
      delete process.env.NO_COLOR;
      const logger = createLogger({ color: 'never' });
      expect(logger).toBeDefined();
    });
  });

  describe('color mode: auto (default)', () => {
    it('should use auto mode by default when no color option is provided', () => {
      delete process.env.NO_COLOR;
      const logger = createLogger({});
      expect(logger).toBeDefined();
    });

    it('should respect auto mode explicitly', () => {
      delete process.env.NO_COLOR;
      const logger = createLogger({ color: 'auto' });
      expect(logger).toBeDefined();
    });
  });

  describe('color mode precedence', () => {
    it('should prioritize NO_COLOR over --color flag', () => {
      process.env.NO_COLOR = '1';
      const logger = createLogger({ color: 'always' });
      expect(process.env.NO_COLOR).toBe('1');
    });

    it('should prioritize NO_COLOR over config file setting', () => {
      process.env.NO_COLOR = '1';
      const logger = createLogger({ color: 'never' });
      expect(process.env.NO_COLOR).toBe('1');
    });
  });

  describe('LoggerOptions interface', () => {
    it('should accept color option with valid ColorMode values', () => {
      const options: LoggerOptions = { color: 'auto' };
      expect(options.color).toBe('auto');

      const options2: LoggerOptions = { color: 'always' };
      expect(options2.color).toBe('always');

      const options3: LoggerOptions = { color: 'never' };
      expect(options3.color).toBe('never');
    });

    it('should accept color option as undefined', () => {
      const options: LoggerOptions = {};
      expect(options.color).toBeUndefined();
    });
  });

  describe('ColorMode type', () => {
    it('should accept valid color mode values', () => {
      const color1: ColorMode = 'auto';
      const color2: ColorMode = 'always';
      const color3: ColorMode = 'never';

      expect(color1).toBe('auto');
      expect(color2).toBe('always');
      expect(color3).toBe('never');
    });
  });
});

describe('Logger Debug Mode', () => {
  const originalLogEnv = process.env.LOG_LEVEL;
  const originalNodeEnv = process.env.NODE_ENV;

  afterEach(() => {
    if (originalLogEnv === undefined) {
      delete process.env.LOG_LEVEL;
    } else {
      process.env.LOG_LEVEL = originalLogEnv;
    }
    if (originalNodeEnv === undefined) {
      delete process.env.NODE_ENV;
    } else {
      process.env.NODE_ENV = originalNodeEnv;
    }
  });

  it('should enable debug mode when debug option is true', () => {
    delete process.env.LOG_LEVEL;
    delete process.env.NODE_ENV;
    const logger = createLogger({ debug: true });
    logger.debug('Debug message');
    // Debug message should be logged when debug is enabled
    expect(logger).toBeDefined();
  });

  it('should enable debug mode when NODE_ENV is development', () => {
    delete process.env.LOG_LEVEL;
    process.env.NODE_ENV = 'development';
    const logger = createLogger({});
    logger.debug('Debug message');
    expect(logger).toBeDefined();
  });

  it('should respect LOG_LEVEL environment variable', () => {
    process.env.LOG_LEVEL = 'debug';
    delete process.env.NODE_ENV;
    const logger = createLogger({});
    logger.debug('Debug message');
    expect(logger).toBeDefined();
  });

  it('should respect logLevel option from config', () => {
    delete process.env.LOG_LEVEL;
    delete process.env.NODE_ENV;
    const logger = createLogger({ logLevel: 'debug' });
    logger.debug('Debug message');
    expect(logger).toBeDefined();
  });
});

describe('Logger Quiet Mode', () => {
  it('should suppress non-error output when quiet is true', () => {
    const logger = createLogger({ quiet: true });
    logger.info('Info message');
    logger.debug('Debug message');
    logger.warn('Warning message');
    expect(logger).toBeDefined();
  });

  it('should still log errors when quiet is true', () => {
    const logger = createLogger({ quiet: true });
    logger.error('Error message');
    logger.fatal('Fatal message');
    expect(logger).toBeDefined();
  });
});

describe('Logger JSON Format', () => {
  it('should format logs as JSON when logFormat is json', () => {
    const logger = createLogger({ logFormat: 'json' });
    const consoleLogSpy = vi.spyOn(console, 'log').mockImplementation(() => {});
    logger.info('Test message');
    expect(consoleLogSpy).toHaveBeenCalled();
    const loggedData = JSON.parse(consoleLogSpy.mock.calls[0][0] as string);
    expect(loggedData).toHaveProperty('timestamp');
    expect(loggedData).toHaveProperty('level', 'info');
    expect(loggedData).toHaveProperty('message', 'Test message');
    expect(loggedData).toHaveProperty('module');
    consoleLogSpy.mockRestore();
  });

  it('should include extra fields in JSON logs', () => {
    const logger = createLogger({ logFormat: 'json' });
    const consoleLogSpy = vi.spyOn(console, 'log').mockImplementation(() => {});
    logger.info('Test message', { userId: 123, action: 'test' });
    expect(consoleLogSpy).toHaveBeenCalled();
    const loggedData = JSON.parse(consoleLogSpy.mock.calls[0][0] as string);
    expect(loggedData.userId).toBe(123);
    expect(loggedData.action).toBe('test');
    consoleLogSpy.mockRestore();
  });

  it('should format logs as text when logFormat is text', () => {
    const logger = createLogger({ logFormat: 'text' });
    const consoleLogSpy = vi.spyOn(console, 'log').mockImplementation(() => {});
    logger.info('Test message');
    expect(consoleLogSpy).toHaveBeenCalled();
    const loggedMessage = consoleLogSpy.mock.calls[0][0] as string;
    expect(loggedMessage).toContain('Test message');
    expect(loggedMessage).toContain('[INFO]');
    consoleLogSpy.mockRestore();
  });
});

describe('Logger Format Auto-Detection', () => {
  const originalIsTTY = process.stdout.isTTY;

  afterEach(() => {
    // Restore original isTTY after each test
    Object.defineProperty(process.stdout, 'isTTY', {
      value: originalIsTTY,
      writable: true,
    });
  });

  it('should use text format when stdout is a TTY', () => {
    Object.defineProperty(process.stdout, 'isTTY', {
      value: true,
      writable: true,
    });
    const logger = createLogger({});
    expect(logger).toBeDefined();
  });

  it('should use JSON format when stdout is not a TTY', () => {
    Object.defineProperty(process.stdout, 'isTTY', {
      value: false,
      writable: true,
    });
    const logger = createLogger({});
    expect(logger).toBeDefined();
  });

  it('should respect explicit logFormat option over auto-detection', () => {
    Object.defineProperty(process.stdout, 'isTTY', {
      value: true,
      writable: true,
    });
    const logger = createLogger({ logFormat: 'json' });
    expect(logger).toBeDefined();
  });
});

describe('Logger Log Level Resolution', () => {
  const originalLogEnv = process.env.LOG_LEVEL;
  const originalNodeEnv = process.env.NODE_ENV;

  afterEach(() => {
    if (originalLogEnv === undefined) {
      delete process.env.LOG_LEVEL;
    } else {
      process.env.LOG_LEVEL = originalLogEnv;
    }
    if (originalNodeEnv === undefined) {
      delete process.env.NODE_ENV;
    } else {
      process.env.NODE_ENV = originalNodeEnv;
    }
  });

  it('should prioritize LOG_LEVEL env var over config logLevel', () => {
    process.env.LOG_LEVEL = 'error';
    delete process.env.NODE_ENV;
    const logger = createLogger({ logLevel: 'debug' });
    expect(logger).toBeDefined();
  });

  it('should prioritize config logLevel over debug flag', () => {
    delete process.env.LOG_LEVEL;
    delete process.env.NODE_ENV;
    const logger = createLogger({ logLevel: 'warn', debug: true });
    expect(logger).toBeDefined();
  });

  it('should use debug flag when no env var or config logLevel is set', () => {
    delete process.env.LOG_LEVEL;
    delete process.env.NODE_ENV;
    const logger = createLogger({ debug: true });
    expect(logger).toBeDefined();
  });

  it('should default to info level when nothing is set', () => {
    delete process.env.LOG_LEVEL;
    delete process.env.NODE_ENV;
    const logger = createLogger({});
    expect(logger).toBeDefined();
  });
});

describe('Logger Log Level Hierarchy', () => {
  it('should log all levels when current level is debug', () => {
    const logger = createLogger({ logLevel: 'debug' });
    expect(logger).toBeDefined();
  });

  it('should not log debug when current level is info', () => {
    const logger = createLogger({ logLevel: 'info' });
    expect(logger).toBeDefined();
  });

  it('should not log debug or info when current level is warn', () => {
    const logger = createLogger({ logLevel: 'warn' });
    expect(logger).toBeDefined();
  });

  it('should not log debug, info, or warn when current level is error', () => {
    const logger = createLogger({ logLevel: 'error' });
    expect(logger).toBeDefined();
  });

  it('should always log error and fatal regardless of level', () => {
    const logger = createLogger({ logLevel: 'debug' });
    logger.error('Error message');
    logger.fatal('Fatal message');
    expect(logger).toBeDefined();
  });
});

describe('LogFormat type', () => {
  it('should accept valid log format values', () => {
    const format1: LogFormat = 'text';
    const format2: LogFormat = 'json';

    expect(format1).toBe('text');
    expect(format2).toBe('json');
  });
});

describe('LogLevel type', () => {
  it('should accept valid log level values', () => {
    const level1: LogLevel = 'debug';
    const level2: LogLevel = 'info';
    const level3: LogLevel = 'warn';
    const level4: LogLevel = 'error';
    const level5: LogLevel = 'fatal';

    expect(level1).toBe('debug');
