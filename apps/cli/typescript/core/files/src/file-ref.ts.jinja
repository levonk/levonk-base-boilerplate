import process from 'process';

/**
 * File Reference Formatting
 *
 * This module provides file reference formatting utilities according to CLI Tool Standards ADR requirement #15.
 * Supports VSCode-compatible format (file:///absolute/path/to/file:line:column) and standard file:line:column format.
 */

export type FileRefFormat = 'vscode' | 'standard' | 'auto';

export interface FileRefOptions {
  format?: FileRefFormat;
  absolute?: boolean;
}

export interface FileLocation {
  path: string;
  line?: number;
  column?: number;
}

/**
 * Detect the appropriate file reference format based on environment
 */
function detectFormat(): FileRefFormat {
  // Check if running in VSCode terminal
  if (process.env.VSCODE_PID || process.env.TERM_PROGRAM === 'vscode') {
    return 'vscode';
  }
  
  // Check if terminal supports hyperlinks (many modern terminals)
  // For now, default to standard format for terminals
  return 'standard';
}

/**
 * Convert a path to absolute if needed
 */
function toAbsolutePath(path: string): string {
  if (path.startsWith('/')) {
    return path; // Already absolute
  }
  
  // Convert relative path to absolute
  return process.cwd() + '/' + path;
}

/**
 * Format a file reference in VSCode-compatible format
 * Format: file:///absolute/path/to/file:line:column
 */
function formatVSCode(location: FileLocation): string {
  const absolutePath = toAbsolutePath(location.path);
  const line = location.line !== undefined ? `:${location.line}` : '';
  const column = location.column !== undefined ? `:${location.column}` : '';
  
  return `file://${absolutePath}${line}${column}`;
}

/**
 * Format a file reference in standard format
 * Format: file:line:column (relative or absolute path)
 */
function formatStandard(location: FileLocation, absolute: boolean = false): string {
  const path = absolute ? toAbsolutePath(location.path) : location.path;
  const line = location.line !== undefined ? `:${location.line}` : '';
  const column = location.column !== undefined ? `:${location.column}` : '';
  
  return `${path}${line}${column}`;
}

/**
 * Format a file reference based on the specified format
 */
export function formatFileRef(location: FileLocation, options: FileRefOptions = {}): string {
  const format = options.format || 'auto';
  const absolute = options.absolute !== undefined ? options.absolute : true;
  
  let selectedFormat: FileRefFormat;
  
  if (format === 'auto') {
    selectedFormat = detectFormat();
  } else {
    selectedFormat = format;
  }
  
  switch (selectedFormat) {
    case 'vscode':
      return formatVSCode(location);
    case 'standard':
      return formatStandard(location, absolute);
    default:
      return formatStandard(location, absolute);
  }
}

/**
 * Format a file reference for error messages
 * Uses VSCode format when appropriate, falls back to standard format
 */
export function formatErrorFileRef(location: FileLocation): string {
  return formatFileRef(location, { format: 'auto', absolute: true });
}

/**
 * Format a file reference for log output
 * Uses standard format by default for better terminal compatibility
 */
export function formatLogFileRef(location: FileLocation): string {
  return formatFileRef(location, { format: 'standard', absolute: false });
}

/**
 * Format a file reference for user-facing output
 * Auto-detects the best format based on environment
 */
export function formatUserFileRef(location: FileLocation): string {
  return formatFileRef(location, { format: 'auto', absolute: true });
}

/**
 * Parse a file reference string into its components
 */
export function parseFileRef(ref: string): FileLocation {
  // Handle VSCode format: file:///absolute/path/to/file:line:column
  if (ref.startsWith('file://')) {
    const withoutPrefix = ref.substring(7); // Remove 'file://'
    const match = withoutPrefix.match(/^(.*?)(?::(\d+))?(?::(\d+))?$/);
    
    if (match) {
      return {
        path: match[1],
        line: match[2] ? parseInt(match[2], 10) : undefined,
        column: match[3] ? parseInt(match[3], 10) : undefined,
      };
    }
  }
  
  // Handle standard format: file:line:column
  const match = ref.match(/^(.*?)(?::(\d+))?(?::(\d+))?$/);
  
  if (match) {
    return {
      path: match[1],
      line: match[2] ? parseInt(match[2], 10) : undefined,
      column: match[3] ? parseInt(match[3], 10) : undefined,
    };
  }
  
  // Fallback: treat entire string as path
  return { path: ref };
}
