            const { stdout } = await execAsync('node dist/index.js --no-deprecation-warnings --help');
            expect(stdout).toContain('Usage:');
        });

        it('should show deprecation status with --deprecation-status', async () => {
            const { stdout } = await execAsync('node dist/index.js --deprecation-status');
            expect(stdout).toBeDefined();
        });
    });
});
