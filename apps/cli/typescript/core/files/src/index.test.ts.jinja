import { describe, it, expect, beforeEach, afterEach } from 'vitest';
import { exec } from 'child_process';
import util from 'util';
import fs from 'fs/promises';
import os from 'os';
import path from 'path';

const execAsync = util.promisify(exec);

describe('CLI', () => {
    it('should show help', async () => {
        const { stdout } = await execAsync('npx ts-node src/index.ts --help');
        expect(stdout).toContain('Usage:');
    });

    describe('--color flag', () => {
        it('should accept --color=auto', async () => {
            const { stdout } = await execAsync('npx ts-node src/index.ts --color=auto --help');
            expect(stdout).toContain('Usage:');
        });

        it('should accept --color=always', async () => {
            const { stdout } = await execAsync('npx ts-node src/index.ts --color=always --help');
            expect(stdout).toContain('Usage:');
        });

        it('should accept --color=never', async () => {
            const { stdout } = await execAsync('npx ts-node src/index.ts --color=never --help');
            expect(stdout).toContain('Usage:');
        });

        it('should default to auto mode when no --color flag is provided', async () => {
            const { stdout } = await execAsync('npx ts-node src/index.ts --help');
            expect(stdout).toContain('Usage:');
        });

        it('should show color option in help text', async () => {
            const { stdout } = await execAsync('npx ts-node src/index.ts --help');
            expect(stdout).toContain('--color');
        });
    });

    describe('NO_COLOR environment variable', () => {
        const originalNoColor = process.env.NO_COLOR;

        afterEach(() => {
            if (originalNoColor === undefined) {
                delete process.env.NO_COLOR;
            } else {
                process.env.NO_COLOR = originalNoColor;
            }
        });

        it('should respect NO_COLOR environment variable', async () => {
            const { stdout } = await execAsync('NO_COLOR=1 npx ts-node src/index.ts --help');
            expect(stdout).toContain('Usage:');
        });

        it('should prioritize NO_COLOR over --color flag', async () => {
            const { stdout } = await execAsync('NO_COLOR=1 npx ts-node src/index.ts --color=always --help');
            expect(stdout).toContain('Usage:');
        });
    });

    describe('Exit Codes', () => {
        let tempFile: string;

        beforeEach(async () => {
            tempFile = await fs.mkdtemp(os.tmpdir()) + '/test-file.txt';
            await fs.writeFile(tempFile, 'test content');
        });

        afterEach(async () => {
            try {
                await fs.unlink(tempFile);
            } catch {
                // Ignore if file doesn't exist
            }
        });

        it('should exit with code 0 on success', async () => {
            const { stdout } = await execAsync(`npx ts-node src/index.ts "${tempFile}"`);
            expect(stdout).toContain('Processed 1 inputs');
        });

        it('should exit with code 2 on usage error (no inputs)', async () => {
            try {
                await execAsync('npx ts-node src/index.ts', { stdio: 'pipe' });
                expect.fail('Should have thrown an error');
            } catch (error: any) {
                expect(error.code).toBe(2);
                expect(error.stderr).toContain('UsageError');
            }
        });

        it('should exit with code 5 on file not found', async () => {
            try {
                await execAsync('npx ts-node src/index.ts /nonexistent/file.txt', { stdio: 'pipe' });
                expect.fail('Should have thrown an error');
            } catch (error: any) {
                expect(error.code).toBe(5);
                expect(error.stderr).toContain('FileNotFoundError');
            }
        });

        it('should exit with code 6 on permission denied', async () => {
            // Create a file with no read permissions
            const noPermFile = await fs.mkdtemp(os.tmpdir()) + '/no-perm.txt';
            await fs.writeFile(noPermFile, 'test');
            await fs.chmod(noPermFile, 0o000);

            try {
                await execAsync(`npx ts-node src/index.ts "${noPermFile}"`, { stdio: 'pipe' });
                expect.fail('Should have thrown an error');
            } catch (error: any) {
                expect(error.code).toBe(6);
                expect(error.stderr).toContain('PermissionDeniedError');
            } finally {
                await fs.chmod(noPermFile, 0o644);
                await fs.unlink(noPermFile);
            }
        });

        it('should include exit code in error messages', async () => {
            try {
                await execAsync('npx ts-node src/index.ts /nonexistent/file.txt', { stdio: 'pipe' });
                expect.fail('Should have thrown an error');
            } catch (error: any) {
                expect(error.stderr).toContain('exit code: 5');
            }
        });
    });

    describe('Config Initialization', () => {
        const testConfigDir = path.join(os.tmpdir(), 'test-config-{{ project_slug }}');
        const testConfigPath = path.join(testConfigDir, 'config.toml');

        beforeEach(async () => {
            // Clean up test directory before each test
            try {
                await fs.rm(testConfigDir, { recursive: true, force: true });
            } catch {
                // Ignore if directory doesn't exist
            }
        });

        afterEach(async () => {
            // Clean up test directory after each test
            try {
                await fs.rm(testConfigDir, { recursive: true, force: true });
            } catch {
                // Ignore if directory doesn't exist
            }
        });

        it('should create default config file on first run', async () => {
            const customXDG = testConfigDir;
            const { stdout, stderr } = await execAsync(
                `XDG_CONFIG_HOME="${customXDG}" npx ts-node src/index.ts --help`
            );

            // Config file should be created
            const exists = await fs.access(testConfigPath).then(() => true).catch(() => false);
            expect(exists).toBe(true);

            // Config file should contain commented settings
            const content = await fs.readFile(testConfigPath, 'utf-8');
            expect(content).toContain('# Configuration file');
            expect(content).toContain('# log_level = "info"');
        });

        it('should not overwrite existing config file', async () => {
            const customXDG = testConfigDir;

            // Create config directory and custom config
            await fs.mkdir(testConfigDir, { recursive: true });
            await fs.writeFile(testConfigPath, '# custom config');

            // Run CLI
            const { stdout } = await execAsync(
                `XDG_CONFIG_HOME="${customXDG}" npx ts-node src/index.ts --help`
            );

            // Config file should not be overwritten
            const content = await fs.readFile(testConfigPath, 'utf-8');
            expect(content).toBe('# custom config');
        });

        it('should log config creation in verbose mode', async () => {
            const customXDG = testConfigDir;
            const { stderr } = await execAsync(
                `XDG_CONFIG_HOME="${customXDG}" npx ts-node src/index.ts --verbose --help`
            );

            expect(stderr).toContain('Created default config file');
        });

        it('should use custom config path if provided', async () => {
            const customConfigPath = path.join(testConfigDir, 'custom.toml');
            const { stdout } = await execAsync(
                `npx ts-node src/index.ts --config "${customConfigPath}" --help`
            );

            // Custom config file should be created
            const exists = await fs.access(customConfigPath).then(() => true).catch(() => false);
            expect(exists).toBe(true);
        });

        it('should load config from environment variables', async () => {
            const customXDG = testConfigDir;
            const prefix = '{{ project_slug | upper | replace("-", "_") }}';
            const { stdout } = await execAsync(
                `${prefix}_LOG_LEVEL=debug XDG_CONFIG_HOME="${customXDG}" npx ts-node src/index.ts --help`
            );

            // Should not error - env var should be loaded
            expect(stdout).toContain('Usage:');
        });

        it('should respect config precedence: CLI > env > config', async () => {
            const customXDG = testConfigDir;

            // Create user config with log_level = warn
            await fs.mkdir(testConfigDir, { recursive: true });
            await fs.writeFile(testConfigPath, 'log_level = "warn"');

            // CLI arg should override config
            const { stdout } = await execAsync(
                `XDG_CONFIG_HOME="${customXDG}" npx ts-node src/index.ts --log-level=debug --help`
            );

            expect(stdout).toContain('Usage:');
        });
    });

    describe('Completion Scripts', () => {
        const testCompletionsDir = path.join(os.tmpdir(), 'test-completions-{{ project_slug }}');

        beforeEach(async () => {
            // Clean up test directory before each test
            try {
                await fs.rm(testCompletionsDir, { recursive: true, force: true });
            } catch {
                // Ignore if directory doesn't exist
            }
        });

        afterEach(async () => {
            // Clean up test directory after each test
            try {
                await fs.rm(testCompletionsDir, { recursive: true, force: true });
            } catch {
                // Ignore if directory doesn't exist
            }
        });

        it('should generate bash completion script', async () => {
            const { stdout } = await execAsync(
                `npx ts-node src/index.ts --completion bash --output-dir "${testCompletionsDir}"`
            );

            const bashScript = path.join(testCompletionsDir, '{{ project_slug }}.bash');
            const exists = await fs.access(bashScript).then(() => true).catch(() => false);
            expect(exists).toBe(true);

            const content = await fs.readFile(bashScript, 'utf-8');
            expect(content).toContain('# Bash completion');
            expect(content).toContain('complete -F');
        });

        it('should generate zsh completion script', async () => {
            const { stdout } = await execAsync(
                `npx ts-node src/index.ts --completion zsh --output-dir "${testCompletionsDir}"`
            );

            const zshScript = path.join(testCompletionsDir, '{{ project_slug }}.zsh');
            const exists = await fs.access(zshScript).then(() => true).catch(() => false);
            expect(exists).toBe(true);

            const content = await fs.readFile(zshScript, 'utf-8');
            expect(content).toContain('#compdef {{ project_slug }}');
        });

        it('should generate fish completion script', async () => {
            const { stdout } = await execAsync(
                `npx ts-node src/index.ts --completion fish --output-dir "${testCompletionsDir}"`
            );

            const fishScript = path.join(testCompletionsDir, '{{ project_slug }}.fish');
            const exists = await fs.access(fishScript).then(() => true).catch(() => false);
            expect(exists).toBe(true);

            const content = await fs.readFile(fishScript, 'utf-8');
            expect(content).toContain('# Fish completion');
        });

        it('should output completion script to stdout with --stdout flag', async () => {
            const { stdout } = await execAsync(
                'npx ts-node src/index.ts --completion bash --stdout'
            );

            expect(stdout).toContain('# Bash completion');
            expect(stdout).toContain('complete -F');
        });

        it('should show completion installation instructions', async () => {
            const { stdout } = await execAsync(
                'npx ts-node src/index.ts --completion-install bash'
            );

            expect(stdout).toContain('Bash completion installation');
            expect(stdout).toContain('~/.bashrc');
        });
    });

    describe('Man Pages', () => {
        const testManDir = path.join(os.tmpdir(), 'test-man-{{ project_slug }}');

        beforeEach(async () => {
            // Clean up test directory before each test
            try {
                await fs.rm(testManDir, { recursive: true, force: true });
            } catch {
                // Ignore if directory doesn't exist
            }
        });

        afterEach(async () => {
            // Clean up test directory after each test
            try {
                await fs.rm(testManDir, { recursive: true, force: true });
            } catch {
                // Ignore if directory doesn't exist
            }
        });

        it('should generate man page', async () => {
            const { stdout } = await execAsync(
                `npx ts-node src/index.ts --man --man-output-dir "${testManDir}"`
            );

            const manFile = path.join(testManDir, '{{ project_slug }}.1');
            const exists = await fs.access(manFile).then(() => true).catch(() => false);
            expect(exists).toBe(true);

            const content = await fs.readFile(manFile, 'utf-8');
            expect(content).toContain('.TH');
            expect(content).toContain('.SH NAME');
            expect(content).toContain('{{ project_slug }}');
        });

        it('should output man page to stdout with --stdout flag', async () => {
            const { stdout } = await execAsync(
                'npx ts-node src/index.ts --man --stdout'
            );

            expect(stdout).toContain('.TH');
            expect(stdout).toContain('.SH NAME');
            expect(stdout).toContain('{{ project_slug }}');
        });

        it('should show man page installation instructions', async () => {
            const { stdout } = await execAsync(
                'npx ts-node src/index.ts --man-install'
            );

            expect(stdout).toContain('Man page installation');
            expect(stdout).toContain('~/.local/share/man/man1');
        });
    });

    describe('Logging Mode Combinations', () => {
        let tempFile: string;

        beforeEach(async () => {
            tempFile = await fs.mkdtemp(os.tmpdir()) + '/test-file.txt';
            await fs.writeFile(tempFile, 'test content');
        });

        afterEach(async () => {
            try {
                await fs.unlink(tempFile);
            } catch {
                // Ignore if file doesn't exist
            }
        });

        it('should accept --debug flag', async () => {
            const { stdout } = await execAsync(`npx ts-node src/index.ts --debug "${tempFile}"`);
            expect(stdout).toContain('Processed 1 inputs');
        });

        it('should accept --log-format=json flag', async () => {
            const { stdout } = await execAsync(`npx ts-node src/index.ts --log-format=json "${tempFile}"`);
            expect(stdout).toContain('Processed 1 inputs');
        });

        it('should accept --log-format=text flag', async () => {
            const { stdout } = await execAsync(`npx ts-node src/index.ts --log-format=text "${tempFile}"`);
            expect(stdout).toContain('Processed 1 inputs');
        });

        it('should accept --quiet flag', async () => {
            const { stdout } = await execAsync(`npx ts-node src/index.ts --quiet "${tempFile}"`);
            // Quiet mode should suppress info output
            expect(stdout).not.toContain('Processing');
        });

        it('should accept --verbose flag', async () => {
            const { stdout } = await execAsync(`npx ts-node src/index.ts --verbose "${tempFile}"`);
            expect(stdout).toContain('Processed 1 inputs');
        });

        it('should accept combination of --debug and --log-format=json', async () => {
            const { stdout } = await execAsync(`npx ts-node src/index.ts --debug --log-format=json "${tempFile}"`);
            expect(stdout).toContain('Processed 1 inputs');
        });

        it('should accept combination of --quiet and --log-format=json', async () => {
            const { stdout } = await execAsync(`npx ts-node src/index.ts --quiet --log-format=json "${tempFile}"`);
            expect(stdout).not.toContain('Processing');
        });

        it('should show logging options in help text', async () => {
            const { stdout } = await execAsync('npx ts-node src/index.ts --help');
            expect(stdout).toContain('--debug');
            expect(stdout).toContain('--log-format');
            expect(stdout).toContain('--quiet');
            expect(stdout).toContain('--verbose');
        });

        it('should show LOG_LEVEL environment variable in help text', async () => {
            const { stdout } = await execAsync('npx ts-node src/index.ts --help');
            expect(stdout).toContain('LOG_LEVEL');
        });

        it('should show NODE_ENV environment variable in help text', async () => {
            const { stdout } = await execAsync('npx ts-node src/index.ts --help');
            expect(stdout).toContain('NODE_ENV');
        });
    });

    describe('Install/Uninstall Workflow', () => {
        const testConfigDir = path.join(os.tmpdir(), 'test-config-{{ project_slug }}');

        beforeEach(async () => {
            // Clean up test directory before each test
            try {
                await fs.rm(testConfigDir, { recursive: true, force: true });
            } catch {
                // Ignore if directory doesn't exist
            }
        });

        afterEach(async () => {
            // Clean up test directory after each test
            try {
                await fs.rm(testConfigDir, { recursive: true, force: true });
            } catch {
                // Ignore if directory doesn't exist
            }
        });

        it('should accept --install flag', async () => {
            const customXDG = testConfigDir;
            const { stdout } = await execAsync(
                `XDG_CONFIG_HOME="${customXDG}" npx ts-node src/index.ts --install --skip-completions`
            );
            expect(stdout).toContain('installed successfully');
        });

        it('should accept --uninstall flag', async () => {
            const customXDG = testConfigDir;

            // First install
            await execAsync(
                `XDG_CONFIG_HOME="${customXDG}" npx ts-node src/index.ts --install --skip-completions`
            );

            // Then uninstall
            const { stdout } = await execAsync(
                `XDG_CONFIG_HOME="${customXDG}" npx ts-node src/index.ts --uninstall --force`
            );
            expect(stdout).toContain('uninstalled successfully');
        });

        it('should show install options in help text', async () => {
            const { stdout } = await execAsync('npx ts-node src/index.ts --help');
            expect(stdout).toContain('--install');
            expect(stdout).toContain('--uninstall');
        });
    });
});
