import { describe, it, expect, vi, afterEach, afterAll } from 'vitest';
import {
    EXIT_CODES,
    CLIError,
    GenericError,
    UsageError,
    NetworkError,
    ValidationError,
    FileNotFoundError,
    PermissionDeniedError,
    handleError,
    isCLIError,
    getExitCode,
    SuggestionGenerator,
    type ErrorCategory,
} from './error.js';
import type { FileLocation } from './file-ref.js';

describe('EXIT_CODES', () => {
    it('should have correct exit code values', () => {
        expect(EXIT_CODES.SUCCESS).toBe(0);
        expect(EXIT_CODES.GENERIC_ERROR).toBe(1);
        expect(EXIT_CODES.USAGE_ERROR).toBe(2);
        expect(EXIT_CODES.NETWORK_ERROR).toBe(3);
        expect(EXIT_CODES.VALIDATION_ERROR).toBe(4);
        expect(EXIT_CODES.FILE_NOT_FOUND).toBe(5);
        expect(EXIT_CODES.PERMISSION_DENIED).toBe(6);
        expect(EXIT_CODES.SIGINT).toBe(130);
    });
});

describe('CLIError', () => {
    it('should create error with message and exit code', () => {
        const error = new CLIError('Test error', 1);
        expect(error.message).toBe('Test error');
        expect(error.exitCode).toBe(1);
        expect(error.name).toBe('CLIError');
    });

    it('should include context in error', () => {
        const context = { file: 'test.txt' };
        const error = new CLIError('Test error', 1, context);
        expect(error.context).toEqual(context);
    });

    it('should include suggestion in error', () => {
        const error = new CLIError('Test error', 1, undefined, undefined, 'Try again');
        expect(error.suggestion).toBe('Try again');
    });

    it('should format message following ADR #14 format with suggestion', () => {
        const error = new CLIError('Test error', 1, undefined, undefined, 'Try again');
        expect(error.getFormattedMessage()).toBe('ERROR: Test error - Try again');
    });

    it('should format message without suggestion', () => {
        const error = new CLIError('Test error', 1);
        expect(error.getFormattedMessage()).toBe('ERROR: Test error');
    });

    it('should format message with context', () => {
        const error = new CLIError('Test error', 1, { file: 'test.txt' });
        expect(error.getFormattedMessage()).toBe('ERROR: Test error {"file":"test.txt"}');
    });

    it('should format message with file location', () => {
        const fileLocation: FileLocation = {
            path: '/path/to/file.ts',
            line: 10,
            column: 5,
        };
        const error = new CLIError('Test error', 1, undefined, fileLocation);
        const formatted = error.getFormattedMessage();
        expect(formatted).toContain('ERROR: Test error');
        expect(formatted).toMatch(/file:\/.*\/path\/to\/file\.ts:10:5/);
    });

    it('should format message with suggestion, context, and file location', () => {
        const fileLocation: FileLocation = {
            path: '/path/to/file.ts',
            line: 10,
            column: 5,
        };
        const error = new CLIError('Test error', 1, { file: 'test.txt' }, fileLocation, 'Try again');
        const formatted = error.getFormattedMessage();
        expect(formatted).toContain('ERROR: Test error - Try again');
        expect(formatted).toMatch(/file:\/.*\/path\/to\/file\.ts:10:5/);
        expect(formatted).toContain('{"file":"test.txt"}');
    });
});

