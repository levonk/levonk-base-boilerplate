import { describe, it, expect, vi } from 'vitest';
import {
    EXIT_CODES,
    CLIError,
    GenericError,
    UsageError,
    NetworkError,
    ValidationError,
    FileNotFoundError,
    PermissionDeniedError,
    handleError,
    isCLIError,
    getExitCode,
} from './error.js';

describe('EXIT_CODES', () => {
    it('should have correct exit code values', () => {
        expect(EXIT_CODES.SUCCESS).toBe(0);
        expect(EXIT_CODES.GENERIC_ERROR).toBe(1);
        expect(EXIT_CODES.USAGE_ERROR).toBe(2);
        expect(EXIT_CODES.NETWORK_ERROR).toBe(3);
        expect(EXIT_CODES.VALIDATION_ERROR).toBe(4);
        expect(EXIT_CODES.FILE_NOT_FOUND).toBe(5);
        expect(EXIT_CODES.PERMISSION_DENIED).toBe(6);
        expect(EXIT_CODES.SIGINT).toBe(130);
    });
});

describe('CLIError', () => {
    it('should create error with message and exit code', () => {
        const error = new CLIError('Test error', 1);
        expect(error.message).toBe('Test error');
        expect(error.exitCode).toBe(1);
        expect(error.name).toBe('CLIError');
    });

    it('should include context in error', () => {
        const context = { file: 'test.txt' };
        const error = new CLIError('Test error', 1, context);
        expect(error.context).toEqual(context);
    });

    it('should format message with exit code', () => {
        const error = new CLIError('Test error', 1);
        expect(error.getFormattedMessage()).toBe('CLIError: Test error (exit code: 1)');
    });

    it('should format message with context', () => {
        const error = new CLIError('Test error', 1, { file: 'test.txt' });
        expect(error.getFormattedMessage()).toBe('CLIError: Test error (exit code: 1) {"file":"test.txt"}');
    });
});

describe('GenericError', () => {
    it('should have exit code 1', () => {
        const error = new GenericError('Generic error');
        expect(error.exitCode).toBe(EXIT_CODES.GENERIC_ERROR);
        expect(error.name).toBe('GenericError');
    });
});

describe('UsageError', () => {
    it('should have exit code 2', () => {
        const error = new UsageError('Usage error');
        expect(error.exitCode).toBe(EXIT_CODES.USAGE_ERROR);
        expect(error.name).toBe('UsageError');
    });
});

describe('NetworkError', () => {
    it('should have exit code 3', () => {
        const error = new NetworkError('Network error');
        expect(error.exitCode).toBe(EXIT_CODES.NETWORK_ERROR);
        expect(error.name).toBe('NetworkError');
    });
});

describe('ValidationError', () => {
    it('should have exit code 4', () => {
        const error = new ValidationError('Validation error');
        expect(error.exitCode).toBe(EXIT_CODES.VALIDATION_ERROR);
        expect(error.name).toBe('ValidationError');
