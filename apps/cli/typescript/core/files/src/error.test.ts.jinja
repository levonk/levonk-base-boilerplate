describe('handleError', () => {
    const mockExit = vi.spyOn(process, 'exit').mockImplementation(() => {
        throw new Error('process.exit called');
    });
    const mockLogger = { error: vi.fn() };

    afterEach(() => {
        mockExit.mockClear();
        mockLogger.error.mockClear();
    });

    afterAll(() => {
        mockExit.mockRestore();
    });

    it('should handle CLIError with correct exit code and ADR #14 format', () => {
        const error = new UsageError('Test usage error', undefined, undefined, 'Run with --help');
        expect(() => handleError(error, mockLogger)).toThrow('process.exit called');
        expect(mockExit).toHaveBeenCalledWith(EXIT_CODES.USAGE_ERROR);
        expect(mockLogger.error).toHaveBeenCalledWith('ERROR: Test usage error - Run with --help');
    });

    it('should handle generic Error with exit code 1', () => {
        const error = new Error('Generic error');
        expect(() => handleError(error, mockLogger)).toThrow('process.exit called');
        expect(mockExit).toHaveBeenCalledWith(EXIT_CODES.GENERIC_ERROR);
        expect(mockLogger.error).toHaveBeenCalledWith('Error: Generic error');
    });

    it('should handle string error with exit code 1', () => {
        const error = 'String error';
        expect(() => handleError(error, mockLogger)).toThrow('process.exit called');
        expect(mockExit).toHaveBeenCalledWith(EXIT_CODES.GENERIC_ERROR);
        expect(mockLogger.error).toHaveBeenCalledWith('String error');
    });

    it('should handle unknown error with exit code 1', () => {
        const error = null;
        expect(() => handleError(error, mockLogger)).toThrow('process.exit called');
        expect(mockExit).toHaveBeenCalledWith(EXIT_CODES.GENERIC_ERROR);
        expect(mockLogger.error).toHaveBeenCalledWith('An unexpected error occurred');
    });

    it('should work without logger', () => {
        const error = new UsageError('Test usage error', undefined, undefined, 'Run with --help');
        const consoleErrorSpy = vi.spyOn(console, 'error').mockImplementation(() => {});
        expect(() => handleError(error)).toThrow('process.exit called');
        expect(consoleErrorSpy).toHaveBeenCalledWith('ERROR: Test usage error - Run with --help');
        consoleErrorSpy.mockRestore();
    });
});

describe('isCLIError', () => {
    it('should return true for CLIError instances', () => {
        const error = new UsageError('Test');
        expect(isCLIError(error, UsageError)).toBe(true);
    });

    it('should return false for non-CLIError instances', () => {
        const error = new Error('Test');
        expect(isCLIError(error, UsageError)).toBe(false);
    });

    it('should return false for wrong CLIError type', () => {
        const error = new UsageError('Test');
        expect(isCLIError(error, NetworkError)).toBe(false);
    });
});

describe('getExitCode', () => {
    it('should return exit code from CLIError', () => {
        const error = new UsageError('Test');
        expect(getExitCode(error)).toBe(EXIT_CODES.USAGE_ERROR);
    });

    it('should return generic exit code for non-CLIError', () => {
        const error = new Error('Test');
        expect(getExitCode(error)).toBe(EXIT_CODES.GENERIC_ERROR);
    });

    it('should return generic exit code for unknown error', () => {
        expect(getExitCode(null)).toBe(EXIT_CODES.GENERIC_ERROR);
    });
});

describe('SuggestionGenerator', () => {
    describe('generate', () => {
        it('should generate usage suggestion with missing arg context', () => {
            const suggestion = SuggestionGenerator.generate('usage', { missing_arg: '--input' });
            expect(suggestion).toBe('Provide the required argument: --input');
        });

        it('should generate usage suggestion with invalid arg context', () => {
            const suggestion = SuggestionGenerator.generate('usage', { invalid_arg: '--invalid' });
            expect(suggestion).toBe('Check the argument value: --invalid');
        });

        it('should generate default usage suggestion', () => {
            const suggestion = SuggestionGenerator.generate('usage');
            expect(suggestion).toBe('Run with --help to see usage information');
        });

        it('should generate network suggestion with URL context', () => {
            const suggestion = SuggestionGenerator.generate('network', { url: 'https://example.com' });
            expect(suggestion).toBe('Check your network connection and verify the URL: https://example.com');
        });

        it('should generate default network suggestion', () => {
            const suggestion = SuggestionGenerator.generate('network');
            expect(suggestion).toBe('Check your network connection and try again');
        });

        it('should generate validation suggestion with field context', () => {
            const suggestion = SuggestionGenerator.generate('validation', { field: 'email' });
            expect(suggestion).toBe('Fix the validation error in field: email');
        });

        it('should generate validation suggestion with config file context', () => {
            const suggestion = SuggestionGenerator.generate('validation', { config_file: '/path/to/config.json' });
            expect(suggestion).toBe('Check your configuration file: /path/to/config.json');
        });

        it('should generate default validation suggestion', () => {
            const suggestion = SuggestionGenerator.generate('validation');
            expect(suggestion).toBe('Review your configuration and fix validation errors');
        });

        it('should generate file not found suggestion with path context', () => {
            const suggestion = SuggestionGenerator.generate('file_not_found', { path: '/path/to/file.txt' });
            expect(suggestion).toBe('Verify the file exists at: /path/to/file.txt');
        });

        it('should generate default file not found suggestion', () => {
            const suggestion = SuggestionGenerator.generate('file_not_found');
            expect(suggestion).toBe('Check that the file exists and the path is correct');
        });

        it('should generate permission denied suggestion with path context', () => {
            const suggestion = SuggestionGenerator.generate('permission_denied', { path: '/path/to/file.txt' });
            expect(suggestion).toBe('Check permissions for: /path/to/file.txt');
        });

        it('should generate default permission denied suggestion', () => {
            const suggestion = SuggestionGenerator.generate('permission_denied');
            expect(suggestion).toBe('Check file permissions and try again with appropriate access');
        });

        it('should generate generic suggestion', () => {
            const suggestion = SuggestionGenerator.generate('generic');
            expect(suggestion).toBe('Try again or contact support if the issue persists');
        });

        it('should return undefined for unknown error type', () => {
            const suggestion = SuggestionGenerator.generate('unknown' as ErrorCategory);
            expect(suggestion).toBeUndefined();
        });
    });
});
