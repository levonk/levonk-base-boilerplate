import { describe, it, expect, beforeEach, afterEach } from 'vitest';
import fs from 'fs/promises';
import path from 'path';
import os from 'os';
import {
    getConfigVersion,
    isLegacyConfig,
    needsMigration,
    backupConfig,
    applyMigrations,
    CURRENT_CONFIG_VERSION,
    registerMigration,
} from './migration.js';
import type { Config } from './config.js';

describe('Migration Module', () => {
    let tempDir: string;

    beforeEach(async () => {
        tempDir = await fs.mkdtemp(path.join(os.tmpdir(), 'migration-test-'));
    });

    afterEach(async () => {
        await fs.rm(tempDir, { recursive: true, force: true });
    });

    describe('getConfigVersion', () => {
        it('should return version from config', () => {
            const config = { _version: 1 };
            expect(getConfigVersion(config)).toBe(1);
        });

        it('should return 0 for config without version', () => {
            const config = { log_level: 'info' };
            expect(getConfigVersion(config)).toBe(0);
        });
    });

    describe('isLegacyConfig', () => {
        it('should return true for config without version', () => {
            const config = { log_level: 'info' };
            expect(isLegacyConfig(config)).toBe(true);
        });

        it('should return false for config with version', () => {
            const config = { _version: 1, log_level: 'info' };
            expect(isLegacyConfig(config)).toBe(false);
        });
    });

    describe('needsMigration', () => {
        it('should return true for legacy config', () => {
            const config = { log_level: 'info' };
            expect(needsMigration(config)).toBe(true);
        });

        it('should return true for outdated version', () => {
            const config = { _version: 0, log_level: 'info' };
            expect(needsMigration(config)).toBe(true);
        });

        it('should return false for current version', () => {
            const config = { _version: CURRENT_CONFIG_VERSION, log_level: 'info' };
            expect(needsMigration(config)).toBe(false);
        });
    });

    describe('backupConfig', () => {
        it('should create backup with .bak suffix', async () => {
            const configPath = path.join(tempDir, 'config.toml');
            await fs.writeFile(configPath, 'log_level = "info"');

            const backupPath = await backupConfig(configPath);

            expect(backupPath).toBe(`${configPath}.bak`);
            expect(await fs.access(backupPath)).not.toThrow();
            const backupContent = await fs.readFile(backupPath, 'utf-8');
            expect(backupContent).toBe('log_level = "info"');
        });
    });

    describe('applyMigrations', () => {
        it('should migrate legacy config to version 1', () => {
            const legacyConfig = {
                log_level: 'debug',
                quiet: true,
                colorMode: 'always',
            };

            const migrated = applyMigrations(legacyConfig);

            expect(migrated._version).toBe(CURRENT_CONFIG_VERSION);
            expect(migrated.log_level).toBe('debug');
            expect(migrated.quiet).toBe(true);
            expect(migrated.color).toBe('always');
        });

        it('should preserve additional fields during migration', () => {
            const legacyConfig = {
                log_level: 'info',
                custom_field: 'custom_value',
            };

            const migrated = applyMigrations(legacyConfig);

            expect((migrated as any).custom_field).toBe('custom_value');
        });

        it('should not modify config at current version', () => {
            const config = {
                _version: CURRENT_CONFIG_VERSION,
                log_level: 'info',
            };

            const migrated = applyMigrations(config);

            expect(migrated._version).toBe(CURRENT_CONFIG_VERSION);
            expect(migrated.log_level).toBe('info');
        });
    });

    describe('registerMigration', () => {
        it('should register and sort migrations by version', () => {
            const migration1 = {
                version: 2,
                description: 'Test migration 2',
                migrate: (c: any) => c,
            };
            const migration2 = {
                version: 1,
                description: 'Test migration 1',
                migrate: (c: any) => c,
            };

            registerMigration(migration1);
            registerMigration(migration2);

            // Migrations should be applied in version order
            const config = { _version: 0 };
            const migrated = applyMigrations(config);
            expect(migrated._version).toBe(CURRENT_CONFIG_VERSION);
        });
    });
});
