/**
 * Secret Management Module
 *
 * This module provides secure handling of sensitive data with no logging of secrets.
 * Supports secure storage options (keyring, environment variables), provides clear
 * warnings about insecure config methods, and implements secret detection and
 * redaction in logs.
 *
 * Implements CLI Tool Standards ADR requirement #25 (Credential/Secret Handling).
 */

import process from 'process';

/**
 * Secret patterns for detection
 * These patterns match common secret formats
 */
const SECRET_PATTERNS = [
  // API keys
  /(?:api[_-]?key|apikey|api[_-]?secret)[:\s=]*["']?([a-zA-Z0-9_\-]{20,})["']?/gi,
  // Passwords
  /(?:password|passwd|pwd)[:\s=]*["']?([^"'\s]{8,})["']?/gi,
  // Tokens
  /(?:token|access[_-]?token|refresh[_-]?token|bearer)[:\s=]*["']?([a-zA-Z0-9_\-\.]{20,})["']?//gi,
  // Secret keys
  /(?:secret[_-]?key|secret)[:\s=]*["']?([a-zA-Z0-9_\-]{20,})["']?/gi,
  // AWS keys
  /(?:aws[_-]?(?:access[_-]?key[_-]?id|secret[_-]?access[_-]?key))[:\s=]*["']?([A-Z0-9]{20})["']?/gi,
  // GitHub tokens
  /(?:ghp_|gho_|ghu_|ghs_|ghr_)[a-zA-Z0-9]{36}/gi,
  // JWT tokens
  /eyJ[a-zA-Z0-9_\-]+\.[a-zA-Z0-9_\-]+\.[a-zA-Z0-9_\-]+/g,
  // Stripe keys
  /(?:sk_live_|sk_test_|pk_live_|pk_test_)[a-zA-Z0-9]{24,}/gi,
  // Generic base64-like strings (potential secrets)
  /[a-zA-Z0-9_\-]{32,}/g,
];

/**
 * Redaction placeholder
 */
export const REDACTION_PLACEHOLDER = '[REDACTED]';

/**
 * Secret storage methods
 */
export enum SecretStorageMethod {
  KEYRING = 'keyring',
  ENVIRONMENT = 'environment',
  CONFIG = 'config',
}

/**
 * Secret storage options
 */
export interface SecretStorageOptions {
  method: SecretStorageMethod;
  serviceName?: string;
  accountName?: string;
  environmentVariable?: string;
}

/**
 * Secret validation result
 */
export interface SecretValidationResult {
  isValid: boolean;
  errors: string[];
  warnings: string[];
}

/**
 * Detect secrets in a string
 * @param text - Text to search for secrets
 * @returns Array of detected secret patterns
 */
export function detectSecrets(text: string): string[] {
  const secrets: string[] = [];

  for (const pattern of SECRET_PATTERNS) {
    let match;
    // Reset regex state
    pattern.lastIndex = 0;
    while ((match = pattern.exec(text)) !== null) {
      const secret = match[1] || match[0];
      if (secret && !secrets.includes(secret)) {
        secrets.push(secret);
      }
    }
  }

  return secrets;
}

/**
 * Redact secrets from a string
 * @param text - Text to redact secrets from
 * @param secrets - Optional list of secrets to redact (if not provided, will auto-detect)
 * @returns Text with secrets redacted
 */
export function redactSecrets(text: string, secrets?: string[]): string {
  const secretsToRedact = secrets || detectSecrets(text);
  let redactedText = text;

  for (const secret of secretsToRedact) {
    // Escape special regex characters in the secret
    const escapedSecret = secret.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    const regex = new RegExp(escapedSecret, 'g');
    redactedText = redactedText.replace(regex, REDACTION_PLACEHOLDER);
  }

  return redactedText;
}

/**
 * Redact secrets from an object
 * @param obj - Object to redact secrets from
 * @returns Object with secrets redacted
 */
export function redactSecretsFromObject(obj: Record<string, unknown>): Record<string, unknown> {
  const redacted: Record<string, unknown> = {};

  for (const [key, value] of Object.entries(obj)) {
    if (typeof value === 'string') {
      redacted[key] = redactSecrets(value);
    } else if (typeof value === 'object' && value !== null) {
      redacted[key] = redactSecretsFromObject(value as Record<string, unknown>);
    } else {
      redacted[key] = value;
    }
  }

  return redacted;
}

/**
 * Validate a secret value
 * @param secret - Secret to validate
 * @returns Validation result
 */
export function validateSecret(secret: string): SecretValidationResult {
  const errors: string[] = [];
  const warnings: string[] = [];

  // Check for empty secret
  if (!secret || secret.trim().length === 0) {
    errors.push('Secret cannot be empty');
  }

  // Check for weak secrets
  if (secret.length < 8) {
    warnings.push('Secret is shorter than 8 characters, consider using a longer secret');
  }

  // Check for common weak patterns
  if (/^(password|123456|qwerty|admin|test)$/i.test(secret)) {
    errors.push('Secret matches a common weak pattern');
  }

  // Check for secrets in config files (insecure)
  if (process.env.SECRET_STORAGE_METHOD === 'config') {
    warnings.push('Storing secrets in config files is insecure. Consider using keyring or environment variables.');
  }

  return {
    isValid: errors.length === 0,
    errors,
    warnings,
  };
}

/**
 * Get a secret from storage
 * @param options - Storage options
 * @returns Secret value or null if not found
 */
export async function getSecret(options: SecretStorageOptions): Promise<string | null> {
  switch (options.method) {
    case SecretStorageMethod.ENVIRONMENT:
      if (options.environmentVariable) {
        return process.env[options.environmentVariable] || null;
      }
      return null;

    case SecretStorageMethod.KEYRING:
      // Try to use keyring library if available
      try {
        // Dynamic import to avoid hard dependency
        const keytar = await import('keytar');
        if (options.serviceName && options.accountName) {
          return await keytar.getPassword(options.serviceName, options.accountName);
        }
      } catch (error) {
        // keytar not available or failed
        console.warn('Keyring library not available. Falling back to environment variables.');
        if (options.environmentVariable) {
          return process.env[options.environmentVariable] || null;
        }
      }
      return null;

    case SecretStorageMethod.CONFIG:
      // Warn about insecure config storage
      console.warn('WARNING: Storing secrets in config files is insecure.');
      if (options.environmentVariable) {
        return process.env[options.environmentVariable] || null;
      }
      return null;

    default:
      return null;
  }
}

/**
 * Set a secret in storage
 * @param options - Storage options
 * @param secret - Secret value to store
 * @returns True if successful
 */
export async function setSecret(options: SecretStorageOptions, secret: string): Promise<boolean> {
  // Validate secret before storing
  const validation = validateSecret(secret);
  if (!validation.isValid) {
    console.error(`Secret validation failed: ${validation.errors.join(', ')}`);
    return false;
  }

  // Log warnings
  if (validation.warnings.length > 0) {
    console.warn(`Secret validation warnings: ${validation.warnings.join(', ')}`);
  }

  switch (options.method) {
    case SecretStorageMethod.ENVIRONMENT:
      // Cannot set environment variables from Node.js
      console.warn('Cannot set environment variables from Node.js. Set them in your shell or .env file.');
      return false;

    case SecretStorageMethod.KEYRING:
      try {
        const keytar = await import('keytar');
        if (options.serviceName && options.accountName) {
          await keytar.setPassword(options.serviceName, options.accountName, secret);
          return true;
        }
      } catch (error) {
        console.error('Failed to store secret in keyring:', error);
        return false;
      }
      return false;

    case SecretStorageMethod.CONFIG:
      console.warn('WARNING: Storing secrets in config files is insecure. Use keyring or environment variables instead.');
      return false;

    default:
      return false;
  }
}

/**
 * Delete a secret from storage
 * @param options - Storage options
 * @returns True if successful
 */
export async function deleteSecret(options: SecretStorageOptions): Promise<boolean> {
  switch (options.method) {
    case SecretStorageMethod.KEYRING:
      try {
        const keytar = await import('keytar');
        if (options.serviceName && options.accountName) {
          await keytar.deletePassword(options.serviceName, options.accountName);
          return true;
        }
      } catch (error) {
        console.error('Failed to delete secret from keyring:', error);
        return false;
      }
      return false;

    case SecretStorageMethod.ENVIRONMENT:
    case SecretStorageMethod.CONFIG:
      console.warn('Cannot delete secrets from environment variables or config files from Node.js.');
      return false;

    default:
      return false;
  }
}

/**
 * Check if keyring is available
 * @returns True if keyring library is available
 */
export async function isKeyringAvailable(): Promise<boolean> {
  try {
    await import('keytar');
    return true;
  } catch {
    return false;
  }
}

/**
 * Get recommended storage method based on platform
 * @returns Recommended storage method
 */
export function getRecommendedStorageMethod(): SecretStorageMethod {
  const keyringAvailable = isKeyringAvailable();
  if (keyringAvailable) {
    return SecretStorageMethod.KEYRING;
  }
  return SecretStorageMethod.ENVIRONMENT;
}
