/**
 * Tests for Secret Management Module
 */

import { describe, it, expect, vi, beforeEach } from 'vitest';
import {
  detectSecrets,
  redactSecrets,
  redactSecretsFromObject,
  validateSecret,
  SecretStorageMethod,
  getSecret,
  setSecret,
  deleteSecret,
  isKeyringAvailable,
  getRecommendedStorageMethod,
  REDACTION_PLACEHOLDER,
} from './secrets.js';

describe('Secret Detection', () => {
  it('should detect API keys', () => {
    const text = 'api_key=sk_live_1234567890abcdef1234567890abcdef';
    const secrets = detectSecrets(text);
    expect(secrets).toHaveLength(1);
    expect(secrets[0]).toContain('sk_live_');
  });

  it('should detect passwords', () => {
    const text = 'password=MySecretPassword123';
    const secrets = detectSecrets(text);
    expect(secrets).toHaveLength(1);
    expect(secrets[0]).toBe('MySecretPassword123');
  });

  it('should detect JWT tokens', () => {
    const text = 'token=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoxNTE2MjM5MDIyfQ.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c';
    const secrets = detectSecrets(text);
    expect(secrets).toHaveLength(1);
    expect(secrets[0]).toMatch(/^eyJ/);
  });

  it('should detect GitHub tokens', () => {
    const text = 'ghp_1234567890abcdef1234567890abcdef12345678';
    const secrets = detectSecrets(text);
    expect(secrets).toHaveLength(1);
    expect(secrets[0]).toMatch(/^ghp_/);
  });

  it('should detect multiple secrets in one string', () => {
    const text = 'api_key=abc123 password=secret456 token=xyz789';
    const secrets = detectSecrets(text);
    expect(secrets.length).toBeGreaterThan(0);
  });

  it('should not detect secrets in clean text', () => {
    const text = 'This is a normal message with no secrets';
    const secrets = detectSecrets(text);
    expect(secrets).toHaveLength(0);
  });
});

describe('Secret Redaction', () => {
  it('should redact detected secrets from text', () => {
    const text = 'api_key=sk_live_1234567890abcdef1234567890abcdef';
    const redacted = redactSecrets(text);
    expect(redacted).toContain(REDACTION_PLACEHOLDER);
    expect(redacted).not.toContain('sk_live_');
  });

  it('should redact specific secrets when provided', () => {
    const text = 'password=MySecretPassword123';
    const secrets = ['MySecretPassword123'];
    const redacted = redactSecrets(text, secrets);
    expect(redacted).toContain(REDACTION_PLACEHOLDER);
    expect(redacted).not.toContain('MySecretPassword123');
  });

  it('should redact secrets from object', () => {
    const obj = {
      username: 'user',
      password: 'secret123',
      apiKey: 'abc456',
    };
    const redacted = redactSecretsFromObject(obj);
    expect(redacted.password).toBe(REDACTION_PLACEHOLDER);
    expect(redacted.apiKey).toBe(REDACTION_PLACEHOLDER);
    expect(redacted.username).toBe('user');
  });

  it('should redact secrets from nested objects', () => {
    const obj = {
      config: {
        password: 'secret123',
        nested: {
          apiKey: 'abc456',
        },
      },
    };
    const redacted = redactSecretsFromObject(obj);
    expect((redacted as any).config.password).toBe(REDACTION_PLACEHOLDER);
    expect((redacted as any).config.nested.apiKey).toBe(REDACTION_PLACEHOLDER);
  });

  it('should not modify non-string values', () => {
    const obj = {
      count: 42,
      enabled: true,
      items: [1, 2, 3],
    };
    const redacted = redactSecretsFromObject(obj);
    expect(redacted.count).toBe(42);
    expect(redacted.enabled).toBe(true);
    expect(redacted.items).toEqual([1, 2, 3]);
  });
});

describe('Secret Validation', () => {
  it('should reject empty secrets', () => {
    const result = validateSecret('');
    expect(result.isValid).toBe(false);
    expect(result.errors).toContain('Secret cannot be empty');
  });

  it('should reject weak common passwords', () => {
    const result = validateSecret('password');
    expect(result.isValid).toBe(false);
    expect(result.errors).toContain('Secret matches a common weak pattern');
  });

  it('should warn about short secrets', () => {
    const result = validateSecret('short');
    expect(result.isValid).toBe(true);
    expect(result.warnings).toContain('Secret is shorter than 8 characters, consider using a longer secret');
  });

  it('should accept strong secrets', () => {
    const result = validateSecret('MyStrongPassword123!');
    expect(result.isValid).toBe(true);
    expect(result.errors).toHaveLength(0);
  });
});

describe('Secret Storage', () => {
  beforeEach(() => {
    vi.mock('keytar', () => ({
      getPassword: vi.fn(),
      setPassword: vi.fn(),
      deletePassword: vi.fn(),
    }));
  });

  it('should get secret from environment variable', async () => {
    process.env.TEST_SECRET = 'my-secret-value';
    const result = await getSecret({
      method: SecretStorageMethod.ENVIRONMENT,
      environmentVariable: 'TEST_SECRET',
    });
    expect(result).toBe('my-secret-value');
    delete process.env.TEST_SECRET;
  });

  it('should return null when environment variable not set', async () => {
    const result = await getSecret({
      method: SecretStorageMethod.ENVIRONMENT,
      environmentVariable: 'NON_EXISTENT_VAR',
    });
    expect(result).toBeNull();
  });

  it('should fail to set environment variable from Node.js', async () => {
    const result = await setSecret(
      {
        method: SecretStorageMethod.ENVIRONMENT,
        environmentVariable: 'TEST_VAR',
      },
      'secret-value'
    );
    expect(result).toBe(false);
  });

  it('should warn about config storage', async () => {
    const consoleWarnSpy = vi.spyOn(console, 'warn');
    await getSecret({
      method: SecretStorageMethod.CONFIG,
      environmentVariable: 'TEST_VAR',
    });
    expect(consoleWarnSpy).toHaveBeenCalledWith(
      'WARNING: Storing secrets in config files is insecure.'
    );
    consoleWarnSpy.mockRestore();
  });
});

describe('Keyring Availability', () => {
  it('should return false when keytar is not available', async () => {
    const result = await isKeyringAvailable();
    // In test environment, keytar may or may not be available
    expect(typeof result).toBe('boolean');
  });
});

describe('Recommended Storage Method', () => {
  it('should return a valid storage method', () => {
    const method = getRecommendedStorageMethod();
    expect([SecretStorageMethod.KEYRING, SecretStorageMethod.ENVIRONMENT]).toContain(method);
  });
});
