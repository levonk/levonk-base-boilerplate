#!/usr/bin/env node
import { Command } from 'commander';
import process from 'process';
import { glob } from 'glob';
import fs from 'fs/promises';
import { createLogger, LoggerOptions } from './logger.js';
import {
    UsageError,
    FileNotFoundError,
    PermissionDeniedError,
    GenericError,
    handleError,
    EXIT_CODES,
} from './error.js';
import {
    loadConfigWithPrecedence,
    initializeConfig,
    type Config,
    type ConfigOptions,
} from './config.js';
import {
    writeCompletionScript,
    getCompletionInstallInstructions,
    type CompletionOptions,
    type ShellType,
} from './completions.js';
import {
    writeManPage,
    getManPageInstallInstructions,
    type ManPageOptions,
} from './man.js';
import {
    install,
    uninstall,
    checkInstallStatus,
    type InstallOptions,
    type UninstallOptions,
} from './install.js';
import {
    initGlobalDryRunManager,
    getGlobalDryRunManager,
    isDryRunEnabled,
} from './dry-run.js';
import {
    confirmDelete,
    confirmOverwrite,
    confirmDestructive,
    type PromptOptions,
} from './prompts.js';
import {
    getProgressManager,
    resetProgressManager,
    type ProgressOptions,
} from './progress.js';
import {
    createPager,
    type PagerOptions,
} from './pager.js';
import {
    launchTUI,
    isTTY,
    checkTUICompatibility,
    type TUIOptions,
} from './tui.js';
import {
    getDaemonManager,
    type DaemonConfig,
    type Job,
} from './daemon.js';
import {
    reloadConfig,
    type ConfigReloadResult,
} from './config.js';
import {
    ensurePath,
    formatErrorPath,
    formatLogPath,
    type PathOptions,
} from './path.js';

// Handle Ctrl+C
process.on('SIGINT', () => {
    process.stderr.write('\nOperation cancelled.\n');
    process.exit(EXIT_CODES.SIGINT);
});

// Global state for config reload
let currentConfigOptions: ConfigOptions | null = null;
let currentCliArgs: Partial<Config> | null = null;
let currentLogger: any = null;

/**
 * Handle SIGHUP signal for config reload
 * Reloads config from file, validates it, and applies if valid
 * Keeps old config active on validation errors
 */
process.on('SIGHUP', async () => {
    if (!currentConfigOptions || !currentLogger) {
        return;
    }

    try {
        currentLogger.info('Received SIGHUP signal, reloading configuration...');

        const reloadResult: ConfigReloadResult = await reloadConfig(
            currentConfigOptions,
            currentCliArgs || undefined,
            currentLogger.options.verbose
        );

        if (reloadResult.success) {
            currentLogger.info('Configuration reloaded successfully');
            if (reloadResult.diff && Object.keys(reloadResult.diff).length > 0) {
                currentLogger.debug('Configuration changes:');
                for (const [key, change] of Object.entries(reloadResult.diff)) {
                    currentLogger.debug(`  ${key}: ${JSON.stringify(change.old)} -> ${JSON.stringify(change.new)}`);
                }
            }
        } else {
            currentLogger.error(`Configuration reload failed: ${reloadResult.error}`);
            currentLogger.error('Keeping previous configuration active');
        }
    } catch (error) {
        currentLogger.error(`Error during config reload: ${error}`);
        currentLogger.error('Keeping previous configuration active');
    }
});

const program = new Command();

program
  .name('{{ project_slug }}')
  .description('{{ description }}')
  .version('1.0.0', '-v, --version', 'Output the version number')
  .helpOption('-h, --help', 'Display help for command')
  .addHelpText('after', 'Use "{{ project_slug }} help <command>" for more information on a command.')
  .addHelpText('after', '\nPath Handling:\n  This CLI automatically handles cross-platform path differences:\n  - Normalizes both forward (/) and backward (\\) slashes\n  - Uses platform-appropriate separators for output\n  - Resolves . and .. segments in paths\n  - Handles paths with spaces and special characters\n  - Works consistently on Windows, Linux, and macOS')
  .addHelpText('after', '\nExit Codes:\n  0   Success\n  1   Generic error\n  2   Usage error (invalid arguments, missing required args)\n  3   Network error (connection failures, timeouts)\n  4   Validation error (invalid config, schema validation failures)\n  5   File not found\n  6   Permission denied\n  130 SIGINT (Ctrl+C)')
  .argument('[inputs...]', 'Input files or glob patterns. Use "-" for stdin.')
  .option('-q, --quiet', 'Suppress all output except errors')
  .option('--verbose', 'Enable verbose output with extra details')
  .option('--debug', 'Enable debug-level logging')
  .option('--usage', 'Display usage information')
  .option('--color <mode>', 'Color mode: auto, always, or never', 'auto')
  .option('--log-format <format>', 'Log format: text or json', 'text')
  .option('--json', 'Output results as JSON')
  .option('--install', 'Install CLI (generate completions, initialize config)')
  .option('--skip-completions', 'Skip shell completion generation during install')
  .option('--uninstall', 'Uninstall CLI (remove completions, clean up config)')
  .option('--force', 'Force operation without confirmation')
  .option('-c, --config <path>', 'Config file path (default: ~/.config/{{ project_slug }}/config.toml)', process.env.{{ project_slug | upper | replace('-', '_') }}_CONFIG)
  .addHelpText('after', '\nConfig Precedence (highest to lowest):\n  1. CLI arguments\n  2. Environment variables ({{ PROJECT_SLUG }}_*)\n  3. Local project config (./.{{ project_slug }}/config.toml)\n  4. User config (~/.config/{{ project_slug }}/config.toml)\n  5. System config (/etc/{{ project_slug }}/config.toml)\n  6. Hardcoded defaults')
  .addHelpText('after', '\nLogging Options:\n  --debug       Enable debug-level logging\n  --log-format  Log format: text (default) or json\n  --quiet        Suppress all output except errors\n  --verbose      Enable verbose output with extra details\n  Environment Variables:\n  LOG_LEVEL      Set log level (debug, info, warn, error, fatal)\n  NODE_ENV       Set to "development" to enable debug mode')
  .addHelpText('after', '\nSecret Handling:\n  Secrets are automatically redacted from all log output, error messages,\n  and debug output. Supported secret patterns include API keys, passwords,\n  tokens, and other sensitive data. Secrets are never logged in plain text.\n  Environment Variables:\n  SECRET_STORAGE_METHOD  Storage method: keyring (recommended), environment, or config')
  .addHelpText('after', '\nURL Formatting:\n  URLs in output are automatically formatted for terminal display\n  - Clickable links are enabled in supported terminals (OSC 8 escape sequences)\n  - URLs are normalized to use HTTP/HTTPS protocol\n  - Special characters are properly encoded\n  - Fallback to plain text for terminals without URL support\n  - NO_COLOR environment variable disables clickable URLs')
  .addHelpText('after', '\nDry-Run Mode:\n  --dry-run     Preview changes without executing them\n                Shows what would be done without making any changes')
  .addHelpText('after', '\nConfirmation Prompts:\n  --force       Bypass confirmation prompts for destructive operations\n                Use with caution in automated scripts\n  Environment Variables:\n  CONFIRM_BYPASS Set to "true" or "1" to bypass prompts in non-TTY environments')
  .addHelpText('after', '\nProgress Indicators:\n  Progress bars are shown for long-running file operations\n  Progress is suppressed in quiet mode (--quiet) or JSON mode (--json)\n  Progress can be cancelled with Ctrl+C (SIGINT)')
  .addHelpText('after', '\nFile References:\n  Error messages and log output include clickable file references\n  Format: file:///absolute/path/to/file:line:column (VSCode)\n  Format: file:line:column (standard terminal)\n  File references are automatically formatted based on environment detection')
  .addHelpText('after', '\nInstallation:\n  --install      Install CLI (generate completions, initialize config)\n  --uninstall    Uninstall CLI (remove completions, clean up config)')
  .addHelpText('after', '\nShell Completion:\n  Generate completion scripts with: {{ project_slug }} --completion <shell>\n  Show installation instructions with: {{ project_slug }} --completion-install <shell>')
  .addHelpText('after', '\nMan Pages:\n  Generate man page with: {{ project_slug }} --man\n  Show installation instructions with: {{ project_slug }} --man-install')
  .addHelpText('after', '\nPager:\n  Long output is automatically paged using the PAGER environment variable (default: less)\n  Use --no-pager to disable paging\n  Paging is disabled for JSON output mode and piped output\n  Environment Variables:\n  PAGER         Set pager command (default: less)')
  .addHelpText('after', '\nTUI Mode:\n  --interactive, --tui  Launch interactive Terminal User Interface\n                        Allows viewing and modifying all arguments before execution\n                        Falls back to CLI mode in non-TTY environments')
  .addHelpText('after', '\nDaemon Mode:\n  --daemon              Pre-launch daemon in background for long-running operations\n  --no-daemon           Force synchronous operation (disable daemon)\n  --list-jobs           List background job status\n  --cancel-job <id>     Cancel a specific background job\n  Daemon auto-spawns on first async operation unless --no-daemon is set')
  .addHelpText('after', '\nConfig Reload:\n  Send SIGHUP signal to reload configuration without restart\n  Example: kill -HUP <pid>\n  New config is validated before applying\n  Validation errors keep old config active\n  Config changes are logged in verbose mode')
  .option('--dry-run', 'Preview changes without executing them')
  .option('--interactive, --tui', 'Launch interactive Terminal User Interface')
  .option('--daemon', 'Pre-launch daemon in background')
  .option('--no-daemon', 'Force synchronous operation (disable daemon)')
  .option('--list-jobs', 'List background job status')
  .option('--cancel-job <id>', 'Cancel a specific background job')
  .option('--completion <shell>', 'Generate shell completion script (bash, zsh, fish)')
  .option('--completion-install <shell>', 'Show shell completion installation instructions')
  .option('--output-dir <path>', 'Output directory for completion scripts', 'completions')
  .option('--stdout', 'Output completion script to stdout instead of file')
  .option('--man', 'Generate man page')
  .option('--man-install', 'Show man page installation instructions')
  .option('--man-output-dir <path>', 'Output directory for man pages', 'man')
  .option('--no-pager', 'Disable pager for long output')
  .action(async (inputs: string[], options) => {
      try {
          // Suppress console output immediately for quiet and json modes
          // This must happen before any other processing to ensure all output is suppressed
          let originalLog: any, originalError: any, originalWarn: any;
          if (options.quiet === true || options.json === true) {
              originalLog = console.log;
              originalError = console.error;
              originalWarn = console.warn;
              console.log = () => {};
              console.error = () => {};
              console.warn = () => {};
          }

          // Handle --usage flag
          if (options.usage) {
              program.helpInformation();
              process.exit(EXIT_CODES.SUCCESS);
          }

          // Handle --completion flag
          if (options.completion) {
              const shell = options.completion as ShellType;
              const completionOptions: CompletionOptions = {
                  shell,
                  outputDir: options.outputDir,
                  stdout: options.stdout,
              };
              const logger = createLogger({ quiet: false, verbose: options.verbose, color: 'auto', module: '{{ project_slug }}' });
              await writeCompletionScript(program, completionOptions, logger);
              process.exit(EXIT_CODES.SUCCESS);
          }

          // Handle --completion-install flag
          if (options.completionInstall) {
              const shell = options.completionInstall as ShellType;
              const instructions = getCompletionInstallInstructions(shell, '{{ project_slug }}');
              console.log(instructions);
              process.exit(EXIT_CODES.SUCCESS);
          }

          // Handle --man flag
          if (options.man) {
              const manOptions: ManPageOptions = {
                  outputDir: options.manOutputDir,
                  stdout: options.stdout,
              };
              const logger = createLogger({ quiet: false, verbose: options.verbose, color: 'auto', module: '{{ project_slug }}' });
              await writeManPage(program, manOptions, logger);
              process.exit(EXIT_CODES.SUCCESS);
          }

          // Handle --man-install flag
          if (options.manInstall) {
              const instructions = getManPageInstallInstructions('{{ project_slug }}');
              console.log(instructions);
              process.exit(EXIT_CODES.SUCCESS);
          }

          // Handle --install flag
          if (options.install) {
              const installOptions: InstallOptions = {
                  projectSlug: '{{ project_slug }}',
                  verbose: options.verbose,
                  force: options.force,
                  skipCompletions: options.skipCompletions,
              };
              const logger = createLogger({ quiet: false, verbose: options.verbose, color: 'auto', module: '{{ project_slug }}' });
              await install(installOptions, logger);
              process.exit(EXIT_CODES.SUCCESS);
          }

          // Handle --uninstall flag
          if (options.uninstall) {
              const uninstallOptions: UninstallOptions = {
                  projectSlug: '{{ project_slug }}',
                  verbose: options.verbose,
                  force: options.force,
                  keepConfig: false,
              };
              const logger = createLogger({ quiet: false, verbose: options.verbose, color: 'auto', module: '{{ project_slug }}' });
              await uninstall(uninstallOptions, logger);
              process.exit(EXIT_CODES.SUCCESS);
          }

          // Handle --list-jobs flag
          if (options.listJobs) {
              const logger = createLogger({ quiet: false, verbose: options.verbose, color: 'auto', module: '{{ project_slug }}' });
              const daemon = getDaemonManager({}, { quiet: false, verbose: options.verbose, color: 'auto', module: 'daemon' });
              const jobs = daemon.listJobs();

              if (jobs.length === 0) {
                  logger.info('No background jobs found');
              } else {
                  logger.info(`Found ${jobs.length} background job(s):`);
                  for (const job of jobs) {
                      logger.info(`  ${job.id}: ${job.status} - ${job.command} ${job.args.join(' ')}`);
                      if (job.progress !== undefined) {
                          logger.info(`    Progress: ${job.progress}%`);
                      }
                  }
              }
              process.exit(EXIT_CODES.SUCCESS);
          }

          // Handle --cancel-job flag
          if (options.cancelJob) {
              const logger = createLogger({ quiet: false, verbose: options.verbose, color: 'auto', module: '{{ project_slug }}' });
              const daemon = getDaemonManager({}, { quiet: false, verbose: options.verbose, color: 'auto', module: 'daemon' });
              const cancelled = await daemon.cancelJob(options.cancelJob);

              if (cancelled) {
                  logger.info(`Job ${options.cancelJob} cancelled successfully`);
              } else {
                  logger.error(`Failed to cancel job ${options.cancelJob}`);
                  process.exit(EXIT_CODES.GENERIC_ERROR);
              }
              process.exit(EXIT_CODES.SUCCESS);
          }

          // Handle --interactive / --tui flag
          if (options.interactive || options.tui) {
              const compatibility = checkTUICompatibility();
              if (!compatibility.compatible) {
                  const logger = createLogger({ quiet: false, verbose: options.verbose, color: 'auto', module: '{{ project_slug }}' });
                  logger.warn(`TUI mode not available: ${compatibility.reason}`);
                  logger.info('Falling back to CLI mode');
              } else {
                  // Initialize config for TUI
                  const configOptions: ConfigOptions = {
                      projectSlug: '{{ project_slug }}',
                      configPath: options.config,
                      debug: options.verbose,
                  };
                  const cliArgs: Partial<Config> = {};
                  if (options.quiet !== undefined) cliArgs.quiet = options.quiet;
                  if (options.verbose !== undefined) cliArgs.verbose = options.verbose;
                  if (options.debug !== undefined) cliArgs.debug = options.debug;
                  if (options.color !== undefined) cliArgs.color = options.color;
                  if (options.logFormat !== undefined) cliArgs.log_format = options.logFormat;
                  if (options.json !== undefined) cliArgs.json = options.json;

                  const config = await loadConfigWithPrecedence(configOptions, cliArgs);

                  const tuiOptions: TUIOptions = {
                      config,
                      onExecute: (modifiedConfig) => {
                          // Store modified config for use in main execution
                          (options as any).tuiConfig = modifiedConfig;
                      },
                      onCancel: () => {
                          const logger = createLogger({ quiet: false, verbose: options.verbose, color: 'auto', module: '{{ project_slug }}' });
                          logger.info('TUI cancelled by user');
                          process.exit(EXIT_CODES.SUCCESS);
                      },
                      projectSlug: '{{ project_slug }}',
                  };

                  launchTUI(tuiOptions);
                  // TUI is synchronous, so we continue after it exits
              }
          }

          // Initialize config with full precedence chain
          const configOptions: ConfigOptions = {
              projectSlug: '{{ project_slug }}',
              configPath: options.config,
              debug: options.verbose,
          };

          // Build CLI args for config precedence
          const cliArgs: Partial<Config> = {};
          if (options.quiet !== undefined) cliArgs.quiet = options.quiet;
          if (options.verbose !== undefined) cliArgs.verbose = options.verbose;
          if (options.debug !== undefined) cliArgs.debug = options.debug;
          if (options.color !== undefined) cliArgs.color = options.color;
          if (options.logFormat !== undefined) cliArgs.log_format = options.logFormat;
          if (options.json !== undefined) cliArgs.json = options.json;

          // Store global state for SIGHUP config reload
          currentConfigOptions = configOptions;
          currentCliArgs = cliArgs;

          let config = await loadConfigWithPrecedence(configOptions, cliArgs);

          // Use TUI-modified config if available
          if ((options as any).tuiConfig) {
              config = { ...config, ...(options as any).tuiConfig };
          }

          // Use merged config (CLI args already applied via precedence)
          // For quiet and json, prefer CLI args directly to ensure they work as expected
          const mergedOptions = {
              quiet: options.quiet === true ? true : config.quiet,
              verbose: options.verbose === true ? true : config.verbose,
              debug: options.debug === true ? true : config.debug,
              color: options.color !== undefined ? options.color : config.color,
              logFormat: options.logFormat !== undefined ? options.logFormat : config.log_format,
              json: options.json === true ? true : config.json,
          };

          // Initialize config (creates default if doesn't exist) - only when not installing/uninstalling
          // This ensures config is created on first run when CLI is invoked
          if (!options.install && !options.uninstall) {
              await initializeConfig(configOptions, options.verbose);
          }

          // Create logger with merged options
          // For quiet and json, use CLI options directly to ensure they work
          const loggerOptions: LoggerOptions = {
              quiet: options.quiet === true || options.json === true,
              verbose: options.verbose === true,
              debug: options.debug === true,
              logLevel: config.log_level as any,
              color: options.color !== undefined ? options.color : config.color,
              logFormat: options.logFormat !== undefined ? options.logFormat : config.log_format,
              module: '{{ project_slug }}',
          };
          const logger = createLogger(loggerOptions);

          // Store logger globally for SIGHUP config reload
          currentLogger = logger;

          // Handle daemon mode
          const daemonConfig: Partial<DaemonConfig> = {
              enabled: options.noDaemon !== true,
              autoSpawn: options.noDaemon !== true,
          };
          const daemon = getDaemonManager(daemonConfig, {
              quiet: options.quiet === true || options.json === true,
              verbose: options.verbose === true,
              color: options.color !== undefined ? options.color : config.color,
              module: 'daemon',
          });

          // Pre-launch daemon if --daemon flag is set
          if (options.daemon) {
              logger.info('Pre-launching daemon in background...');
              await daemon.start();
              logger.info('Daemon launched successfully');
          }

          // Initialize dry-run manager
          initGlobalDryRunManager(logger, options.dryRun);

          // Initialize progress manager
          const progressOptions: ProgressOptions = {
              quiet: mergedOptions.quiet,
              json: mergedOptions.json,
          };
          const progressManager = getProgressManager(progressOptions);

          // Initialize pager
          const pagerOptions: PagerOptions = {
              enabled: !options.noPager,
              isJsonOutput: mergedOptions.json,
          };
          const pager = createPager(pagerOptions);

          // Input Processing
          const filesToProcess: string[] = [];
          let readStdin = false;

          if (inputs.length === 0) {
              // Check if stdin is a TTY
              if (process.stdin.isTTY) {
                  throw new UsageError('No inputs provided. Use "-" for stdin or provide file patterns.');
              } else {
                  readStdin = true;
              }
          } else {
              for (const input of inputs) {
                  if (input === '-') {
                      readStdin = true;
                  } else {
                      // Globbing
                      const matches = await glob(input, { nodir: true });
                      if (matches.length === 0) {
                          logger.warn(`No files found for pattern '${input}'`);
                      }
                      filesToProcess.push(...matches);
                  }
              }
          }

          const results: any[] = [];

          if (readStdin) {
              logger.info('Processing stdin...');
              const chunks = [];
              for await (const chunk of process.stdin) {
                  chunks.push(chunk);
              }
              const content = Buffer.concat(chunks).toString('utf-8');
              results.push({ source: 'stdin', length: content.length });
          }

          // Process files with progress bar
          if (filesToProcess.length > 0 && !mergedOptions.quiet && !mergedOptions.json) {
              const bar = progressManager.createBar(filesToProcess.length, 'Processing files');
              for (const file of filesToProcess) {
                  try {
                      const normalizedPath = ensurePath(file, { normalize: true });
                      const content = await fs.readFile(normalizedPath, 'utf-8');
                      results.push({ source: normalizedPath, length: content.length });
                      bar?.increment();
                  } catch (error) {
                      bar?.stop();
                      if ((error as NodeJS.ErrnoException).code === 'ENOENT') {
                          throw new FileNotFoundError(`File not found: ${formatErrorPath(file)}`, { file });
                      } else if ((error as NodeJS.ErrnoException).code === 'EACCES') {
                          throw new PermissionDeniedError(`Permission denied: ${formatErrorPath(file)}`, { file });
                      } else {
                          throw new GenericError(`Error processing ${formatErrorPath(file)}: ${error}`, { file, error });
                      }
                  }
              }
              bar?.stop();
          } else {
              for (const file of filesToProcess) {
                  try {
                      const normalizedPath = ensurePath(file, { normalize: true });
                      logger.info(`Processing ${formatLogPath(file, mergedOptions.debug)}...`);
                      const content = await fs.readFile(normalizedPath, 'utf-8');
                      results.push({ source: normalizedPath, length: content.length });
                  } catch (error) {
                      if ((error as NodeJS.ErrnoException).code === 'ENOENT') {
                      throw new FileNotFoundError(`File not found: ${formatErrorPath(file)}`, { file });
                  } else if ((error as NodeJS.ErrnoException).code === 'EACCES') {
                      throw new PermissionDeniedError(`Permission denied: ${formatErrorPath(file)}`, { file });
                  } else {
                      throw new GenericError(`Error processing ${formatErrorPath(file)}: ${error}`, { file, error });
                  }
                  }
              }
          }

          if (mergedOptions.json) {
              const output = {
                  dryRun: isDryRunEnabled(),
                  results,
              };
              // Restore console functions temporarily to output JSON
              if (originalLog && originalError && originalWarn) {
                  console.log = originalLog;
                  console.error = originalError;
                  console.warn = originalWarn;
              }
              console.log(JSON.stringify(output, null, 2));
              // Re-suppress after output
              console.log = () => {};
              console.error = () => {};
              console.warn = () => {};
          } else {
              if (isDryRunEnabled()) {
                  logger.info('[DRY-RUN] Mode enabled - no changes were made');
              }

              // Build output string
              const outputLines: string[] = [];
              outputLines.push(`Processed ${results.length} inputs.`);

              if (results.length > 0) {
                  outputLines.push('');
                  outputLines.push('Results:');
                  for (const result of results) {
                      outputLines.push(`  ${result.source}: ${result.length} bytes`);
                  }
              }

              const outputString = outputLines.join('\n');

              // Use pager for output if enabled and output is long
              if (!options.noPager) {
                  pager.page(outputString);
              } else {
                  console.log(outputString);
              }
          }

          // Restore console functions if they were suppressed
          if ((options.quiet === true || options.json === true) && originalLog && originalError && originalWarn) {
              console.log = originalLog;
              console.error = originalError;
              console.warn = originalWarn;
          }
      } catch (error) {
          const logger = createLogger({ quiet: false, verbose: false, color: 'auto', module: '{{ project_slug }}' });
          handleError(error, logger);
      }
  });

program.parse();
