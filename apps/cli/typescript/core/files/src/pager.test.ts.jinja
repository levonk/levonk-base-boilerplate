import { describe, it, expect, beforeEach, afterEach, vi } from 'vitest';
import { createPager, PagerOptions } from './pager.js';

describe('Pager', () => {
  const originalPager = process.env.PAGER;
  const originalStdoutIsTTY = process.stdout.isTTY;

  afterEach(() => {
    // Restore original PAGER value after each test
    if (originalPager === undefined) {
      delete process.env.PAGER;
    } else {
      process.env.PAGER = originalPager;
    }
  });

  describe('PAGER environment variable detection', () => {
    it('should use PAGER environment variable when set', () => {
      process.env.PAGER = 'more';
      const pager = createPager();
      expect(pager.getPager()).toBe('more');
    });

    it('should default to less when PAGER is not set', () => {
      delete process.env.PAGER;
      const pager = createPager();
      expect(pager.getPager()).toBe('less');
    });

    it('should use custom pager from options', () => {
      const pager = createPager({ pager: 'most' });
      expect(pager.getPager()).toBe('most');
    });

    it('should prioritize options.pager over PAGER environment variable', () => {
      process.env.PAGER = 'more';
      const pager = createPager({ pager: 'most' });
      expect(pager.getPager()).toBe('most');
    });
  });

  describe('Terminal height detection', () => {
    it('should detect terminal height from process.stdout.rows', () => {
      // Mock process.stdout.rows
      const originalRows = process.stdout.rows;
      Object.defineProperty(process.stdout, 'rows', { value: 40, configurable: true });

      const pager = createPager();
      expect(pager.getTerminalHeight()).toBe(40);

      // Restore original value
      Object.defineProperty(process.stdout, 'rows', { value: originalRows, configurable: true });
    });

    it('should use default height when detection fails', () => {
      // Mock process.stdout.rows to undefined
      const originalRows = process.stdout.rows;
      Object.defineProperty(process.stdout, 'rows', { value: undefined, configurable: true });

      const pager = createPager();
      expect(pager.getTerminalHeight()).toBe(24); // default fallback

      // Restore original value
      Object.defineProperty(process.stdout, 'rows', { value: originalRows, configurable: true });
    });

    it('should use custom terminal height from options', () => {
      const pager = createPager({ terminalHeight: 50 });
      expect(pager.getTerminalHeight()).toBe(50);
    });
  });

  describe('Piped output detection', () => {
    it('should detect piped output when stdout is not a TTY', () => {
      // Mock process.stdout.isTTY to false
      const originalIsTTY = process.stdout.isTTY;
      Object.defineProperty(process.stdout, 'isTTY', { value: false, configurable: true });

      const pager = createPager();
      // The pager should detect piped output internally
      // We can't directly test isPipedOutput since it's private
      // But we can test that pager is disabled for piped output
      expect(pager).toBeDefined();

      // Restore original value
      Object.defineProperty(process.stdout, 'isTTY', { value: originalIsTTY, configurable: true });
    });
  });

  describe('Pager enable/disable', () => {
    it('should be enabled by default', () => {
      const pager = createPager();
      // We can't directly test enabled state since it's private
      // But we can test the setter
      expect(pager).toBeDefined();
    });

    it('should be disabled when options.enabled is false', () => {
      const pager = createPager({ enabled: false });
      expect(pager).toBeDefined();
    });

    it('should allow enabling and disabling pager', () => {
      const pager = createPager();
      pager.setEnabled(false);
      pager.setEnabled(true);
      expect(pager).toBeDefined();
    });
  });

  describe('JSON output mode', () => {
    it('should set JSON output mode', () => {
      const pager = createPager({ isJsonOutput: true });
      expect(pager).toBeDefined();
    });

    it('should allow changing JSON output mode', () => {
      const pager = createPager();
      pager.setJsonOutput(true);
      pager.setJsonOutput(false);
      expect(pager).toBeDefined();
    });
  });

  describe('Piped output mode', () => {
    it('should set piped output mode', () => {
      const pager = createPager({ isPipedOutput: true });
      expect(pager).toBeDefined();
    });

    it('should allow changing piped output mode', () => {
      const pager = createPager();
      pager.setPagedOutput(true);
      pager.setPagedOutput(false);
      expect(pager).toBeDefined();
    });
  });

  describe('PagerOptions interface', () => {
    it('should accept all valid options', () => {
      const options: PagerOptions = {
        enabled: true,
        pager: 'less',
        terminalHeight: 24,
        isJsonOutput: false,
        isPipedOutput: false,
      };
      const pager = createPager(options);
      expect(pager).toBeDefined();
    });

    it('should accept partial options', () => {
      const options: PagerOptions = {
        enabled: false,
      };
      const pager = createPager(options);
      expect(pager).toBeDefined();
    });

    it('should accept empty options', () => {
      const options: PagerOptions = {};
      const pager = createPager(options);
      expect(pager).toBeDefined();
    });
  });

  describe('Pager invocation', () => {
    it('should have a page method', () => {
      const pager = createPager();
      expect(typeof pager.page).toBe('function');
    });

    it('should handle short output without paging', () => {
      const pager = createPager({ terminalHeight: 24 });
      const shortOutput = 'Short output';
      // Should not throw error
      expect(() => pager.page(shortOutput)).not.toThrow();
    });

    it('should handle long output with paging', () => {
      const pager = createPager({ terminalHeight: 5, enabled: false }); // Disable for test
      const longOutput = 'Line 1\nLine 2\nLine 3\nLine 4\nLine 5\nLine 6\nLine 7\nLine 8\nLine 9\nLine 10';
      // Should not throw error
      expect(() => pager.page(longOutput)).not.toThrow();
    });

    it('should bypass pager when disabled', () => {
      const pager = createPager({ enabled: false, terminalHeight: 5 });
      const longOutput = 'Line 1\nLine 2\nLine 3\nLine 4\nLine 5\nLine 6\nLine 7\nLine 8\nLine 9\nLine 10';
      expect(() => pager.page(longOutput)).not.toThrow();
    });

    it('should bypass pager for JSON output mode', () => {
      const pager = createPager({ isJsonOutput: true, terminalHeight: 5 });
      const longOutput = 'Line 1\nLine 2\nLine 3\nLine 4\nLine 5\nLine 6\nLine 7\nLine 8\nLine 9\nLine 10';
      expect(() => pager.page(longOutput)).not.toThrow();
    });

    it('should bypass pager for piped output', () => {
      const pager = createPager({ isPipedOutput: true, terminalHeight: 5 });
      const longOutput = 'Line 1\nLine 2\nLine 3\nLine 4\nLine 5\nLine 6\nLine 7\nLine 8\nLine 9\nLine 10';
      expect(() => pager.page(longOutput)).not.toThrow();
    });

    it('should handle empty output', () => {
      const pager = createPager();
      const emptyOutput = '';
      expect(() => pager.page(emptyOutput)).not.toThrow();
    });

    it('should handle single line output', () => {
      const pager = createPager({ terminalHeight: 24 });
      const singleLine = 'Single line output';
      expect(() => pager.page(singleLine)).not.toThrow();
    });

    it('should handle output exactly at terminal height', () => {
      const pager = createPager({ terminalHeight: 5, enabled: false });
      const exactOutput = 'Line 1\nLine 2\nLine 3\nLine 4\nLine 5';
      expect(() => pager.page(exactOutput)).not.toThrow();
    });

    it('should handle output one line over terminal height', () => {
      const pager = createPager({ terminalHeight: 5, enabled: false });
      const overOutput = 'Line 1\nLine 2\nLine 3\nLine 4\nLine 5\nLine 6';
      expect(() => pager.page(overOutput)).not.toThrow();
    });
  });

  describe('Output length detection', () => {
    it('should count lines correctly for simple output', () => {
      const pager = createPager({ terminalHeight: 3 });
      const output = 'Line 1\nLine 2';
      expect(() => pager.page(output)).not.toThrow();
    });

    it('should count lines correctly for output with trailing newline', () => {
      const pager = createPager({ terminalHeight: 3 });
      const output = 'Line 1\nLine 2\n';
      expect(() => pager.page(output)).not.toThrow();
    });

    it('should handle output with multiple consecutive newlines', () => {
      const pager = createPager({ terminalHeight: 5 });
      const output = 'Line 1\n\n\nLine 2';
      expect(() => pager.page(output)).not.toThrow();
    });
  });
});
