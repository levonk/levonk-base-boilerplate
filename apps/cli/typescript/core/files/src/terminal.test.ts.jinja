import { describe, it, expect, beforeEach, afterEach } from 'vitest';
import {
  createTerminal,
  getTerminalWidth,
  type TerminalSize,
  type TerminalOptions,
} from './terminal.js';

describe('Terminal Size Awareness', () => {
  let terminal: ReturnType<typeof createTerminal>;

  beforeEach(() => {
    terminal = createTerminal({ isTTY: false });
  });

  afterEach(() => {
    terminal.destroy();
  });

  it('should get terminal size', () => {
    const size = terminal.getSize();
    expect(size).toHaveProperty('columns');
    expect(size).toHaveProperty('rows');
    expect(size.columns).toBeGreaterThan(0);
    expect(size.rows).toBeGreaterThan(0);
  });

  it('should get terminal width', () => {
    const width = terminal.getWidth();
    expect(typeof width).toBe('number');
    expect(width).toBeGreaterThan(0);
  });

  it('should get terminal height', () => {
    const height = terminal.getHeight();
    expect(typeof height).toBe('number');
    expect(height).toBeGreaterThan(0);
  });

  it('should check TTY status', () => {
    const isTTY = terminal.isTTY();
    expect(typeof isTTY).toBe('boolean');
  });

  it('should wrap text to fit terminal width', () => {
    const text = 'This is a long line of text that should be wrapped to fit within the terminal width';
    const wrapped = terminal.wrapText(text, 0);
    expect(wrapped).toContain('\n');
  });

  it('should wrap text with indentation', () => {
    const text = 'This is a long line of text that should be wrapped with indentation';
    const wrapped = terminal.wrapText(text, 4);
    expect(wrapped).toContain('    ');
  });

  it('should format table to fit terminal width', () => {
    const headers = ['Name', 'Age', 'Email'];
    const rows = [
      ['John Doe', '30', 'john@example.com'],
      ['Jane Smith', '25', 'jane@example.com'],
    ];
    const table = terminal.formatTable(headers, rows);
    expect(table).toHaveLength(3); // header, separator, 1 row
  });

  it('should truncate text with ellipsis', () => {
    const text = 'This is a very long text that should be truncated with an ellipsis at the end';
    const truncated = terminal.truncateText(text, '...');
    expect(truncated).toContain('...');
    expect(truncated.length).toBeLessThanOrEqual(terminal.getWidth());
  });

  it('should add resize listener', () => {
    let called = false;
    const listener = (size: TerminalSize) => {
      called = true;
    };
    terminal.onResize(listener);
    expect(called).toBe(false); // Not called immediately
  });

  it('should remove resize listener', () => {
    const listener = (size: TerminalSize) => {};
    terminal.onResize(listener);
    terminal.offResize(listener);
    // Listener should be removed
  });

  it('should clean up event listeners on destroy', () => {
    terminal.destroy();
    // Should not throw error
  });

  it('should handle custom terminal options', () => {
    const options: TerminalOptions = {
      isTTY: false,
      minWidth: 50,
      maxWidth: 150,
      defaultWidth: 100,
    };
    const customTerminal = createTerminal(options);
    expect(customTerminal.getWidth()).toBe(100);
    customTerminal.destroy();
  });

  it('should get terminal width convenience function', () => {
    const width = getTerminalWidth();
    expect(typeof width).toBe('number');
    expect(width).toBeGreaterThan(0);
  });

  it('should format wrapped table when too wide', () => {
    const headers = ['Very Long Header Name That Exceeds Width', 'Another Long Header'];
    const rows = [
      ['Long cell content that should be wrapped', 'Another long cell content'],
    ];
    const table = terminal.formatTable(headers, rows);
    expect(table.length).toBeGreaterThan(0);
  });
});
