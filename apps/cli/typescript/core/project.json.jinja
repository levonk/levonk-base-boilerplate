{
  "name": "{{ project_name | default('cli-tool') }}",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "options": {
        "platform": "node",
        "bundle": true,
        "main": "src/main.mts",
        "outputPath": "dist/{{ project_name | default('cli-tool') }}",
        "format": ["esm"],
        "target": "node20"
      },
      "dependsOn": ["^build"],
      "cache": true
    },
    "test": {
      "executor": "@nx/vite:test",
      "options": {
        "config": "vitest.config.mts"
      },
      "dependsOn": ["^build"],
      "cache": true
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["**/*.ts", "**/*.tsx"]
      },
      "cache": true
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "{projectRoot}"
      }
    },
    "run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/{{ project_name | default('cli-tool') }}/main.mjs",
        "cwd": "{projectRoot}"
      }
    }
  }
}
