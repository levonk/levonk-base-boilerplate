package {{ group_id }}.{{ project_slug | replace('-', '_') }}

import com.github.ajalt.clikt.core.CliktCommand
import com.github.ajalt.clikt.parameters.options.option
import com.github.ajalt.clikt.parameters.options.default
import com.github.ajalt.clikt.parameters.types.int
import org.slf4j.LoggerFactory

class Main : CliktCommand(
    name = "{{ project_slug }}",
    help = "{{ description }}"
) {
    private val logger = LoggerFactory.getLogger(Main::class.java)

    private val count by option(
        "--count", "-c",
        help = "Number of times to run"
    ).int().default(1)

    override fun run() {
        logger.info("Starting {{ project_name }}...")
        echo("{{ project_name }} - {{ description }}")
        echo("Running $count time(s)")

        repeat(count) {
            echo("Iteration ${it + 1}")
        }

        logger.info("{{ project_name }} completed successfully")
    }
}

fun main(args: Array<String>) = Main().main(args)
