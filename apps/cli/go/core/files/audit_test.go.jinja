func TestAppendOnlySchema(t *testing.T) {
	tmpDir := t.TempDir()
	dbPath := tmpDir + "/audit.db"

	auditLogger, err := NewAuditLogger(dbPath, 90, nil)
	if err != nil {
		t.Fatalf("Failed to create audit logger: %v", err)
	}
	defer auditLogger.Close()

	ctx := context.Background()

	// Log events
	for i := 0; i < 5; i++ {
		metadata := map[string]interface{}{"index": i}
		auditLogger.LogEvent(ctx, "test_event", "test", metadata)
	}

	// Verify IDs are sequential and increasing
	rows, err := auditLogger.db.Query("SELECT id FROM audit_events ORDER BY id")
	if err != nil {
		t.Fatalf("Failed to query events: %v", err)
	}
	defer rows.Close()

	ids := []int64{}
	for rows.Next() {
		var id int64
		if err := rows.Scan(&id); err != nil {
			t.Fatalf("Failed to scan id: %v", err)
		}
		ids = append(ids, id)
	}

	// Verify IDs are sequential
	for i := 1; i < len(ids); i++ {
		if ids[i] != ids[i-1]+1 {
			t.Errorf("IDs are not sequential: %v", ids)
		}
	}
}

