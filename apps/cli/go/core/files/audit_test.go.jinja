func TestNewAuditLogger(t *testing.T) {
	// Create a temporary database path
	tmpDir := t.TempDir()
	dbPath := tmpDir + "/audit.db"

	// Create audit logger
	auditLogger, err := NewAuditLogger(dbPath, 90, nil)
	if err != nil {
		t.Fatalf("Failed to create audit logger: %v", err)
	}
	defer auditLogger.Close()

	// Verify it's enabled
	if !auditLogger.IsEnabled() {
		t.Error("Expected audit logger to be enabled by default")
	}

	// Verify retention days
	if auditLogger.GetRetentionDays() != 90 {
		t.Errorf("Expected retention days to be 90, got %d", auditLogger.GetRetentionDays())
	}
}

func TestLogEvent(t *testing.T) {
	tmpDir := t.TempDir()
	dbPath := tmpDir + "/audit.db"

	auditLogger, err := NewAuditLogger(dbPath, 90, nil)
	if err != nil {
		t.Fatalf("Failed to create audit logger: %v", err)
	}
	defer auditLogger.Close()

	ctx := context.Background()
	metadata := map[string]interface{}{
		"user": "test-user",
		"file": "test.txt",
	}

	err = auditLogger.LogEvent(ctx, "file_processed", "stdin", metadata)
	if err != nil {
		t.Fatalf("Failed to log event: %v", err)
	}

	// Verify event was logged
	count, err := auditLogger.GetEventCount(ctx)
	if err != nil {
		t.Fatalf("Failed to get event count: %v", err)
	}
	if count != 1 {
		t.Errorf("Expected 1 event, got %d", count)
	}
}

