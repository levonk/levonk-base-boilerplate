	auditLogger, err := NewAuditLogger(dbPath, 90, nil)
	if err != nil {
		t.Fatalf("Failed to create audit logger: %v", err)
	}
	defer auditLogger.Close()

	// Disable
	auditLogger.SetEnabled(false)
	if auditLogger.IsEnabled() {
		t.Error("Expected audit logger to be disabled")
	}

	// Enable
	auditLogger.SetEnabled(true)
	if !auditLogger.IsEnabled() {
		t.Error("Expected audit logger to be enabled")
	}
}

