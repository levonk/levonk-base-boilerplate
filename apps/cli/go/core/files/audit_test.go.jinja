func TestPruneOldEvents(t *testing.T) {
	tmpDir := t.TempDir()
	dbPath := tmpDir + "/audit.db"

	auditLogger, err := NewAuditLogger(dbPath, 7, nil) // 7 day retention
	if err != nil {
		t.Fatalf("Failed to create audit logger: %v", err)
	}
	defer auditLogger.Close()

	ctx := context.Background()

	// Log some events
	for i := 0; i < 5; i++ {
		metadata := map[string]interface{}{"index": i}
		auditLogger.LogEvent(ctx, "test_event", "test", metadata)
	}

	// Verify initial count
	count, _ := auditLogger.GetEventCount(ctx)
	if count != 5 {
		t.Errorf("Expected 5 events before prune, got %d", count)
	}

	// Prune events older than 1 day (should not prune anything)
	cutoff := time.Now().AddDate(0, 0, -1)
	query := `UPDATE audit_events SET timestamp = ? WHERE id = ?`
	auditLogger.db.Exec(query, cutoff.Format("2006-01-02 15:04:05"), 1)

	auditLogger.PruneOldEvents(ctx)
	count, _ = auditLogger.GetEventCount(ctx)
	if count != 4 {
		t.Errorf("Expected 4 events after pruning 1 old event, got %d", count)
	}
}

