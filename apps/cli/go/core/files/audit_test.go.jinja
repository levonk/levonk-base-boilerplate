func TestExportEvents(t *testing.T) {
	tmpDir := t.TempDir()
	dbPath := tmpDir + "/audit.db"
	exportPath := tmpDir + "/export.json"

	auditLogger, err := NewAuditLogger(dbPath, 90, nil)
	if err != nil {
		t.Fatalf("Failed to create audit logger: %v", err)
	}
	defer auditLogger.Close()

	ctx := context.Background()

	// Log some events
	for i := 0; i < 3; i++ {
		metadata := map[string]interface{}{"index": i}
		auditLogger.LogEvent(ctx, "test_event", "test", metadata)
	}

	// Export all events
	err = auditLogger.ExportEvents(ctx, exportPath, nil, time.Time{})
	if err != nil {
		t.Fatalf("Failed to export events: %v", err)
	}

	// Verify export file exists
	if _, err := os.Stat(exportPath); os.IsNotExist(err) {
		t.Error("Export file was not created")
	}

	// Verify export content
	data, err := os.ReadFile(exportPath)
	if err != nil {
		t.Fatalf("Failed to read export file: %v", err)
	}

	var events []AuditEvent
	if err := json.Unmarshal(data, &events); err != nil {
		t.Fatalf("Failed to unmarshal export data: %v", err)
	}

	if len(events) != 3 {
		t.Errorf("Expected 3 exported events, got %d", len(events))
	}
}

func TestExportEventsWithFilters(t *testing.T) {
	tmpDir := t.TempDir()
	dbPath := tmpDir + "/audit.db"
	exportPath := tmpDir + "/export.json"

	auditLogger, err := NewAuditLogger(dbPath, 90, nil)
	if err != nil {
		t.Fatalf("Failed to create audit logger: %v", err)
	}
	defer auditLogger.Close()

	ctx := context.Background()

	// Log events with different types
	auditLogger.LogEvent(ctx, "file_processed", "test", map[string]interface{}{"index": 1})
	auditLogger.LogEvent(ctx, "config_loaded", "test", map[string]interface{}{"index": 2})
	auditLogger.LogEvent(ctx, "file_processed", "test", map[string]interface{}{"index": 3})

	// Export only file_processed events
	eventTypes := []string{"file_processed"}
	err = auditLogger.ExportEvents(ctx, exportPath, eventTypes, time.Time{})
	if err != nil {
		t.Fatalf("Failed to export events with filter: %v", err)
	}

	// Verify export content
	data, err := os.ReadFile(exportPath)
	if err != nil {
		t.Fatalf("Failed to read export file: %v", err)
	}

	var events []AuditEvent
	if err := json.Unmarshal(data, &events); err != nil {
		t.Fatalf("Failed to unmarshal export data: %v", err)
	}

	if len(events) != 2 {
		t.Errorf("Expected 2 exported events with filter, got %d", len(events))
	}

	// Verify all events are of the correct type
	for _, event := range events {
		if event.EventType != "file_processed" {
			t.Errorf("Expected event type 'file_processed', got '%s'", event.EventType)
		}
	}
}

func TestExportEventsWithSince(t *testing.T) {
	tmpDir := t.TempDir()
	dbPath := tmpDir + "/audit.db"
	exportPath := tmpDir + "/export.json"

	auditLogger, err := NewAuditLogger(dbPath, 90, nil)
	if err != nil {
		t.Fatalf("Failed to create audit logger: %v", err)
	}
	defer auditLogger.Close()

	ctx := context.Background()

	// Log events
	auditLogger.LogEvent(ctx, "test_event", "test", map[string]interface{}{"index": 1})

	// Manually set one event to be old
	oldTime := time.Now().AddDate(0, 0, -10)
	query := `UPDATE audit_events SET timestamp = ? WHERE id = 1`
	auditLogger.db.Exec(query, oldTime.Format("2006-01-02 15:04:05"))

	// Log a new event
	auditLogger.LogEvent(ctx, "test_event", "test", map[string]interface{}{"index": 2})

	// Export events since yesterday
	since := time.Now().AddDate(0, 0, -1)
	err = auditLogger.ExportEvents(ctx, exportPath, nil, since)
	if err != nil {
		t.Fatalf("Failed to export events with since filter: %v", err)
	}

	// Verify export content
	data, err := os.ReadFile(exportPath)
	if err != nil {
		t.Fatalf("Failed to read export file: %v", err)
	}

	var events []AuditEvent
	if err := json.Unmarshal(data, &events); err != nil {
		t.Fatalf("Failed to unmarshal export data: %v", err)
	}

	if len(events) != 1 {
		t.Errorf("Expected 1 exported event with since filter, got %d", len(events))
	}
}

func TestSetRetentionDays(t *testing.T) {
	tmpDir := t.TempDir()
	dbPath := tmpDir + "/audit.db"

	auditLogger, err := NewAuditLogger(dbPath, 90, nil)
	if err != nil {
		t.Fatalf("Failed to create audit logger: %v", err)
	}
	defer auditLogger.Close()

	// Set new retention period
	auditLogger.SetRetentionDays(30)
	if auditLogger.GetRetentionDays() != 30 {
		t.Errorf("Expected retention days to be 30, got %d", auditLogger.GetRetentionDays())
	}

	// Set to 0 (disabled)
	auditLogger.SetRetentionDays(0)
	if auditLogger.GetRetentionDays() != 0 {
		t.Errorf("Expected retention days to be 0, got %d", auditLogger.GetRetentionDays())
	}
}

func TestSetEnabled(t *testing.T) {
	tmpDir := t.TempDir()
