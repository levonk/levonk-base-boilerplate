package main

import (
	"context"
	"encoding/json"
	"fmt"
	"io"
	"os"
	"os/signal"
	"path/filepath"

	"github.com/bmatcuk/doublestar/v4"
	"github.com/mattn/go-isatty"
	"github.com/spf13/cobra"
	"github.com/spf13/viper"
)

var (
	cfgFile string
	jsonOutput bool
	quiet bool
	verbose bool
	debug bool
	colorMode string
	installFlag bool
	uninstallFlag bool
	dryRun bool
	logger *Logger
	version = "1.0.0"

	rootCmd = &cobra.Command{
		Use:   "{{ project_slug }} [inputs...]",
		Short: "{{ description }}",
		Long: `{{ description }}

Examples:
  {{ project_slug }} file.txt
  {{ project_slug }} "**/*.txt"
  cat file.txt | {{ project_slug }} -`,
		Version: version,
		RunE: func(cmd *cobra.Command, args []string) error {
			ctx := cmd.Context()

			// Handle --install flag
			if installFlag {
				return RunInstall(cmd)
			}

			// Handle --uninstall flag
			if uninstallFlag {
				return RunUninstall(cmd)
			}

			// Handle --usage flag
			usage, _ := cmd.Flags().GetBool("usage")
			if usage {
				return cmd.Usage()
			}

			// Initialize logger
			logger = NewLogger("main")
			logger.SetQuiet(quiet)
			logger.SetVerbose(verbose)
			logger.SetDebug(debug)
			logger.SetColorMode(colorMode)

			// Log dry-run mode and add to context
			if dryRun {
				logger.Info("Dry-run mode enabled - no changes will be executed")
				ctx = context.WithValue(ctx, "dry-run", true)
			} else {
				ctx = context.WithValue(ctx, "dry-run", false)
			}

			if !quiet {
				logger.Info("Using config file: %s", viper.ConfigFileUsed())
			}

			filesToProcess := []string{}
			readStdin := false

			// Input Strategy
			if len(args) == 0 {
				if !isatty.IsTerminal(os.Stdin.Fd()) {
					readStdin = true
				} else {
					return cmd.Help()
				}
			} else {
				for _, arg := range args {
					if arg == "-" {
						readStdin = true
					} else {
						// Glob expansion
						base, pattern := doublestar.SplitPattern(arg)
						fs := os.DirFS(base)
						if base == "." {
							fs = os.DirFS(".")
							pattern = arg
						}

						matches, err := doublestar.Glob(fs, pattern)
						if err != nil {
							logger.Error("Error globbing %s: %v", arg, err)
							continue
						}
						if len(matches) == 0 {
							logger.Warn("No files found for pattern '%s'", arg)
						}
						for _, m := range matches {
							if base != "." {
								filesToProcess = append(filesToProcess, base+string(os.PathSeparator)+m)
							} else {
								filesToProcess = append(filesToProcess, m)
							}
						}
					}
				}
			}

			results := []map[string]interface{}{}

			// Process Stdin
			if readStdin {
				DryRunFileOp(ctx, "read", "stdin")
				logger.Info("Processing stdin...")
				content, err := io.ReadAll(os.Stdin)
				if err != nil {
					logger.Error("Error reading stdin: %v", err)
					return err
				}
				results = append(results, processContent(ctx, string(content), "stdin"))
			}

			// Process Files
			for _, file := range filesToProcess {
				select {
				case <-ctx.Done():
					return ctx.Err()
				default:
					DryRunFileOp(ctx, "read", file)
					logger.Info("Processing %s...", file)
					content, err := os.ReadFile(file)
					if err != nil {
						logger.Error("Error reading %s: %v", file, err)
						continue
					}
					results = append(results, processContent(ctx, string(content), file))
				}
			}

			// Output Strategy
			if jsonOutput {
				enc := json.NewEncoder(os.Stdout)
				enc.SetIndent("", "  ")
				return enc.Encode(results)
			} else {
				fmt.Printf("Processed %d inputs.\n", len(results))
			}

			return nil
		},
	}
)

func processContent(ctx context.Context, content string, source string) map[string]interface{} {
	// Dummy logic
	DryRunLog(ctx, "Would process content from %s (length: %d)", source, len(content))
	return map[string]interface{}{
		"source": source,
		"length": len(content),
		"status": "processed",
	}
}

func init() {
	cobra.OnInitialize(initConfig)

	// Persistent flags
	rootCmd.PersistentFlags().StringVar(&cfgFile, "config", "", "config file (default is $HOME/.config/{{ project_slug }}/config.yaml)")
	rootCmd.PersistentFlags().BoolVar(&jsonOutput, "json", false, "Output results as JSON")
	rootCmd.PersistentFlags().BoolVarP(&quiet, "quiet", "q", false, "Suppress all output except errors")
	rootCmd.PersistentFlags().BoolVarP(&verbose, "verbose", "v", false, "Enable verbose output")
	rootCmd.PersistentFlags().BoolVar(&debug, "debug", false, "Enable debug logging with stack traces")
	rootCmd.PersistentFlags().StringVar(&colorMode, "color", "auto", "Color output: auto, always, never")

	// Local flags
	rootCmd.Flags().Bool("usage", false, "Show usage information")
	rootCmd.Flags().BoolVar(&installFlag, "install", false, "Install shell completions and initialize config")
	rootCmd.Flags().BoolVar(&uninstallFlag, "uninstall", false, "Remove shell completions and config files")
	rootCmd.Flags().BoolVar(&dryRun, "dry-run", false, "Preview changes without executing them")

	viper.BindPFlag("author", rootCmd.PersistentFlags().Lookup("author"))
}

func initConfig() {
	var configPath string

	if cfgFile != "" {
		// User explicitly specified a config file
		viper.SetConfigFile(cfgFile)
		configPath = cfgFile
	} else {
		// Use full precedence chain
		configPaths, err := GetConfigPrecedence()
		if err != nil {
			fmt.Fprintf(os.Stderr, "Warning: Failed to get config precedence: %v\n", err)
		}

		// Add all config paths to viper (in order of precedence)
		for _, path := range configPaths {
			configDir := filepath.Dir(path)
			viper.AddConfigPath(configDir)
			viper.SetConfigName("config")
			configPath = path
		}

		// If no config files found, use default user config path
		if len(configPaths) == 0 {
			configDir, _ := os.UserConfigDir()
			viper.AddConfigPath(configDir + "/{{ project_slug }}")
			viper.SetConfigName("config")
			configPath = configDir + "/{{ project_slug }}/config.yaml"
		}
	}

	// Initialize config file if it doesn't exist (first run)
	if err := InitConfigIfNeeded(configPath); err != nil {
		fmt.Fprintf(os.Stderr, "Warning: Failed to initialize config file: %v\n", err)
	}

	// Set environment variable prefix
	viper.SetEnvPrefix("{{ project_slug | upper | replace('-', '_') }}")
	viper.AutomaticEnv()

	// Read config file (will use the highest priority one found)
	if err := viper.ReadInConfig(); err != nil {
		// Config file not found is not an error - we'll use defaults
		if _, ok := err.(viper.ConfigFileNotFoundError); !ok {
			fmt.Fprintf(os.Stderr, "Warning: Failed to read config file: %v\n", err)
		}
	} else {
		// Validate the loaded configuration
		config := viper.AllSettings()
		validationErrors := ValidateConfig(config, configPath)
		if len(validationErrors) > 0 {
			fmt.Fprintf(os.Stderr, "Configuration validation errors:\n")
			for _, validationErr := range validationErrors {
				fmt.Fprintf(os.Stderr, "  - %s\n", validationErr.Error())
			}
			os.Exit(1)
		}
	}

	// Set hardcoded defaults
	defaults := GetHardcodedDefaults()
	for key, value := range defaults {
		viper.SetDefault(key, value)
	}
}

func main() {
	ctx, stop := signal.NotifyContext(context.Background(), os.Interrupt)
	defer stop()

	if err := rootCmd.ExecuteContext(ctx); err != nil {
		os.Exit(1)
	}
}

