// GetURLFormat determines the URL format based on the url-format flag and terminal capabilities
func GetURLFormat() URLFormat {
	switch urlFormat {
	case "plain":
		return FormatPlain
	case "terminal":
		return FormatTerminal
	case "auto":
		// Auto-detect: use terminal linking if stdout is a terminal
		if isatty.IsTerminal(os.Stdout.Fd()) {
			return FormatTerminal
		}
		return FormatPlain
	default:
		return FormatPlain
	}
}

// FormatOutputURL formats a URL for output based on the current configuration
func FormatOutputURL(rawURL string) string {
	format := GetURLFormat()
	return FormatURL(rawURL, format)
}

func init() {
	cobra.OnInitialize(initConfig)

	// Persistent flags
	rootCmd.PersistentFlags().StringVar(&cfgFile, "config", "", "config file (default is $HOME/.config/{{ project_slug }}/config.yaml)")
	rootCmd.PersistentFlags().BoolVar(&jsonOutput, "json", false, "Output results as JSON")
	rootCmd.PersistentFlags().BoolVarP(&quiet, "quiet", "q", false, "Suppress all output except errors")
	rootCmd.PersistentFlags().BoolVarP(&verbose, "verbose", "v", false, "Enable verbose output")
	rootCmd.PersistentFlags().BoolVar(&debug, "debug", false, "Enable debug logging with stack traces")
	rootCmd.PersistentFlags().StringVar(&colorMode, "color", "auto", "Color output: auto, always, never")

	// Local flags
	rootCmd.Flags().Bool("usage", false, "Show usage information")
	rootCmd.Flags().BoolVar(&installFlag, "install", false, "Install shell completions and initialize config")
	rootCmd.Flags().BoolVar(&uninstallFlag, "uninstall", false, "Remove shell completions and config files")
	rootCmd.Flags().BoolVar(&manFlag, "man", false, "Generate and display man page")
	rootCmd.Flags().BoolVar(&dryRun, "dry-run", false, "Preview changes without executing them")
	rootCmd.Flags().BoolVarP(&force, "force", "f", false, "Bypass confirmation prompts for destructive operations")
	rootCmd.Flags().BoolVar(&noPager, "no-pager", false, "Disable automatic paging for long output")
	rootCmd.Flags().BoolVar(&humanModeFlag, "human", false, "Force human mode (interactive)")
	rootCmd.Flags().BoolVar(&interactiveFlag, "interactive", false, "Force human mode (alias for --human)")
	rootCmd.Flags().BoolVar(&tuiFlag, "tui", false, "Launch TUI mode (alias for --interactive)")
	rootCmd.Flags().BoolVar(&daemonFlag, "daemon", false, "Pre-launch daemon in background")
	rootCmd.Flags().BoolVar(&noDaemonFlag, "no-daemon", false, "Force synchronous operation (disable daemon)")
	rootCmd.Flags().BoolVar(&listJobsFlag, "list-jobs", false, "List background jobs")
	rootCmd.Flags().StringVar(&cancelJobFlag, "cancel-job", "", "Cancel a background job by ID")
	rootCmd.Flags().StringVar(&urlFormat, "url-format", "auto", "URL format: auto, plain, terminal")
	rootCmd.Flags().BoolVar(&healthCheckFlag, "health-check", false, "Run health check and exit")
	rootCmd.Flags().BoolVar(&privacyFlag, "privacy", false, "Enable privacy mode to ignore sensitive identifiers")
	rootCmd.Flags().StringVar(&auditExportFile, "audit-export", "", "Export audit log to specified file")
