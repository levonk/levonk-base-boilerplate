	"github.com/spf13/viper"
)

var (
	cfgFile string
	jsonOutput bool
	quiet bool
	verbose bool
	debug bool
	colorMode string
	installFlag bool
	uninstallFlag bool
	dryRun bool
	force bool
	logger *Logger
	version = "1.0.0"

	rootCmd = &cobra.Command{
		Use:   "{{ project_slug }} [inputs...]",
		Short: "{{ description }}",
		Long: `{{ description }}

Examples:
  {{ project_slug }} file.txt
  {{ project_slug }} "**/*.txt"
  cat file.txt | {{ project_slug }} -`,
		Version: version,
		RunE: func(cmd *cobra.Command, args []string) error {
			ctx := cmd.Context()

			// Handle --install flag
			if installFlag {
				return RunInstall(cmd)
			}

			// Handle --uninstall flag
			if uninstallFlag {
				return RunUninstall(cmd)
			}

			// Handle --usage flag
			usage, _ := cmd.Flags().GetBool("usage")
			if usage {
				return cmd.Usage()
			}

			// Initialize logger
			logger = NewLogger("main")
			logger.SetQuiet(quiet)
			logger.SetVerbose(verbose)
			logger.SetDebug(debug)
			logger.SetColorMode(colorMode)

			// Log dry-run mode and add to context
			if dryRun {
				logger.Info("Dry-run mode enabled - no changes will be executed")
				ctx = context.WithValue(ctx, "dry-run", true)
			} else {
				ctx = context.WithValue(ctx, "dry-run", false)
			}

			if !quiet {
				logger.Info("Using config file: %s", viper.ConfigFileUsed())
			}

			filesToProcess := []string{}
			readStdin := false

			// Input Strategy
			if len(args) == 0 {
				if !isatty.IsTerminal(os.Stdin.Fd()) {
					readStdin = true
				} else {
					return cmd.Help()
				}
			} else {
				for _, arg := range args {
					if arg == "-" {
						readStdin = true
					} else {
						// Glob expansion
						base, pattern := doublestar.SplitPattern(arg)
						fs := os.DirFS(base)
						if base == "." {
							fs = os.DirFS(".")
							pattern = arg
						}

						matches, err := doublestar.Glob(fs, pattern)
						if err != nil {
							logger.Error("Error globbing %s: %v", arg, err)
							continue
						}
						if len(matches) == 0 {
							logger.Warn("No files found for pattern '%s'", arg)
						}
						for _, m := range matches {
							if base != "." {
								filesToProcess = append(filesToProcess, base+string(os.PathSeparator)+m)
							} else {
								filesToProcess = append(filesToProcess, m)
							}
						}
					}
				}
			}

			results := []map[string]interface{}{}

			// Process Stdin
			if readStdin {
				DryRunFileOp(ctx, "read", "stdin")
				logger.Info("Processing stdin...")
				content, err := io.ReadAll(os.Stdin)
				if err != nil {
					return WrapError(err, ErrorTypeFile, "Failed to read from stdin", "Ensure stdin is properly connected")
				}
				results = append(results, processContent(ctx, string(content), "stdin"))
			}

			// Process Files
			if len(filesToProcess) > 0 && !quiet {
				// Calculate total size for progress bar
				var totalSize int64
				for _, file := range filesToProcess {
					if info, err := os.Stat(file); err == nil {
						totalSize += info.Size()
					}
				}

				// Create progress bar
				bar := NewProgressBar(ProgressConfig{
					Total:      totalSize,
					Description: "Processing files",
					Quiet:      quiet,
				})

				if bar != nil {
					bar.RenderBlank()
				}

				for _, file := range filesToProcess {
					select {
					case <-ctx.Done():
						if bar != nil {
							bar.Finish()
						}
						return ctx.Err()
					default:
						DryRunFileOp(ctx, "read", file)
						if !quiet {
							logger.Info("Processing %s...", file)
						}

						// Read file with progress tracking
						var content []byte
						var err error

						if bar != nil {
							fileInfo, _ := os.Stat(file)
							reader := NewProgressReader(nil, bar, fileInfo.Size())
							// Actually read the file
							content, err = os.ReadFile(file)
							if err == nil {
								bar.Add64(int64(len(content)))
							}
						} else {
							content, err = os.ReadFile(file)
						}

						if err != nil {
							logger.ErrorApp(WrapError(err, ErrorTypeFile, fmt.Sprintf("Failed to read file '%s' with progress bar", file), "Check file permissions and ensure the file exists"))
							continue
						}
						results = append(results, processContent(ctx, string(content), file))
					}
				}

				if bar != nil {
					bar.Finish()
				}
			} else {
				// Process files without progress bar (quiet mode or no files)
				for _, file := range filesToProcess {
					select {
					case <-ctx.Done():
						return ctx.Err()
					default:
						DryRunFileOp(ctx, "read", file)
						logger.Info("Processing %s...", file)
						content, err := os.ReadFile(file)
						if err != nil {
							logger.ErrorApp(WrapError(err, ErrorTypeFile, fmt.Sprintf("Failed to read file '%s' without progress bar", file), "Check file permissions and ensure the file exists"))
							continue
						}
						results = append(results, processContent(ctx, string(content), file))
					}
				}
			}

			// Check for destructive operations and prompt for confirmation
			if !force && !quiet {
				// Example: If we were deleting files, we would prompt here
				// This is a placeholder for when delete/overwrite operations are added
				// if hasDeleteOperations {
				// 	if !PromptForDelete(target, force, quiet) {
				// 		logger.Info("Operation cancelled by user")
				// 		return nil
				// 	}
				// }
			}

			// Output Strategy
			if jsonOutput {
				enc := json.NewEncoder(os.Stdout)
				enc.SetIndent("", "  ")
				return enc.Encode(results)
			} else {
				fmt.Printf("Processed %d inputs.\n", len(results))
			}

			return nil
		},
	}
)

func processContent(ctx context.Context, content string, source string) map[string]interface{} {
	// Dummy logic
	DryRunLog(ctx, "Would process content from %s (length: %d)", source, len(content))
	return map[string]interface{}{
		"source": source,
		"length": len(content),
		"status": "processed",
	}
}

