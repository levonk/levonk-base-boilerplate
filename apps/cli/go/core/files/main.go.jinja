var (
	cfgFile string
	jsonOutput bool
	quiet bool
	verbose bool
	debug bool
	colorMode string
	installFlag bool
	uninstallFlag bool
	manFlag bool
	dryRun bool
	force bool
	noPager bool
	interactiveFlag bool
	tuiFlag bool
	daemonFlag bool
	noDaemonFlag bool
	listJobsFlag bool
	cancelJobFlag string
	urlFormat string
	healthCheckFlag bool
	privacyFlag bool
	auditExportFile string
	auditExportSince string
	auditExportTypes string
	humanModeFlag bool
	logger *Logger
	terminal *Terminal
	deprecationManager *DeprecationManager
	daemonManager *DaemonManager
	version = "1.0.0"

	rootCmd = &cobra.Command{
		Use:   "{{ project_slug }} [inputs...]",
		Short: "{{ description }}",
		Long: `{{ description }}

Mode Selection:
  The CLI operates in two modes: agent (default) and human (interactive).

  Agent Mode:
    - Default for non-interactive environments
    - Automatically detected when no TTY or agent session is present
    - Optimized for automation and AI agent integration
    - Can be forced with MYTOOL_MODE=agent environment variable

  Human Mode:
    - Interactive mode for human users
    - Automatically detected when TTY is present and no agent session
    - Can be forced with --human or --interactive flags
    - Can be forced with MYTOOL_MODE=human environment variable
    - Can be set in config file with mode: human

  Mode Precedence (highest to lowest):
    1. CLI flags (--human, --interactive)
    2. Environment variables (MYTOOL_MODE)
    3. Config file setting
    4. Auto-detection based on environment

Examples:
  {{ project_slug }} file.txt
  {{ project_slug }} "**/*.txt"
  cat file.txt | {{ project_slug }} -`,
		Version: version,
		RunE: func(cmd *cobra.Command, args []string) error {
			ctx := cmd.Context()

			// Determine the operation mode
			// Get mode from config file if available
			configMode := ""
			if viper.IsSet("mode") {
				configMode = viper.GetString("mode")
			}

			// Determine mode based on precedence chain
			mode := DetermineMode(humanModeFlag, configMode)

			// Add mode to context for use by other features
			ctx = context.WithValue(ctx, "mode", mode)

			// Handle --health-check flag
			if healthCheckFlag {
				return RunHealthCheck(cmd)
			}

			// Handle --audit-export flag
			if auditExportFile != "" {
				return RunAuditExport(ctx)
			}

			// Handle --list-jobs flag
			if listJobsFlag {
				return RunListJobsCommand()
			}

			// Handle --cancel-job flag
			if cancelJobFlag != "" {
				return RunCancelJobCommand(cancelJobFlag)
			}

			// Handle --install flag
			if installFlag {
				return RunInstall(cmd)
			}

			// Handle --uninstall flag
			if uninstallFlag {
				return RunUninstall(cmd)
			}

			// Handle --man flag
			if manFlag {
				return RunGenMan(cmd)
			}

			// Handle --usage flag
			usage, _ := cmd.Flags().GetBool("usage")
			if usage {
				return cmd.Usage()
			}

			// Handle TUI mode
			if interactiveFlag || tuiFlag {
				modifiedArgs, err := RunTUI(args)
				if err != nil {
					return fmt.Errorf("TUI error: %w", err)
				}
				args = modifiedArgs
			}

			// Initialize logger
			logger = NewLogger("main")
			logger.SetQuiet(quiet)
			logger.SetVerbose(verbose)
			logger.SetDebug(debug)
			logger.SetColorMode(colorMode)
			logger.SetPrivacyMode(privacyFlag)

			// Initialize daemon manager
			daemonManager = NewDaemonManager(logger)

			// Handle daemon flags
			if daemonFlag {
				if !daemonManager.IsPlatformSupported() {
					return WrapError(fmt.Errorf("daemon mode not supported on %s", runtime.GOOS), ErrorTypePlatform, "Daemon not supported", "Daemon mode is only supported on Linux, macOS, and Windows")
				}
				if err := daemonManager.StartDaemon(); err != nil {
					return WrapError(err, ErrorTypeExecution, "Failed to start daemon", "Check system permissions and daemon configuration")
				}
				logger.Info("Daemon started in background")
				return nil
			}

			if noDaemonFlag {
				logger.Debug("Daemon mode explicitly disabled")
			}

			// Initialize terminal size detection
			terminal = NewTerminal()
			if !quiet {
				logger.Debug("Terminal size detected: %dx%d", terminal.GetWidth(), terminal.GetHeight())
			}

			// Log dry-run mode and add to context
			if dryRun {
				logger.Info("Dry-run mode enabled - no changes will be executed")
				ctx = context.WithValue(ctx, "dry-run", true)
			} else {
				ctx = context.WithValue(ctx, "dry-run", false)
			}

			if !quiet {
				logger.Info("Using config file: %s", viper.ConfigFileUsed())
			}

			filesToProcess := []string{}
			readStdin := false

			// Input Strategy
			if len(args) == 0 {
				if !isatty.IsTerminal(os.Stdin.Fd()) {
					readStdin = true
				} else {
					return cmd.Help()
				}
			} else {
				for _, arg := range args {
					if arg == "-" {
						readStdin = true
					} else {
						// Glob expansion
						base, pattern := doublestar.SplitPattern(arg)
						fs := os.DirFS(base)
						if base == "." {
							fs = os.DirFS(".")
							pattern = arg
						}

						matches, err := doublestar.Glob(fs, pattern)
						if err != nil {
							logger.Error("Error globbing %s: %v", arg, err)
							continue
						}
						if len(matches) == 0 {
							logger.Warn("No files found for pattern '%s'", arg)
						}
						for _, m := range matches {
							if base != "." {
								filesToProcess = append(filesToProcess, base+string(os.PathSeparator)+m)
							} else {
								filesToProcess = append(filesToProcess, m)
							}
						}
					}
				}
			}

			results := []map[string]interface{}{}

			// Process Stdin
			if readStdin {
				DryRunFileOp(ctx, "read", "stdin")
				logger.Info("Processing stdin...")
				content, err := io.ReadAll(os.Stdin)
				if err != nil {
					return WrapError(err, ErrorTypeFile, "Failed to read from stdin", "Ensure stdin is properly connected")
				}
				results = append(results, processContent(ctx, string(content), "stdin"))
			}

			// Process Files
			if len(filesToProcess) > 0 && !quiet {
				// Calculate total size for progress bar
				var totalSize int64
				for _, file := range filesToProcess {
					if info, err := os.Stat(file); err == nil {
						totalSize += info.Size()
					}
				}

				// Create progress bar
				bar := NewProgressBar(ProgressConfig{
					Total:      totalSize,
					Description: "Processing files",
					Quiet:      quiet,
				})

				if bar != nil {
					bar.RenderBlank()
				}

				for _, file := range filesToProcess {
					select {
					case <-ctx.Done():
						if bar != nil {
							bar.Finish()
						}
						return ctx.Err()
					default:
						DryRunFileOp(ctx, "read", file)
						if !quiet {
							logger.Info("Processing %s...", file)
						}

						// Read file with progress tracking
						var content []byte
						var err error

						if bar != nil {
							fileInfo, _ := os.Stat(file)
							_ = NewProgressReader(nil, bar, fileInfo.Size())
							// Actually read the file
							content, err = os.ReadFile(file)
							if err == nil {
								bar.Add64(int64(len(content)))
							}
						} else {
							content, err = os.ReadFile(file)
						}

						if err != nil {
							logger.ErrorApp(WrapError(err, ErrorTypeFile, fmt.Sprintf("Failed to read file '%s' with progress bar", file), "Check file permissions and ensure the file exists"))
							continue
						}
						results = append(results, processContent(ctx, string(content), file))
					}
				}

				if bar != nil {
					bar.Finish()
				}
			} else {
				// Process files without progress bar (quiet mode or no files)
				for _, file := range filesToProcess {
					select {
					case <-ctx.Done():
						return ctx.Err()
					default:
						DryRunFileOp(ctx, "read", file)
						logger.Info("Processing %s...", file)
						content, err := os.ReadFile(file)
						if err != nil {
							logger.ErrorApp(WrapError(err, ErrorTypeFile, fmt.Sprintf("Failed to read file '%s' without progress bar", file), "Check file permissions and ensure the file exists"))
							continue
						}
						results = append(results, processContent(ctx, string(content), file))
					}
				}
			}

			// Check for destructive operations and prompt for confirmation
			if !force && !quiet {
				// Example: If we were deleting files, we would prompt here
				// This is a placeholder for when delete/overwrite operations are added
				// if hasDeleteOperations {
				// 	if !PromptForDelete(target, force, quiet) {
				// 		logger.Info("Operation cancelled by user")
				// 		return nil
				// 	}
				// }
			}

			// Output Strategy
			if jsonOutput {
				enc := json.NewEncoder(os.Stdout)
				enc.SetIndent("", "  ")
				return enc.Encode(results)
			} else {
				// Count lines in output to determine if pager is needed
				outputLines := 1 // Start with 1 for the summary line
				for _, result := range results {
					if jsonBytes, err := json.MarshalIndent(result, "", "  "); err == nil {
						outputLines += len(strings.Split(string(jsonBytes), "\n"))
					}
				}

				// Use pager if output is long and --no-pager is not set
				pager := NewPager(noPager)
				if pager.ShouldUsePager(outputLines) {
					if err := pager.Start(); err != nil {
						logger.Warn("Failed to start pager: %v", err)
					} else {
						defer pager.Close()
						logger.Debug("Using pager: %s", GetPagerCommand())
					}
				}

				fmt.Printf("Processed %d inputs.\n", len(results))
			}

			return nil
		},
	}
)

func processContent(ctx context.Context, content string, source string) map[string]interface{} {
	// Dummy logic
	DryRunLog(ctx, "Would process content from %s (length: %d)", source, len(content))
	return map[string]interface{}{
		"source": source,
		"length": len(content),
		"status": "processed",
	}
}

// RunAuditExport exports audit log to a file
func RunAuditExport(ctx context.Context) error {
	// Get audit configuration
	auditEnabled := viper.GetBool("audit.enabled")
	if !auditEnabled {
		return fmt.Errorf("audit logging is not enabled")
	}

	// Get audit database path
	auditPath, err := GetDefaultAuditPath()
	if err != nil {
		return WrapError(err, ErrorTypeConfig, "Failed to get audit path", "Check user config directory")
	}

	// Initialize audit logger
	retentionDays := viper.GetInt("audit.retention_days")
	auditLogger, err := NewAuditLogger(auditPath, retentionDays, logger)
	if err != nil {
		return WrapError(err, ErrorTypeConfig, "Failed to initialize audit logger", "Check audit database permissions")
	}
	defer auditLogger.Close()

	// Parse filters
	var since time.Time
	if auditExportSince != "" {
		since, err = time.Parse("2006-01-02", auditExportSince)
		if err != nil {
			return WrapError(err, ErrorTypeConfig, "Invalid date format for --audit-since", "Use YYYY-MM-DD format")
		}
	}

	var eventTypes []string
	if auditExportTypes != "" {
		eventTypes = strings.Split(auditExportTypes, ",")
		for i := range eventTypes {
			eventTypes[i] = strings.TrimSpace(eventTypes[i])
		}
	}

	// Export events
	if err := auditLogger.ExportEvents(ctx, auditExportFile, eventTypes, since); err != nil {
		return WrapError(err, ErrorTypeFile, "Failed to export audit events", "Check output file path and permissions")
	}

	logger.Info("Audit log exported to %s", auditExportFile)
	return nil
}

