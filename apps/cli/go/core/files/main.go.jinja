func init() {
	cobra.OnInitialize(initConfig)

	// Persistent flags
	rootCmd.PersistentFlags().StringVar(&cfgFile, "config", "", "config file (default is $HOME/.config/{{ project_slug }}/config.yaml)")
	rootCmd.PersistentFlags().BoolVar(&jsonOutput, "json", false, "Output results as JSON")
	rootCmd.PersistentFlags().BoolVarP(&quiet, "quiet", "q", false, "Suppress all output except errors")
	rootCmd.PersistentFlags().BoolVarP(&verbose, "verbose", "v", false, "Enable verbose output")
	rootCmd.PersistentFlags().BoolVar(&debug, "debug", false, "Enable debug logging with stack traces")
	rootCmd.PersistentFlags().StringVar(&colorMode, "color", "auto", "Color output: auto, always, never")

	// Local flags
	rootCmd.Flags().Bool("usage", false, "Show usage information")
	rootCmd.Flags().BoolVar(&installFlag, "install", false, "Install shell completions and initialize config")
	rootCmd.Flags().BoolVar(&uninstallFlag, "uninstall", false, "Remove shell completions and config files")
	rootCmd.Flags().BoolVar(&dryRun, "dry-run", false, "Preview changes without executing them")
	rootCmd.Flags().BoolVarP(&force, "force", "f", false, "Bypass confirmation prompts for destructive operations")

	viper.BindPFlag("author", rootCmd.PersistentFlags().Lookup("author"))
}

func initConfig() {
	var configPath string

	if cfgFile != "" {
		// User explicitly specified a config file
		viper.SetConfigFile(cfgFile)
		configPath = cfgFile
	} else {
		// Use full precedence chain
		configPaths, err := GetConfigPrecedence()
		if err != nil {
			logger.ErrorApp(WrapError(err, ErrorTypeConfig, "Failed to get config precedence", "Check config directory permissions"))
		}

		// Add all config paths to viper (in order of precedence)
		for _, path := range configPaths {
			configDir := filepath.Dir(path)
			viper.AddConfigPath(configDir)
			viper.SetConfigName("config")
			configPath = path
		}

		// If no config files found, use default user config path
		if len(configPaths) == 0 {
			configDir, _ := os.UserConfigDir()
			viper.AddConfigPath(configDir + "/{{ project_slug }}")
			viper.SetConfigName("config")
			configPath = configDir + "/{{ project_slug }}/config.yaml"
		}
	}

	// Initialize config file if it doesn't exist (first run)
	if err := InitConfigIfNeeded(configPath); err != nil {
		logger.ErrorApp(WrapError(err, ErrorTypeConfig, "Failed to initialize config file", "Check config directory permissions and disk space"))
	}

	// Set environment variable prefix
	viper.SetEnvPrefix("{{ project_slug | upper | replace('-', '_') }}")
	viper.AutomaticEnv()

	// Read config file (will use the highest priority one found)
	if err := viper.ReadInConfig(); err != nil {
		// Config file not found is not an error - we'll use defaults
		if _, ok := err.(viper.ConfigFileNotFoundError); !ok {
			logger.ErrorApp(WrapError(err, ErrorTypeConfig, "Failed to read config file", "Check config file syntax and permissions"))
		}
	} else {
		// Validate the loaded configuration
		config := viper.AllSettings()
		validationErrors := ValidateConfig(config, configPath)
		if len(validationErrors) > 0 {
			errMsg := fmt.Sprintf("Configuration validation failed with %d error(s)", len(validationErrors))
			suggestion := "Review the configuration file and fix the validation errors"
			validationErr := NewValidationError(errMsg)
			validationErr.Suggestion = suggestion
			logger.ErrorApp(validationErr)
			for _, validationErr := range validationErrors {
				logger.Error("  - %s", validationErr.Error())
			}
			os.Exit(ExitConfigError)
		}
	}

	// Set hardcoded defaults
	defaults := GetHardcodedDefaults()
	for key, value := range defaults {
		viper.SetDefault(key, value)
	}
}

func main() {
	ctx, stop := signal.NotifyContext(context.Background(), os.Interrupt)
	defer stop()

	if err := rootCmd.ExecuteContext(ctx); err != nil {
		os.Exit(1)
	}
}

