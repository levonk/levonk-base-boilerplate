FROM golang:1.21-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /app/{{ project_slug }} .

FROM alpine:latest
WORKDIR /app
COPY --from=builder /app/{{ project_slug }} /usr/local/bin/
ENTRYPOINT ["{{ project_slug }}"]
CMD ["--help"]

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD {{ project_slug }} --health-check || exit 1
