package main

import (
	"path/filepath"
	"runtime"
	"strings"
	"testing"
)

func TestNewFileReference(t *testing.T) {
	ref := NewFileReference(1)
	if ref == nil {
		t.Fatal("NewFileReference returned nil")
	}

	if ref.Path == "" {
		t.Error("Path should not be empty")
	}

	if ref.Line <= 0 {
		t.Error("Line should be positive")
	}

	if ref.AbsPath == "" {
		t.Error("AbsPath should not be empty")
	}
}

func TestNewFileReferenceFromPath(t *testing.T) {
	tests := []struct {
		name   string
		path   string
		line   int
		column int
	}{
		{"with line and column", "/path/to/file.go", 10, 5},
		{"with line only", "/path/to/file.go", 10, 0},
		{"with zero values", "/path/to/file.go", 0, 0},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			ref := NewFileReferenceFromPath(tt.path, tt.line, tt.column)
			if ref == nil {
				t.Fatal("NewFileReferenceFromPath returned nil")
			}

			if ref.Path != tt.path {
				t.Errorf("Path = %v, want %v", ref.Path, tt.path)
			}

			if ref.Line != tt.line {
				t.Errorf("Line = %v, want %v", ref.Line, tt.line)
			}

			if ref.Column != tt.column {
				t.Errorf("Column = %v, want %v", ref.Column, tt.column)
			}

			if ref.AbsPath == "" {
				t.Error("AbsPath should not be empty")
			}
		})
	}
}

func TestFileReference_FormatVSCode(t *testing.T) {
	tests := []struct {
		name     string
		path     string
		line     int
		column   int
		expected string
	}{
		{
			name:     "with line and column",
			path:     "/path/to/file.go",
			line:     10,
			column:   5,
			expected: "file:///path/to/file.go:10:5",
		},
		{
			name:     "with line only",
			path:     "/path/to/file.go",
			line:     10,
			column:   0,
			expected: "file:///path/to/file.go:10",
		},
		{
			name:     "with zero values",
			path:     "/path/to/file.go",
			line:     0,
			column:   0,
			expected: "file:///path/to/file.go",
		},
		{
			name:     "windows path",
			path:     "C:\\path\\to\\file.go",
			line:     10,
			column:   5,
			expected: "file:///C:/path/to/file.go:10:5",
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			ref := NewFileReferenceFromPath(tt.path, tt.line, tt.column)
			result := ref.FormatVSCode()

			if result != tt.expected {
				t.Errorf("FormatVSCode() = %v, want %v", result, tt.expected)
			}
		})
	}
}

