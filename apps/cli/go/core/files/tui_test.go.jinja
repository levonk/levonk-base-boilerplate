package main

import (
	"testing"

	tea "github.com/charmbracelet/bubbletea"
)

func TestNewTUIModel(t *testing.T) {
	args := []string{"arg1", "arg2", "arg3"}
	model := NewTUIModel(args)

	if len(model.args) != 3 {
		t.Errorf("Expected 3 args, got %d", len(model.args))
	}

	if model.cursor != 0 {
		t.Errorf("Expected cursor at 0, got %d", model.cursor)
	}

	if model.selected == nil {
		t.Error("Expected selected map to be initialized")
	}
}

func TestTUIModelInit(t *testing.T) {
	model := NewTUIModel([]string{})
	cmd := model.Init()

	if cmd != nil {
		t.Error("Expected nil command from Init")
	}
}

func TestTUIModelNavigation(t *testing.T) {
	model := NewTUIModel([]string{"a", "b", "c"})

	// Test down navigation
	model, _ = model.Update(tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune("j")})
	if model.cursor != 1 {
		t.Errorf("Expected cursor at 1 after down, got %d", model.cursor)
	}

	// Test up navigation
	model, _ = model.Update(tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune("k")})
	if model.cursor != 0 {
		t.Errorf("Expected cursor at 0 after up, got %d", model.cursor)
	}

	// Test boundary - up at top
	model, _ = model.Update(tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune("k")})
	if model.cursor != 0 {
		t.Errorf("Expected cursor to stay at 0, got %d", model.cursor)
	}

	// Test boundary - down at bottom
	model.cursor = 2
	model, _ = model.Update(tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune("j")})
	if model.cursor != 2 {
		t.Errorf("Expected cursor to stay at 2, got %d", model.cursor)
	}
}

func TestTUIModelEdit(t *testing.T) {
	model := NewTUIModel([]string{"original"})

	// Enter edit mode
	model, _ = model.Update(tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune("e")})
	if !model.editing {
		t.Error("Expected editing to be true")
	}

	if model.editValue != "original" {
		t.Errorf("Expected editValue to be 'original', got '%s'", model.editValue)
	}

	// Type characters
	model, _ = model.Update(tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune("modified")})
	if model.editValue != "originalmodified" {
		t.Errorf("Expected editValue to be 'originalmodified', got '%s'", model.editValue)
	}

	// Backspace
	model, _ = model.Update(tea.KeyMsg{Type: tea.KeyBackspace})
	if model.editValue != "originalmodifie" {
		t.Errorf("Expected editValue to be 'originalmodifie', got '%s'", model.editValue)
	}

	// Save with Enter
	model, _ = model.Update(tea.KeyMsg{Type: tea.KeyEnter})
	if model.editing {
		t.Error("Expected editing to be false after Enter")
	}

	if model.args[0] != "originalmodifie" {
		t.Errorf("Expected arg to be 'originalmodifie', got '%s'", model.args[0])
	}
}

func TestTUIModelDelete(t *testing.T) {
	model := NewTUIModel([]string{"a", "b", "c"})

	// Delete middle item
	model.cursor = 1
	model, _ = model.Update(tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune("d")})

	if len(model.args) != 2 {
		t.Errorf("Expected 2 args after delete, got %d", len(model.args))
	}

	if model.args[1] != "c" {
		t.Errorf("Expected second arg to be 'c', got '%s'", model.args[1])
	}
}

func TestTUIModelConfirm(t *testing.T) {
	model := NewTUIModel([]string{"a", "b"})

	// Enter confirm mode
	model, _ = model.Update(tea.KeyMsg{Type: tea.KeyEnter})
	if !model.confirming {
		t.Error("Expected confirming to be true")
	}

	// Cancel with N
	model, _ = model.Update(tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune("n")})
	if model.confirming {
		t.Error("Expected confirming to be false after N")
	}

	// Enter confirm mode again
	model, _ = model.Update(tea.KeyMsg{Type: tea.KeyEnter})

	// Confirm with Y
	model, _ = model.Update(tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune("y")})
	if !model.quitting {
		t.Error("Expected quitting to be true after Y")
	}
}

func TestTUIModelQuit(t *testing.T) {
	model := NewTUIModel([]string{"a"})

	model, _ = model.Update(tea.KeyMsg{Type: tea.KeyRunes, Runes: []rune("q")})
	if !model.quitting {
		t.Error("Expected quitting to be true after q")
	}
}

func TestTUIModelEmptyArgs(t *testing.T) {
	model := NewTUIModel([]string{})

	// Should handle empty args gracefully
	view := model.View()
	if view == "" {
		t.Error("Expected non-empty view for empty args")
	}
}

func TestTUIModelView(t *testing.T) {
	model := NewTUIModel([]string{"arg1", "arg2"})

	view := model.View()
	if view == "" {
		t.Error("Expected non-empty view")
	}

	if len(view) < 10 {
		t.Error("Expected view to have content")
	}
}

