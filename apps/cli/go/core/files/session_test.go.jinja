	if sessionCmd.Flags().Lookup("session-context") == nil {
		t.Error("session command missing session-context flag")
	}
	if sessionCmd.Flags().Lookup("install-agent-hooks") == nil {
		t.Error("session command missing install-agent-hooks flag")
	}
}

func TestSessionCommandInRoot(t *testing.T) {
	// Verify session command is added to root
	found := false
	for _, c := range rootCmd.Commands() {
		if c.Name() == "session" {
			found = true
			break
		}
	}
	if !found {
		t.Error("session command not added to root command")
	}
}

func TestSessionContextOutput(t *testing.T) {
	// Capture stdout
	old := os.Stdout
	r, w, _ := os.Pipe()
	os.Stdout = w

	sessionContextFlag = true
	cmd := &cobra.Command{}
	err := runSessionContext(cmd, []string{})

	w.Close()
	os.Stdout = old

	if err != nil {
		t.Fatalf("runSessionContext failed: %v", err)
	}

	// Read captured output
	var buf bytes.Buffer
	buf.ReadFrom(r)
	output := buf.String()

	if output == "" {
		t.Error("session context output is empty")
	}

	// Verify it contains expected fields
	expectedFields := []string{"working_dir", "project_type", "has_config", "has_data"}
	for _, field := range expectedFields {
		if !containsString(output, field) {
			t.Errorf("output missing expected field: %s", field)
		}
	}
}

