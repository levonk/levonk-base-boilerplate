// Helper function
func containsString(s, substr string) bool {
	return len(s) >= len(substr) && findSubstringString(s, substr)
}

func findSubstringString(s, substr string) bool {
	for i := 0; i <= len(s)-len(substr); i++ {
		if s[i:i+len(substr)] == substr {
			return true
		}
	}
	return false
}
