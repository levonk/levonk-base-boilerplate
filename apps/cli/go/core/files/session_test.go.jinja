func TestInstallAgentHooksIntegration(t *testing.T) {
	tmpDir := t.TempDir()

	// Create a fake home directory
	homeDir := filepath.Join(tmpDir, "home")
	claudeDir := filepath.Join(homeDir, ".claude")
	if err := os.MkdirAll(claudeDir, 0755); err != nil {
		t.Fatalf("Failed to create test directories: %v", err)
	}

	// Set up test environment
	oldHome := os.Getenv("HOME")
	os.Setenv("HOME", homeDir)
	defer os.Setenv("HOME", oldHome)

	// Create a test executable
	testExec := filepath.Join(tmpDir, "test-exec")
	if err := os.WriteFile(testExec, []byte("#!/bin/sh\necho test"), 0755); err != nil {
		t.Fatalf("Failed to create test executable: %v", err)
	}

	// Test hook installation
	opts := session.HookOptions{
		AgentType:      session.AgentClaude,
		ExecutablePath: testExec,
		SessionEnd:     true,
	}

	result, err := session.RegisterHook(opts)
	if err != nil {
		t.Fatalf("RegisterHook failed: %v", err)
	}

	if !result.Success {
		t.Error("RegisterHook returned unsuccessful result")
	}

	// Verify hook file was created
	hookFile := filepath.Join(claudeDir, "settings.json")
	if _, err := os.Stat(hookFile); os.IsNotExist(err) {
		t.Error("Hook file was not created")
	}

	// Test idempotent installation (should be no-op)
	result2, err := session.RegisterHook(opts)
	if err != nil {
		t.Fatalf("RegisterHook failed on second call: %v", err)
	}

	if result2.Updated {
		t.Error("RegisterHook should not update on idempotent call")
	}

	if result2.Message != "Hook already installed with same path (no-op)" {
		t.Errorf("Expected no-op message, got: %s", result2.Message)
	}
}

func TestInstallAgentHooksForceUpdate(t *testing.T) {
	tmpDir := t.TempDir()

	// Create a fake home directory
	homeDir := filepath.Join(tmpDir, "home")
	claudeDir := filepath.Join(homeDir, ".claude")
	if err := os.MkdirAll(claudeDir, 0755); err != nil {
		t.Fatalf("Failed to create test directories: %v", err)
	}

	// Set up test environment
	oldHome := os.Getenv("HOME")
	os.Setenv("HOME", homeDir)
	defer os.Setenv("HOME", oldHome)

	// Create a test executable
	testExec := filepath.Join(tmpDir, "test-exec")
	if err := os.WriteFile(testExec, []byte("#!/bin/sh\necho test"), 0755); err != nil {
		t.Fatalf("Failed to create test executable: %v", err)
	}

	// Install hook
	opts := session.HookOptions{
		AgentType:      session.AgentClaude,
		ExecutablePath: testExec,
		SessionEnd:     true,
		ForceUpdate:    false,
	}

	_, err := session.RegisterHook(opts)
	if err != nil {
		t.Fatalf("RegisterHook failed: %v", err)
	}

	// Force update
	opts.ForceUpdate = true
	result, err := session.RegisterHook(opts)
	if err != nil {
		t.Fatalf("RegisterHook with force failed: %v", err)
	}

	if !result.Updated {
		t.Error("RegisterHook with force should update even if path is same")
	}
}

