func TestWithPager(t *testing.T) {
	// Test with no-pager flag
	err := WithPager(true, 100, func() error {
		return nil
	})
	if err != nil {
		t.Errorf("WithPager() returned error: %v", err)
	}

	// Test with short output (should not use pager)
	err = WithPager(false, 5, func() error {
		return nil
	})
	if err != nil {
		t.Errorf("WithPager() returned error: %v", err)
	}
}

