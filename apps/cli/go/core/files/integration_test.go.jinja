	time.Sleep(100 * time.Millisecond)

	// Test daemon status command
	statusCmd := exec.Command("go", "run", ".", "daemon", "status")
	statusOutput, err := statusCmd.CombinedOutput()
	if err != nil {
		t.Logf("Daemon status failed: %v\nOutput: %s", err, string(statusOutput))
	}

	// Test daemon stop command
	stopCmd := exec.Command("go", "run", ".", "daemon", "stop")
	stopOutput, err := stopCmd.CombinedOutput()
	if err != nil {
		t.Logf("Daemon stop failed: %v\nOutput: %s", err, string(stopOutput))
	}
}

func TestIntegrationTUIMode(t *testing.T) {
	if testing.Short() {
		t.Skip("Skipping integration test in short mode")
	}

	// Test TUI mode with timeout to prevent hanging
	cmd := exec.Command("timeout", "1s", "go", "run", ".", "--tui")
	output, err := cmd.CombinedOutput()
	if err != nil {
		// Timeout is expected for TUI mode
		t.Logf("TUI mode timed out as expected: %v", err)
	}

	// Verify TUI was attempted
	outputStr := string(output)
	if len(outputStr) > 0 {
		t.Logf("TUI output: %s", outputStr[:min(200, len(outputStr))])
	}
}

// Helper function for min
func min(a, b int) int {
	if a < b {
		return a
	}
	return b
}
