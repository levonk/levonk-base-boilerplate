	}

	// This test is optional as daemon support may not be implemented
	// Test daemon start command
	startCmd := exec.Command("go", "run", ".", "daemon", "start", "--test-mode")
	output, err := startCmd.CombinedOutput()
	if err != nil {
		t.Logf("Daemon start failed (may not be implemented): %v\nOutput: %s", err, string(output))
