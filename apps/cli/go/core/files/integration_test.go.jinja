func TestIntegrationCrossPlatformPathHandling(t *testing.T) {
	if testing.Short() {
		t.Skip("Skipping integration test in short mode")
	}

	tempDir := t.TempDir()

	// Test path with spaces
	pathWithSpaces := filepath.Join(tempDir, "path with spaces")
	err := os.MkdirAll(pathWithSpaces, 0755)
	if err != nil {
		t.Fatalf("Failed to create path with spaces: %v", err)
	}

	configPath := filepath.Join(pathWithSpaces, "config.yaml")
	err = InitConfigIfNeeded(configPath)
	if err != nil {
		t.Errorf("Failed to initialize config in path with spaces: %v", err)
	}

	// Test path with special characters (platform-specific)
	var specialPath string
	if runtime.GOOS == "windows" {
		specialPath = filepath.Join(tempDir, "path-with-special!@#")
	} else {
		specialPath = filepath.Join(tempDir, "path-with-special-@#")
	}

	err = os.MkdirAll(specialPath, 0755)
	if err != nil {
		t.Fatalf("Failed to create path with special characters: %v", err)
	}

	specialConfigPath := filepath.Join(specialPath, "config.yaml")
	err = InitConfigIfNeeded(specialConfigPath)
	if err != nil {
		t.Errorf("Failed to initialize config in path with special characters: %v", err)
	}
}

func TestIntegrationConfigMigration(t *testing.T) {
	if testing.Short() {
		t.Skip("Skipping integration test in short mode")
	}

	tempDir := t.TempDir()
	configPath := filepath.Join(tempDir, "config.yaml")

	// Create an old version config file
	oldConfig := `
version: "1.0"
log_level: info
`
	err := os.WriteFile(configPath, []byte(oldConfig), 0644)
	if err != nil {
		t.Fatalf("Failed to write old config: %v", err)
	}

	// Load config which should trigger migration
	cfg, err := LoadConfig(configPath)
	if err != nil {
		t.Fatalf("Failed to load old config: %v", err)
	}

	// Verify migration occurred (version should be updated)
	if cfg.Version == "" {
		t.Logf("Config version not set, migration may not be implemented")
	}

	// Verify config is still functional
	if cfg.LogLevel != "info" {
		t.Errorf("Expected log_level to be 'info', got '%s'", cfg.LogLevel)
	}
}

func TestIntegrationDaemonProcessLifecycle(t *testing.T) {
	if testing.Short() {
