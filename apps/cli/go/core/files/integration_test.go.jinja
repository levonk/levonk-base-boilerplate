// Integration tests verify the entire CLI tool works end-to-end
// These tests require the binary to be built and test complete workflows

func TestIntegrationCompleteCLIWorkflow(t *testing.T) {
	if testing.Short() {
		t.Skip("Skipping integration test in short mode")
	}

	// Build the binary first
	buildCmd := exec.Command("go", "build", "-o", "{{ project_slug }}-test", ".")
	if output, err := buildCmd.CombinedOutput(); err != nil {
		t.Fatalf("Failed to build binary: %v\nOutput: %s", err, string(output))
	}
	defer os.Remove("{{ project_slug }}-test")

	// Test help command
	helpCmd := exec.Command("./{{ project_slug }}-test", "--help")
	output, err := helpCmd.CombinedOutput()
	if err != nil {
		t.Fatalf("Help command failed: %v\nOutput: %s", err, string(output))
	}
	if !strings.Contains(string(output), "Usage:") {
		t.Errorf("Expected help output to contain 'Usage:', got: %s", string(output))
	}

	// Test version command if available
	versionCmd := exec.Command("./{{ project_slug }}-test", "--version")
	output, err = versionCmd.CombinedOutput()
	if err == nil {
		// Version command succeeded, verify output
		if len(output) == 0 {
			t.Errorf("Version command produced no output")
		}
	}
}

func TestIntegrationConfigFileInitialization(t *testing.T) {
	if testing.Short() {
		t.Skip("Skipping integration test in short mode")
	}

	tempDir := t.TempDir()
	configPath := filepath.Join(tempDir, "config.yaml")

	// Test config initialization
	initCmd := exec.Command("go", "run", ".", "--config", configPath, "init")
	initCmd.Dir = tempDir
	output, err := initCmd.CombinedOutput()
	if err != nil {
		t.Logf("Config init command output: %s", string(output))
		// Some implementations may not have an explicit init command
		// Try alternative: run the tool and let it create config
	}

	// Verify config file was created
	if _, err := os.Stat(configPath); os.IsNotExist(err) {
		// Try creating config via API
		err = InitConfigIfNeeded(configPath)
		if err != nil {
			t.Fatalf("Failed to initialize config: %v", err)
		}
	}

	// Verify config file has content
	content, err := os.ReadFile(configPath)
	if err != nil {
		t.Fatalf("Failed to read config file: %v", err)
	}
	if len(content) == 0 {
		t.Errorf("Config file is empty")
	}
}

func TestIntegrationConfigPrecedenceChain(t *testing.T) {
	if testing.Short() {
		t.Skip("Skipping integration test in short mode")
	}

	tempDir := t.TempDir()
	configPath := filepath.Join(tempDir, "config.yaml")

	// Create a config file with specific values
	configContent := `
log_level: debug
color: true
`
	err := os.WriteFile(configPath, []byte(configContent), 0644)
	if err != nil {
		t.Fatalf("Failed to write config file: %v", err)
	}

	// Test that config is loaded correctly
	cfg, err := LoadConfig(configPath)
	if err != nil {
		t.Fatalf("Failed to load config: %v", err)
	}

	// Verify values
	if cfg.LogLevel != "debug" {
		t.Errorf("Expected log_level to be 'debug', got '%s'", cfg.LogLevel)
	}
	if cfg.Color != true {
		t.Errorf("Expected color to be true, got %v", cfg.Color)
	}

	// Test environment variable override
	os.Setenv("{{ project_slug | upper }}_LOG_LEVEL", "error")
	defer os.Unsetenv("{{ project_slug | upper }}_LOG_LEVEL")

	cfg2, err := LoadConfig(configPath)
	if err != nil {
		t.Fatalf("Failed to load config with env override: %v", err)
	}

	// Verify environment variable takes precedence
	if cfg2.LogLevel != "error" {
		t.Errorf("Expected log_level to be 'error' from env, got '%s'", cfg2.LogLevel)
	}
}

