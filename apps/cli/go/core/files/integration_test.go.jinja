func TestIntegrationShellCompletionInstallation(t *testing.T) {
	if testing.Short() {
		t.Skip("Skipping integration test in short mode")
	}

	// Test completion generation for different shells
	shells := []string{"bash", "zsh", "fish"}

	for _, shell := range shells {
		t.Run(shell, func(t *testing.T) {
			cmd := exec.Command("go", "run", ".", "completion", shell)
			output, err := cmd.CombinedOutput()
			if err != nil {
				t.Logf("Completion for %s failed (may not be implemented): %v", shell, err)
				return
			}

			// Verify output contains completion script markers
			outputStr := string(output)
			if len(outputStr) == 0 {
				t.Errorf("Completion script for %s is empty", shell)
			}

			// Shell-specific checks
			switch shell {
			case "bash":
				if !strings.Contains(outputStr, "complete") {
					t.Logf("Bash completion may not contain 'complete': %s", outputStr[:min(100, len(outputStr))])
				}
			case "zsh":
				if !strings.Contains(outputStr, "compdef") {
					t.Logf("Zsh completion may not contain 'compdef': %s", outputStr[:min(100, len(outputStr))])
				}
			case "fish":
				if !strings.Contains(outputStr, "complete") {
					t.Logf("Fish completion may not contain 'complete': %s", outputStr[:min(100, len(outputStr))])
				}
			}
		})
	}
}

func TestIntegrationColorControl(t *testing.T) {
	if testing.Short() {
		t.Skip("Skipping integration test in short mode")
	}

	// Test with color enabled
	cmd := exec.Command("go", "run", ".", "--color=always", "--help")
	output, err := cmd.CombinedOutput()
	if err != nil {
		t.Fatalf("Command with color failed: %v", err)
	}

	// Check for ANSI color codes in output
	outputStr := string(output)
	hasColor := strings.Contains(outputStr, "\x1b[") || strings.Contains(outputStr, "\033[")
	if !hasColor {
		t.Logf("Output may not contain color codes (this is OK if terminal detection is working)")
	}

	// Test with color disabled
	cmdNoColor := exec.Command("go", "run", ".", "--color=never", "--help")
	cmdNoColor.Env = append(os.Environ(), "TERM=dumb")
	outputNoColor, err := cmdNoColor.CombinedOutput()
	if err != nil {
		t.Fatalf("Command without color failed: %v", err)
	}

	// Verify no color codes
	outputNoColorStr := string(outputNoColor)
	hasColorNoColor := strings.Contains(outputNoColorStr, "\x1b[") || strings.Contains(outputNoColorStr, "\033[")
	if hasColorNoColor {
		t.Errorf("Output with --color=never should not contain color codes")
	}
}

