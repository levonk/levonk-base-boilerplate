package main

import (
	"crypto/aes"
	"crypto/cipher"
	"crypto/rand"
	"encoding/json"
	"errors"
	"fmt"
	"io"
	"os"
	"regexp"
	"sync"
	"syscall"

	"github.com/99designs/keyring"
	"golang.org/x/term"
)

// SecretManager handles secure storage and retrieval of sensitive data
type SecretManager struct {
	keyring      keyring.Keyring
	encryptionKey []byte
	redactionPatterns []*regexp.Regexp
	useMockKeyring bool
	mockStore     map[string][]byte
	mockMutex     sync.RWMutex
}

// Secret represents a stored credential
type Secret struct {
	Service string
	Account string
	Value   string
}

// NewSecretManager creates a new secret manager with keychain support
// In test mode (when TEST_MODE=true environment variable is set), it uses a mock keyring
func NewSecretManager() (*SecretManager, error) {
	// Check if we're in test mode
	useMock := os.Getenv("TEST_MODE") == "true"

	var kr keyring.Keyring
	var err error

	if useMock {
		// Use mock keyring for testing
		kr = &mockKeyring{
			store: make(map[string][]byte),
		}
	} else {
		// Initialize keyring with platform-specific backend
		kr, err = keyring.Open(keyring.Config{
			ServiceName: "{{ project_slug }}",
			AllowedBackends: []keyring.BackendType{
				keyring.KeychainBackend,     // macOS
				keyring.SecretServiceBackend, // Windows
				keyring.KWalletBackend,      // Linux KDE
				keyring.PassBackend,         // Linux (pass)
			},
		})
		if err != nil {
			return nil, fmt.Errorf("failed to initialize keyring: %w", err)
		}
	}

	// Initialize redaction patterns for common secret patterns
	patterns := []*regexp.Regexp{
		regexp.MustCompile(`(?i)(password|passwd|pwd|secret|token|api[_-]?key|access[_-]?key|private[_-]?key)[\s=:]+["']?([^"'\s]+)["']?`),
		regexp.MustCompile(`Bearer\s+[A-Za-z0-9\-._~+/]+=*`),
		regexp.MustCompile(`Basic\s+[A-Za-z0-9+/=]+`),
		regexp.MustCompile(`[A-Za-z0-9]{32,}`), // Likely API keys/tokens
	}

	return &SecretManager{
		keyring:           kr,
		redactionPatterns: patterns,
		useMockKeyring:    useMock,
		mockStore:         make(map[string][]byte),
	}, nil
}

// SetEncryptionKey sets the encryption key for file-based storage
func (sm *SecretManager) SetEncryptionKey(key []byte) error {
	if len(key) != 32 {
		return errors.New("encryption key must be 32 bytes (AES-256)")
	}
	sm.encryptionKey = key
	return nil
}

// PromptForEncryptionKey prompts user for encryption key securely
func (sm *SecretManager) PromptForEncryptionKey() error {
	fmt.Print("Enter encryption key (32 characters): ")
	key, err := term.ReadPassword(int(syscall.Stdin))
	fmt.Println()
	if err != nil {
		return fmt.Errorf("failed to read encryption key: %w", err)
	}
	if len(key) != 32 {
		return errors.New("encryption key must be 32 characters")
	}
	sm.encryptionKey = key
	return nil
}

// Store stores a secret in the keychain
func (sm *SecretManager) Store(service, account, value string) error {
	if sm.useMockKeyring {
		sm.mockMutex.Lock()
		defer sm.mockMutex.Unlock()
		key := fmt.Sprintf("%s/%s", service, account)
		sm.mockStore[key] = []byte(value)
		return nil
	}

	item := keyring.Item{
		Key:  fmt.Sprintf("%s/%s", service, account),
		Data: []byte(value),
		Label: fmt.Sprintf("%s - %s", service, account),
	}

	if err := sm.keyring.Set(item); err != nil {
		return fmt.Errorf("failed to store secret in keychain: %w", err)
	}

	return nil
}

// Retrieve retrieves a secret from the keychain
func (sm *SecretManager) Retrieve(service, account string) (string, error) {
	if sm.useMockKeyring {
		sm.mockMutex.RLock()
		defer sm.mockMutex.RUnlock()
		key := fmt.Sprintf("%s/%s", service, account)
		data, exists := sm.mockStore[key]
		if !exists {
			return "", fmt.Errorf("secret not found in mock keyring")
		}
		return string(data), nil
	}

	key := fmt.Sprintf("%s/%s", service, account)
	item, err := sm.keyring.Get(key)
	if err != nil {
		return "", fmt.Errorf("failed to retrieve secret from keychain: %w", err)
	}

	return string(item.Data), nil
}

// Delete removes a secret from the keychain
func (sm *SecretManager) Delete(service, account string) error {
	if sm.useMockKeyring {
		sm.mockMutex.Lock()
		defer sm.mockMutex.Unlock()
		key := fmt.Sprintf("%s/%s", service, account)
		delete(sm.mockStore, key)
		return nil
	}

	key := fmt.Sprintf("%s/%s", service, account)
	if err := sm.keyring.Remove(key); err != nil {
		return fmt.Errorf("failed to delete secret from keychain: %w", err)
	}

	return nil
}

// StoreToFile stores a secret in an encrypted file
func (sm *SecretManager) StoreToFile(filepath, service, account, value string) error {
	if sm.encryptionKey == nil {
		return errors.New("encryption key not set - call SetEncryptionKey or PromptForEncryptionKey first")
	}

	secret := Secret{
		Service: service,
		Account: account,
		Value:   value,
	}

	data, err := json.Marshal(secret)
	if err != nil {
		return fmt.Errorf("failed to marshal secret: %w", err)
	}

	encrypted, err := sm.encrypt(data)
	if err != nil {
		return fmt.Errorf("failed to encrypt secret: %w", err)
	}

	if err := os.WriteFile(filepath, encrypted, 0600); err != nil {
		return fmt.Errorf("failed to write encrypted file: %w", err)
	}

	return nil
}

// RetrieveFromFile retrieves a secret from an encrypted file
func (sm *SecretManager) RetrieveFromFile(filepath string) (*Secret, error) {
	if sm.encryptionKey == nil {
		return nil, errors.New("encryption key not set - call SetEncryptionKey or PromptForEncryptionKey first")
	}

	encrypted, err := os.ReadFile(filepath)
	if err != nil {
		return nil, fmt.Errorf("failed to read encrypted file: %w", err)
	}

	decrypted, err := sm.decrypt(encrypted)
	if err != nil {
		return nil, fmt.Errorf("failed to decrypt secret: %w", err)
	}

	var secret Secret
	if err := json.Unmarshal(decrypted, &secret); err != nil {
		return nil, fmt.Errorf("failed to unmarshal secret: %w", err)
	}

	return &secret, nil
}

// encrypt encrypts data using AES-256-GCM
func (sm *SecretManager) encrypt(plaintext []byte) ([]byte, error) {
	block, err := aes.NewCipher(sm.encryptionKey)
	if err != nil {
		return nil, err
	}

	gcm, err := cipher.NewGCM(block)
	if err != nil {
		return nil, err
	}

	nonce := make([]byte, gcm.NonceSize())
	if _, err := io.ReadFull(rand.Reader, nonce); err != nil {
		return nil, err
	}

	ciphertext := gcm.Seal(nonce, nonce, plaintext, nil)
	return ciphertext, nil
}

// decrypt decrypts data using AES-256-GCM
func (sm *SecretManager) decrypt(ciphertext []byte) ([]byte, error) {
	block, err := aes.NewCipher(sm.encryptionKey)
	if err != nil {
		return nil, err
	}

	gcm, err := cipher.NewGCM(block)
	if err != nil {
		return nil, err
	}

	nonceSize := gcm.NonceSize()
	if len(ciphertext) < nonceSize {
		return nil, errors.New("ciphertext too short")
	}

	nonce, ciphertext := ciphertext[:nonceSize], ciphertext[nonceSize:]
	plaintext, err := gcm.Open(nil, nonce, ciphertext, nil)
	if err != nil {
		return nil, err
	}

	return plaintext, nil
}

// RedactSecrets redacts potential secrets from a string
func (sm *SecretManager) RedactSecrets(input string) string {
	redacted := input

	// Apply all redaction patterns
	for _, pattern := range sm.redactionPatterns {
		redacted = pattern.ReplaceAllStringFunc(redacted, func(match string) string {
			// Keep the first part (label) but redact the value
			// Find the last colon (value separator)
			lastColonIndex := -1
			for i, c := range match {
				if c == ':' {
					lastColonIndex = i
				}
			}
			if lastColonIndex >= 0 {
				// Return the label with colon and redacted value
				return match[:lastColonIndex] + ": [REDACTED]"
			}
			return "[REDACTED]"
		})
	}

	return redacted
}

// ValidateSecret checks if a value appears to be a secret that shouldn't be stored insecurely
func (sm *SecretManager) ValidateSecret(value string) (bool, string) {
	// Check for common secret patterns first
	for _, pattern := range sm.redactionPatterns {
		if pattern.MatchString(value) {
			return true, "value appears to contain sensitive data"
		}
	}

	// Check for high entropy (likely random secret/token)
	if len(value) > 20 && sm.isHighEntropy(value) {
		return true, "value has high entropy - likely a secret or token"
	}

	return false, ""
}

// isHighEntropy checks if a string has high entropy (likely a secret)
func (sm *SecretManager) isHighEntropy(s string) bool {
	uniqueChars := make(map[rune]bool)
	for _, c := range s {
		uniqueChars[c] = true
	}

	// If more than 70% of characters are unique, it's likely high entropy
	return float64(len(uniqueChars))/float64(len(s)) > 0.7
}

// WarnInsecureConfig logs a warning if secrets are detected in config
func (sm *SecretManager) WarnInsecureConfig(configKey, configValue string) {
	isSecret, reason := sm.ValidateSecret(configValue)
	if isSecret {
		fmt.Fprintf(os.Stderr, "WARNING: Insecure configuration detected\n")
		fmt.Fprintf(os.Stderr, "  Key: %s\n", configKey)
		fmt.Fprintf(os.Stderr, "  Reason: %s\n", reason)
		fmt.Fprintf(os.Stderr, "  Recommendation: Use secure storage (keychain or encrypted file) instead\n")
	}
}

// ValidateConfig checks a config map for insecure secret storage
func (sm *SecretManager) ValidateConfig(config map[string]string) []string {
	warnings := []string{}

	for key, value := range config {
		isSecret, reason := sm.ValidateSecret(value)
		if isSecret {
			warning := fmt.Sprintf("Key '%s': %s", key, reason)
			warnings = append(warnings, warning)
		}
	}

	return warnings
}

// GetSupportedBackends returns the list of supported keyring backends
func (sm *SecretManager) GetSupportedBackends() []string {
	return []string{
		"keychain (macOS)",
		"secret-service (Windows)",
		"kwallet (Linux KDE)",
		"pass (Linux)",
	}
}

// IsKeychainAvailable checks if keychain storage is available
func (sm *SecretManager) IsKeychainAvailable() bool {
	return sm.keyring != nil
}

// mockKeyring is an in-memory keyring implementation for testing
type mockKeyring struct {
	store map[string][]byte
}

// Get retrieves a keyring item
func (m *mockKeyring) Get(key string) (keyring.Item, error) {
	data, exists := m.store[key]
	if !exists {
		return keyring.Item{}, fmt.Errorf("key not found: %s", key)
	}
	return keyring.Item{
		Data: data,
		Key:  key,
	}, nil
}

// GetMetadata retrieves metadata for a keyring item
func (m *mockKeyring) GetMetadata(key string) (keyring.Metadata, error) {
	_, exists := m.store[key]
	if !exists {
		return keyring.Metadata{}, fmt.Errorf("key not found: %s", key)
	}
	return keyring.Metadata{}, nil
}

// Set stores a keyring item
func (m *mockKeyring) Set(item keyring.Item) error {
	m.store[item.Key] = item.Data
	return nil
}

// Remove removes a keyring item
func (m *mockKeyring) Remove(key string) error {
	delete(m.store, key)
	return nil
}

// Keys returns all keys in the keyring
func (m *mockKeyring) Keys() ([]string, error) {
	keys := make([]string, 0, len(m.store))
	for k := range m.store {
		keys = append(keys, k)
	}
	return keys, nil
}

