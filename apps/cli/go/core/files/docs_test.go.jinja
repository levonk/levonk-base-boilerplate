package main

import (
	"bytes"
	"os"
	"path/filepath"
	"strings"
	"testing"

	"github.com/spf13/cobra"
)

func TestRunGenMan(t *testing.T) {
	// Create a test command
	cmd := &cobra.Command{
		Use:   "{{ project_slug }}",
		Short: "{{ description }}",
		Long:  "{{ description }}",
	}

	// Capture stdout
	var buf bytes.Buffer
	oldStdout := os.Stdout
	r, w, _ := os.Pipe()
	os.Stdout = w

	// Run man page generation
	err := RunGenMan(cmd)

	// Restore stdout
	w.Close()
	os.Stdout = oldStdout
	buf.ReadFrom(r)

	if err != nil {
		t.Errorf("RunGenMan() error = %v", err)
	}

	// Check that output contains man page sections
	output := buf.String()
	if !strings.Contains(output, "NAME") {
		t.Error("Man page output should contain NAME section")
	}
	if !strings.Contains(output, "SYNOPSIS") {
		t.Error("Man page output should contain SYNOPSIS section")
	}
	if !strings.Contains(output, "DESCRIPTION") {
		t.Error("Man page output should contain DESCRIPTION section")
	}
	if !strings.Contains(output, "OPTIONS") {
		t.Error("Man page output should contain OPTIONS section")
	}
}

func TestGenManToFile(t *testing.T) {
	// Create a test command
	cmd := &cobra.Command{
		Use:   "{{ project_slug }}",
		Short: "{{ description }}",
		Long:  "{{ description }}",
	}

	// Create temporary directory
	tmpDir := t.TempDir()

	// Generate man page to file
	err := GenManToFile(cmd, tmpDir)
	if err != nil {
		t.Errorf("GenManToFile() error = %v", err)
	}

	// Check that file was created
	manFile := filepath.Join(tmpDir, "{{ project_slug }}.1")
	if _, err := os.Stat(manFile); os.IsNotExist(err) {
		t.Error("Man page file was not created")
	}

	// Read and check file content
	content, err := os.ReadFile(manFile)
	if err != nil {
		t.Errorf("Failed to read man page file: %v", err)
	}

	contentStr := string(content)
	if !strings.Contains(contentStr, "NAME") {
		t.Error("Man page file should contain NAME section")
	}
	if !strings.Contains(contentStr, "SYNOPSIS") {
		t.Error("Man page file should contain SYNOPSIS section")
	}
	if !strings.Contains(contentStr, "DESCRIPTION") {
		t.Error("Man page file should contain DESCRIPTION section")
	}
}

func TestInstallManPage(t *testing.T) {
	// Create a test command
	cmd := &cobra.Command{
		Use:   "{{ project_slug }}",
		Short: "{{ description }}",
		Long:  "{{ description }}",
	}

	// Create temporary directory to simulate home
	tmpDir := t.TempDir()
	manDir := filepath.Join(tmpDir, ".local", "share", "man", "man1")

	// Create a mock context (we'll skip dry-run for this test)
	// In a real test, you'd need to set up the context properly
	// For now, we'll test the directory creation and file generation

	// Manually call the install logic without context
	err := os.MkdirAll(manDir, 0755)
	if err != nil {
		t.Errorf("Failed to create man directory: %v", err)
	}

	err = GenManToFile(cmd, manDir)
	if err != nil {
		t.Errorf("Failed to generate man page: %v", err)
	}

	// Check that file was created
	manFile := filepath.Join(manDir, "{{ project_slug }}.1")
	if _, err := os.Stat(manFile); os.IsNotExist(err) {
		t.Error("Man page file was not created")
	}
}

func TestUninstallManPage(t *testing.T) {
	// Create temporary directory to simulate home
	tmpDir := t.TempDir()
	manDir := filepath.Join(tmpDir, ".local", "share", "man", "man1")
	manFile := filepath.Join(manDir, "{{ project_slug }}.1")

	// Create the man page file first
	err := os.MkdirAll(manDir, 0755)
	if err != nil {
		t.Errorf("Failed to create man directory: %v", err)
	}

	err = os.WriteFile(manFile, []byte("test man page content"), 0644)
	if err != nil {
		t.Errorf("Failed to create test man page file: %v", err)
	}

	// Remove the file
	err = os.Remove(manFile)
	if err != nil {
		t.Errorf("Failed to remove man page file: %v", err)
	}

	// Check that file was removed
	if _, err := os.Stat(manFile); !os.IsNotExist(err) {
		t.Error("Man page file was not removed")
	}
}
