package schema

import (
	"testing"
)

func TestGetRootCommandSchema(t *testing.T) {
	s := GetRootCommandSchema()
	
	if s.CommandName != "root" {
		t.Errorf("Expected command name 'root', got '%s'", s.CommandName)
	}
	
	if len(s.DefaultFields) != 3 {
		t.Errorf("Expected 3 default fields, got %d", len(s.DefaultFields))
	}
	
	// Verify default fields don't include long-form content
	for _, field := range s.DefaultFields {
		if field == "body" || field == "description" || field == "content" {
			t.Errorf("Default fields should not include long-form content, got '%s'", field)
		}
	}
	
	// Validate schema
	if err := s.Validate(); err != nil {
		t.Errorf("Schema validation failed: %v", err)
	}
}

func TestGetListCommandSchema(t *testing.T) {
	s := GetListCommandSchema()
	
	if s.CommandName != "list" {
		t.Errorf("Expected command name 'list', got '%s'", s.CommandName)
	}
	
	if len(s.DefaultFields) != 3 {
		t.Errorf("Expected 3 default fields, got %d", len(s.DefaultFields))
	}
	
	// Verify default fields don't include long-form content
	for _, field := range s.DefaultFields {
		if field == "body" || field == "description" || field == "content" {
			t.Errorf("Default fields should not include long-form content, got '%s'", field)
		}
	}
	
	// Verify that description and body fields exist but are not in defaults
	if !s.HasField("description") {
		t.Error("Expected schema to have 'description' field")
	}
	
	if !s.HasField("body") {
		t.Error("Expected schema to have 'body' field")
	}
	
	// Validate schema
	if err := s.Validate(); err != nil {
		t.Errorf("Schema validation failed: %v", err)
	}
}

