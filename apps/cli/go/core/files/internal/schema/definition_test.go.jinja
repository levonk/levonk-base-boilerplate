func TestParseFieldNames(t *testing.T) {
	t.Run("valid comma-separated", func(t *testing.T) {
		fields := ParseFieldNames("id,title,status")
		if len(fields) != 3 {
			t.Errorf("Expected 3 fields, got %d", len(fields))
		}
		
		expected := []string{"id", "title", "status"}
		for i, exp := range expected {
			if fields[i] != exp {
				t.Errorf("Expected field %d to be '%s', got '%s'", i, exp, fields[i])
			}
		}
	})
	
	t.Run("with spaces", func(t *testing.T) {
		fields := ParseFieldNames("id, title, status")
		if len(fields) != 3 {
			t.Errorf("Expected 3 fields, got %d", len(fields))
		}
		
		expected := []string{"id", "title", "status"}
		for i, exp := range expected {
			if fields[i] != exp {
				t.Errorf("Expected field %d to be '%s', got '%s'", i, exp, fields[i])
			}
		}
	})
	
	t.Run("empty string", func(t *testing.T) {
		fields := ParseFieldNames("")
		if fields != nil {
			t.Error("Expected nil for empty string")
		}
	})
	
	t.Run("single field", func(t *testing.T) {
		fields := ParseFieldNames("id")
		if len(fields) != 1 {
			t.Errorf("Expected 1 field, got %d", len(fields))
		}
		
		if fields[0] != "id" {
			t.Errorf("Expected field 'id', got '%s'", fields[0])
		}
	})
}

func TestValidateFieldNames(t *testing.T) {
	s := NewSchema("test-command")
	s.AddField("id", FieldTypeString, "ID", true, nil)
	s.AddField("title", FieldTypeString, "Title", true, nil)
	s.AddField("status", FieldTypeString, "Status", true, nil)
	
	t.Run("valid field names", func(t *testing.T) {
		err := s.ValidateFieldNames([]string{"id", "title"})
		if err != nil {
			t.Errorf("Expected no error, got: %v", err)
		}
	})
	
	t.Run("invalid field name", func(t *testing.T) {
		err := s.ValidateFieldNames([]string{"id", "nonexistent"})
		if err == nil {
			t.Error("Expected error for invalid field name")
		}
	})
	
	t.Run("empty field names", func(t *testing.T) {
		err := s.ValidateFieldNames([]string{})
		if err != nil {
			t.Errorf("Expected no error for empty field names, got: %v", err)
		}
	})
}
