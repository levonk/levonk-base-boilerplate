func TestGetSessionSummary(t *testing.T) {
	tmpDir := t.TempDir()
	store := &MetadataStore{cacheDir: tmpDir}

	sessionID, _ := store.StartSession("/test/dir", "go")
	store.RecordCommand(sessionID, "test", 0, 100*time.Millisecond)
	store.RecordFileTouch(sessionID, "/test/file.txt")
	store.EndSession(sessionID, 0)

	summary, err := store.GetSessionSummary(sessionID)
	if err != nil {
		t.Fatalf("GetSessionSummary failed: %v", err)
	}

	if summary == "" {
		t.Error("GetSessionSummary returned empty summary")
	}

	// Verify summary contains expected information
	expectedSubstrings := []string{
		"Session:",
		"Working Dir:",
		"Project Type:",
		"Commands Executed:",
		"Files Touched:",
	}

	for _, substr := range expectedSubstrings {
		if !containsStringHelper2(summary, substr) {
			t.Errorf("Summary missing expected substring: %s", substr)
		}
	}
}

// Helper function
func containsStringHelper2(s, substr string) bool {
	return len(s) >= len(substr) && findSubstringHelper2(s, substr)
}

func findSubstringHelper2(s, substr string) bool {
	for i := 0; i <= len(s)-len(substr); i++ {
		if s[i:i+len(substr)] == substr {
			return true
		}
	}
	return false
}

func TestGenerateSessionID(t *testing.T) {
	id1 := generateSessionID()

	// Add a small delay to ensure different timestamps
	time.Sleep(1 * time.Millisecond)

	id2 := generateSessionID()

	if id1 == id2 {
		t.Error("generateSessionID returned duplicate IDs")
	}

	if id1 == "" {
		t.Error("generateSessionID returned empty ID")
	}
}
