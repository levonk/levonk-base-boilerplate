func TestNewMetadataStore(t *testing.T) {
	store, err := NewMetadataStore()
	if err != nil {
		t.Fatalf("NewMetadataStore failed: %v", err)
	}

	if store.cacheDir == "" {
		t.Error("cacheDir is empty")
	}
}

func TestStartSession(t *testing.T) {
	tmpDir := t.TempDir()

	// Create a custom store with temp directory
	store := &MetadataStore{cacheDir: tmpDir}

	sessionID, err := store.StartSession("/test/dir", "go")
	if err != nil {
		t.Fatalf("StartSession failed: %v", err)
	}

	if sessionID == "" {
		t.Error("StartSession returned empty session ID")
	}

	// Verify metadata was saved
	metadata, err := store.LoadMetadata(sessionID)
	if err != nil {
		t.Fatalf("LoadMetadata failed: %v", err)
	}

	if metadata.WorkingDir != "/test/dir" {
		t.Errorf("WorkingDir = %v, want /test/dir", metadata.WorkingDir)
	}

	if metadata.ProjectType != "go" {
		t.Errorf("ProjectType = %v, want go", metadata.ProjectType)
	}
}

func TestEndSession(t *testing.T) {
	tmpDir := t.TempDir()
	store := &MetadataStore{cacheDir: tmpDir}

	sessionID, _ := store.StartSession("/test/dir", "go")

	err := store.EndSession(sessionID, 0)
	if err != nil {
		t.Fatalf("EndSession failed: %v", err)
	}

	// Verify session was ended
	metadata, err := store.LoadMetadata(sessionID)
	if err != nil {
		t.Fatalf("LoadMetadata failed: %v", err)
	}

	if metadata.EndTime.IsZero() {
		t.Error("EndTime is zero after EndSession")
	}

	if metadata.ExitCode != 0 {
		t.Errorf("ExitCode = %v, want 0", metadata.ExitCode)
	}

	if metadata.Duration == "" {
		t.Error("Duration is empty after EndSession")
	}
}

func TestRecordCommand(t *testing.T) {
	tmpDir := t.TempDir()
	store := &MetadataStore{cacheDir: tmpDir}

	sessionID, _ := store.StartSession("/test/dir", "go")

	err := store.RecordCommand(sessionID, "test command", 0, 100*time.Millisecond)
	if err != nil {
		t.Fatalf("RecordCommand failed: %v", err)
	}

	// Verify command was recorded
	metadata, err := store.LoadMetadata(sessionID)
	if err != nil {
		t.Fatalf("LoadMetadata failed: %v", err)
	}

	if len(metadata.Commands) != 1 {
		t.Errorf("Commands length = %v, want 1", len(metadata.Commands))
	}

	if metadata.Commands[0].Command != "test command" {
		t.Errorf("Command = %v, want test command", metadata.Commands[0].Command)
	}
}

func TestRecordFileTouch(t *testing.T) {
	tmpDir := t.TempDir()
	store := &MetadataStore{cacheDir: tmpDir}

	sessionID, _ := store.StartSession("/test/dir", "go")

	err := store.RecordFileTouch(sessionID, "/test/file.txt")
	if err != nil {
		t.Fatalf("RecordFileTouch failed: %v", err)
	}

	// Verify file was recorded
	metadata, err := store.LoadMetadata(sessionID)
	if err != nil {
		t.Fatalf("LoadMetadata failed: %v", err)
	}

	if len(metadata.FilesTouched) != 1 {
		t.Errorf("FilesTouched length = %v, want 1", len(metadata.FilesTouched))
	}

	// Test duplicate prevention
	err = store.RecordFileTouch(sessionID, "/test/file.txt")
	if err != nil {
		t.Fatalf("RecordFileTouch failed on duplicate: %v", err)
	}

	metadata, _ = store.LoadMetadata(sessionID)
	if len(metadata.FilesTouched) != 1 {
		t.Errorf("FilesTouched length = %v, want 1 (duplicate should be prevented)", len(metadata.FilesTouched))
	}
}

