func TestUninstallClaudeHook(t *testing.T) {
	tmpDir := t.TempDir()
	hookFile := filepath.Join(tmpDir, "settings.json")

	// Create settings with session hook
	settings := map[string]interface{}{
		"sessionHooks": []interface{}{
			map[string]interface{}{
				"command":    "/usr/bin/test --session-context",
				"executable": "/usr/bin/test",
			},
			map[string]interface{}{
				"command":    "/usr/bin/other",
				"executable": "/usr/bin/other",
			},
		},
	}

	data, err := json.MarshalIndent(settings, "", "  ")
	if err != nil {
		t.Fatalf("Failed to marshal settings: %v", err)
	}

	if err := os.WriteFile(hookFile, data, 0644); err != nil {
		t.Fatalf("Failed to write settings: %v", err)
	}

	// Uninstall hook
	if err := uninstallClaudeHook(hookFile); err != nil {
		t.Fatalf("uninstallClaudeHook failed: %v", err)
	}

	// Verify hook was removed
	data, err = os.ReadFile(hookFile)
	if err != nil {
		t.Fatalf("Failed to read settings: %v", err)
	}

	var updatedSettings map[string]interface{}
	if err := json.Unmarshal(data, &updatedSettings); err != nil {
		t.Fatalf("Failed to unmarshal settings: %v", err)
	}

	sessionHooksInterface, ok := updatedSettings["sessionHooks"].([]interface{})
	if !ok {
		t.Fatal("sessionHooks not found in settings")
	}

	if len(sessionHooksInterface) != 1 {
		t.Errorf("Expected 1 hook after uninstall, got %d", len(sessionHooksInterface))
	}

	// Verify the remaining hook is not the session-context hook
	remainingHook, ok := sessionHooksInterface[0].(map[string]interface{})
	if !ok {
		t.Fatal("Remaining hook is not a map")
	}

	if cmd, ok := remainingHook["command"].(string); ok && cmd == "/usr/bin/test --session-context" {
		t.Error("Session-context hook was not removed")
	}
}

