	if err != nil {
		// Expected to fail in test environment
		t.Logf("RegisterHook failed as expected in test environment: %v", err)
	}
}

func TestListHooks(t *testing.T) {
	output, err := ListHooks()
	if err != nil {
		t.Fatalf("ListHooks failed: %v", err)
	}

	if output == "" {
		t.Error("ListHooks returned empty output")
	}

	// Output should be in TOON format
	if !containsStringHelper(output, "[") {
		t.Error("ListHooks output is not in TOON format")
	}
}

// Helper function
func containsStringHelper(s, substr string) bool {
	return len(s) >= len(substr) && findSubstringHelper(s, substr)
}

func findSubstringHelper(s, substr string) bool {
	for i := 0; i <= len(s)-len(substr); i++ {
		if s[i:i+len(substr)] == substr {
			return true
		}
	}
	return false
}
