func TestResolveExecutablePath(t *testing.T) {
	// Test with absolute path
	tmpDir := t.TempDir()
	testExec := filepath.Join(tmpDir, "test-exec")
	if err := os.WriteFile(testExec, []byte("#!/bin/sh\necho test"), 0755); err != nil {
		t.Fatalf("Failed to create test executable: %v", err)
	}

	path, err := resolveExecutablePath(testExec)
	if err != nil {
		t.Fatalf("resolveExecutablePath failed: %v", err)
	}
	if path != testExec {
		t.Errorf("resolveExecutablePath = %v, want %v", path, testExec)
	}

	// Test with non-existent path
	_, err = resolveExecutablePath("/nonexistent/path")
	if err == nil {
		t.Error("resolveExecutablePath should fail for non-existent path")
	}
}

func TestGetHookFilePath(t *testing.T) {
	tests := []struct {
		name     string
		agent    AgentType
		wantErr  bool
	}{
		{
			name:    "claude agent",
			agent:   AgentClaude,
			wantErr: false,
		},
		{
			name:    "codex agent",
			agent:   AgentCodex,
			wantErr: false,
		},
		{
			name:    "unsupported agent",
			agent:   AgentType("unknown"),
			wantErr: true,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			path, err := getHookFilePath(tt.agent)
			if (err != nil) != tt.wantErr {
				t.Errorf("getHookFilePath() error = %v, wantErr %v", err, tt.wantErr)
				return
			}
			if !tt.wantErr && path == "" {
				t.Error("getHookFilePath returned empty path")
			}
		})
	}
}

func TestInstallClaudeHook(t *testing.T) {
	tmpDir := t.TempDir()
	hookFile := filepath.Join(tmpDir, "settings.json")

	config := HookConfig{
		AgentType:  AgentClaude,
		Command:    "/usr/bin/test --session-context",
		Executable: "/usr/bin/test",
		SessionEnd: true,
	}

	// Test new installation
	updated, err := installClaudeHook(hookFile, config)
	if err != nil {
		t.Fatalf("installClaudeHook failed: %v", err)
	}
	if !updated {
		t.Error("installClaudeHook should return true for new installation")
	}

	// Verify file was created
	data, err := os.ReadFile(hookFile)
	if err != nil {
		t.Fatalf("Failed to read hook file: %v", err)
	}

	var settings map[string]interface{}
	if err := json.Unmarshal(data, &settings); err != nil {
		t.Fatalf("Failed to unmarshal settings: %v", err)
	}

	sessionHooksInterface, ok := settings["sessionHooks"].([]interface{})
	if !ok {
		t.Fatal("sessionHooks not found in settings")
	}

	if len(sessionHooksInterface) != 1 {
		t.Errorf("Expected 1 hook, got %d", len(sessionHooksInterface))
	}

	// Test update with same command
	updated, err = installClaudeHook(hookFile, config)
	if err != nil {
		t.Fatalf("installClaudeHook update failed: %v", err)
	}
	// Note: installClaudeHook always returns true when it updates the file
	// even if the command is the same, because it rewrites the file
}

