package errors

import (
	"fmt"
	"strings"
)

// Translator translates dependency errors into structured CLI errors
type Translator struct {
	projectSlug string
	suggestionGenerator *SuggestionGenerator
}

// NewTranslator creates a new error translator
func NewTranslator(projectSlug string) *Translator {
	return &Translator{
		projectSlug: projectSlug,
		suggestionGenerator: NewSuggestionGenerator(projectSlug),
	}
}

// Translate translates a raw error into a structured error
func (t *Translator) Translate(err error) *StructuredError {
	if err == nil {
		return nil
	}

	// If it's already a StructuredError, return it as-is
	if structuredErr, ok := err.(*StructuredError); ok {
		return structuredErr
	}

	errorMsg := err.Error()
	lowerMsg := strings.ToLower(errorMsg)

	// Translate based on error patterns
	if t.isFileError(lowerMsg) {
		return t.translateFileError(errorMsg, lowerMsg)
	}
	if t.isNetworkError(lowerMsg) {
		return t.translateNetworkError(errorMsg, lowerMsg)
	}
	if t.isPermissionError(lowerMsg) {
		return t.translatePermissionError(errorMsg, lowerMsg)
	}
	if t.isConfigError(lowerMsg) {
		return t.translateConfigError(errorMsg, lowerMsg)
	}
	if t.isValidationError(lowerMsg) {
		return t.translateValidationError(errorMsg, lowerMsg)
	}
	if t.isExecutionError(lowerMsg) {
		return t.translateExecutionError(errorMsg, lowerMsg)
	}

	// Default to general error
	return t.translateGeneralError(errorMsg)
}

// isFileError checks if the error is a file-related error
func (t *Translator) isFileError(msg string) bool {
	filePatterns := []string{
		"no such file or directory",
		"file not found",
		"cannot find the file specified",
		"enoent",
		"is a directory",
		"not a directory",
	}
	for _, pattern := range filePatterns {
		if strings.Contains(msg, pattern) {
			return true
		}
	}
	return false
}

