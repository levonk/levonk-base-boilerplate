func TestFormatUnsupportedFormat(t *testing.T) {
	formatter := NewFormatter("test-project")
	
	err := NewStructuredError(ErrorTypeConfig, "config error", "check config")
	
	_, err := formatter.Format(err, FormatType("unsupported"))
	if err == nil {
		t.Error("Format() should return error for unsupported format type")
	}
}

func TestExitCodeMapping(t *testing.T) {
	tests := []struct {
		errorType ErrorType
		wantCode  int
	}{
		{ErrorTypeConfig, ExitConfigError},
		{ErrorTypeFile, ExitFileError},
		{ErrorTypeValidation, ExitUsage},
		{ErrorTypeGeneral, ExitError},
		{ErrorTypeNetwork, ExitError},
		{ErrorTypePermission, ExitError},
		{ErrorTypeExecution, ExitError},
		{ErrorTypePlatform, ExitError},
	}
	
	for _, tt := range tests {
		t.Run(tt.wantCode, func(t *testing.T) {
			gotCode := getExitCodeForErrorType(tt.errorType)
			if gotCode != tt.wantCode {
				t.Errorf("getExitCodeForErrorType() = %v, want %v", gotCode, tt.wantCode)
			}
		})
	}
}

