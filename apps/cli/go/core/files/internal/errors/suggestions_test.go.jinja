func TestNewSuggestionGenerator(t *testing.T) {
	generator := NewSuggestionGenerator("test-project")
	
	if generator.projectSlug != "test-project" {
		t.Errorf("Expected projectSlug 'test-project', got %v", generator.projectSlug)
	}
}

func TestGetSuggestionConfigErrors(t *testing.T) {
	generator := NewSuggestionGenerator("my-cli")
	
	tests := []struct {
		name     string
		message  string
		wantIn   string
	}{
		{
			name:    "config not found",
			message: "config file not found",
			wantIn:  "config init",
		},
		{
			name:    "invalid config",
			message: "invalid configuration",
			wantIn:  "config validate",
		},
		{
			name:    "permission error",
			message: "permission denied on config",
			wantIn:  "permission",
		},
		{
			name:    "missing config",
			message: "required config missing",
			wantIn:  "config init",
		},
	}
	
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			suggestion := generator.GetSuggestion(ErrorTypeConfig, tt.message)
			if !strings.Contains(strings.ToLower(suggestion), strings.ToLower(tt.wantIn)) {
				t.Errorf("GetSuggestion() = %v, want to contain %v", suggestion, tt.wantIn)
			}
		})
	}
}

