func TestGetSuggestionGeneralErrors(t *testing.T) {
	generator := NewSuggestionGenerator("my-cli")
	
	suggestion := generator.GetSuggestion(ErrorTypeGeneral, "some error")
	
	if suggestion == "" {
		t.Error("GetSuggestion() should return a suggestion for general errors")
	}
}

func TestFormatCommand(t *testing.T) {
	generator := NewSuggestionGenerator("my-cli")
	
	suggestion := generator.formatCommand("config init", "to create config")
	
	if !strings.Contains(suggestion, "my-cli") {
		t.Error("formatCommand should include project slug")
	}
	if !strings.Contains(suggestion, "config init") {
		t.Error("formatCommand should include command")
	}
	if !strings.Contains(suggestion, "to create config") {
		t.Error("formatCommand should include action")
	}
}

func TestFormatCommandNoProjectSlug(t *testing.T) {
	generator := NewSuggestionGenerator("")
	
	suggestion := generator.formatCommand("config init", "to create config")
	
	if strings.Contains(suggestion, "my-cli") {
		t.Error("formatCommand should not include project slug when empty")
	}
	if !strings.Contains(suggestion, "config init") {
		t.Error("formatCommand should include command even without project slug")
	}
}

func TestGetSuggestionForError(t *testing.T) {
	suggestion := GetSuggestionForError("my-cli", ErrorTypeConfig, "config not found")
	
	if suggestion == "" {
		t.Error("GetSuggestionForError should return a suggestion")
	}
	if !strings.Contains(strings.ToLower(suggestion), "config") {
		t.Error("GetSuggestionForError should return config-related suggestion")
	}
}
