package content

import (
	"context"
	"os"
	"path/filepath"
	"testing"
)

func TestNewSelector(t *testing.T) {
	ctx := context.Background()
	selector := NewSelector(ctx)

	if selector == nil {
		t.Fatal("NewSelector returned nil")
	}

	if selector.ctx != ctx {
		t.Error("Selector context not set correctly")
	}
}

func TestDetectContext(t *testing.T) {
	ctx := context.Background()
	selector := NewSelector(ctx)

	// Test in current directory
	detectedCtx, err := selector.DetectContext()
	if err != nil {
		t.Fatalf("DetectContext failed: %v", err)
	}

	if detectedCtx.WorkingDir == "" {
		t.Error("Working directory not detected")
	}

	// Test that files are detected
	if len(detectedCtx.Files) == 0 {
		t.Log("No files detected in current directory (may be empty)")
	}
}

func TestDetectProjectType(t *testing.T) {
	tests := []struct {
		filename   string
		projectType string
	}{
		{"package.json", "nodejs"},
		{"go.mod", "go"},
		{"Cargo.toml", "rust"},
		{"pom.xml", "java"},
		{"requirements.txt", "python"},
		{"pyproject.toml", "python"},
		{"setup.py", "python"},
		{"composer.json", "php"},
		{"Gemfile", "ruby"},
		{"build.gradle", "gradle"},
		{".project", "dotnet"},
		{".csproj", "dotnet"},
		{"sln", "dotnet"},
		{"unknown.txt", "unknown"},
	}

	for _, tt := range tests {
		t.Run(tt.filename, func(t *testing.T) {
			result := detectProjectType(tt.filename)
			if result != tt.projectType {
				t.Errorf("detectProjectType(%s) = %s, want %s", tt.filename, result, tt.projectType)
			}
		})
	}
}

func TestSelectContent(t *testing.T) {
	ctx := context.Background()
	selector := NewSelector(ctx)

	tests := []struct {
		name        string
		context     *Context
		expected    ContentType
	}{
		{
			name: "project directory",
			context: &Context{
				IsProjectDir: true,
				ProjectType:  "go",
			},
			expected: ContentTypeState,
		},
		{
			name: "git repository",
			context: &Context{
				IsGitRepo:   true,
				IsProjectDir: false,
			},
			expected: ContentTypeContext,
		},
		{
			name: "no context",
			context: &Context{
				IsGitRepo:   false,
				IsProjectDir: false,
			},
			expected: ContentTypeHelp,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			result := selector.SelectContent(tt.context)
			if result != tt.expected {
				t.Errorf("SelectContent() = %s, want %s", result, tt.expected)
			}
		})
	}
}

func TestGetContentDescription(t *testing.T) {
	ctx := context.Background()
	selector := NewSelector(ctx)

	tests := []struct {
		contentType ContentType
		expected    string
	}{
		{ContentTypeState, "Current state summary"},
		{ContentTypeContext, "Context-aware information"},
		{ContentTypeAggregates, "Pre-computed aggregates"},
		{ContentTypeHelp, "Usage information"},
	}

	for _, tt := range tests {
		t.Run(string(tt.contentType), func(t *testing.T) {
			result := selector.GetContentDescription(tt.contentType)
			if result != tt.expected {
				t.Errorf("GetContentDescription() = %s, want %s", result, tt.expected)
			}
		})
	}
}

func TestDetectContextInTempDir(t *testing.T) {
	// Create a temporary directory with a project file
	tmpDir := t.TempDir()
	
	// Create a go.mod file to simulate a Go project
	goModPath := filepath.Join(tmpDir, "go.mod")
	if err := os.WriteFile(goModPath, []byte("module test\n"), 0644); err != nil {
		t.Fatalf("Failed to create go.mod: %v", err)
	}

	// Change to temp directory
	originalWd, err := os.Getwd()
	if err != nil {
		t.Fatalf("Failed to get working directory: %v", err)
	}
	defer os.Chdir(originalWd)

	if err := os.Chdir(tmpDir); err != nil {
		t.Fatalf("Failed to change directory: %v", err)
	}

	ctx := context.Background()
	selector := NewSelector(ctx)
	detectedCtx, err := selector.DetectContext()
	if err != nil {
		t.Fatalf("DetectContext failed: %v", err)
	}

	if !detectedCtx.IsProjectDir {
		t.Error("Expected IsProjectDir to be true")
	}

	if detectedCtx.ProjectType != "go" {
		t.Errorf("Expected ProjectType to be 'go', got '%s'", detectedCtx.ProjectType)
	}
}

