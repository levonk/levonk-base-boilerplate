func TestNewGenerator(t *testing.T) {
	ctx := context.Background()
	generator := NewGenerator(ctx)

	if generator == nil {
		t.Fatal("NewGenerator returned nil")
	}

	if generator.ctx != ctx {
		t.Error("Generator context not set correctly")
	}
}

func TestGenerateSummary(t *testing.T) {
	ctx := context.Background()
	generator := NewGenerator(ctx)

	wd, _ := os.Getwd()
	selectorCtx := &Context{
		WorkingDir:  wd,
		IsGitRepo:   false,
		IsProjectDir: false,
		Files:       []string{"test.txt"},
	}

	summary, err := generator.GenerateSummary(selectorCtx)
	if err != nil {
		t.Fatalf("GenerateSummary failed: %v", err)
	}

	if summary.WorkingDir != wd {
		t.Errorf("Expected WorkingDir to be '%s', got '%s'", wd, summary.WorkingDir)
	}

	if summary.FileCount != 1 {
		t.Errorf("Expected FileCount to be 1, got %d", summary.FileCount)
	}

	if summary.LastModified.IsZero() {
		t.Error("Expected LastModified to be set")
	}
}

func TestGenerateSummaryWithProject(t *testing.T) {
	ctx := context.Background()
	generator := NewGenerator(ctx)

	wd, _ := os.Getwd()
	selectorCtx := &Context{
		WorkingDir:  wd,
		IsGitRepo:   true,
		IsProjectDir: true,
		ProjectType:  "go",
		Files:       []string{"go.mod", "main.go"},
	}

	summary, err := generator.GenerateSummary(selectorCtx)
	if err != nil {
		t.Fatalf("GenerateSummary failed: %v", err)
	}

	if !summary.IsGitRepo {
		t.Error("Expected IsGitRepo to be true")
	}

	if summary.ProjectType != "go" {
		t.Errorf("Expected ProjectType to be 'go', got '%s'", summary.ProjectType)
	}

	if len(summary.Suggestions) == 0 {
		t.Error("Expected suggestions to be generated")
	}
}

func TestGenerateSuggestions(t *testing.T) {
	ctx := context.Background()
	generator := NewGenerator(ctx)

	tests := []struct {
		name        string
		context     *Context
		expectSugg bool
	}{
		{
			name: "go project",
			context: &Context{
				IsProjectDir: true,
				ProjectType:  "go",
			},
			expectSugg: true,
		},
		{
			name: "nodejs project",
			context: &Context{
				IsProjectDir: true,
				ProjectType:  "nodejs",
			},
			expectSugg: true,
		},
		{
			name: "git repo",
			context: &Context{
				IsGitRepo:   true,
				IsProjectDir: false,
			},
			expectSugg: true,
		},
		{
			name: "no context",
			context: &Context{
				IsGitRepo:   false,
				IsProjectDir: false,
			},
			expectSugg: true,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			suggestions := generator.generateSuggestions(tt.context)
			if tt.expectSugg && len(suggestions) == 0 {
				t.Error("Expected suggestions to be generated")
			}
		})
	}
}

