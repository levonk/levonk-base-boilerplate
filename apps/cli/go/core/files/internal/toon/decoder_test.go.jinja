func TestDecodeTabularArray(t *testing.T) {
	decoder := NewDecoder(DefaultDecoderOptions())

	input := `[2]{id,name,role}:
  1,Alice,admin
  2,Bob,user`

	result, err := decoder.Decode(input)
	if err != nil {
		t.Fatalf("Decode() error = %v", err)
	}

	// Tabular arrays with a header at root should decode as Array
	arr, ok := result.(Array)
	if !ok {
		t.Fatalf("Decode() result is not Array, got %T", result)
	}

	if arr.Length != 2 {
		t.Errorf("Array.Length = %v, want 2", arr.Length)
	}

	if len(arr.Fields) != 3 {
		t.Errorf("Array.Fields length = %v, want 3", len(arr.Fields))
	}

	if !arr.IsTabular {
		t.Errorf("Array.IsTabular = false, want true")
	}
}

func TestDecodeObject(t *testing.T) {
	decoder := NewDecoder(DefaultDecoderOptions())

	input := `name: Alice
age: 30
admin: true`

	result, err := decoder.Decode(input)
	if err != nil {
		t.Fatalf("Decode() error = %v", err)
	}

	obj, ok := result.(Object)
	if !ok {
		t.Fatalf("Decode() result is not Object, got %T", result)
	}

	if len(obj.Fields) != 3 {
		t.Errorf("Object.Fields length = %v, want 3", len(obj.Fields))
	}

	if _, ok := obj.Fields["name"]; !ok {
		t.Errorf("Object.Fields missing 'name' key")
	}

	if _, ok := obj.Fields["age"]; !ok {
		t.Errorf("Object.Fields missing 'age' key")
	}

	if _, ok := obj.Fields["admin"]; !ok {
		t.Errorf("Object.Fields missing 'admin' key")
	}
}

