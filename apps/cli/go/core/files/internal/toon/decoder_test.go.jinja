func TestParseHeader(t *testing.T) {
	decoder := NewDecoder(DefaultDecoderOptions())

	tests := []struct {
		name          string
		input         string
		expectedKey   string
		expectedLen   int
		expectedDelim Delimiter
		expectedFields []string
	}{
		{
			name:          "simple header",
			input:         "[3]:",
			expectedKey:   "",
			expectedLen:   3,
			expectedDelim: DelimiterComma,
			expectedFields: nil,
		},
		{
			name:          "header with key",
			input:         "items[3]:",
			expectedKey:   "items",
			expectedLen:   3,
			expectedDelim: DelimiterComma,
			expectedFields: nil,
		},
		{
			name:          "header with tab delimiter",
			input:         "[3\t]:",
			expectedKey:   "",
			expectedLen:   3,
			expectedDelim: DelimiterTab,
			expectedFields: nil,
		},
		{
			name:          "header with pipe delimiter",
			input:         "[3|]:",
			expectedKey:   "",
			expectedLen:   3,
			expectedDelim: DelimiterPipe,
			expectedFields: nil,
		},
		{
			name:          "tabular header",
			input:         "[3]{id,name}:",
			expectedKey:   "",
			expectedLen:   3,
			expectedDelim: DelimiterComma,
			expectedFields: []string{"id", "name"},
		},
		{
			name:          "full header",
			input:         "items[3]{id,name}:",
			expectedKey:   "items",
			expectedLen:   3,
			expectedDelim: DelimiterComma,
			expectedFields: []string{"id", "name"},
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			result, err := decoder.parseHeader(tt.input)
			if err != nil {
				t.Fatalf("parseHeader() error = %v", err)
			}

			if result.Key != tt.expectedKey {
				t.Errorf("parseHeader().Key = %v, want %v", result.Key, tt.expectedKey)
			}

			if result.Length != tt.expectedLen {
				t.Errorf("parseHeader().Length = %v, want %v", result.Length, tt.expectedLen)
			}

			if result.Delimiter != tt.expectedDelim {
				t.Errorf("parseHeader().Delimiter = %v, want %v", result.Delimiter, tt.expectedDelim)
			}

			if len(result.Fields) != len(tt.expectedFields) {
				t.Errorf("parseHeader().Fields length = %v, want %v", len(result.Fields), len(tt.expectedFields))
			}
		})
	}
}
