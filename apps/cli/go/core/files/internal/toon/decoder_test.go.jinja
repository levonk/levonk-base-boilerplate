package toon

import (
	"testing"
)

func TestDecodePrimitive(t *testing.T) {
	decoder := NewDecoder(DefaultDecoderOptions())

	tests := []struct {
		name     string
		input    string
		expected Value
	}{
		{
			name:     "string",
			input:    "hello",
			expected: StringValue("hello"),
		},
		{
			name:     "quoted string",
			input:    `"hello world"`,
			expected: StringValue("hello world"),
		},
		{
			name:     "number",
			input:    "42",
			expected: NumberValue(42),
		},
		{
			name:     "negative number",
			input:    "-42",
			expected: NumberValue(-42),
		},
		{
			name:     "float",
			input:    "3.14",
			expected: NumberValue(3.14),
		},
		{
			name:     "true",
			input:    "true",
			expected: BoolValue(true),
		},
		{
			name:     "false",
			input:    "false",
			expected: BoolValue(false),
		},
		{
			name:     "null",
			input:    "null",
			expected: NullValue{},
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			result, err := decoder.Decode(tt.input)
			if err != nil {
				t.Fatalf("Decode() error = %v", err)
			}

			switch exp := tt.expected.(type) {
			case StringValue:
				if res, ok := result.(StringValue); !ok || string(res) != string(exp) {
					t.Errorf("Decode() = %v, want %v", result, tt.expected)
				}
			case NumberValue:
				if res, ok := result.(NumberValue); !ok || float64(res) != float64(exp) {
					t.Errorf("Decode() = %v, want %v", result, tt.expected)
				}
			case BoolValue:
				if res, ok := result.(BoolValue); !ok || bool(res) != bool(exp) {
					t.Errorf("Decode() = %v, want %v", result, tt.expected)
				}
			case NullValue:
				if _, ok := result.(NullValue); !ok {
					t.Errorf("Decode() = %v, want %v", result, tt.expected)
				}
			}
		})
	}
}

func TestDecodeInlineArray(t *testing.T) {
	decoder := NewDecoder(DefaultDecoderOptions())

	input := "[3]: hello,42,true"
	result, err := decoder.Decode(input)
	if err != nil {
		t.Fatalf("Decode() error = %v", err)
	}

	arr, ok := result.(Array)
	if !ok {
		t.Fatalf("Decode() result is not Array, got %T", result)
	}

	if arr.Length != 3 {
		t.Errorf("Array.Length = %v, want 3", arr.Length)
	}

	if len(arr.Items) != 3 {
		t.Fatalf("Array.Items length = %v, want 3", len(arr.Items))
	}
}

