package toon

import (
	"strings"
	"testing"
)

func TestComplianceTabularArray(t *testing.T) {
	// Test compliance with spec example from https://toonformat.dev
	encoder := NewEncoder(DefaultEncoderOptions())

	arr := Array{
		Length:    2,
		Delimiter: DelimiterComma,
		Fields:    []string{"id", "name", "role"},
		IsTabular: true,
		Items: []Value{
			Object{
				Fields: map[string]Value{
					"id":   NumberValue(1),
					"name": StringValue("Alice"),
					"role": StringValue("admin"),
				},
			},
			Object{
				Fields: map[string]Value{
					"id":   NumberValue(2),
					"name": StringValue("Bob"),
					"role": StringValue("user"),
				},
			},
		},
	}

	result, err := encoder.EncodeValue(arr)
	if err != nil {
		t.Fatalf("EncodeValue() error = %v", err)
	}

	// Verify header format: key[N<delim?>]{fields}:
	if !strings.Contains(result, "[2]{id,name,role}:") {
		t.Errorf("Missing correct header format")
	}

	// Verify rows are at correct indentation
	lines := strings.Split(result, "\n")
	if len(lines) < 3 {
		t.Fatalf("Expected at least 3 lines (header + 2 rows), got %d", len(lines))
	}

	// Verify row format: values separated by delimiter
	for i, line := range lines[1:3] {
		if !strings.HasPrefix(line, "  ") {
			t.Errorf("Row %d not properly indented", i)
		}
		parts := strings.Split(strings.TrimSpace(line), ",")
		if len(parts) != 3 {
			t.Errorf("Row %d has wrong number of fields: %d", i, len(parts))
		}
	}
}

func TestCompliancePrimitiveArray(t *testing.T) {
	encoder := NewEncoder(DefaultEncoderOptions())

	arr := Array{
		Length:    3,
		Delimiter: DelimiterComma,
		Items: []Value{
			StringValue("hello"),
			NumberValue(42),
			BoolValue(true),
		},
	}

	result, err := encoder.EncodeValue(arr)
	if err != nil {
		t.Fatalf("EncodeValue() error = %v", err)
	}

	// Verify inline format: [N]: v1,v2,v3
	expected := "[3]: hello,42,true"
	if result != expected {
		t.Errorf("Primitive array format incorrect: got %v, want %v", result, expected)
	}
}

func TestComplianceObjectEncoding(t *testing.T) {
	encoder := NewEncoder(DefaultEncoderOptions())

	obj := Object{
		Fields: map[string]Value{
			"name":  StringValue("Alice"),
			"age":   NumberValue(30),
			"admin": BoolValue(true),
		},
	}

	result, err := encoder.EncodeValue(obj)
	if err != nil {
		t.Fatalf("EncodeValue() error = %v", err)
	}

	// Verify key: value format for primitives
	if !strings.Contains(result, "name: Alice") {
		t.Errorf("Missing 'name: Alice' field")
	}
	if !strings.Contains(result, "age: 30") {
		t.Errorf("Missing 'age: 30' field")
	}
	if !strings.Contains(result, "admin: true") {
		t.Errorf("Missing 'admin: true' field")
	}
}

func TestComplianceStringQuoting(t *testing.T) {
	encoder := NewEncoder(DefaultEncoderOptions())

	tests := []struct {
		name     string
		input    StringValue
		shouldBeQuoted bool
	}{
		{
			name:           "simple alphanumeric",
			input:          "hello",
			shouldBeQuoted: false,
		},
		{
			name:           "with space",
			input:          "hello world",
			shouldBeQuoted: true,
		},
		{
			name:           "with comma",
			input:          "hello,world",
			shouldBeQuoted: true,
		},
		{
			name:           "with colon",
			input:          "hello:world",
			shouldBeQuoted: true,
		},
		{
			name:           "with tab",
			input:          "hello\tworld",
			shouldBeQuoted: true,
		},
		{
			name:           "with pipe",
			input:          "hello|world",
			shouldBeQuoted: true,
		},
		{
			name:           "reserved word true",
			input:          "true",
			shouldBeQuoted: true,
		},
		{
			name:           "reserved word false",
			input:          "false",
			shouldBeQuoted: true,
		},
		{
			name:           "reserved word null",
			input:          "null",
			shouldBeQuoted: true,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			result := encoder.encodeString(string(tt.input))
			isQuoted := strings.HasPrefix(result, `"`) && strings.HasSuffix(result, `"`)
			if isQuoted != tt.shouldBeQuoted {
				t.Errorf("String quoting incorrect: %v (quoted=%v, want quoted=%v)", result, isQuoted, tt.shouldBeQuoted)
			}
		})
	}
}

func TestComplianceEscapeSequences(t *testing.T) {
	encoder := NewEncoder(DefaultEncoderOptions())

	tests := []struct {
		name     string
		input    string
		expected string
	}{
		{
			name:     "backslash",
			input:    "hello\\world",
			expected: `hello\\world`,
		},
		{
			name:     "quote",
			input:    `hello"world`,
			expected: `hello\"world`,
		},
		{
			name:     "newline",
			input:    "hello\nworld",
			expected: `hello\nworld`,
		},
		{
			name:     "carriage return",
			input:    "hello\rworld",
			expected: `hello\rworld`,
		},
		{
			name:     "tab",
			input:    "hello\tworld",
			expected: `hello\tworld`,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			result := encoder.quoteString(tt.input)
			if !strings.Contains(result, tt.expected) {
				t.Errorf("Escape sequence incorrect: got %v, want to contain %v", result, tt.expected)
			}
		})
	}
}

func TestComplianceNumberFormatting(t *testing.T) {
	encoder := NewEncoder(DefaultEncoderOptions())

	tests := []struct {
		name     string
		input    NumberValue
		expected string
	}{
		{
			name:     "canonical decimal",
			input:    42,
			expected: "42",
		},
		{
			name:     "decimal in range",
			input:    3.14,
			expected: "3.14",
		},
		{
			name:     "small number",
			input:    1e-7,
			expected: "1e-07",
		},
		{
			name:     "large number",
			input:    1e21,
			expected: "1e+21",
		},
		{
			name:     "zero",
			input:    0,
			expected: "0",
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			result := encoder.encodeNumber(float64(tt.input))
			if result != tt.expected {
				t.Errorf("Number formatting incorrect: got %v, want %v", result, tt.expected)
			}
		})
	}
}

func TestComplianceKeyEncoding(t *testing.T) {
	encoder := NewEncoder(DefaultEncoderOptions())

	tests := []struct {
		name     string
		input    string
		shouldBeQuoted bool
	}{
		{
			name:           "simple key",
			input:          "name",
			shouldBeQuoted: false,
		},
		{
			name:           "key with underscore",
			input:          "user_name",
			shouldBeQuoted: false,
		},
		{
			name:           "key with dot",
			input:          "user.name",
			shouldBeQuoted: false,
		},
		{
			name:           "key starting with underscore",
			input:          "_private",
			shouldBeQuoted: false,
		},
		{
			name:           "key with space",
			input:          "user name",
			shouldBeQuoted: true,
		},
		{
			name:           "key starting with number",
			input:          "1name",
			shouldBeQuoted: true,
		},
		{
			name:           "key with special char",
			input:          "user-name",
			shouldBeQuoted: true,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			result := encoder.encodeKey(tt.input)
			isQuoted := strings.HasPrefix(result, `"`) && strings.HasSuffix(result, `"`)
			if isQuoted != tt.shouldBeQuoted {
				t.Errorf("Key quoting incorrect: %v (quoted=%v, want quoted=%v)", result, isQuoted, tt.shouldBeQuoted)
			}
		})
	}
}

func TestComplianceEmptyArray(t *testing.T) {
	encoder := NewEncoder(DefaultEncoderOptions())

	arr := Array{Length: 0}
	result, err := encoder.EncodeValue(arr)
	if err != nil {
		t.Fatalf("EncodeValue() error = %v", err)
	}

	// Empty arrays should use [] form
	if result != "[]" {
		t.Errorf("Empty array should be [], got %v", result)
	}
}

