func TestComplianceHeaderSyntax(t *testing.T) {
	encoder := NewEncoder(DefaultEncoderOptions())

	tests := []struct {
		name          string
		length        int
		delim         Delimiter
		fields        []string
		expectedIn    string
	}{
		{
			name:       "comma delimiter",
			length:     3,
			delim:      DelimiterComma,
			fields:     nil,
			expectedIn: "[3]:",
		},
		{
			name:       "tab delimiter",
			length:     3,
			delim:      DelimiterTab,
			fields:     nil,
			expectedIn: "[3\t]:",
		},
		{
			name:       "pipe delimiter",
			length:     3,
			delim:      DelimiterPipe,
			fields:     nil,
			expectedIn: "[3|]:",
		},
		{
			name:       "with fields",
			length:     3,
			delim:      DelimiterComma,
			fields:     []string{"id", "name"},
			expectedIn: "[3]{id,name}:",
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			result := encoder.buildHeader("", tt.length, tt.delim, tt.fields)
			if !strings.Contains(result, tt.expectedIn) {
				t.Errorf("Header syntax incorrect: got %v, want to contain %v", result, tt.expectedIn)
			}
		})
	}
}

func TestComplianceIndentation(t *testing.T) {
	encoder := NewEncoder(EncoderOptions{IndentSpaces: 2})

	obj := Object{
		Fields: map[string]Value{
			"outer": Object{
				Fields: map[string]Value{
					"inner": StringValue("value"),
				},
			},
		},
	}

	result, err := encoder.EncodeValue(obj)
	if err != nil {
		t.Fatalf("EncodeValue() error = %v", err)
	}

	lines := strings.Split(result, "\n")

	// First line should not be indented
	if strings.HasPrefix(lines[0], " ") {
		t.Errorf("First line should not be indented")
	}

	// Nested lines should be indented
	for i, line := range lines[1:] {
		if line != "" && !strings.HasPrefix(line, "  ") {
			t.Errorf("Line %d should be indented with 2 spaces", i+1)
		}
	}
}
