package toon

import (
	"testing"
)

func TestEncodeString(t *testing.T) {
	encoder := NewEncoder(DefaultEncoderOptions())

	tests := []struct {
		name     string
		input    StringValue
		expected string
	}{
		{
			name:     "simple string",
			input:    "hello",
			expected: "hello",
		},
		{
			name:     "string with space",
			input:    "hello world",
			expected: `"hello world"`,
		},
		{
			name:     "string with comma",
			input:    "hello,world",
			expected: `"hello,world"`,
		},
		{
			name:     "string with colon",
			input:    "hello:world",
			expected: `"hello:world"`,
		},
		{
			name:     "empty string",
			input:    "",
			expected: `""`,
		},
		{
			name:     "string with escape",
			input:    "hello\nworld",
			expected: `"hello\nworld"`,
		},
		{
			name:     "string with quote",
			input:    `hello"world`,
			expected: `"hello\"world"`,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			result, err := encoder.EncodeValue(tt.input)
			if err != nil {
				t.Fatalf("EncodeValue() error = %v", err)
			}
			if result != tt.expected {
				t.Errorf("EncodeValue() = %v, want %v", result, tt.expected)
			}
		})
	}
}

