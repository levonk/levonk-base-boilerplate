package toon

import (
	"encoding/json"
	"strconv"
	"strings"
	"testing"
)

func BenchmarkEncodeString(b *testing.B) {
	encoder := NewEncoder(DefaultEncoderOptions())
	value := StringValue("hello world")

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		_, _ = encoder.EncodeValue(value)
	}
}

func BenchmarkEncodeNumber(b *testing.B) {
	encoder := NewEncoder(DefaultEncoderOptions())
	value := NumberValue(42.5)

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		_, _ = encoder.EncodeValue(value)
	}
}

func BenchmarkEncodeBool(b *testing.B) {
	encoder := NewEncoder(DefaultEncoderOptions())
	value := BoolValue(true)

	b.ResetTimer()
	for i := 0; i < b.N; i++ {
		_, _ = encoder.EncodeValue(value)
