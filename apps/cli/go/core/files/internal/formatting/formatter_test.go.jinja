func TestFormatterWithTruncation(t *testing.T) {
	// Test that truncation is applied when fullFlag is false
	formatter := NewFormatter(ModeAgent, false, "", false, false)

	// Create a long string
	longString := string(make([]byte, 2000))

	// Format the value
	result, err := formatter.FormatValue(longString)
	if err != nil {
		t.Fatalf("FormatValue() error = %v", err)
	}

	// Result should be truncated
	if len(result) >= len(longString) {
		t.Errorf("Expected truncated result, got length %d (original %d)", len(result), len(longString))
	}
}

func TestFormatterWithFullFlag(t *testing.T) {
	// Test that truncation is disabled when fullFlag is true
	formatter := NewFormatter(ModeAgent, false, "", false, true)

	// Create a long string
	longString := string(make([]byte, 2000))

	// Format the value
	result, err := formatter.FormatValue(longString)
	if err != nil {
		t.Fatalf("FormatValue() error = %v", err)
	}

	// Result should not be truncated
	if len(result) != len(longString) {
		t.Errorf("Expected full result with --full flag, got length %d (original %d)", len(result), len(longString))
	}
}

