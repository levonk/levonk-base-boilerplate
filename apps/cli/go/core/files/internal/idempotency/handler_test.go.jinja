package idempotency

import (
	"context"
	"os"
	"path/filepath"
	"testing"
)

// MockLogger for testing
type MockLogger struct {
	messages []string
}

func (m *MockLogger) Info(format string, args ...interface{}) {
	m.messages = append(m.messages, format)
}

func (m *MockLogger) Debug(format string, args ...interface{}) {
	m.messages = append(m.messages, format)
}

func TestCheckFileExists(t *testing.T) {
	// Test with existing file
	tmpDir := t.TempDir()
	existingFile := filepath.Join(tmpDir, "existing.txt")
	os.WriteFile(existingFile, []byte("test"), 0644)

	state, err := CheckFileExists(existingFile)
	if err != nil {
		t.Fatalf("CheckFileExists failed: %v", err)
	}
	if !state.Exists {
		t.Error("Expected file to exist")
	}

	// Test with non-existing file
	nonExisting := filepath.Join(tmpDir, "non-existing.txt")
	state, err = CheckFileExists(nonExisting)
	if err != nil {
		t.Fatalf("CheckFileExists failed: %v", err)
	}
	if state.Exists {
		t.Error("Expected file to not exist")
	}
}

func TestCheckDirectoryExists(t *testing.T) {
	// Test with existing directory
	tmpDir := t.TempDir()

	state, err := CheckDirectoryExists(tmpDir)
	if err != nil {
		t.Fatalf("CheckDirectoryExists failed: %v", err)
	}
	if !state.Exists {
		t.Error("Expected directory to exist")
	}

	// Test with non-existing directory
	nonExisting := filepath.Join(tmpDir, "non-existing")
	state, err = CheckDirectoryExists(nonExisting)
	if err != nil {
		t.Fatalf("CheckDirectoryExists failed: %v", err)
	}
	if state.Exists {
		t.Error("Expected directory to not exist")
	}

	// Test with file instead of directory
	filePath := filepath.Join(tmpDir, "file.txt")
	os.WriteFile(filePath, []byte("test"), 0644)
	state, err = CheckDirectoryExists(filePath)
	if err == nil {
		t.Error("Expected error for file path")
	}
}

func TestCheckFileContains(t *testing.T) {
	tmpDir := t.TempDir()
	filePath := filepath.Join(tmpDir, "test.txt")
	content := "test content"
	os.WriteFile(filePath, []byte(content), 0644)

	// Test with existing content
	state, err := CheckFileContains(filePath, "test")
	if err != nil {
		t.Fatalf("CheckFileContains failed: %v", err)
	}
	if !state.Exists {
		t.Error("Expected file to exist")
	}
	contains, ok := state.Value.(bool)
	if !ok || !contains {
		t.Error("Expected file to contain content")
	}

	// Test with non-existing content
	state, err = CheckFileContains(filePath, "non-existing")
	if err != nil {
		t.Fatalf("CheckFileContains failed: %v", err)
	}
	contains, ok = state.Value.(bool)
	if !ok || contains {
		t.Error("Expected file to not contain content")
	}

	// Test with non-existing file
	nonExisting := filepath.Join(tmpDir, "non-existing.txt")
	state, err = CheckFileContains(nonExisting, "test")
	if err != nil {
		t.Fatalf("CheckFileContains failed: %v", err)
	}
	if state.Exists {
		t.Error("Expected file to not exist")
	}
}

func TestIdempotentOperation_Skip(t *testing.T) {
	logger := &MockLogger{}
	handler := NewHandler(logger)
	ctx := context.Background()

	checkCalled := false
	applyCalled := false

	result, err := handler.IdempotentOperation(
		ctx,
		func() (State, error) {
			checkCalled = true
			return State{Exists: true, Value: "test"}, nil
		},
		func(State) bool { return true },
		func() error {
			applyCalled = true
			return nil
		},
		func(State) string { return "Already exists" },
		func() string { return "Created" },
	)

	if err != nil {
		t.Fatalf("IdempotentOperation failed: %v", err)
	}
	if !checkCalled {
		t.Error("Expected checkState to be called")
	}
	if applyCalled {
		t.Error("Expected applyChange to not be called when state is desired")
	}
	if !result.Skipped {
		t.Error("Expected operation to be skipped")
	}
	if result.ActionPerformed {
		t.Error("Expected ActionPerformed to be false")
	}
	if len(logger.messages) == 0 {
		t.Error("Expected logger message")
	}
}

func TestIdempotentOperation_Apply(t *testing.T) {
	logger := &MockLogger{}
	handler := NewHandler(logger)
	ctx := context.Background()

	checkCalled := false
	applyCalled := false

	result, err := handler.IdempotentOperation(
		ctx,
		func() (State, error) {
			checkCalled = true
			return State{Exists: false}, nil
		},
		func(State) bool { return false },
		func() error {
			applyCalled = true
			return nil
		},
		func(State) string { return "Already exists" },
		func() string { return "Created" },
	)

	if err != nil {
		t.Fatalf("IdempotentOperation failed: %v", err)
	}
	if !checkCalled {
		t.Error("Expected checkState to be called")
	}
	if !applyCalled {
		t.Error("Expected applyChange to be called when state is not desired")
	}
	if result.Skipped {
		t.Error("Expected operation to not be skipped")
	}
	if !result.ActionPerformed {
		t.Error("Expected ActionPerformed to be true")
	}
}

func TestIdempotentOperation_CheckError(t *testing.T) {
	logger := &MockLogger{}
	handler := NewHandler(logger)
