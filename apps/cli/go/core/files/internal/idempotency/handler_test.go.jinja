	_, err := handler.IdempotentOperation(
		ctx,
		func() (State, error) {
			return State{}, os.ErrNotExist
		},
		func(State) bool { return false },
		func() error { return nil },
		func(State) string { return "Skip" },
		func() string { return "Success" },
	)

	if err == nil {
		t.Error("Expected error from checkState failure")
	}
}

