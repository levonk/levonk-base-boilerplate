func TestEnsureDirectory(t *testing.T) {
	logger := &MockLogger{}
	handler := NewHandler(logger)
	ctx := context.Background()
	tmpDir := t.TempDir()
	newDir := filepath.Join(tmpDir, "newdir")

	// First call should create directory
	result, err := handler.EnsureDirectory(ctx, newDir)
	if err != nil {
		t.Fatalf("EnsureDirectory failed: %v", err)
	}
	if result.Skipped {
		t.Error("Expected directory to be created on first call")
	}
	if !result.ActionPerformed {
		t.Error("Expected ActionPerformed to be true")
	}

	// Second call should skip
	result, err = handler.EnsureDirectory(ctx, newDir)
	if err != nil {
		t.Fatalf("EnsureDirectory failed: %v", err)
	}
	if !result.Skipped {
		t.Error("Expected directory creation to be skipped on second call")
	}
	if result.ActionPerformed {
		t.Error("Expected ActionPerformed to be false on skip")
	}
}

func TestEnsureFileExists(t *testing.T) {
	logger := &MockLogger{}
	handler := NewHandler(logger)
	ctx := context.Background()
	tmpDir := t.TempDir()
	newFile := filepath.Join(tmpDir, "newfile.txt")
	content := []byte("test content")

	// First call should create file
	result, err := handler.EnsureFileExists(ctx, newFile, content, 0644)
	if err != nil {
		t.Fatalf("EnsureFileExists failed: %v", err)
	}
	if result.Skipped {
		t.Error("Expected file to be created on first call")
	}

	// Verify file content
	data, err := os.ReadFile(newFile)
	if err != nil {
		t.Fatalf("Failed to read file: %v", err)
	}
	if string(data) != string(content) {
		t.Error("File content mismatch")
	}

	// Second call should skip
	result, err = handler.EnsureFileExists(ctx, newFile, content, 0644)
	if err != nil {
		t.Fatalf("EnsureFileExists failed: %v", err)
	}
	if !result.Skipped {
		t.Error("Expected file creation to be skipped on second call")
	}
}

func TestEnsureFileContains(t *testing.T) {
	logger := &MockLogger{}
	handler := NewHandler(logger)
	ctx := context.Background()
	tmpDir := t.TempDir()
	filePath := filepath.Join(tmpDir, "test.txt")
	content := "completion script"

	// Create file without content
	os.WriteFile(filePath, []byte("initial content\n"), 0644)

	// First call should add content
	result, err := handler.EnsureFileContains(ctx, filePath, content)
	if err != nil {
		t.Fatalf("EnsureFileContains failed: %v", err)
	}
	if result.Skipped {
		t.Error("Expected content to be added on first call")
	}

	// Verify content was added
	data, err := os.ReadFile(filePath)
	if err != nil {
		t.Fatalf("Failed to read file: %v", err)
	}
	fileContent := string(data)
	if !contains(fileContent, content) {
		t.Error("Expected file to contain content")
	}

	// Second call should skip
	result, err = handler.EnsureFileContains(ctx, filePath, content)
	if err != nil {
		t.Fatalf("EnsureFileContains failed: %v", err)
	}
	if !result.Skipped {
		t.Error("Expected content addition to be skipped on second call")
	}
}

func TestHelperFunctions(t *testing.T) {
	// Test IsFileExists
	if !IsFileExists(State{Exists: true}) {
		t.Error("IsFileExists should return true for existing state")
	}
	if IsFileExists(State{Exists: false}) {
		t.Error("IsFileExists should return false for non-existing state")
	}

	// Test IsDirectoryExists
	if !IsDirectoryExists(State{Exists: true}) {
		t.Error("IsDirectoryExists should return true for existing state")
	}
	if IsDirectoryExists(State{Exists: false}) {
		t.Error("IsDirectoryExists should return false for non-existing state")
	}

	// Test IsFileContains
	if !IsFileContains(State{Value: true}) {
		t.Error("IsFileContains should return true for true value")
	}
	if IsFileContains(State{Value: false}) {
		t.Error("IsFileContains should return false for false value")
	}
	if IsFileContains(State{Value: "string"}) {
		t.Error("IsFileContains should return false for non-bool value")
	}

	// Test IsProcessRunning
	if !IsProcessRunning(State{Exists: true}) {
		t.Error("IsProcessRunning should return true for existing state")
	}
	if IsProcessRunning(State{Exists: false}) {
		t.Error("IsProcessRunning should return false for non-existing state")
	}
}

func TestSkipMessages(t *testing.T) {
	state := State{Value: "/path/to/file"}

	msg := SkipMessageFileExists(state)
	if msg != "File already exists: /path/to/file" {
		t.Errorf("Unexpected skip message: %s", msg)
	}

	msg = SkipMessageDirectoryExists(state)
	if msg != "Directory already exists: /path/to/file" {
		t.Errorf("Unexpected skip message: %s", msg)
	}

	stateWithMetadata := State{
		Value: true,
		Metadata: map[string]interface{}{
			"path": "/path/to/config",
		},
	}
	msg = SkipMessageFileContains(stateWithMetadata)
	if msg != "Completions already installed in /path/to/config" {
		t.Errorf("Unexpected skip message: %s", msg)
	}

	stateWithPID := State{Value: 1234}
	msg = SkipMessageProcessRunning(stateWithPID)
	if msg != "Process already running (PID: 1234)" {
		t.Errorf("Unexpected skip message: %s", msg)
	}
}

func TestSuccessMessages(t *testing.T) {
	msg := SuccessMessageFileCreated("/path/to/file")()
	if msg != "File created: /path/to/file" {
		t.Errorf("Unexpected success message: %s", msg)
	}

	msg = SuccessMessageDirectoryCreated("/path/to/dir")()
	if msg != "Directory created: /path/to/dir" {
		t.Errorf("Unexpected success message: %s", msg)
	}

	msg = SuccessMessageCompletionsInstalled("/path/to/config")()
	if msg != "Completions installed to /path/to/config" {
		t.Errorf("Unexpected success message: %s", msg)
	}

	msg = SuccessMessageProcessStarted(1234)()
	if msg != "Process started (PID: 1234)" {
		t.Errorf("Unexpected success message: %s", msg)
	}
}

// Helper function to check if string contains substring
func contains(s, substr string) bool {
	return len(s) >= len(substr) && (s == substr || len(s) > len(substr) && findSubstring(s, substr))
}

func findSubstring(s, substr string) bool {
	for i := 0; i <= len(s)-len(substr); i++ {
		if s[i:i+len(substr)] == substr {
			return true
		}
	}
	return false
}
