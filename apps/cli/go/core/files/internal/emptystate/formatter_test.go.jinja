package emptystate

import (
	"testing"
)

func TestFormatter_Format(t *testing.T) {
	formatter := NewFormatter()
	ctx := Context{
		Command:    "list",
		Resource:   "items",
		Filters:    map[string]string{"status": "active"},
		Scope:      "all",
		TotalCount: 100,
	}
	es := &EmptyState{
		IsEmpty:  true,
		Context:  ctx,
		Message:  "No results found for items with filters: [status=active] in scope: all (total: 100). Command executed successfully.",
		ExitCode: 0,
	}

	tests := []struct {
		name        string
		format      string
		shouldError bool
		contains    []string
	}{
		{
			name:        "TOON format",
			format:      "toon",
			shouldError: false,
			contains:    []string{"# Empty State", "message:", "context:"},
		},
		{
			name:        "JSON format",
			format:      "json",
			shouldError: false,
			contains:    []string{"\"empty\": true", "\"message\":", "\"exit_code\": 0"},
		},
		{
			name:        "human format",
			format:      "human",
			shouldError: false,
			contains:    []string{"No results found", "Resource:", "Filters:"},
		},
		{
			name:        "unknown format defaults to human",
			format:      "unknown",
			shouldError: false,
			contains:    []string{"No results found"},
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			result, err := formatter.Format(es, tt.format)
			if (err != nil) != tt.shouldError {
				t.Errorf("Format() error = %v, shouldError %v", err, tt.shouldError)
				return
			}
			for _, substr := range tt.contains {
				if !contains(result, substr) {
					t.Errorf("Format() should contain %q, got: %s", substr, result)
				}
			}
		})
	}
}

func TestFormatter_formatTOON(t *testing.T) {
	formatter := NewFormatter()
	ctx := Context{
		Command:  "list",
		Resource: "items",
		Filters:  map[string]string{"status": "active"},
	}
	es := &EmptyState{
		IsEmpty:  true,
		Context:  ctx,
		Message:  "No results found",
		ExitCode: 0,
	}

	result, err := formatter.formatTOON(es)
	if err != nil {
		t.Fatalf("formatTOON() error = %v", err)
	}

	expectedSubstrings := []string{
		"# Empty State",
		"message:",
		"context:",
		"resource:",
		"items",
		"filters:",
		"status",
		"active",
	}

	for _, substr := range expectedSubstrings {
		if !contains(result, substr) {
			t.Errorf("formatTOON() should contain %q, got: %s", substr, result)
		}
	}
}

