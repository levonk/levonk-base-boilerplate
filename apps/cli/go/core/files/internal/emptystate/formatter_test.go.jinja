func TestFormatter_formatHuman(t *testing.T) {
	formatter := NewFormatter()
	ctx := Context{
		Command:  "list",
		Resource: "items",
		Scope:    "all",
		Filters:  map[string]string{"status": "active", "type": "foo"},
	}
	es := &EmptyState{
		IsEmpty:  true,
		Context:  ctx,
		Message:  "No results found",
		ExitCode: 0,
	}

	result, err := formatter.formatHuman(es)
	if err != nil {
		t.Fatalf("formatHuman() error = %v", err)
	}

	expectedSubstrings := []string{
		"No results found",
		"Resource: items",
		"Scope: all",
		"Filters:",
		"status: active",
		"type: foo",
	}

	for _, substr := range expectedSubstrings {
		if !contains(result, substr) {
			t.Errorf("formatHuman() should contain %q, got: %s", substr, result)
		}
	}
}

func TestFormatter_Format_NonEmpty(t *testing.T) {
	formatter := NewFormatter()
	es := &EmptyState{
		IsEmpty:  false,
		ExitCode: 0,
	}

	result, err := formatter.Format(es, "json")
	if err != nil {
		t.Errorf("Format() for non-empty should not error, got: %v", err)
	}
	if result != "" {
		t.Errorf("Format() for non-empty should return empty string, got: %s", result)
	}
}
