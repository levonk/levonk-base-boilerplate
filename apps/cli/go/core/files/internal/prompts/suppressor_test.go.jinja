		})
	}
}

func TestRequireValue(t *testing.T) {
	logger := &mockLogger{}

	tests := []struct {
		name      string
		value     string
		fieldName string
		mode      Mode
		wantErr   bool
	}{
		{"valid value passes", "test-value", "field", ModeAgent, false},
		{"empty value fails", "", "field", ModeAgent, true},
		{"empty value in human mode fails", "", "field", ModeHuman, true},
		{"non-empty value in human mode passes", "value", "field", ModeHuman, false},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			ps := NewPromptSuppressor(tt.mode, false, false, logger)
			err := ps.RequireValue(tt.value, tt.fieldName)
			if (err != nil) != tt.wantErr {
				t.Errorf("RequireValue() error = %v, wantErr %v", err, tt.wantErr)
			}
		})
	}
}

