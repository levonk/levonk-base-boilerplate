package prompts

import (
	"testing"
)

// mockLogger is a simple mock for testing
type mockLogger struct {
	debugCalls []string
}

func (m *mockLogger) Debug(format string, args ...interface{}) {
	m.debugCalls = append(m.debugCalls, format)
}

func TestNewPromptSuppressor(t *testing.T) {
	logger := &mockLogger{}

	ps := NewPromptSuppressor(ModeAgent, false, false, logger)

	if ps.mode != ModeAgent {
		t.Errorf("NewPromptSuppressor() mode = %v, want %v", ps.mode, ModeAgent)
	}
	if ps.force != false {
		t.Errorf("NewPromptSuppressor() force = %v, want false", ps.force)
	}
	if ps.quiet != false {
		t.Errorf("NewPromptSuppressor() quiet = %v, want false", ps.quiet)
	}
}

func TestShouldSuppress(t *testing.T) {
	logger := &mockLogger{}

	tests := []struct {
		name     string
		mode     Mode
		force    bool
		quiet    bool
		expected bool
	}{
		{"agent mode suppresses", ModeAgent, false, false, true},
		{"human mode allows", ModeHuman, false, false, false},
		{"force flag suppresses", ModeHuman, true, false, true},
		{"quiet flag suppresses", ModeHuman, false, true, true},
		{"force in agent mode", ModeAgent, true, false, true},
		{"quiet in agent mode", ModeAgent, false, true, true},
		{"both force and quiet", ModeHuman, true, true, true},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			ps := NewPromptSuppressor(tt.mode, tt.force, tt.quiet, logger)
			result := ps.ShouldSuppress()
			if result != tt.expected {
				t.Errorf("ShouldSuppress() = %v, want %v", result, tt.expected)
			}
		})
	}
}

