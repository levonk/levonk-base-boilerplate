	}{
		{"force explanation", ModeHuman, true, false, "Prompts bypassed via --force flag"},
		{"quiet explanation", ModeHuman, false, true, "Prompts suppressed via --quiet flag (using safe default: no)"},
		{"agent mode explanation", ModeAgent, false, false, "Prompts suppressed in agent mode (non-interactive environment)"},
