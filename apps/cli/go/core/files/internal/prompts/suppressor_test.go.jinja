func TestIsAgentMode(t *testing.T) {
	logger := &mockLogger{}

	psAgent := NewPromptSuppressor(ModeAgent, false, false, logger)
	if !psAgent.IsAgentMode() {
		t.Error("IsAgentMode() should return true for agent mode")
	}

	psHuman := NewPromptSuppressor(ModeHuman, false, false, logger)
	if psHuman.IsAgentMode() {
		t.Error("IsAgentMode() should return false for human mode")
	}
}

func TestIsHumanMode(t *testing.T) {
	logger := &mockLogger{}

	psHuman := NewPromptSuppressor(ModeHuman, false, false, logger)
	if !psHuman.IsHumanMode() {
		t.Error("IsHumanMode() should return true for human mode")
	}

	psAgent := NewPromptSuppressor(ModeAgent, false, false, logger)
	if psAgent.IsHumanMode() {
		t.Error("IsHumanMode() should return false for agent mode")
	}
}

func TestSetMode(t *testing.T) {
	logger := &mockLogger{}

	ps := NewPromptSuppressor(ModeAgent, false, false, logger)
	ps.SetMode(ModeHuman)

	if ps.mode != ModeHuman {
		t.Errorf("SetMode() did not update mode, got %v, want %v", ps.mode, ModeHuman)
	}
}

func TestSetForce(t *testing.T) {
	logger := &mockLogger{}

	ps := NewPromptSuppressor(ModeHuman, false, false, logger)
	ps.SetForce(true)

	if ps.force != true {
		t.Errorf("SetForce() did not update force, got %v, want true", ps.force)
	}
}

func TestSetQuiet(t *testing.T) {
	logger := &mockLogger{}

	ps := NewPromptSuppressor(ModeHuman, false, false, logger)
	ps.SetQuiet(true)

	if ps.quiet != true {
		t.Errorf("SetQuiet() did not update quiet, got %v, want true", ps.quiet)
	}
}

