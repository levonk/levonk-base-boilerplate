func TestSuggestionRelevance(t *testing.T) {
	rule := NewDefaultRule(10)

	suggestions := rule.Generate(&Context{
		OutputState: "empty",
	})

	// Check that all suggestions have relevance scores
	for _, s := range suggestions {
		if s.Relevance <= 0 {
			t.Errorf("Expected positive relevance, got %d", s.Relevance)
		}
		if s.Relevance > 100 {
			t.Errorf("Expected relevance <= 100, got %d", s.Relevance)
		}
	}
}

func TestSuggestionFields(t *testing.T) {
	rule := NewDefaultRule(10)

	suggestions := rule.Generate(&Context{
		OutputState: "empty",
	})

	// Check that all suggestions have required fields
	for _, s := range suggestions {
		if s.Command == "" {
			t.Error("Expected non-empty command")
		}
		if s.Description == "" {
			t.Error("Expected non-empty description")
		}
	}
}

