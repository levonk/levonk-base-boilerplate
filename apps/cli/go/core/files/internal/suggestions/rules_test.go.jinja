package suggestions

import (
	"testing"
)

func TestNewDefaultRule(t *testing.T) {
	rule := NewDefaultRule(10)

	if rule == nil {
		t.Fatal("NewDefaultRule returned nil")
	}

	if rule.priority != 10 {
		t.Errorf("Expected priority 10, got %d", rule.priority)
	}
}

func TestDefaultRuleGenerate(t *testing.T) {
	rule := NewDefaultRule(10)

	// Test with empty context
	suggestions := rule.Generate(&Context{})
	if len(suggestions) == 0 {
		t.Error("Expected at least one suggestion (help)")
	}

	// Test with empty output state
	suggestions = rule.Generate(&Context{
		OutputState: "empty",
	})
	if len(suggestions) == 0 {
		t.Error("Expected suggestions for empty state")
	}

	// Check for create suggestion
	found := false
	for _, s := range suggestions {
		if s.Command == "{{ project_slug }} create" {
			found = true
			break
		}
	}
	if !found {
		t.Error("Expected create suggestion for empty state")
	}

	// Test with open output state
	suggestions = rule.Generate(&Context{
		OutputState: "open",
	})
	found = false
	for _, s := range suggestions {
		if s.Command == "{{ project_slug }} close --all" {
			found = true
			break
		}
	}
	if !found {
		t.Error("Expected close suggestion for open state")
	}

	// Test with git repository
	suggestions = rule.Generate(&Context{
		IsGitRepo: true,
	})
	found = false
	for _, s := range suggestions {
		if s.Command == "{{ project_slug }} git status" {
			found = true
			break
		}
	}
	if !found {
		t.Error("Expected git status suggestion for git repo")
	}

	// Test with project directory
	suggestions = rule.Generate(&Context{
		IsProjectDir: true,
		ProjectType:  "go",
	})
	found = false
	for _, s := range suggestions {
		if s.Command == "{{ project_slug }} go test" {
			found = true
			break
		}
	}
	if !found {
		t.Error("Expected go test suggestion for Go project")
	}
}

