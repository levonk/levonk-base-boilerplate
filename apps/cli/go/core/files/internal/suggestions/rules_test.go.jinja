}

func TestContextualRuleGenerate(t *testing.T) {
	rule := NewContextualRule(10)

	// Test with view command
	suggestions := rule.Generate(&Context{
		Command: "view",
		Flags:   map[string]string{"format": "json"},
	})
	if len(suggestions) == 0 {
		t.Error("Expected suggestions for view command")
	}

	// Check for edit suggestion with flags
	found := false
	for _, s := range suggestions {
		if s.Command == "{{ project_slug }} edit <id> --format=json" {
			found = true
			break
		}
	}
	if !found {
		t.Error("Expected edit suggestion with carried-forward flags")
	}

	// Test with edit command
	suggestions = rule.Generate(&Context{
		Command: "edit",
		Flags:   map[string]string{"force": "true"},
	})
	found = false
	for _, s := range suggestions {
		if s.Command == "{{ project_slug }} save --force=true" {
			found = true
			break
		}
	}
	if !found {
		t.Error("Expected save suggestion for edit command")
	}

	// Test with project directory
	suggestions = rule.Generate(&Context{
		IsProjectDir: true,
		ProjectType:  "nodejs",
	})
	found = false
	for _, s := range suggestions {
		if s.Command == "{{ project_slug }} build --type=nodejs" {
			found = true
			break
		}
	}
	if !found {
		t.Error("Expected build suggestion for project")
	}
}

