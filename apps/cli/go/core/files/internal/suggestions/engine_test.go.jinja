func TestFormatSuggestionsEmpty(t *testing.T) {
	ctx := context.Background()
	engine := NewEngine(ctx, 4)

	suggestions := []Suggestion{}

	// Test TOON format
	output, err := engine.FormatSuggestions(suggestions, "toon")
	if err != nil {
		t.Fatalf("FormatSuggestions failed: %v", err)
	}
	if output != "help[]" {
		t.Errorf("Expected 'help[]' for empty suggestions, got '%s'", output)
	}

	// Test human format
	output, err = engine.FormatSuggestions(suggestions, "human")
	if err != nil {
		t.Fatalf("FormatSuggestions failed: %v", err)
	}
	if output != "" {
		t.Errorf("Expected empty string for human format with no suggestions, got '%s'", output)
	}
}

func TestSuggestionRelevanceSorting(t *testing.T) {
	ctx := context.Background()
	engine := NewEngine(ctx, 10)

	rule := NewDefaultRule(10)
	engine.AddRule(rule)

	suggestions := engine.Generate(&Context{
		OutputState: "empty",
		IsGitRepo:   true,
	})

	// Check that suggestions are sorted by relevance (highest first)
	for i := 0; i < len(suggestions)-1; i++ {
		if suggestions[i].Relevance < suggestions[i+1].Relevance {
			t.Errorf("Suggestions not sorted by relevance: %d < %d at index %d",
				suggestions[i].Relevance, suggestions[i+1].Relevance, i)
		}
	}
}

