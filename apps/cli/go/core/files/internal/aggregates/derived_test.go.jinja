func TestComputeSummary(t *testing.T) {
	data := map[string]interface{}{
		"total":          float64(3),
		"passed":         float64(3),
		"comment_count":  float64(7),
		"total_tasks":    float64(10),
		"completed_tasks": float64(5),
		"status":         "success",
		"healthy":        true,
	}

	ds := ComputeSummary(data)
	fields := ds.GetFields()

	if len(fields) != 5 {
		t.Errorf("Expected 5 derived fields, got %d", len(fields))
	}

	// Check that all expected fields are present
	fieldMap := make(map[string]string)
	for _, field := range fields {
		fieldMap[field.Name] = field.Value
	}

	expectedFields := map[string]string{
		"tests":   "3/3 passed",
		"comments": "7 comments",
		"tasks":   "5/10 completed",
		"build":   "✓ passed",
		"health":  "healthy",
	}

	for name, expectedValue := range expectedFields {
		if value, ok := fieldMap[name]; !ok {
			t.Errorf("Expected field '%s' not found", name)
		} else if value != expectedValue {
			t.Errorf("Field '%s': expected '%s', got '%s'", name, expectedValue, value)
		}
	}
}

func TestComputeSummaryEmpty(t *testing.T) {
	data := map[string]interface{}{
		"unrelated":  "value",
	}

	ds := ComputeSummary(data)
	if len(ds.GetFields()) != 0 {
		t.Errorf("Expected no derived fields for empty data, got %d", len(ds.GetFields()))
	}
}
