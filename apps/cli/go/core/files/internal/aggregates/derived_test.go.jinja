package aggregates

import (
	"testing"
)

func TestNewDerivedStatus(t *testing.T) {
	ds := NewDerivedStatus()
	if ds == nil {
		t.Fatal("NewDerivedStatus returned nil")
	}
	if len(ds.GetFields()) != 0 {
		t.Errorf("Expected empty fields, got %d", len(ds.GetFields()))
	}
}

func TestAddField(t *testing.T) {
	ds := NewDerivedStatus()
	ds.AddField("status", "passed")

	fields := ds.GetFields()
	if len(fields) != 1 {
		t.Fatalf("Expected 1 field, got %d", len(fields))
	}

	if fields[0].Name != "status" {
		t.Errorf("Expected field name 'status', got '%s'", fields[0].Name)
	}

	if fields[0].Value != "passed" {
		t.Errorf("Expected field value 'passed', got '%s'", fields[0].Value)
	}
}

func TestFormat(t *testing.T) {
	ds := NewDerivedStatus()
	ds.AddField("tests", "3/3 passed")
	ds.AddField("comments", "7 comments")

	expected := "tests: 3/3 passed, comments: 7 comments"
	actual := ds.Format()

	if actual != expected {
		t.Errorf("Expected format '%s', got '%s'", expected, actual)
	}
}

func TestFormatEmpty(t *testing.T) {
	ds := NewDerivedStatus()
	if ds.Format() != "" {
		t.Error("Expected empty string for no fields")
	}
}

