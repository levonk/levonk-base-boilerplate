func TestComputeBuildStatus(t *testing.T) {
	tests := []struct {
		status   string
		expected string
	}{
		{"success", "✓ passed"},
		{"passed", "✓ passed"},
		{"failure", "✗ failed"},
		{"failed", "✗ failed"},
		{"running", "⟳ running"},
		{"pending", "○ pending"},
		{"unknown", "unknown"},
	}

	for _, tt := range tests {
		data := map[string]interface{}{
			"status": tt.status,
		}
		result := ComputeBuildStatus(data)
		if result != tt.expected {
			t.Errorf("For status '%s', expected '%s', got '%s'", tt.status, tt.expected, result)
		}
	}
}

