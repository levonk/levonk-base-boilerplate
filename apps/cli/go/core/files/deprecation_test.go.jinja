func TestNewDeprecationManager(t *testing.T) {
	logger := NewLogger("test")
	dm := NewDeprecationManager(logger)

	if dm == nil {
		t.Fatal("NewDeprecationManager returned nil")
	}

	if dm.policies == nil {
		t.Error("policies map is not initialized")
	}

	if dm.logger == nil {
		t.Error("logger is not set")
	}
}

func TestRegisterPolicy(t *testing.T) {
	logger := NewLogger("test")
	dm := NewDeprecationManager(logger)

	// Test valid policy
	policy := &DeprecationPolicy{
		FeatureName:     "test-feature",
		DeprecatedSince: time.Now().Add(-24 * time.Hour),
		RemovalDate:     time.Now().Add(6 * 30 * 24 * time.Hour),
		WarningMessage:  "This feature is deprecated",
	}

	err := dm.RegisterPolicy(policy)
	if err != nil {
		t.Errorf("RegisterPolicy failed: %v", err)
	}

	// Test empty feature name
	invalidPolicy := &DeprecationPolicy{
		FeatureName: "",
	}

	err = dm.RegisterPolicy(invalidPolicy)
	if err == nil {
		t.Error("RegisterPolicy should fail with empty feature name")
	}

	// Test removal date before deprecation date
	invalidPolicy2 := &DeprecationPolicy{
		FeatureName:     "invalid-feature",
		DeprecatedSince: time.Now().Add(6 * 30 * 24 * time.Hour),
		RemovalDate:     time.Now().Add(-24 * time.Hour),
	}

	err = dm.RegisterPolicy(invalidPolicy2)
	if err == nil {
		t.Error("RegisterPolicy should fail with removal date before deprecation date")
	}
}

func TestGetStatus(t *testing.T) {
	logger := NewLogger("test")
	dm := NewDeprecationManager(logger)

	now := time.Now()

	// Test active feature (not deprecated yet)
	activePolicy := &DeprecationPolicy{
		FeatureName:     "active-feature",
		DeprecatedSince: now.Add(24 * time.Hour),
		RemovalDate:     now.Add(6 * 30 * 24 * time.Hour),
	}
	dm.RegisterPolicy(activePolicy)

	status := dm.GetStatus("active-feature")
	if status != StatusActive {
		t.Errorf("Expected StatusActive, got %v", status)
	}

	// Test deprecated feature
	deprecatedPolicy := &DeprecationPolicy{
		FeatureName:     "deprecated-feature",
		DeprecatedSince: now.Add(-24 * time.Hour),
		RemovalDate:     now.Add(6 * 30 * 24 * time.Hour),
	}
	dm.RegisterPolicy(deprecatedPolicy)

	status = dm.GetStatus("deprecated-feature")
	if status != StatusDeprecated {
		t.Errorf("Expected StatusDeprecated, got %v", status)
	}

	// Test removed feature
	removedPolicy := &DeprecationPolicy{
		FeatureName:     "removed-feature",
		DeprecatedSince: now.Add(-12 * 30 * 24 * time.Hour),
		RemovalDate:     now.Add(-24 * time.Hour),
	}
	dm.RegisterPolicy(removedPolicy)

	status = dm.GetStatus("removed-feature")
	if status != StatusRemoved {
		t.Errorf("Expected StatusRemoved, got %v", status)
	}

	// Test non-existent feature
	status = dm.GetStatus("non-existent-feature")
	if status != StatusActive {
		t.Errorf("Expected StatusActive for non-existent feature, got %v", status)
	}
}

func TestCheckAndWarn(t *testing.T) {
	logger := NewLogger("test")
	dm := NewDeprecationManager(logger)
	dm.SetQuietMode(true) // Suppress actual output during tests

	now := time.Now()

	// Test deprecated feature - should not return error
	deprecatedPolicy := &DeprecationPolicy{
		FeatureName:     "deprecated-feature",
		DeprecatedSince: now.Add(-24 * time.Hour),
		RemovalDate:     now.Add(6 * 30 * 24 * time.Hour),
		WarningMessage:  "This feature is deprecated",
	}
	dm.RegisterPolicy(deprecatedPolicy)

	err := dm.CheckAndWarn("deprecated-feature")
	if err != nil {
		t.Errorf("CheckAndWarn should not return error for deprecated feature: %v", err)
	}

	// Test removed feature - should return error
	removedPolicy := &DeprecationPolicy{
		FeatureName:     "removed-feature",
		DeprecatedSince: now.Add(-12 * 30 * 24 * time.Hour),
		RemovalDate:     now.Add(-24 * time.Hour),
		WarningMessage:  "This feature has been removed",
	}
	dm.RegisterPolicy(removedPolicy)

	err = dm.CheckAndWarn("removed-feature")
	if err == nil {
		t.Error("CheckAndWarn should return error for removed feature")
	}

	// Test active feature - should not return error
	activePolicy := &DeprecationPolicy{
		FeatureName:     "active-feature",
		DeprecatedSince: now.Add(24 * time.Hour),
		RemovalDate:     now.Add(6 * 30 * 24 * time.Hour),
	}
	dm.RegisterPolicy(activePolicy)

	err = dm.CheckAndWarn("active-feature")
	if err != nil {
		t.Errorf("CheckAndWarn should not return error for active feature: %v", err)
	}
}

func TestIsDeprecated(t *testing.T) {
	logger := NewLogger("test")
	dm := NewDeprecationManager(logger)

	now := time.Now()

	// Test deprecated feature
	deprecatedPolicy := &DeprecationPolicy{
		FeatureName:     "deprecated-feature",
		DeprecatedSince: now.Add(-24 * time.Hour),
		RemovalDate:     now.Add(6 * 30 * 24 * time.Hour),
	}
	dm.RegisterPolicy(deprecatedPolicy)

	if !dm.IsDeprecated("deprecated-feature") {
		t.Error("IsDeprecated should return true for deprecated feature")
	}

	// Test active feature
	activePolicy := &DeprecationPolicy{
		FeatureName:     "active-feature",
		DeprecatedSince: now.Add(24 * time.Hour),
		RemovalDate:     now.Add(6 * 30 * 24 * time.Hour),
	}
	dm.RegisterPolicy(activePolicy)

	if dm.IsDeprecated("active-feature") {
		t.Error("IsDeprecated should return false for active feature")
	}
}

