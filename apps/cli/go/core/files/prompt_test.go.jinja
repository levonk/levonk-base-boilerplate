// TestPromptBehaviorInDifferentModes tests prompt behavior across agent and human modes
func TestPromptBehaviorInDifferentModes(t *testing.T) {
	logger := NewLogger(LoggerConfig{Quiet: true})

	// Test agent mode behavior
	t.Run("Agent Mode", func(t *testing.T) {
		suppressor := prompts.NewPromptSuppressor(ModeAgent, false, false, logger)

		// In agent mode, prompts should be suppressed
		if suppressor.ShouldPrompt() {
			t.Error("Agent mode should suppress prompts")
		}

		// Result should be safe default (no)
		if suppressor.GetPromptResult() {
			t.Error("Agent mode should return safe default (no)")
		}

		// Explanation should mention agent mode
		explanation := suppressor.GetPromptExplanation()
		if !strings.Contains(explanation, "agent mode") {
			t.Errorf("Explanation should mention agent mode, got: %s", explanation)
		}
	})

	// Test human mode behavior
	t.Run("Human Mode", func(t *testing.T) {
		suppressor := prompts.NewPromptSuppressor(ModeHuman, false, false, logger)

		// In human mode, prompts should be allowed
		if !suppressor.ShouldPrompt() {
			t.Error("Human mode should allow prompts")
		}

		// Explanation should mention human mode
		explanation := suppressor.GetPromptExplanation()
		if !strings.Contains(explanation, "human mode") {
			t.Errorf("Explanation should mention human mode, got: %s", explanation)
		}
	})

	// Test force flag in human mode
	t.Run("Human Mode with Force", func(t *testing.T) {
		suppressor := prompts.NewPromptSuppressor(ModeHuman, true, false, logger)

		// Force should suppress prompts
		if suppressor.ShouldPrompt() {
			t.Error("Force flag should suppress prompts in human mode")
		}

		// Result should be true (bypass confirmation)
		if !suppressor.GetPromptResult() {
			t.Error("Force flag should return true (bypass confirmation)")
		}
	})

	// Test quiet flag in human mode
	t.Run("Human Mode with Quiet", func(t *testing.T) {
		suppressor := prompts.NewPromptSuppressor(ModeHuman, false, true, logger)

		// Quiet should suppress prompts
		if suppressor.ShouldPrompt() {
			t.Error("Quiet flag should suppress prompts in human mode")
		}

		// Result should be false (safe default)
		if suppressor.GetPromptResult() {
			t.Error("Quiet flag should return false (safe default)")
		}
	})
}
