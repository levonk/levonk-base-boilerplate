// TestPromptForConfirmation_Force tests that force flag bypasses prompt
func TestPromptForConfirmation_Force(t *testing.T) {
	cfg := PromptConfig{
		Message:  "Test prompt",
		Force:    true,
		Quiet:    false,
		DefaultYes: false,
	}

	result := PromptForConfirmation(cfg)

	if !result {
		t.Errorf("PromptForConfirmation() with force=true should return true, got %v", result)
	}
}

// TestPromptForConfirmation_Quiet tests that quiet flag returns safe default (no)
func TestPromptForConfirmation_Quiet(t *testing.T) {
	cfg := PromptConfig{
		Message:  "Test prompt",
		Force:    false,
		Quiet:    true,
		DefaultYes: false,
	}

	result := PromptForConfirmation(cfg)

	if result {
		t.Errorf("PromptForConfirmation() with quiet=true should return false (safe default), got %v", result)
	}
}

// TestPromptForConfirmation_DefaultYes tests that empty response uses default
func TestPromptForConfirmation_DefaultYes(t *testing.T) {
	tests := []struct {
		name       string
		defaultYes bool
		expected   bool
	}{
		{"default yes", true, true},
		{"default no", false, false},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			r, w, _ := os.Pipe()
			oldStdin := os.Stdin
			os.Stdin = r
			defer func() {
				r.Close()
				os.Stdin = oldStdin
			}()

			go func() {
				w.Write([]byte("\n"))
				w.Close()
			}()

			cfg := PromptConfig{
				Message:  "Test prompt",
				Force:    false,
				Quiet:    false,
				DefaultYes: tt.defaultYes,
			}

			result := PromptForConfirmation(cfg)

			if bool(result) != tt.expected {
				t.Errorf("PromptForConfirmation() with defaultYes=%v = %v, want %v", tt.defaultYes, result, tt.expected)
			}
		})
	}
}

// TestPromptForDelete tests the delete-specific prompt
func TestPromptForDelete(t *testing.T) {
	tests := []struct {
		name     string
		target   string
		force    bool
		quiet    bool
		input    string
		expected bool
	}{
		{"normal delete with yes", "file.txt", false, false, "y\n", true},
		{"normal delete with no", "file.txt", false, false, "n\n", false},
		{"force bypasses prompt", "file.txt", true, false, "", true},
		{"quiet returns safe default", "file.txt", false, true, "", false},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			if tt.input != "" {
				r, w, _ := os.Pipe()
				oldStdin := os.Stdin
				os.Stdin = r
				defer func() {
					r.Close()
					os.Stdin = oldStdin
				}()

				go func() {
					w.Write([]byte(tt.input))
					w.Close()
				}()
			}

			result := PromptForDelete(tt.target, tt.force, tt.quiet)

			if bool(result) != tt.expected {
				t.Errorf("PromptForDelete() = %v, want %v", result, tt.expected)
			}
		})
	}
}

