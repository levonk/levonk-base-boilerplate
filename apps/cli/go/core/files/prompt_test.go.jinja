// TestPromptFormat tests that the prompt message is formatted correctly
func TestPromptFormat(t *testing.T) {
	tests := []struct {
		name       string
		message    string
		defaultYes bool
		expected   string
	}{
		{"default no prompt", "Delete file.txt?", false, "Delete file.txt? [y/N]? "},
		{"default yes prompt", "Continue?", true, "Continue? [Y/n]? "},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			r, w, _ := os.Pipe()
			oldStdin := os.Stdin
			os.Stdin = r
			defer func() {
				r.Close()
				os.Stdin = oldStdin
			}()

			go func() {
				w.Write([]byte("n\n"))
				w.Close()
			}()

			// Capture stdout
			oldStdout := os.Stdout
			var buf bytes.Buffer
			rOut, wOut, _ := os.Pipe()
			os.Stdout = wOut
			defer func() {
				wOut.Close()
				os.Stdout = oldStdout
			}()

			cfg := PromptConfig{
				Message:  tt.message,
				Force:    false,
				Quiet:    false,
				DefaultYes: tt.defaultYes,
			}

			PromptForConfirmation(cfg)

			wOut.Close()
			os.Stdout = oldStdout
			io.Copy(&buf, rOut)

			output := buf.String()
			if !strings.Contains(output, tt.expected) {
				t.Errorf("Prompt format incorrect. Expected to contain %q, got %q", tt.expected, output)
			}
		})
	}
}

// TestPromptForConfirmation_WithSuppressor tests prompt suppression via suppressor
func TestPromptForConfirmation_WithSuppressor(t *testing.T) {
	logger := NewLogger(LoggerConfig{Quiet: true})

	tests := []struct {
		name     string
		mode     Mode
		force    bool
		quiet    bool
		expected bool
	}{
		{"agent mode suppresses with safe default (no)", ModeAgent, false, false, false},
		{"force flag bypasses in agent mode", ModeAgent, true, false, true},
		{"quiet flag suppresses in human mode", ModeHuman, false, true, false},
		{"human mode allows prompt", ModeHuman, false, false, false}, // Would prompt, but we test suppressor logic
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			suppressor := prompts.NewPromptSuppressor(tt.mode, tt.force, tt.quiet, logger)
			cfg := PromptConfig{
				Message:  "Test prompt",
				Force:    false,
				Quiet:    false,
				DefaultYes: false,
				Mode:     tt.mode,
				Suppressor: suppressor,
			}

			result := PromptForConfirmation(cfg)
			if result != tt.expected {
				t.Errorf("PromptForConfirmation() with suppressor = %v, want %v", result, tt.expected)
			}
		})
	}
}

