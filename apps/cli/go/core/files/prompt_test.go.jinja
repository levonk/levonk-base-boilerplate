// TestPromptFlagBasedCompletion tests that all prompted operations can be completed via flags
func TestPromptFlagBasedCompletion(t *testing.T) {
	logger := NewLogger(LoggerConfig{Quiet: true})

	tests := []struct {
		name        string
		mode        Mode
		force       bool
		quiet       bool
		shouldPrompt bool
		description string
	}{
		{"agent mode: no prompt needed", ModeAgent, false, false, false, "Agent mode suppresses prompts automatically"},
		{"human mode with force: no prompt", ModeHuman, true, false, false, "Force flag bypasses prompts"},
		{"human mode with quiet: no prompt", ModeHuman, false, true, false, "Quiet flag suppresses prompts with safe default"},
		{"human mode: prompt allowed", ModeHuman, false, false, true, "Human mode allows prompts without flags"},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			suppressor := prompts.NewPromptSuppressor(tt.mode, tt.force, tt.quiet, logger)
			shouldPrompt := suppressor.ShouldPrompt()

			if shouldPrompt != tt.shouldPrompt {
				t.Errorf("ShouldPrompt() = %v, want %v (%s)", shouldPrompt, tt.shouldPrompt, tt.description)
			}
		})
	}
}

// TestPromptRequireValue tests that required values fail with clear error in agent mode
func TestPromptRequireValue(t *testing.T) {
	logger := NewLogger(LoggerConfig{Quiet: true})

	suppressor := prompts.NewPromptSuppressor(ModeAgent, false, false, logger)

	tests := []struct {
		name      string
		value     string
		fieldName string
		wantErr   bool
	}{
		{"valid value passes", "test-value", "api-key", false},
		{"empty value fails", "", "api-key", true},
		{"whitespace only fails", "   ", "api-key", true},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			err := suppressor.RequireValue(tt.value, tt.fieldName)
			if (err != nil) != tt.wantErr {
				t.Errorf("RequireValue() error = %v, wantErr %v", err, tt.wantErr)
			}
			if err != nil && tt.wantErr {
				// Check that error message is clear and helpful
				if !strings.Contains(err.Error(), "required value") {
					t.Errorf("Error message should mention 'required value', got: %v", err)
				}
				if !strings.Contains(err.Error(), tt.fieldName) {
					t.Errorf("Error message should mention field name '%s', got: %v", tt.fieldName, err)
				}
			}
		})
	}
}

