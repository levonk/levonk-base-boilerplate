func TestDaemonManager_IsPlatformSupported(t *testing.T) {
	logger := NewLogger("test")
	dm := NewDaemonManager(logger)

	// Test supported platforms
	switch runtime.GOOS {
	case "linux", "darwin", "windows":
		assert.True(t, dm.IsPlatformSupported(), "Daemon should be supported on %s", runtime.GOOS)
	default:
		assert.False(t, dm.IsPlatformSupported(), "Daemon should not be supported on %s", runtime.GOOS)
	}
}

func TestJobQueue_CreateJob(t *testing.T) {
	logger := NewLogger("test")
	dm := NewDaemonManager(logger)

	job, err := dm.CreateJob("echo", []string{"hello"})
	require.NoError(t, err)
	require.NotNil(t, job)

	assert.NotEmpty(t, job.ID)
	assert.Equal(t, "echo", job.Command)
	assert.Equal(t, []string{"hello"}, job.Args)
	assert.Equal(t, "pending", job.Status)
	assert.False(t, job.CreatedAt.IsZero())
}

func TestJobQueue_CreateJob_MaxLimit(t *testing.T) {
	logger := NewLogger("test")
	dm := NewDaemonManager(logger)
	dm.config.MaxJobs = 2

	// Create jobs up to limit
	job1, err := dm.CreateJob("echo", []string{"1"})
	require.NoError(t, err)

	job2, err := dm.CreateJob("echo", []string{"2"})
	require.NoError(t, err)

	// Third job should fail
	job3, err := dm.CreateJob("echo", []string{"3"})
	assert.Error(t, err)
	assert.Nil(t, job3)
	assert.Contains(t, err.Error(), "maximum job limit")

	// Clean up
	dm.jobQueue.mu.Lock()
	delete(dm.jobQueue.jobs, job1.ID)
	delete(dm.jobQueue.jobs, job2.ID)
	dm.jobQueue.mu.Unlock()
}

func TestJobQueue_ExecuteJob(t *testing.T) {
	logger := NewLogger("test")
	dm := NewDaemonManager(logger)

	job, err := dm.CreateJob("echo", []string{"test"})
	require.NoError(t, err)

	ctx := context.Background()
	err = dm.ExecuteJob(ctx, job.ID)
	require.NoError(t, err)

	// Verify job status
	dm.jobQueue.mu.RLock()
	job = dm.jobQueue.jobs[job.ID]
	dm.jobQueue.mu.RUnlock()

	assert.Equal(t, "completed", job.Status)
	assert.NotNil(t, job.StartedAt)
	assert.NotNil(t, job.CompletedAt)
	assert.NotNil(t, job.Result)
}

func TestJobQueue_CancelJob(t *testing.T) {
	logger := NewLogger("test")
	dm := NewDaemonManager(logger)

	job, err := dm.CreateJob("sleep", []string{"10"})
	require.NoError(t, err)

	err = dm.CancelJob(job.ID)
	require.NoError(t, err)

	// Verify job status
	dm.jobQueue.mu.RLock()
	job = dm.jobQueue.jobs[job.ID]
	dm.jobQueue.mu.RUnlock()

	assert.Equal(t, "cancelled", job.Status)
	assert.NotNil(t, job.CompletedAt)
}

