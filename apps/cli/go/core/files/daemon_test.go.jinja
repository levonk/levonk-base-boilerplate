func TestJobQueue_CleanupCompletedJobs(t *testing.T) {
	logger := NewLogger("test")
	dm := NewDaemonManager(logger)

	// Create a job and complete it
	job, err := dm.CreateJob("echo", []string{"test"})
	require.NoError(t, err)

	ctx := context.Background()
	err = dm.ExecuteJob(ctx, job.ID)
	require.NoError(t, err)

	// Mark as old
	oldTime := time.Now().Add(-25 * time.Hour)
	dm.jobQueue.mu.Lock()
	job.CompletedAt = &oldTime
	dm.jobQueue.mu.Unlock()

	// Cleanup jobs older than 24 hours
	dm.CleanupCompletedJobs(24 * time.Hour)

	// Verify job was cleaned up
	dm.jobQueue.mu.RLock()
	_, exists := dm.jobQueue.jobs[job.ID]
	dm.jobQueue.mu.RUnlock()

	assert.False(t, exists, "Old completed job should be cleaned up")
}

