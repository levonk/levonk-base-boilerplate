func TestJob_Metadata(t *testing.T) {
	logger := NewLogger("test")
	dm := NewDaemonManager(logger)

	job, err := dm.CreateJob("echo", []string{"test"})
	require.NoError(t, err)

	assert.NotNil(t, job.Metadata)
	assert.Empty(t, job.Metadata)

	// Add metadata
	job.Metadata["key"] = "value"
	job.Metadata["number"] = 123

	assert.Equal(t, "value", job.Metadata["key"])
	assert.Equal(t, 123, job.Metadata["number"])

	// Clean up
	dm.jobQueue.mu.Lock()
	delete(dm.jobQueue.jobs, job.ID)
	dm.jobQueue.mu.Unlock()
}
