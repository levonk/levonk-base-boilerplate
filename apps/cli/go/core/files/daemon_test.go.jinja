func TestDaemonManager_AutoSpawnDaemon(t *testing.T) {
	logger := NewLogger("test")
	dm := NewDaemonManager(logger)

	// Disable noisy behavior for test
	dm.config.NoisyBehavior = false

	// Auto-spawn should succeed if platform is supported
	if dm.IsPlatformSupported() {
		// Note: This test may fail if daemon cannot actually start
		// In a real environment, you might need to mock the service
		err := dm.AutoSpawnDaemon()
		// We expect this to potentially fail in test environment
		// but the logic should be correct
		if err != nil {
			assert.Contains(t, err.Error(), "failed to start service")
		}
	} else {
		err := dm.AutoSpawnDaemon()
		assert.Error(t, err)
		assert.Contains(t, err.Error(), "not supported")
	}
}

func TestDaemonManager_PlatformFallback(t *testing.T) {
	logger := NewLogger("test")
	dm := NewDaemonManager(logger)

	if !dm.IsPlatformSupported() {
		err := dm.StartDaemon()
		assert.Error(t, err)
		assert.Contains(t, err.Error(), "not supported")
		assert.Contains(t, err.Error(), runtime.GOOS)
	}
}

