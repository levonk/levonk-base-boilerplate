func TestFormatURLWithLabel(t *testing.T) {
	tests := []struct {
		name   string
		rawURL string
		label  string
		format URLFormat
		want   string
	}{
		{
			name:   "plain format with label",
			rawURL: "https://example.com",
			label:  "Click here",
			format: FormatPlain,
			want:   "Click here (https://example.com)",
		},
		{
			name:   "terminal format with label",
			rawURL: "https://example.com",
			label:  "Click here",
			format: FormatTerminal,
			want:   "\x1b]8;;https://example.com\x1b\\Click here\x1b]8;;\x1b\\",
		},
		{
			name:   "invalid URL with label",
			rawURL: "://invalid",
			label:  "Click here",
			format: FormatTerminal,
			want:   "Click here",
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			got := FormatURLWithLabel(tt.rawURL, tt.label, tt.format)
			if got != tt.want {
				t.Errorf("FormatURLWithLabel() = %v, want %v", got, tt.want)
			}
		})
	}
}

func TestStripTerminalLinks(t *testing.T) {
	tests := []struct {
		name  string
		text  string
		want  string
	}{
		{
			name:  "text with terminal links",
			text:  "\x1b]8;;https://example.com\x1b\\Click here\x1b]8;;\x1b\\",
			want:  "Click here",
		},
		{
			name:  "plain text",
			text:  "Just plain text",
			want:  "Just plain text",
		},
		{
			name:  "empty string",
			text:  "",
			want:  "",
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			got := StripTerminalLinks(tt.text)
			if got != tt.want {
				t.Errorf("StripTerminalLinks() = %v, want %v", got, tt.want)
			}
		})
	}
}

func TestURL_Nil(t *testing.T) {
	var u *URL

	if u.FormatPlain() != "" {
		t.Errorf("nil URL.FormatPlain() should return empty string")
	}
	if u.FormatTerminal() != "" {
		t.Errorf("nil URL.FormatTerminal() should return empty string")
	}
	if u.Format(FormatPlain) != "" {
		t.Errorf("nil URL.Format() should return empty string")
	}
}

