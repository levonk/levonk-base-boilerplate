func TestURL_FormatTerminal(t *testing.T) {
	tests := []struct {
		name string
		rawURL string
		wantContains string
	}{
		{
			name:         "valid URL",
			rawURL:       "https://example.com",
			wantContains: "\x1b]8;;https://example.com\x1b\\",
		},
		{
			name:         "URL without scheme",
			rawURL:       "example.com",
			wantContains: "\x1b]8;;https://example.com\x1b\\",
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			u := NewURL(tt.rawURL)
			got := u.FormatTerminal()
			if !strings.Contains(got, tt.wantContains) {
				t.Errorf("URL.FormatTerminal() = %v, want to contain %v", got, tt.wantContains)
			}
		})
	}
}

