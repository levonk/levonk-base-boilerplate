package main

import (
	"strings"
	"testing"
)

func TestNewURL(t *testing.T) {
	tests := []struct {
		name     string
		rawURL   string
		wantValid bool
		wantEncoded string
	}{
		{
			name:     "valid https URL",
			rawURL:   "https://example.com",
			wantValid: true,
			wantEncoded: "https://example.com",
		},
		{
			name:     "valid http URL",
			rawURL:   "http://example.com",
			wantValid: true,
			wantEncoded: "http://example.com",
		},
		{
			name:     "URL without scheme",
			rawURL:   "example.com",
			wantValid: true,
			wantEncoded: "https://example.com",
		},
		{
			name:     "URL with path",
			rawURL:   "https://example.com/path/to/resource",
			wantValid: true,
			wantEncoded: "https://example.com/path/to/resource",
		},
		{
			name:     "URL with query",
			rawURL:   "https://example.com?query=value",
			wantValid: true,
			wantEncoded: "https://example.com?query=value",
		},
		{
			name:     "URL with fragment",
			rawURL:   "https://example.com#section",
			wantValid: true,
			wantEncoded: "https://example.com#section",
		},
		{
			name:     "invalid URL",
			rawURL:   "://invalid",
			wantValid: false,
			wantEncoded: "://invalid",
		},
		{
			name:     "empty string",
			rawURL:   "",
			wantValid: false,
			wantEncoded: "",
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			u := NewURL(tt.rawURL)
			if u.Valid != tt.wantValid {
				t.Errorf("NewURL().Valid = %v, want %v", u.Valid, tt.wantValid)
			}
			if u.Encoded != tt.wantEncoded {
				t.Errorf("NewURL().Encoded = %v, want %v", u.Encoded, tt.wantEncoded)
			}
		})
	}
}

