package main

import (
	"fmt"
	"path/filepath"
	"runtime"
	"strings"
)

// ReferenceFormat represents the format for file references
type ReferenceFormat int

const (
	// FormatVSCode uses VSCode-compatible format: file:///absolute/path/to/file:line:column
	FormatVSCode ReferenceFormat = iota
	// FormatStandard uses standard terminal format: file:line:column
	FormatStandard
)

// FileReference represents a file location with line and column information
type FileReference struct {
	Path    string
	Line    int
	Column  int
	AbsPath string
}

// NewFileReference creates a new file reference from runtime caller information
func NewFileReference(skip int) *FileReference {
	pc, file, line, ok := runtime.Caller(skip)
	if !ok {
		return nil
	}

	// Get absolute path
	absPath, err := filepath.Abs(file)
	if err != nil {
		absPath = file
	}

	return &FileReference{
		Path:    file,
		Line:    line,
		Column:  0, // Column info not available from runtime.Caller
		AbsPath: absPath,
	}
}

// NewFileReferenceFromPath creates a file reference from a path and line number
func NewFileReferenceFromPath(path string, line int, column int) *FileReference {
	absPath, err := filepath.Abs(path)
	if err != nil {
		absPath = path
	}

	return &FileReference{
		Path:    path,
		Line:    line,
		Column:  column,
		AbsPath: absPath,
	}
}

// FormatVSCode returns the VSCode-compatible format
// Format: file:///absolute/path/to/file:line:column
func (fr *FileReference) FormatVSCode() string {
	if fr == nil {
		return ""
	}

	// Convert path to use forward slashes for VSCode compatibility
	path := strings.ReplaceAll(fr.AbsPath, "\\", "/")

	var builder strings.Builder
	builder.WriteString("file:///")
	builder.WriteString(path)

	if fr.Line > 0 {
		builder.WriteString(fmt.Sprintf(":%d", fr.Line))
		if fr.Column > 0 {
			builder.WriteString(fmt.Sprintf(":%d", fr.Column))
		}
	}

	return builder.String()
}

// FormatStandard returns the standard terminal format
// Format: file:line:column
func (fr *FileReference) FormatStandard() string {
	if fr == nil {
		return ""
	}

	var builder strings.Builder
	builder.WriteString(fr.Path)

	if fr.Line > 0 {
		builder.WriteString(fmt.Sprintf(":%d", fr.Line))
		if fr.Column > 0 {
			builder.WriteString(fmt.Sprintf(":%d", fr.Column))
		}
	}

	return builder.String()
}

// Format returns the file reference in the specified format
func (fr *FileReference) Format(format ReferenceFormat) string {
	switch format {
	case FormatVSCode:
		return fr.FormatVSCode()
	case FormatStandard:
		return fr.FormatStandard()
	default:
		return fr.FormatStandard()
	}
}

// FormatErrorWithReference formats an error message with a file reference
func FormatErrorWithReference(message string, ref *FileReference, format ReferenceFormat) string {
	if ref == nil {
		return message
	}

	refStr := ref.Format(format)
	return fmt.Sprintf("%s (%s)", message, refStr)
}

// GetCallerReference gets a file reference from the caller's location
func GetCallerReference(skip int) *FileReference {
	return NewFileReference(skip + 1)
}

