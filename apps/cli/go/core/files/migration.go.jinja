package main

import (
	"fmt"
	"os"
	"path/filepath"
	"time"
)

const (
	// CurrentConfigVersion is the current config schema version
	CurrentConfigVersion = 2

	// LegacyConfigVersion is the version before migration was needed
	LegacyConfigVersion = 1
)

// ConfigVersion represents the version of a config file
type ConfigVersion int

// Migration represents a config migration step
type Migration struct {
	FromVersion int
	ToVersion   int
	MigrateFunc func(map[string]interface{}) (map[string]interface{}, error)
}

// MigrationManager handles config file migrations
type MigrationManager struct {
	configPath string
	logger     *Logger
	migrations []Migration
}

// NewMigrationManager creates a new migration manager
func NewMigrationManager(configPath string, logger *Logger) *MigrationManager {
	mm := &MigrationManager{
		configPath: configPath,
		logger:     logger,
	}

	// Register migrations
	mm.registerMigrations()

	return mm
}

// registerMigrations registers all available migrations
func (mm *MigrationManager) registerMigrations() {
	// Add migration from version 1 to version 2
	mm.migrations = append(mm.migrations, Migration{
		FromVersion: LegacyConfigVersion,
		ToVersion:   CurrentConfigVersion,
		MigrateFunc: mm.migrateV1ToV2,
	})
}

// DetectConfigVersion detects the version of a config file
func (mm *MigrationManager) DetectConfigVersion() (int, error) {
	// If config file doesn't exist, it's a new install (current version)
	if _, err := os.Stat(mm.configPath); os.IsNotExist(err) {
		return CurrentConfigVersion, nil
	}

	// Read config file to detect version
	content, err := os.ReadFile(mm.configPath)
	if err != nil {
		return 0, fmt.Errorf("failed to read config file: %w", err)
	}

	// Check for version field in config
	config, err := parseConfigContent(string(content))
	if err != nil {
		// If we can't parse it, assume it's legacy version 1
		mm.logger.Debug("Could not parse config, assuming legacy version 1")
		return LegacyConfigVersion, nil
	}

	// Check for version field
	if version, ok := config["version"].(int); ok {
		return version, nil
	}

	// No version field means legacy version 1
	return LegacyConfigVersion, nil
}

// NeedsMigration checks if the config file needs migration
func (mm *MigrationManager) NeedsMigration() (bool, int, error) {
	currentVersion, err := mm.DetectConfigVersion()
	if err != nil {
		return false, 0, err
	}

	return currentVersion < CurrentConfigVersion, currentVersion, nil
}

// Migrate performs the migration if needed
func (mm *MigrationManager) Migrate() error {
	needsMigration, currentVersion, err := mm.NeedsMigration()
	if err != nil {
		return fmt.Errorf("failed to check migration status: %w", err)
	}

	if !needsMigration {
		mm.logger.Debug("Config is already at current version %d", CurrentConfigVersion)
		return nil
	}

	mm.logger.Info("Migrating config from version %d to %d", currentVersion, CurrentConfigVersion)

	// Create backup before migration
	if err := mm.createBackup(); err != nil {
		return fmt.Errorf("failed to create backup: %w", err)
	}

	// Read current config
	content, err := os.ReadFile(mm.configPath)
	if err != nil {
		return fmt.Errorf("failed to read config file: %w", err)
	}

	// Parse config
	config, err := parseConfigContent(string(content))
	if err != nil {
		return fmt.Errorf("failed to parse config: %w", err)
	}

	// Apply migrations sequentially
	for _, migration := range mm.migrations {
		if config["version"] == migration.FromVersion {
			mm.logger.Info("Applying migration from version %d to %d", migration.FromVersion, migration.ToVersion)

			migratedConfig, err := migration.MigrateFunc(config)
			if err != nil {
				return fmt.Errorf("migration from %d to %d failed: %w", migration.FromVersion, migration.ToVersion, err)
			}

			config = migratedConfig
		}
	}

	// Update version
	config["version"] = CurrentConfigVersion

	// Validate migrated config
	if err := mm.validateMigratedConfig(config); err != nil {
		return fmt.Errorf("migrated config validation failed: %w", err)
	}

	// Write migrated config
	if err := mm.writeConfig(config); err != nil {
		return fmt.Errorf("failed to write migrated config: %w", err)
	}

	mm.logger.Info("Config migration completed successfully")
	return nil
}

// createBackup creates a backup of the current config file
func (mm *MigrationManager) createBackup() error {
	backupPath := mm.configPath + ".bak"

	// Check if backup already exists
	if _, err := os.Stat(backupPath); err == nil {
		// Backup exists, add timestamp
		timestamp := time.Now().Format("20060102-150405")
		backupPath = fmt.Sprintf("%s.bak.%s", mm.configPath, timestamp)
	}

	mm.logger.Info("Creating backup at %s", backupPath)

	// Read original file
	content, err := os.ReadFile(mm.configPath)
	if err != nil {
		return fmt.Errorf("failed to read config file for backup: %w", err)
	}

	// Write backup
	if err := os.WriteFile(backupPath, content, 0600); err != nil {
		return fmt.Errorf("failed to write backup file: %w", err)
	}

	return nil
}

// validateMigratedConfig validates the migrated config
func (mm *MigrationManager) validateMigratedConfig(config map[string]interface{}) error {
	// Check that version is set
	if version, ok := config["version"].(int); !ok || version != CurrentConfigVersion {
		return fmt.Errorf("config version is not set correctly after migration")
	}

	// Use existing validation
	configPath := mm.configPath
	validationErrors := ValidateConfig(config, configPath)
	if len(validationErrors) > 0 {
		return fmt.Errorf("migrated config has validation errors: %d errors", len(validationErrors))
	}

	return nil
}

// writeConfig writes the config map to the config file
func (mm *MigrationManager) writeConfig(config map[string]interface{}) error {
	// Convert config map to YAML-like format
	var yamlContent string
	yamlContent += fmt.Sprintf("# Configuration for {{ project_name }}\n")
	yamlContent += fmt.Sprintf("# Config version: %d\n", CurrentConfigVersion)
	yamlContent += fmt.Sprintf("version: %d\n\n", CurrentConfigVersion)

	// Write config fields
	for key, value := range config {
		if key == "version" {
			continue // Already written
		}
		switch v := value.(type) {
		case bool:
			yamlContent += fmt.Sprintf("%s: %t\n", key, v)
		case string:
			yamlContent += fmt.Sprintf("%s: %q\n", key, v)
		case int:
			yamlContent += fmt.Sprintf("%s: %d\n", key, v)
		default:
			yamlContent += fmt.Sprintf("%s: %v\n", key, v)
		}
	}

	// Write to file
	if err := os.WriteFile(mm.configPath, []byte(yamlContent), 0600); err != nil {
		return fmt.Errorf("failed to write config file: %w", err)
	}

	return nil
}

// migrateV1ToV2 migrates config from version 1 to version 2
func (mm *MigrationManager) migrateV1ToV2(config map[string]interface{}) (map[string]interface{}, error) {
	mm.logger.Debug("Applying V1 to V2 migration")

	// V1 to V2 migration logic
	// This is a placeholder - actual migration logic depends on schema changes
	// For now, we just add the version field
	migrated := make(map[string]interface{})
	for k, v := range config {
		migrated[k] = v
	}
	migrated["version"] = 2

	return migrated, nil
}

// CheckLegacyFormat checks if the config is in legacy format and shows deprecation warning
func (mm *MigrationManager) CheckLegacyFormat() bool {
	needsMigration, currentVersion, err := mm.NeedsMigration()
	if err != nil {
		mm.logger.Debug("Could not check for legacy format: %v", err)
		return false
	}

	if needsMigration {
		mm.logger.Warn("Config file is using legacy format (version %d)", currentVersion)
		mm.logger.Warn("Legacy format will be deprecated in the next release")
		mm.logger.Warn("Config will be automatically migrated to version %d", CurrentConfigVersion)
		return true
	}

	return false
}

// parseConfigContent parses config file content into a map
func parseConfigContent(content string) (map[string]interface{}, error) {
	config := make(map[string]interface{})
	
	// Simple YAML-like parser
	// This is a basic implementation - in production, use a proper YAML parser
	lines := splitLines(content)
	for _, line := range lines {
		line = trimSpace(line)
		if len(line) == 0 || line[0] == '#' {
			continue
		}
		
		parts := splitColon(line)
		if len(parts) == 2 {
			key := trimSpace(parts[0])
			value := trimSpace(parts[1])
			config[key] = value
		}
	}
	
	return config, nil
}

// Helper functions for parsing (simplified for template)
func splitLines(s string) []string {
	var lines []string
	start := 0
	for i := 0; i < len(s); i++ {
		if s[i] == '\n' {
			lines = append(lines, s[start:i])
			start = i + 1
		}
	}
	if start < len(s) {
		lines = append(lines, s[start:])
	}
	return lines
}

func trimSpace(s string) string {
	start := 0
	for start < len(s) && (s[start] == ' ' || s[start] == '\t') {
		start++
	}
	end := len(s)
	for end > start && (s[end-1] == ' ' || s[end-1] == '\t' || s[end-1] == '\r') {
		end--
	}
	return s[start:end]
}

func splitColon(s string) []string {
	for i := 0; i < len(s); i++ {
		if s[i] == ':' {
			return []string{s[:i], s[i+1:]}
		}
	}
	return []string{s}
}

