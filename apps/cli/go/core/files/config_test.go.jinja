func TestValidateConfigWithAXIFields(t *testing.T) {
	tempDir := t.TempDir()
	configPath := filepath.Join(tempDir, "config.yaml")

	// Test valid AXI config
	config := map[string]interface{}{
		"mode":                   string(ModeAgent),
		"default_format":         string(FormatToon),
		"truncation_limit":       1000,
		"enable_contextual_help":  true,
		"session_context_enabled": false,
	}
	configContent := "mode: agent\ndefault_format: toon\ntruncation_limit: 1000\nenable_contextual_help: true\nsession_context_enabled: false"
	os.WriteFile(configPath, []byte(configContent), 0600)

	errors := ValidateConfig(config, configPath)
	if len(errors) != 0 {
		t.Errorf("ValidateConfig should not error on valid AXI config, got %d errors", len(errors))
	}

	// Test invalid default_format
	config["default_format"] = "invalid"
	configContent = "mode: agent\ndefault_format: invalid\ntruncation_limit: 1000"
	os.WriteFile(configPath, []byte(configContent), 0600)
	errors = ValidateConfig(config, configPath)
	if len(errors) == 0 {
		t.Errorf("ValidateConfig should error on invalid default_format")
	}

	// Test invalid truncation_limit type
	config["default_format"] = string(FormatToon)
	config["truncation_limit"] = "not_a_number"
	configContent = "mode: agent\ndefault_format: toon\ntruncation_limit: not_a_number"
	os.WriteFile(configPath, []byte(configContent), 0600)
	errors = ValidateConfig(config, configPath)
	if len(errors) == 0 {
		t.Errorf("ValidateConfig should error on invalid truncation_limit type")
	}
}

func TestParseConfigContentFromFile(t *testing.T) {
	// Test parsing config from file
	tempDir := t.TempDir()
	configPath := filepath.Join(tempDir, "config.yaml")
	configContent := "quiet: false\nverbose: true\ncolor: auto"
	if err := os.WriteFile(configPath, []byte(configContent), 0600); err != nil {
		t.Fatalf("Failed to create config file: %v", err)
	}

	config, err := parseConfigContentFromFile(configPath)
	if err != nil {
		t.Fatalf("parseConfigContentFromFile failed: %v", err)
	}

	// Verify parsed config
	if config["quiet"] != "false" {
		t.Errorf("Expected quiet to be 'false', got %v", config["quiet"])
	}
	if config["verbose"] != "true" {
		t.Errorf("Expected verbose to be 'true', got %v", config["verbose"])
	}
	if config["color"] != "auto" {
		t.Errorf("Expected color to be 'auto', got %v", config["color"])
	}
}

