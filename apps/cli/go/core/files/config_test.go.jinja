func TestConfigSchema(t *testing.T) {
	schema := GetConfigSchema()

	// Test that schema has expected fields
	expectedFields := []string{"quiet", "verbose", "debug", "color", "json", "mode", "default_format", "truncation_limit", "enable_contextual_help", "session_context_enabled"}
	for _, field := range expectedFields {
		if _, ok := schema.Fields[field]; !ok {
			t.Errorf("ConfigSchema missing field: %s", field)
		}
	}

	// Test that color field has correct enum values
	colorField := schema.Fields["color"]
	if colorField.Type != "enum" {
		t.Errorf("color field should be enum type, got %s", colorField.Type)
	}
	expectedValues := []string{"auto", "always", "never"}
	for i, val := range colorField.AllowedValues {
		if val != expectedValues[i] {
			t.Errorf("color field allowed value %d should be %s, got %s", i, expectedValues[i], val)
		}
	}

	// Test that mode field has correct enum values
	modeField := schema.Fields["mode"]
	if modeField.Type != "enum" {
		t.Errorf("mode field should be enum type, got %s", modeField.Type)
	}
	expectedModeValues := []string{string(ModeAgent), string(ModeHuman)}
	for i, val := range modeField.AllowedValues {
		if val != expectedModeValues[i] {
			t.Errorf("mode field allowed value %d should be %s, got %s", i, expectedModeValues[i], val)
		}
	}

	// Test that default_format field has correct enum values
	formatField := schema.Fields["default_format"]
	if formatField.Type != "enum" {
		t.Errorf("default_format field should be enum type, got %s", formatField.Type)
	}
	expectedFormatValues := []string{string(FormatToon), string(FormatJSON), string(FormatHuman)}
	for i, val := range formatField.AllowedValues {
		if val != expectedFormatValues[i] {
			t.Errorf("default_format field allowed value %d should be %s, got %s", i, expectedFormatValues[i], val)
		}
	}

	// Test that truncation_limit field is int type
	truncationField := schema.Fields["truncation_limit"]
	if truncationField.Type != "int" {
		t.Errorf("truncation_limit field should be int type, got %s", truncationField.Type)
	}
	if truncationField.DefaultValue != 1000 {
		t.Errorf("truncation_limit default value should be 1000, got %v", truncationField.DefaultValue)
	}

	// Test that enable_contextual_help field is bool type
	helpField := schema.Fields["enable_contextual_help"]
	if helpField.Type != "bool" {
		t.Errorf("enable_contextual_help field should be bool type, got %s", helpField.Type)
	}
	if helpField.DefaultValue != true {
		t.Errorf("enable_contextual_help default value should be true, got %v", helpField.DefaultValue)
	}

	// Test that session_context_enabled field is bool type
	sessionField := schema.Fields["session_context_enabled"]
	if sessionField.Type != "bool" {
		t.Errorf("session_context_enabled field should be bool type, got %s", sessionField.Type)
	}
	if sessionField.DefaultValue != false {
		t.Errorf("session_context_enabled default value should be false, got %v", sessionField.DefaultValue)
	}
}

