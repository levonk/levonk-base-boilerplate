func TestValidateConfigInvalidType(t *testing.T) {
	// Test that validation catches invalid types
	config := map[string]interface{}{
		"quiet": "true", // Should be bool, not string
	}
	tempDir := t.TempDir()
	configPath := filepath.Join(tempDir, "config.yaml")
	os.WriteFile(configPath, []byte("quiet: true"), 0600)

	errors := ValidateConfig(config, configPath)
	if len(errors) == 0 {
		t.Errorf("ValidateConfig should catch invalid type for quiet")
	}
}

