func TestGetHardcodedDefaults(t *testing.T) {
	defaults := GetHardcodedDefaults()

	// Test that defaults contains expected keys
	expectedKeys := []string{"quiet", "verbose", "debug", "color", "json"}
	for _, key := range expectedKeys {
		if _, ok := defaults[key]; !ok {
			t.Errorf("GetHardcodedDefaults missing key: %s", key)
		}
	}

	// Test that quiet is false by default
	if defaults["quiet"] != false {
		t.Errorf("GetHardcodedDefaults quiet should be false, got %v", defaults["quiet"])
	}

	// Test that color is "auto" by default
	if defaults["color"] != "auto" {
		t.Errorf("GetHardcodedDefaults color should be auto, got %v", defaults["color"])
	}
}

