func TestDefaultConfigTemplate(t *testing.T) {
	// Read the default config template
	templatePath := "config.default.yaml.jinja"
	content, err := os.ReadFile(templatePath)
	if err != nil {
		t.Fatalf("Failed to read default config template: %v", err)
	}

	templateContent := string(content)

	// Test that template contains required sections
	requiredSections := []string{
		"# General Settings",
		"# Color Control",
		"# Logging",
		"# Input Processing",
		"# Output Formatting",
		"# Performance",
		"# Security",
		"# Advanced",
	}

	for _, section := range requiredSections {
		if !strings.Contains(templateContent, section) {
			t.Errorf("Default config template missing required section: %s", section)
		}
	}

	// Test that template contains color control settings
	colorSettings := []string{
		"color: auto",
		"NO_COLOR",
		"auto, always, or never",
	}

	for _, setting := range colorSettings {
		if !strings.Contains(templateContent, setting) {
			t.Errorf("Default config template missing color setting: %s", setting)
		}
	}

	// Test that template contains logging settings
	loggingSettings := []string{
		"log-level",
		"log-file",
		"log-format",
	}

	for _, setting := range loggingSettings {
		if !strings.Contains(templateContent, setting) {
			t.Errorf("Default config template missing logging setting: %s", setting)
		}
	}

	// Test that template contains configuration precedence information
	if !strings.Contains(templateContent, "Configuration precedence") {
		t.Errorf("Default config template missing configuration precedence information")
	}

	// Test that template contains project name placeholder
	if !strings.Contains(templateContent, "{{ project_name }}") {
		t.Errorf("Default config template missing project name placeholder")
	}

	// Test that template contains description placeholder
	if !strings.Contains(templateContent, "{{ description }}") {
		t.Errorf("Default config template missing description placeholder")
	}

	// Test that all settings are commented (lines starting with #)
	lines := strings.Split(templateContent, "\n")
	for _, line := range lines {
		trimmed := strings.TrimSpace(line)
		// Skip empty lines and section headers
		if trimmed == "" || strings.HasPrefix(trimmed, "#") || strings.HasPrefix(trimmed, "-") {
			continue
		}
		// Check if line contains a setting (contains :)
		if strings.Contains(trimmed, ":") && !strings.HasPrefix(trimmed, "#") {
			t.Errorf("Default config template has uncommented setting: %s", trimmed)
		}
	}
}

func TestEnsureConfigDir(t *testing.T) {
	// Test creating a new directory
	tempDir := t.TempDir()
	configPath := filepath.Join(tempDir, "subdir", "config.yaml")

	err := EnsureConfigDir(configPath)
	if err != nil {
		t.Fatalf("EnsureConfigDir failed: %v", err)
	}

	// Verify directory was created
	if _, err := os.Stat(filepath.Dir(configPath)); os.IsNotExist(err) {
		t.Errorf("Config directory was not created")
	}

	// Test that existing directory doesn't cause error
	err = EnsureConfigDir(configPath)
	if err != nil {
		t.Errorf("EnsureConfigDir failed for existing directory: %v", err)
	}
}

func TestCreateDefaultConfig(t *testing.T) {
	// Test creating default config
	tempDir := t.TempDir()
	configPath := filepath.Join(tempDir, "config.yaml")

	err := CreateDefaultConfig(configPath)
	if err != nil {
		t.Fatalf("CreateDefaultConfig failed: %v", err)
	}

	// Verify file was created
	if _, err := os.Stat(configPath); os.IsNotExist(err) {
		t.Errorf("Config file was not created")
	}

	// Verify file has content
	content, err := os.ReadFile(configPath)
	if err != nil {
		t.Fatalf("Failed to read config file: %v", err)
	}
	if len(content) == 0 {
		t.Errorf("Config file is empty")
	}

	// Verify file contains expected content
	if !strings.Contains(string(content), "# Default configuration") {
		t.Errorf("Config file missing expected content")
	}

	// Verify file permissions
	info, err := os.Stat(configPath)
	if err != nil {
		t.Fatalf("Failed to get file info: %v", err)
	}
	if info.Mode().Perm() != 0600 {
		t.Errorf("Config file has incorrect permissions: %v, expected 0600", info.Mode().Perm())
	}
}

func TestGetLocalProjectConfigPath(t *testing.T) {
	// Test finding local config in current directory
	tempDir := t.TempDir()
	configDir := filepath.Join(tempDir, ".config", "{{ project_slug }}")
	if err := os.MkdirAll(configDir, 0755); err != nil {
		t.Fatalf("Failed to create config directory: %v", err)
	}
	configPath := filepath.Join(configDir, "config.yaml")
	if err := os.WriteFile(configPath, []byte("test: true"), 0600); err != nil {
		t.Fatalf("Failed to create config file: %v", err)
	}

	// Change to temp directory
	originalDir, err := os.Getwd()
	if err != nil {
		t.Fatalf("Failed to get current directory: %v", err)
	}
	defer os.Chdir(originalDir)
	if err := os.Chdir(tempDir); err != nil {
		t.Fatalf("Failed to change directory: %v", err)
	}

	foundPath, err := GetLocalProjectConfigPath()
	if err != nil {
		t.Fatalf("GetLocalProjectConfigPath failed: %v", err)
	}
	if foundPath != configPath {
		t.Errorf("GetLocalProjectConfigPath returned %s, expected %s", foundPath, configPath)
	}
}

