func TestDetermineMode(t *testing.T) {
	tests := []struct {
		name        string
		humanFlag  bool
		configMode string
		envMode    string
		expected   Mode
	}{
		{"Human flag overrides all", true, "agent", "agent", ModeHuman},
		{"Env overrides config", false, "agent", "human", ModeHuman},
		{"Config used when no env", false, "human", "", ModeHuman},
		{"Config used when invalid env", false, "agent", "invalid", ModeAgent},
		{"Auto-detection when no config", false, "", "", ModeAgent}, // Default to agent in tests
	}

	for _, tt := range tests {
