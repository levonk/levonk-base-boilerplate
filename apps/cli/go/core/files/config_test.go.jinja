}

func TestReloadConfigInvalid(t *testing.T) {
	// Test that invalid config is rejected and old config is kept
	tempDir := t.TempDir()
	configPath := filepath.Join(tempDir, "config.yaml")
	configContent := "quiet: invalid" // Invalid type
	if err := os.WriteFile(configPath, []byte(configContent), 0600); err != nil {
		t.Fatalf("Failed to create config file: %v", err)
	}

	logger := NewLogger("test")
	err := ReloadConfig(configPath, logger)
	if err == nil {
		t.Errorf("ReloadConfig should fail with invalid config")
	}
}

func TestReloadConfigMissingFile(t *testing.T) {
