func TestConfigSchema(t *testing.T) {
	schema := GetConfigSchema()

	// Test that schema has expected fields
	expectedFields := []string{"quiet", "verbose", "debug", "color", "json"}
	for _, field := range expectedFields {
		if _, ok := schema.Fields[field]; !ok {
			t.Errorf("ConfigSchema missing field: %s", field)
		}
	}

	// Test that color field has correct enum values
	colorField := schema.Fields["color"]
	if colorField.Type != "enum" {
		t.Errorf("color field should be enum type, got %s", colorField.Type)
	}
	expectedValues := []string{"auto", "always", "never"}
	for i, val := range colorField.AllowedValues {
		if val != expectedValues[i] {
			t.Errorf("color field allowed value %d should be %s, got %s", i, expectedValues[i], val)
		}
	}
}

