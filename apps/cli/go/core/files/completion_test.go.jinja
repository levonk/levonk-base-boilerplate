func TestCompletionWithSubcommands(t *testing.T) {
	// Test that completions include subcommands
	var out bytes.Buffer
	err := rootCmd.GenBashCompletion(&out)
	if err != nil {
		t.Fatalf("GenBashCompletion failed: %v", err)
	}

	output := out.String()
	// Check for known subcommands
	if strings.Contains(output, "completion") {
		// completion command should be in the completion script
		t.Logf("completion command found in bash completion")
	}
}

func TestCompletionWithFlags(t *testing.T) {
	// Test that completions include flags
	var out bytes.Buffer
	err := rootCmd.GenBashCompletion(&out)
	if err != nil {
		t.Fatalf("GenBashCompletion failed: %v", err)
	}

	output := out.String()
	// Check for known flags
	if strings.Contains(output, "--config") {
		t.Logf("--config flag found in bash completion")
	}
	if strings.Contains(output, "--help") {
		t.Logf("--help flag found in bash completion")
	}
}
