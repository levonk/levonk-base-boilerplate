func TestGlobbing(t *testing.T) {
	// Create temporary directory with test files
	tempDir := t.TempDir()

	// Create test files
	testFile1 := filepath.Join(tempDir, "test1.txt")
	testFile2 := filepath.Join(tempDir, "test2.txt")
	testFile3 := filepath.Join(tempDir, "other.txt")

	os.WriteFile(testFile1, []byte("content1"), 0600)
	os.WriteFile(testFile2, []byte("content2"), 0600)
	os.WriteFile(testFile3, []byte("content3"), 0600)

	// Test glob pattern matching
	pattern := filepath.Join(tempDir, "*.txt")
	rootCmd.SetArgs([]string{pattern})
	buf := new(bytes.Buffer)
	rootCmd.SetOut(buf)

	// Change to temp directory for the test
	oldWd, _ := os.Getwd()
	os.Chdir(tempDir)
	defer os.Chdir(oldWd)

	err := rootCmd.Execute()
	if err != nil {
		t.Fatalf("Execute failed with glob pattern: %v", err)
	}

	// The command should execute successfully with glob pattern
	output := buf.String()
	if !strings.Contains(output, "Processed") {
		t.Errorf("Expected processing output with glob, got: %s", output)
	}
}

func TestStdinHandling(t *testing.T) {
	// Test stdin handling with "-" argument
	oldStdin := os.Stdin
	r, w, _ := os.Pipe()
	os.Stdin = r

	go func() {
		w.Write([]byte("test content from stdin"))
		w.Close()
	}()

	rootCmd.SetArgs([]string{"-"})
	buf := new(bytes.Buffer)
	rootCmd.SetOut(buf)

	err := rootCmd.Execute()
	if err != nil {
		t.Fatalf("Execute failed with stdin: %v", err)
	}

	// Restore stdin
	os.Stdin = oldStdin

	// The command should process stdin
	output := buf.String()
	if !strings.Contains(output, "Processed") {
		t.Errorf("Expected processing output with stdin, got: %s", output)
	}
}

