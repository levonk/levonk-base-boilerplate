// TestMain sets up test environment before running tests
func TestMain(m *testing.M) {
	// Set TEST_MODE to use mock keyring instead of real keychain
	// This prevents password prompts during testing
	os.Setenv("TEST_MODE", "true")
	defer os.Unsetenv("TEST_MODE")

	// Run tests
	code := m.Run()
	os.Exit(code)
}

// TestSecretRedaction tests that secrets are properly redacted from log messages
func TestSecretRedaction(t *testing.T) {
	sm, err := NewSecretManager()
	if err != nil {
		t.Fatalf("Failed to create secret manager: %v", err)
	}

	tests := []struct {
		name     string
		input    string
		expected string
	}{
		{
			name:     "password with colon",
			input:    "password: mySecret123",
			expected: "password: [REDACTED]",
		},
		{
			name:     "api key",
			input:    "api_key: sk_live_1234567890abcdef",
			expected: "api_key: [REDACTED]",
		},
		{
			name:     "bearer token",
			input:    "Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9",
			expected: "Authorization: [REDACTED]",
		},
		{
			name:     "basic auth",
			input:    "Authorization: Basic dXNlcm5hbWU6cGFzc3dvcmQ=",
			expected: "Authorization: [REDACTED]",
		},
		{
			name:     "high entropy string",
			input:    "token: aB3dE5fG7hI9jK1lM3nO5pQ7rS9tU1vW3xY5z",
			expected: "token: [REDACTED]",
		},
		{
			name:     "normal message without secrets",
			input:    "Processing file: /path/to/file.txt",
			expected: "Processing file: /path/to/file.txt",
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			result := sm.RedactSecrets(tt.input)
			if result != tt.expected {
				t.Errorf("RedactSecrets() = %v, want %v", result, tt.expected)
			}
		})
	}
}

// TestSecretValidation tests that secrets are detected correctly
func TestSecretValidation(t *testing.T) {
	sm, err := NewSecretManager()
	if err != nil {
		t.Fatalf("Failed to create secret manager: %v", err)
	}

	tests := []struct {
		name        string
		value       string
		isSecret    bool
		containsMsg string
	}{
		{
			name:        "password pattern",
			value:       "password: mySecret123",
			isSecret:    true,
			containsMsg: "sensitive",
		},
		{
			name:        "api key pattern",
			value:       "api_key: sk_live_1234567890abcdef",
			isSecret:    true,
			containsMsg: "sensitive",
		},
		{
			name:        "high entropy",
			value:       "aB3dE5fG7hI9jK1lM3nO5pQ7rS9tU1vW3xY5z",
			isSecret:    true,
			containsMsg: "sensitive",
		},
		{
			name:        "normal string",
			value:       "hello world",
			isSecret:    false,
			containsMsg: "",
		},
		{
			name:        "short string",
			value:       "abc123",
			isSecret:    false,
			containsMsg: "",
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			isSecret, reason := sm.ValidateSecret(tt.value)
			if isSecret != tt.isSecret {
				t.Errorf("ValidateSecret() isSecret = %v, want %v", isSecret, tt.isSecret)
			}
			if tt.containsMsg != "" && !strings.Contains(reason, tt.containsMsg) {
				t.Errorf("ValidateSecret() reason = %v, want to contain %v", reason, tt.containsMsg)
			}
		})
	}
}

// TestKeychainStorage tests keychain storage operations
// Uses mock keyring in test mode to avoid password prompts
func TestKeychainStorage(t *testing.T) {
	sm, err := NewSecretManager()
	if err != nil {
		t.Fatalf("Failed to create secret manager: %v", err)
	}

	if !sm.IsKeychainAvailable() {
		t.Fatal("Keyring not available")
	}

	service := "test-service"
	account := "test-account"
	secret := "test-secret-value"

	// Clean up any existing test secret
	sm.Delete(service, account)

	// Test storing a secret
	err = sm.Store(service, account, secret)
	if err != nil {
		t.Fatalf("Failed to store secret: %v", err)
	}

	// Test retrieving a secret
	retrieved, err := sm.Retrieve(service, account)
	if err != nil {
		t.Fatalf("Failed to retrieve secret: %v", err)
	}

	if retrieved != secret {
		t.Errorf("Retrieved secret = %v, want %v", retrieved, secret)
	}

	// Test deleting a secret
	err = sm.Delete(service, account)
	if err != nil {
		t.Fatalf("Failed to delete secret: %v", err)
	}

	// Verify secret is deleted
	_, err = sm.Retrieve(service, account)
	if err == nil {
		t.Error("Expected error when retrieving deleted secret, got nil")
	}
}

// TestEncryptedFileStorage tests encrypted file storage operations
func TestEncryptedFileStorage(t *testing.T) {
	sm, err := NewSecretManager()
	if err != nil {
		t.Fatalf("Failed to create secret manager: %v", err)
	}

	// Set a test encryption key
	key := []byte("12345678901234567890123456789012") // 32 bytes
	err = sm.SetEncryptionKey(key)
	if err != nil {
		t.Fatalf("Failed to set encryption key: %v", err)
	}

	// Create a temporary file for testing
	tmpDir := t.TempDir()
	tmpFile := filepath.Join(tmpDir, "secret.enc")

	service := "test-service"
	account := "test-account"
	secret := "test-secret-value"

	// Test storing to file
	err = sm.StoreToFile(tmpFile, service, account, secret)
	if err != nil {
		t.Fatalf("Failed to store secret to file: %v", err)
	}

	// Verify file exists
	if _, err := os.Stat(tmpFile); os.IsNotExist(err) {
		t.Fatal("Encrypted file was not created")
	}

	// Test retrieving from file
	retrievedSecret, err := sm.RetrieveFromFile(tmpFile)
	if err != nil {
		t.Fatalf("Failed to retrieve secret from file: %v", err)
	}

	if retrievedSecret.Service != service {
		t.Errorf("Service = %v, want %v", retrievedSecret.Service, service)
	}

	if retrievedSecret.Account != account {
		t.Errorf("Account = %v, want %v", retrievedSecret.Account, account)
	}

	if retrievedSecret.Value != secret {
		t.Errorf("Value = %v, want %v", retrievedSecret.Value, secret)
	}

	// Test that file is encrypted (not plain text)
	content, err := os.ReadFile(tmpFile)
	if err != nil {
		t.Fatalf("Failed to read encrypted file: %v", err)
	}

	if strings.Contains(string(content), secret) {
		t.Error("Secret appears in plain text in encrypted file")
	}
}

// TestInsecureConfigWarnings tests that insecure config values generate warnings
func TestInsecureConfigWarnings(t *testing.T) {
	sm, err := NewSecretManager()
	if err != nil {
		t.Fatalf("Failed to create secret manager: %v", err)
	}

	tests := []struct {
		name          string
		config        map[string]string
		expectWarning bool
	}{
		{
			name: "config with password",
			config: map[string]string{
				"database_password": "mySecret123",
			},
			expectWarning: true,
		},
		{
			name: "config with api key",
			config: map[string]string{
				"api_key": "sk_live_1234567890abcdef",
			},
			expectWarning: true,
		},
		{
			name: "config with normal values",
			config: map[string]string{
				"host":     "localhost",
				"port":     "8080",
				"username": "admin",
			},
			expectWarning: false,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			configMap := make(map[string]interface{})
			for k, v := range tt.config {
				configMap[k] = v
			}

			// Convert to map[string]string for ValidateConfig
			configStrMap := make(map[string]string)
			for k, v := range configMap {
				configStrMap[k] = fmt.Sprintf("%v", v)
			}

			warnings := sm.ValidateConfig(configStrMap)
			hasWarning := len(warnings) > 0

			if hasWarning != tt.expectWarning {
				t.Errorf("ValidateConfig() hasWarning = %v, want %v", hasWarning, tt.expectWarning)
			}
		})
	}
}

// TestWarnInsecureConfig tests the warning output for insecure config
func TestWarnInsecureConfig(t *testing.T) {
	sm, err := NewSecretManager()
	if err != nil {
		t.Fatalf("Failed to create secret manager: %v", err)
	}

	// Capture stderr output
	oldStderr := os.Stderr
	r, w, _ := os.Pipe()
	os.Stderr = w

	sm.WarnInsecureConfig("api_key", "sk_live_1234567890abcdef")

	w.Close()
	os.Stderr = oldStderr

	var output strings.Builder
	io.Copy(&output, r)
	result := output.String()

	if !strings.Contains(result, "WARNING") {
		t.Error("Warning output does not contain 'WARNING'")
	}

	if !strings.Contains(result, "api_key") {
		t.Error("Warning output does not contain key name")
	}

	if !strings.Contains(result, "secure storage") {
		t.Error("Warning output does not contain recommendation")
	}
}

// TestEncryptionKeyValidation tests that encryption key validation works
func TestEncryptionKeyValidation(t *testing.T) {
	sm, err := NewSecretManager()
	if err != nil {
		t.Fatalf("Failed to create secret manager: %v", err)
	}

	// Test invalid key length
	shortKey := []byte("short")
	err = sm.SetEncryptionKey(shortKey)
	if err == nil {
		t.Error("Expected error for short encryption key, got nil")
	}

	// Test valid key length
	validKey := []byte("12345678901234567890123456789012")
	err = sm.SetEncryptionKey(validKey)
	if err != nil {
		t.Errorf("Expected no error for valid encryption key, got %v", err)
	}
}

// TestHighEntropyDetection tests the entropy-based secret detection
func TestHighEntropyDetection(t *testing.T) {
	sm, err := NewSecretManager()
	if err != nil {
		t.Fatalf("Failed to create secret manager: %v", err)
	}

	tests := []struct {
		name     string
		value    string
		isSecret bool
	}{
		{
			name:     "high entropy random string",
			value:    "aB3dE5fG7hI9jK1lM3nO5pQ7rS9tU1vW3xY5z",
			isSecret: true,
		},
		{
			name:     "low entropy readable string",
			value:    "hello world this is a test",
			isSecret: false,
		},
		{
			name:     "medium entropy with patterns",
			value:    "user123@example.com",
			isSecret: false,
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			isSecret, _ := sm.ValidateSecret(tt.value)
			if isSecret != tt.isSecret {
				t.Errorf("ValidateSecret() isSecret = %v, want %v", isSecret, tt.isSecret)
			}
		})
	}
}

// TestGetSupportedBackends tests that supported backends are returned
func TestGetSupportedBackends(t *testing.T) {
	sm, err := NewSecretManager()
	if err != nil {
		t.Fatalf("Failed to create secret manager: %v", err)
	}

	backends := sm.GetSupportedBackends()
	if len(backends) == 0 {
		t.Error("Expected at least one supported backend")
	}

	// Check that expected backends are mentioned
	allBackends := strings.Join(backends, " ")
	if !strings.Contains(allBackends, "keychain") {
		t.Error("Expected 'keychain' in supported backends")
	}
}

