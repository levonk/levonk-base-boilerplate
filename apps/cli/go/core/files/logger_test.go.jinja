package main

import (
	"bytes"
	"os"
	"strings"
	"testing"
)

func TestColorModeAuto(t *testing.T) {
	logger := NewLogger("test")
	logger.SetColorMode("auto")

	// Test that color mode is set to ColorAuto
	if logger.colorMode != ColorAuto {
		t.Errorf("Expected colorMode to be ColorAuto, got %v", logger.colorMode)
	}
}

func TestColorModeAlways(t *testing.T) {
	logger := NewLogger("test")
	logger.SetColorMode("always")

	// Test that color mode is set to ColorAlways
	if logger.colorMode != ColorAlways {
		t.Errorf("Expected colorMode to be ColorAlways, got %v", logger.colorMode)
	}
}

func TestColorModeNever(t *testing.T) {
	logger := NewLogger("test")
	logger.SetColorMode("never")

	// Test that color mode is set to ColorNever
	if logger.colorMode != ColorNever {
		t.Errorf("Expected colorMode to be ColorNever, got %v", logger.colorMode)
