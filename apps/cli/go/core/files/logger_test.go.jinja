	logger.Debug("debug message")

	output := buf.String()
	if output != "" {
		t.Error("Debug messages should not appear when debug is false")
	}

	logger.SetDebug(true)
	logger.Debug("debug message")

	output = buf.String()
	if output == "" {
		t.Error("Debug messages should appear when debug is true")
	}
	if !strings.Contains(output, "DEBUG") {
		t.Error("Debug messages should contain DEBUG level")
	}
}

