func TestLogLevelUpdate(t *testing.T) {
	// Test that log level updates when settings change
	var buf bytes.Buffer
	logger := NewLogger("test")
	logger.SetWriter(&buf)

	// Initial level should be based on resolveLogLevel
	initialLevel := logger.logrusLogger.GetLevel()

	// Set debug mode
	logger.SetDebug(true)
	if logger.logrusLogger.GetLevel() != logrus.DebugLevel {
		t.Error("SetDebug(true) should set log level to DebugLevel")
	}

	// Set quiet mode
	logger.SetDebug(false)
	logger.SetQuiet(true)
	if logger.logrusLogger.GetLevel() != logrus.ErrorLevel {
		t.Error("SetQuiet(true) should set log level to ErrorLevel")
	}

	// Reset to normal
	logger.SetQuiet(false)
	logger.SetVerbose(true)
	if logger.logrusLogger.GetLevel() != logrus.InfoLevel {
		t.Error("SetVerbose(true) should set log level to InfoLevel")
	}

	// Restore initial
	logger.SetVerbose(false)
	if logger.logrusLogger.GetLevel() != initialLevel {
		t.Error("Resetting should restore initial log level")
	}
}
