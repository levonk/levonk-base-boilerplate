func TestDebugIsSeparateFromVerbose(t *testing.T) {
	var buf bytes.Buffer
	logger := NewLogger("test")
	logger.SetWriter(&buf)

	// Test with debug=true, verbose=false
	logger.SetDebug(true)
	logger.SetVerbose(false)
	logger.Debug("debug message")

	output := buf.String()
	if output == "" {
		t.Error("Debug should work independently of verbose")
	}

	// Clear buffer
	buf.Reset()

	// Test with debug=false, verbose=true
	logger.SetDebug(false)
	logger.SetVerbose(true)
	logger.Debug("debug message")

	output = buf.String()
	if output != "" {
		t.Error("Debug should not appear when debug is false, even if verbose is true")
	}
}

func TestStructuredLoggingJSONFormat(t *testing.T) {
	// Test that non-TTY output uses JSON format
	var buf bytes.Buffer
	logger := NewLogger("test")
	logger.SetWriter(&buf)

	// Force JSON formatter by setting to non-TTY
	logger.logrusLogger.SetFormatter(&logrus.JSONFormatter{})

	logger.Info("test message")

	output := buf.String()
	// JSON format should contain structured fields
	if !strings.Contains(output, "test message") {
		t.Error("Output should contain the test message")
	}
	if !strings.Contains(output, "module") {
		t.Error("JSON output should contain module field")
	}
	if !strings.Contains(output, "level") {
		t.Error("JSON output should contain level field")
	}
	if !strings.Contains(output, "time") {
		t.Error("JSON output should contain time field")
	}
}

