func TestLOG_LEVELEnvVar(t *testing.T) {
	// Test LOG_LEVEL environment variable precedence
	oldLogLevel := os.Getenv("LOG_LEVEL")
	defer os.Setenv("LOG_LEVEL", oldLogLevel)

	// Set LOG_LEVEL to DEBUG
	os.Setenv("LOG_LEVEL", "DEBUG")

	// Reset viper to avoid interference
	viper.Reset()

	level := resolveLogLevel()
	if level != logrus.DebugLevel {
		t.Errorf("LOG_LEVEL=DEBUG should resolve to DebugLevel, got %v", level)
	}

	// Test other levels
	os.Setenv("LOG_LEVEL", "INFO")
	level = resolveLogLevel()
	if level != logrus.InfoLevel {
		t.Errorf("LOG_LEVEL=INFO should resolve to InfoLevel, got %v", level)
	}

	os.Setenv("LOG_LEVEL", "WARN")
	level = resolveLogLevel()
	if level != logrus.WarnLevel {
		t.Errorf("LOG_LEVEL=WARN should resolve to WarnLevel, got %v", level)
	}

	os.Setenv("LOG_LEVEL", "ERROR")
	level = resolveLogLevel()
	if level != logrus.ErrorLevel {
		t.Errorf("LOG_LEVEL=ERROR should resolve to ErrorLevel, got %v", level)
	}
}

func TestLogLevelResolutionPrecedence(t *testing.T) {
	// Test precedence: env vars > CLI flags > config file > defaults

	// Reset viper
	viper.Reset()

	// 1. Test default (no env, no flags, no config)
	oldLogLevel := os.Getenv("LOG_LEVEL")
	os.Unsetenv("LOG_LEVEL")
	defer os.Setenv("LOG_LEVEL", oldLogLevel)

	level := resolveLogLevel()
	if level != logrus.InfoLevel {
		t.Errorf("Default should be InfoLevel, got %v", level)
	}

	// 2. Test config file precedence (no env, no flags)
	viper.Set("log_level", "DEBUG")
	level = resolveLogLevel()
	if level != logrus.DebugLevel {
		t.Errorf("Config log_level=DEBUG should resolve to DebugLevel, got %v", level)
	}

	// 3. Test CLI flag precedence (no env)
	viper.Set("debug", true)
	level = resolveLogLevel()
	if level != logrus.DebugLevel {
		t.Errorf("CLI flag debug=true should resolve to DebugLevel, got %v", level)
	}

	// 4. Test env var precedence (highest)
	os.Setenv("LOG_LEVEL", "ERROR")
	level = resolveLogLevel()
	if level != logrus.ErrorLevel {
		t.Errorf("LOG_LEVEL=ERROR should override CLI flags and config, got %v", level)
	}

	// Cleanup
	viper.Reset()
}

func TestStructuredLoggingFields(t *testing.T) {
	// Test that structured logs include consistent fields
	var buf bytes.Buffer
	logger := NewLogger("test")
	logger.SetWriter(&buf)
	logger.logrusLogger.SetFormatter(&logrus.JSONFormatter{})

	logger.Info("test message")

	output := buf.String()

	// Check for consistent fields
	if !strings.Contains(output, "module") {
		t.Error("Structured logs should include module field")
	}
	if !strings.Contains(output, "test") {
		t.Error("Module field should be 'test'")
	}
	if !strings.Contains(output, "level") {
		t.Error("Structured logs should include level field")
	}
	if !strings.Contains(output, "time") {
		t.Error("Structured logs should include time field")
	}
	if !strings.Contains(output, "msg") {
		t.Error("Structured logs should include msg field")
	}
}

