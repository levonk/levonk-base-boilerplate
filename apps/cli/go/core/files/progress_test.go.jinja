package main

import (
	"bytes"
	"io"
	"strings"
	"testing"
)

func TestNewProgressBar(t *testing.T) {
	t.Run("creates progress bar when not quiet", func(t *testing.T) {
		config := ProgressConfig{
			Total:      100,
			Description: "Test",
			Quiet:      false,
		}
		bar := NewProgressBar(config)
		if bar == nil {
			t.Error("Expected non-nil progress bar when quiet is false")
		}
	})

	t.Run("returns nil when quiet", func(t *testing.T) {
		config := ProgressConfig{
			Total:      100,
			Description: "Test",
			Quiet:      true,
		}
		bar := NewProgressBar(config)
		if bar != nil {
			t.Error("Expected nil progress bar when quiet is true")
		}
	})
}

func TestProgressWriter(t *testing.T) {
	t.Run("writes data and tracks progress", func(t *testing.T) {
		var buf bytes.Buffer
		bar := NewProgressBar(ProgressConfig{
			Total:      10,
			Description: "Test",
			Quiet:      true, // Suppress output in test
		})

		pw := NewProgressWriter(&buf, bar, 10)
		data := []byte("hello")
		n, err := pw.Write(data)

		if err != nil {
			t.Errorf("Unexpected error: %v", err)
		}
		if n != len(data) {
			t.Errorf("Expected to write %d bytes, wrote %d", len(data), n)
		}
		if pw.written != int64(len(data)) {
			t.Errorf("Expected written to be %d, got %d", len(data), pw.written)
		}
		if buf.String() != string(data) {
			t.Errorf("Expected buffer to contain %q, got %q", string(data), buf.String())
		}
	})
}

func TestProgressReader(t *testing.T) {
	t.Run("reads data and tracks progress", func(t *testing.T) {
		data := []byte("hello world")
		reader := bytes.NewReader(data)
		bar := NewProgressBar(ProgressConfig{
			Total:      int64(len(data)),
			Description: "Test",
			Quiet:      true, // Suppress output in test
		})

		pr := NewProgressReader(reader, bar, int64(len(data)))
		buf := make([]byte, 5)
		n, err := pr.Read(buf)

		if err != nil {
			t.Errorf("Unexpected error: %v", err)
		}
		if n != 5 {
			t.Errorf("Expected to read 5 bytes, read %d", n)
		}
		if pr.read != 5 {
			t.Errorf("Expected read to be 5, got %d", pr.read)
		}
		if string(buf) != "hello" {
			t.Errorf("Expected buffer to contain 'hello', got %q", string(buf))
		}
	})
}

func TestProgressWriterMultipleWrites(t *testing.T) {
	t.Run("tracks progress across multiple writes", func(t *testing.T) {
		var buf bytes.Buffer
		bar := NewProgressBar(ProgressConfig{
			Total:      20,
			Description: "Test",
			Quiet:      true,
		})

		pw := NewProgressWriter(&buf, bar, 20)
		pw.Write([]byte("hello"))
		pw.Write([]byte(" world"))
		pw.Write([]byte(" test"))

		if pw.written != 16 {
			t.Errorf("Expected written to be 16, got %d", pw.written)
		}
		if buf.String() != "hello world test" {
			t.Errorf("Expected buffer to contain 'hello world test', got %q", buf.String())
		}
	})
}

func TestProgressReaderFullRead(t *testing.T) {
	t.Run("reads all data and tracks total progress", func(t *testing.T) {
		data := []byte("hello world")
		reader := bytes.NewReader(data)
		bar := NewProgressBar(ProgressConfig{
			Total:      int64(len(data)),
			Description: "Test",
			Quiet:      true,
		})

		pr := NewProgressReader(reader, bar, int64(len(data)))
		buf := make([]byte, len(data))
		n, err := io.ReadFull(pr, buf)

		if err != nil {
			t.Errorf("Unexpected error: %v", err)
		}
		if n != len(data) {
			t.Errorf("Expected to read %d bytes, read %d", len(data), n)
		}
		if pr.read != int64(len(data)) {
			t.Errorf("Expected read to be %d, got %d", len(data), pr.read)
		}
		if string(buf) != string(data) {
			t.Errorf("Expected buffer to contain %q, got %q", string(data), string(buf))
		}
	})
}

func TestProgressQuietMode(t *testing.T) {
	t.Run("progress bar is nil in quiet mode", func(t *testing.T) {
		config := ProgressConfig{
			Total:      100,
			Description: "Test",
			Quiet:      true,
		}
		bar := NewProgressBar(config)

		if bar != nil {
			t.Error("Progress bar should be nil in quiet mode")
		}

		// Test that writer works without progress bar
		var buf bytes.Buffer
		pw := NewProgressWriter(&buf, bar, 100)
		pw.Write([]byte("test"))

		if buf.String() != "test" {
			t.Errorf("Writer should still work without progress bar")
		}
	})
}

func TestProgressAccuracy(t *testing.T) {
	t.Run("progress tracking is accurate", func(t *testing.T) {
		data := strings.Repeat("x", 1000)
		reader := strings.NewReader(data)
		bar := NewProgressBar(ProgressConfig{
			Total:      1000,
			Description: "Test",
			Quiet:      true,
		})

		pr := NewProgressReader(reader, bar, 1000)
		buf := make([]byte, 100)
		totalRead := 0

		for {
			n, err := pr.Read(buf)
			if err == io.EOF {
				break
			}
			if err != nil {
				t.Errorf("Unexpected error: %v", err)
				break
			}
			totalRead += n
		}

		if totalRead != 1000 {
			t.Errorf("Expected to read 1000 bytes total, read %d", totalRead)
		}
		if pr.read != 1000 {
			t.Errorf("Expected progress reader to track 1000 bytes, tracked %d", pr.read)
		}
	})
}
