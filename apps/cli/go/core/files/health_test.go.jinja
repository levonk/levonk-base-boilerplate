func TestCheckHealth(t *testing.T) {
	status := checkHealth()

	if status.Status != "healthy" {
		t.Errorf("Expected status to be 'healthy', got '%s'", status.Status)
	}

	if status.Version == "" {
		t.Error("Expected version to be set")
	}

	if status.Uptime == "" {
		t.Error("Expected uptime to be set")
	}

	if status.Timestamp.IsZero() {
		t.Error("Expected timestamp to be set")
	}
}

func TestCheckHealthNoSideEffects(t *testing.T) {
	// Call health check multiple times to ensure no side effects
	status1 := checkHealth()
	status2 := checkHealth()

	// Status should always be healthy
	if status1.Status != "healthy" || status2.Status != "healthy" {
		t.Error("Health check should always return healthy status")
	}

	// Uptime should increase (no side effects on state)
	if status2.Timestamp.Before(status1.Timestamp) {
		t.Error("Timestamp should not go backwards")
	}
}

func TestCheckHealthResponseTime(t *testing.T) {
	start := time.Now()
	status := checkHealth()
	elapsed := time.Since(start)

	if elapsed > 100*time.Millisecond {
		t.Errorf("Health check took too long: %v (should be <100ms)", elapsed)
	}

	if status.Status != "healthy" {
		t.Errorf("Expected status to be 'healthy', got '%s'", status.Status)
	}
}

func TestHealthHandler(t *testing.T) {
	req := httptest.NewRequest("GET", "/health", nil)
	w := httptest.NewRecorder()

	healthHandler(w, req)

	if w.Code != http.StatusOK {
		t.Errorf("Expected status code %d, got %d", http.StatusOK, w.Code)
	}

	var status HealthStatus
	if err := json.NewDecoder(w.Body).Decode(&status); err != nil {
		t.Fatalf("Failed to decode response: %v", err)
	}

	if status.Status != "healthy" {
		t.Errorf("Expected status to be 'healthy', got '%s'", status.Status)
	}
}

func TestHealthHandlerHealthz(t *testing.T) {
	req := httptest.NewRequest("GET", "/healthz", nil)
	w := httptest.NewRecorder()

	healthHandler(w, req)

	if w.Code != http.StatusOK {
		t.Errorf("Expected status code %d, got %d", http.StatusOK, w.Code)
	}
}

func TestHealthHandlerResponseTime(t *testing.T) {
	req := httptest.NewRequest("GET", "/health", nil)
	w := httptest.NewRecorder()

	start := time.Now()
	healthHandler(w, req)
	elapsed := time.Since(start)

	if elapsed > 100*time.Millisecond {
		t.Errorf("Health handler took too long: %v (should be <100ms)", elapsed)
	}

	// Check that response time header is set
	responseTime := w.Header().Get("X-Response-Time")
	if responseTime == "" {
		t.Error("Expected X-Response-Time header to be set")
	}
}

func TestHealthHandlerContentType(t *testing.T) {
	req := httptest.NewRequest("GET", "/health", nil)
	w := httptest.NewRecorder()

	healthHandler(w, req)

	contentType := w.Header().Get("Content-Type")
	if contentType != "application/json" {
		t.Errorf("Expected Content-Type to be 'application/json', got '%s'", contentType)
	}
}

