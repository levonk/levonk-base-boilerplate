	// This test verifies that the signal handler can be set up without panicking
	// We can't easily test the actual signal handling in a unit test

	// Reset signal handlers if already set
	// Note: This is a minimal test to ensure the function doesn't panic
	defer func() {
		if r := recover(); r != nil {
			t.Errorf("SetupSignalHealthCheck panicked: %v", r)
		}
