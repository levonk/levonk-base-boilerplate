// IsRunningUnderAgent checks if the CLI is running under an agent
// by examining the parent process
func IsRunningUnderAgent() (bool, error) {
	parentName, err := GetParentProcessName()
	if err != nil {
		return false, err
	}

	// Known agent process names
	agentProcesses := map[string]bool{
		"claude": true,
		"codex": true,
		"cursor": true,
		"windsurf": true,
		"copilot": true,
	}

	if agentProcesses[parentName] {
		return true, nil
	}

	return false, nil
}

// DetectMode automatically detects the appropriate mode based on environment
// Returns agent mode if no TTY or agent session detected, human mode otherwise
func DetectMode() Mode {
	// If no TTY, assume agent mode
	if !IsTerminal() {
		return ModeAgent
	}

	// If agent session detected, use agent mode
	if IsAgentSession() {
		return ModeAgent
	}

	// Check if running under agent process
	if runningUnderAgent, err := IsRunningUnderAgent(); err == nil && runningUnderAgent {
		return ModeAgent
	}

	// Default to human mode when TTY present and no agent detected
	return ModeHuman
}

// DetermineMode determines the mode based on precedence chain:
// CLI flags > env vars > config file > auto-detection
func DetermineMode(humanFlag bool, configMode string) Mode {
	// 1. CLI flags have highest precedence
	if humanFlag {
		return ModeHuman
	}

	// 2. Environment variables
	envMode := GetModeFromEnv()
	if envMode != "" {
		return Mode(envMode)
	}

	// 3. Config file setting
	if configMode != "" {
		mode := Mode(configMode)
		if mode.IsValid() {
			return mode
		}
	}

	// 4. Auto-detection
	return DetectMode()
}

// ConfigValidationError represents a configuration validation error with context
type ConfigValidationError struct {
	Field       string
	LineNumber  int
	Description string
	Suggestion  string
}

func (e ConfigValidationError) Error() string {
	return fmt.Sprintf("config error at line %d: %s (field: %s). Suggestion: %s", e.LineNumber, e.Description, e.Field, e.Suggestion)
}

// ConfigSchema defines the validation rules for configuration fields
type ConfigSchema struct {
	Fields map[string]FieldSchema
}

// FieldSchema defines validation rules for a single field
type FieldSchema struct {
	Type         string   // "bool", "string", "int", "enum"
	Required     bool
	AllowedValues []string // For enum types
	DefaultValue interface{}
}

// GetConfigSchema returns the configuration schema
func GetConfigSchema() ConfigSchema {
	return ConfigSchema{
		Fields: map[string]FieldSchema{
			"quiet": {
				Type:         "bool",
				Required:     false,
				DefaultValue: false,
			},
			"verbose": {
				Type:         "bool",
				Required:     false,
				DefaultValue: false,
			},
			"debug": {
				Type:         "bool",
				Required:     false,
				DefaultValue: false,
			},
			"color": {
				Type:         "enum",
				Required:     false,
				AllowedValues: []string{"auto", "always", "never"},
				DefaultValue: "auto",
			},
			"json": {
				Type:         "bool",
				Required:     false,
				DefaultValue: false,
			},
			"mode": {
				Type:         "enum",
				Required:     false,
				AllowedValues: []string{string(ModeAgent), string(ModeHuman)},
				DefaultValue: string(ModeAgent),
			},
			"default_format": {
				Type:         "enum",
				Required:     false,
				AllowedValues: []string{string(FormatToon), string(FormatJSON), string(FormatHuman)},
				DefaultValue: string(FormatToon),
			},
			"truncation_limit": {
				Type:         "int",
				Required:     false,
				DefaultValue: 1000,
			},
			"enable_contextual_help": {
				Type:         "bool",
				Required:     false,
				DefaultValue: true,
			},
			"session_context_enabled": {
				Type:         "bool",
				Required:     false,
				DefaultValue: false,
			},
		},
	}
}

// ValidateConfig validates a configuration map against the schema
func ValidateConfig(config map[string]interface{}, configPath string) []ConfigValidationError {
	var errors []ConfigValidationError
	schema := GetConfigSchema()

	// Read config file to get line numbers
	content, err := os.ReadFile(configPath)
	if err != nil {
		// If we can't read the file, we can't provide line numbers
		// Still validate the values, just without line numbers
		for field, value := range config {
			if fieldSchema, ok := schema.Fields[field]; ok {
				if err := validateField(field, value, fieldSchema); err != nil {
					errors = append(errors, ConfigValidationError{
						Field:       field,
						LineNumber:  0,
						Description: err.Error(),
						Suggestion:  getErrorSuggestion(field, err),
					})
				}
			}
		}
		return errors
	}

	lines := strings.Split(string(content), "\n")

	// Validate each field
	for field, value := range config {
		if fieldSchema, ok := schema.Fields[field]; ok {
			lineNumber := findLineNumber(lines, field)
			if err := validateField(field, value, fieldSchema); err != nil {
				errors = append(errors, ConfigValidationError{
					Field:       field,
					LineNumber:  lineNumber,
					Description: err.Error(),
					Suggestion:  getErrorSuggestion(field, err),
				})
			}
		}
	}

	// Check for secrets in config values
	secretWarnings := ValidateConfigForSecrets(config)
	for _, warning := range secretWarnings {
		fmt.Fprintf(os.Stderr, "WARNING: %s\n", warning)
	}

	return errors
}

// ValidateConfigForSecrets checks a config map for insecure secret storage
func ValidateConfigForSecrets(config map[string]interface{}) []string {
	warnings := []string{}

	// Initialize a secret manager for validation
	sm, err := NewSecretManager()
	if err != nil {
		// If we can't initialize the secret manager, skip validation
		return warnings
	}

	// Check each config value
	for key, value := range config {
		strValue, ok := value.(string)
		if !ok {
			continue
		}

		isSecret, reason := sm.ValidateSecret(strValue)
		if isSecret {
			warning := fmt.Sprintf("Insecure config detected: key '%s' - %s. Use secure storage (keychain or encrypted file) instead.", key, reason)
			warnings = append(warnings, warning)
		}
	}

	return warnings
}

// validateField validates a single field against its schema
func validateField(field string, value interface{}, schema FieldSchema) error {
	switch schema.Type {
	case "bool":
		if _, ok := value.(bool); !ok {
			return fmt.Errorf("expected boolean, got %T", value)
		}
	case "string":
		if _, ok := value.(string); !ok {
			return fmt.Errorf("expected string, got %T", value)
		}
	case "int":
		if _, ok := value.(int); !ok {
			return fmt.Errorf("expected integer, got %T", value)
		}
	case "enum":
		strValue, ok := value.(string)
		if !ok {
			return fmt.Errorf("expected string for enum, got %T", value)
		}
		valid := false
		for _, allowed := range schema.AllowedValues {
			if strValue == allowed {
				valid = true
				break
			}
		}
		if !valid {
			return fmt.Errorf("invalid value '%s', allowed values: %v", strValue, schema.AllowedValues)
		}
	}
	return nil
}

// findLineNumber finds the line number where a field is defined
func findLineNumber(lines []string, field string) int {
	for i, line := range lines {
		if strings.Contains(line, field+":") {
			return i + 1 // Line numbers are 1-indexed
		}
	}
	return 0
}

// getErrorSuggestion provides a suggestion for fixing a validation error
func getErrorSuggestion(field string, err error) string {
	errMsg := err.Error()

	if strings.Contains(errMsg, "expected boolean") {
		return fmt.Sprintf("Set %s to true or false", field)
	}
	if strings.Contains(errMsg, "expected string") {
		return fmt.Sprintf("Set %s to a string value", field)
	}
	if strings.Contains(errMsg, "expected integer") {
		return fmt.Sprintf("Set %s to an integer value", field)
	}
	if strings.Contains(errMsg, "invalid value") {
		return fmt.Sprintf("Check the allowed values for %s in the config schema", field)
	}

	return fmt.Sprintf("Review the configuration for field %s", field)
}

// ReloadConfig reloads the configuration from the config file
// It validates the new config before applying it, and keeps the old config if validation fails
func ReloadConfig(configPath string, logger *Logger) error {
	logger.Info("Attempting to reload configuration from %s", configPath)

	// Read the new config file
	newConfig, err := parseConfigContentFromFile(configPath)
	if err != nil {
		logger.Error("Failed to read config file during reload: %v", err)
		return fmt.Errorf("failed to read config file: %w", err)
	}

	// Validate the new config
	validationErrors := ValidateConfig(newConfig, configPath)
	if len(validationErrors) > 0 {
		logger.Error("Config validation failed during reload, keeping old config")
		for _, validationErr := range validationErrors {
			logger.Error("  - %s", validationErr.Error())
		}
		return fmt.Errorf("config validation failed with %d error(s)", len(validationErrors))
	}

	// Config is valid, apply it
	// In a real implementation, this would update the global config state
	// For now, we just log that the reload was successful
	logger.Info("Configuration reloaded successfully")
	return nil
}

// parseConfigContentFromFile reads and parses the config file
func parseConfigContentFromFile(configPath string) (map[string]interface{}, error) {
	content, err := os.ReadFile(configPath)
	if err != nil {
		return nil, fmt.Errorf("failed to read config file: %w", err)
	}

	return parseConfigContent(string(content))
}

