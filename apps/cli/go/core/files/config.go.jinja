// Mode represents the CLI operation mode
type Mode string

const (
	// ModeAgent is the agent mode (default for non-interactive environments)
	ModeAgent Mode = "agent"
	// ModeHuman is the human mode (interactive)
	ModeHuman Mode = "human"
)

// String returns the string representation of the mode
func (m Mode) String() string {
	return string(m)
}

// IsValid checks if the mode is valid
func (m Mode) IsValid() bool {
	return m == ModeAgent || m == ModeHuman
}

// Format represents the output format
type Format string

const (
	// FormatToon is the TOON format (structured, agent-friendly)
	FormatToon Format = "toon"
	// FormatJSON is the JSON format
	FormatJSON Format = "json"
	// FormatHuman is the human-readable format
	FormatHuman Format = "human"
)

// String returns the string representation of the format
func (f Format) String() string {
	return string(f)
}

// IsValid checks if the format is valid
func (f Format) IsValid() bool {
	return f == FormatToon || f == FormatJSON || f == FormatHuman
}

// IsFirstRun checks if this is the first run by detecting if the config file exists
func IsFirstRun(configPath string) bool {
	if configPath == "" {
		return true
	}
	_, err := os.Stat(configPath)
	return os.IsNotExist(err)
}

// GetConfigPath returns the default config file path
func GetConfigPath() (string, error) {
	configDir, err := os.UserConfigDir()
	if err != nil {
		return "", fmt.Errorf("failed to get user config directory: %w", err)
	}
	configPath := filepath.Join(configDir, "{{ project_slug }}", "config.yaml")
	return configPath, nil
}

// ValidateConfigPath checks if the config path is valid and accessible
func ValidateConfigPath(configPath string) error {
	if configPath == "" {
		return fmt.Errorf("config path cannot be empty")
	}

	// Check if the path is absolute
	if !filepath.IsAbs(configPath) {
		return fmt.Errorf("config path must be absolute: %s", configPath)
	}

	// Check if the parent directory is accessible
	configDir := filepath.Dir(configPath)
	if _, err := os.Stat(configDir); err != nil {
		if os.IsNotExist(err) {
			// Directory doesn't exist yet, which is okay for first run
			return nil
		}
		return fmt.Errorf("config directory is not accessible: %w", err)
	}

	// If config file exists, check if it's readable
	if _, err := os.Stat(configPath); err == nil {
		file, err := os.Open(configPath)
		if err != nil {
			return fmt.Errorf("config file exists but is not readable: %w", err)
		}
		file.Close()
	}

	return nil
}

// EnsureConfigDir creates the config directory if it doesn't exist
func EnsureConfigDir(configPath string) error {
	configDir := filepath.Dir(configPath)
	if _, err := os.Stat(configDir); os.IsNotExist(err) {
		if err := os.MkdirAll(configDir, 0755); err != nil {
			return fmt.Errorf("failed to create config directory: %w", err)
		}
	}
	return nil
}

// CreateDefaultConfig creates a default config file with all settings commented out
func CreateDefaultConfig(configPath string) error {
	// Ensure the config directory exists
	if err := EnsureConfigDir(configPath); err != nil {
		return err
	}

	// Create a basic default config file
	// This will be replaced with the full template in the next sub-task
	defaultConfig := `# Default configuration for {{ project_name }}
# All settings are commented out with their default values
# Uncomment and modify as needed

# Example setting:
# setting_name: default_value
`

	if err := os.WriteFile(configPath, []byte(defaultConfig), 0600); err != nil {
		return fmt.Errorf("failed to create default config file: %w", err)
	}

	return nil
}

// InitConfigIfNeeded initializes the config file if it doesn't exist
// This should be called during application initialization
func InitConfigIfNeeded(configPath string) error {
	if IsFirstRun(configPath) {
		if err := CreateDefaultConfig(configPath); err != nil {
			return fmt.Errorf("failed to initialize config file: %w", err)
		}
	}
	return nil
}

// SupportsLegacyFormat checks if the config file is in legacy format
func SupportsLegacyFormat(configPath string) bool {
	if _, err := os.Stat(configPath); os.IsNotExist(err) {
		return false
	}

	content, err := os.ReadFile(configPath)
	if err != nil {
		return false
	}

	// Check for version field - if missing, it's legacy format
	config, err := parseConfigContent(string(content))
	if err != nil {
		return true // If we can't parse it, assume legacy
	}

	_, hasVersion := config["version"]
	return !hasVersion
}

// parseConfigContent parses config file content into a map
// This is a simplified parser for both legacy and new formats
func parseConfigContent(content string) (map[string]interface{}, error) {
	config := make(map[string]interface{})

	// Simple YAML-like parser
	lines := splitLines(content)
	for _, line := range lines {
		line = trimSpace(line)
		if len(line) == 0 || line[0] == '#' {
			continue
		}

		parts := splitColon(line)
		if len(parts) == 2 {
			key := trimSpace(parts[0])
			value := trimSpace(parts[1])

			// Try to parse as integer first
			if intVal, err := parseInt(value); err == nil {
				config[key] = intVal
			} else if boolVal, err := parseBool(value); err == nil {
				config[key] = boolVal
			} else {
				// Keep as string (remove quotes if present)
				config[key] = unquote(value)
			}
		}
	}

	return config, nil
}

// Helper functions for parsing
func splitLines(s string) []string {
	var lines []string
	start := 0
	for i := 0; i < len(s); i++ {
		if s[i] == '\n' {
			lines = append(lines, s[start:i])
			start = i + 1
		}
	}
	if start < len(s) {
		lines = append(lines, s[start:])
	}
	return lines
}

func trimSpace(s string) string {
	start := 0
	for start < len(s) && (s[start] == ' ' || s[start] == '\t') {
		start++
	}
	end := len(s)
	for end > start && (s[end-1] == ' ' || s[end-1] == '\t' || s[end-1] == '\r') {
		end--
	}
	return s[start:end]
}

func splitColon(s string) []string {
	for i := 0; i < len(s); i++ {
		if s[i] == ':' {
			return []string{s[:i], s[i+1:]}
		}
	}
	return []string{s}
}

// parseInt parses a string as an integer
func parseInt(s string) (int, error) {
	var result int
	for _, c := range s {
		if c >= '0' && c <= '9' {
			result = result*10 + int(c-'0')
		} else {
			return 0, fmt.Errorf("not a number")
		}
	}
	return result, nil
}

// parseBool parses a string as a boolean
func parseBool(s string) (bool, error) {
	switch s {
	case "true", "True", "TRUE":
		return true, nil
	case "false", "False", "FALSE":
		return false, nil
	default:
		return false, fmt.Errorf("not a boolean")
	}
}

// unquote removes quotes from a string if present
func unquote(s string) string {
	if len(s) >= 2 {
		if (s[0] == '"' && s[len(s)-1] == '"') || (s[0] == '\'' && s[len(s)-1] == '\'') {
			return s[1 : len(s)-1]
		}
	}
	return s
}

// GetLocalProjectConfigPath returns the path to a local project config file
// This looks for .config/{project_slug}/config.yaml in the current directory or parent directories
func GetLocalProjectConfigPath() (string, error) {
	currentDir, err := os.Getwd()
	if err != nil {
		return "", fmt.Errorf("failed to get current directory: %w", err)
	}

	// Search for .config/{project_slug}/config.yaml in current directory and parents
	dir := currentDir
	for {
		configPath := filepath.Join(dir, ".config", "{{ project_slug }}", "config.yaml")
		if _, err := os.Stat(configPath); err == nil {
			return configPath, nil
		}

		// Move to parent directory
		parentDir := filepath.Dir(dir)
		if parentDir == dir {
			// Reached root, no local config found
			return "", nil
		}
		dir = parentDir
	}
}

// GetSystemConfigPath returns the path to the system/enterprise config file
// This is typically /etc/{project_slug}/config.yaml
func GetSystemConfigPath() (string, error) {
	systemConfigPath := filepath.Join("/etc", "{{ project_slug }}", "config.yaml")
	return systemConfigPath, nil
}

// GetConfigPrecedence returns a list of config paths in precedence order
// from lowest to highest priority (excluding CLI args and env vars)
// Order: system config -> user config -> local project config
func GetConfigPrecedence() ([]string, error) {
	var configPaths []string

	// 1. System/enterprise config (lowest priority)
	systemConfig, err := GetSystemConfigPath()
	if err != nil {
		return nil, err
	}
	if _, err := os.Stat(systemConfig); err == nil {
		configPaths = append(configPaths, systemConfig)
	}

	// 2. User config (XDG)
	userConfig, err := GetConfigPath()
	if err != nil {
		return nil, err
	}
	if _, err := os.Stat(userConfig); err == nil {
		configPaths = append(configPaths, userConfig)
	}

	// 3. Local project config (highest priority among files)
	localConfig, err := GetLocalProjectConfigPath()
	if err != nil {
		return nil, err
	}
	if localConfig != "" {
		configPaths = append(configPaths, localConfig)
	}

	return configPaths, nil
}

// GetHardcodedDefaults returns the hardcoded default values for all settings
// These are used when no config file exists
func GetHardcodedDefaults() map[string]interface{} {
	return map[string]interface{}{
		"quiet":                  false,
		"verbose":                false,
		"debug":                  false,
		"color":                  "auto",
		"json":                   false,
		"mode":                   string(ModeAgent), // Default to agent mode
		"default_format":         string(FormatToon), // Default to TOON format
		"truncation_limit":       1000, // Default truncation limit
		"enable_contextual_help":  true, // Default to enable contextual help
		"session_context_enabled": false, // Default to disable session context
	}
}

// GetModeFromEnv returns the mode from the MYTOOL_MODE environment variable
// Returns empty string if not set or invalid
func GetModeFromEnv() string {
	envMode := os.Getenv("MYTOOL_MODE")
	if envMode == "" {
		return ""
	}

	// Validate the mode
	mode := Mode(envMode)
	if !mode.IsValid() {
		return ""
	}

	return envMode
}

// IsAgentSession checks if the CLI is running in an agent session
// by checking for known agent session environment variables
func IsAgentSession() bool {
	// Check for Claude session
	if os.Getenv("CLAUDE_SESSION") != "" {
		return true
	}

	// Check for Codex session
	if os.Getenv("CODEX_SESSION") != "" {
		return true
	}

	return false
}

