package main

import (
	"fmt"
	"os"
	"path/filepath"
	"strings"
)

// IsFirstRun checks if this is the first run by detecting if the config file exists
func IsFirstRun(configPath string) bool {
	if configPath == "" {
		return true
	}
	_, err := os.Stat(configPath)
	return os.IsNotExist(err)
}

// GetConfigPath returns the default config file path
func GetConfigPath() (string, error) {
	configDir, err := os.UserConfigDir()
	if err != nil {
		return "", fmt.Errorf("failed to get user config directory: %w", err)
	}
	configPath := filepath.Join(configDir, "{{ project_slug }}", "config.yaml")
	return configPath, nil
}

// ValidateConfigPath checks if the config path is valid and accessible
func ValidateConfigPath(configPath string) error {
	if configPath == "" {
		return fmt.Errorf("config path cannot be empty")
	}

	// Check if the path is absolute
	if !filepath.IsAbs(configPath) {
		return fmt.Errorf("config path must be absolute: %s", configPath)
	}

	// Check if the parent directory is accessible
	configDir := filepath.Dir(configPath)
	if _, err := os.Stat(configDir); err != nil {
		if os.IsNotExist(err) {
			// Directory doesn't exist yet, which is okay for first run
			return nil
		}
		return fmt.Errorf("config directory is not accessible: %w", err)
	}

	// If config file exists, check if it's readable
	if _, err := os.Stat(configPath); err == nil {
		file, err := os.Open(configPath)
		if err != nil {
			return fmt.Errorf("config file exists but is not readable: %w", err)
		}
		file.Close()
	}

	return nil
}

// EnsureConfigDir creates the config directory if it doesn't exist
func EnsureConfigDir(configPath string) error {
	configDir := filepath.Dir(configPath)
	if _, err := os.Stat(configDir); os.IsNotExist(err) {
		if err := os.MkdirAll(configDir, 0755); err != nil {
			return fmt.Errorf("failed to create config directory: %w", err)
		}
	}
	return nil
}

// CreateDefaultConfig creates a default config file with all settings commented out
func CreateDefaultConfig(configPath string) error {
	// Ensure the config directory exists
	if err := EnsureConfigDir(configPath); err != nil {
		return err
	}

	// Create a basic default config file
	// This will be replaced with the full template in the next sub-task
	defaultConfig := `# Default configuration for {{ project_name }}
# All settings are commented out with their default values
# Uncomment and modify as needed

# Example setting:
# setting_name: default_value
`

	if err := os.WriteFile(configPath, []byte(defaultConfig), 0600); err != nil {
		return fmt.Errorf("failed to create default config file: %w", err)
	}

	return nil
}

// InitConfigIfNeeded initializes the config file if it doesn't exist
// This should be called during application initialization
func InitConfigIfNeeded(configPath string) error {
	if IsFirstRun(configPath) {
		if err := CreateDefaultConfig(configPath); err != nil {
			return fmt.Errorf("failed to initialize config file: %w", err)
		}
	}
	return nil
}

// GetLocalProjectConfigPath returns the path to a local project config file
// This looks for .config/{project_slug}/config.yaml in the current directory or parent directories
func GetLocalProjectConfigPath() (string, error) {
	currentDir, err := os.Getwd()
	if err != nil {
		return "", fmt.Errorf("failed to get current directory: %w", err)
	}

	// Search for .config/{project_slug}/config.yaml in current directory and parents
	dir := currentDir
	for {
		configPath := filepath.Join(dir, ".config", "{{ project_slug }}", "config.yaml")
		if _, err := os.Stat(configPath); err == nil {
			return configPath, nil
		}

		// Move to parent directory
		parentDir := filepath.Dir(dir)
		if parentDir == dir {
			// Reached root, no local config found
			return "", nil
		}
		dir = parentDir
	}
}

// GetSystemConfigPath returns the path to the system/enterprise config file
// This is typically /etc/{project_slug}/config.yaml
func GetSystemConfigPath() (string, error) {
	systemConfigPath := filepath.Join("/etc", "{{ project_slug }}", "config.yaml")
	return systemConfigPath, nil
}

// GetConfigPrecedence returns a list of config paths in precedence order
// from lowest to highest priority (excluding CLI args and env vars)
// Order: system config -> user config -> local project config
func GetConfigPrecedence() ([]string, error) {
	var configPaths []string

	// 1. System/enterprise config (lowest priority)
	systemConfig, err := GetSystemConfigPath()
	if err != nil {
		return nil, err
	}
	if _, err := os.Stat(systemConfig); err == nil {
		configPaths = append(configPaths, systemConfig)
	}

	// 2. User config (XDG)
	userConfig, err := GetConfigPath()
	if err != nil {
		return nil, err
	}
	if _, err := os.Stat(userConfig); err == nil {
		configPaths = append(configPaths, userConfig)
	}

	// 3. Local project config (highest priority among files)
	localConfig, err := GetLocalProjectConfigPath()
	if err != nil {
		return nil, err
	}
	if localConfig != "" {
		configPaths = append(configPaths, localConfig)
	}

	return configPaths, nil
}

// GetHardcodedDefaults returns the hardcoded default values for all settings
// These are used when no config file exists
func GetHardcodedDefaults() map[string]interface{} {
	return map[string]interface{}{
		"quiet":   false,
		"verbose": false,
		"debug":   false,
		"color":   "auto",
		"json":    false,
	}
}

// ConfigValidationError represents a configuration validation error with context
type ConfigValidationError struct {
	Field       string
	LineNumber  int
	Description string
	Suggestion  string
}

func (e ConfigValidationError) Error() string {
	return fmt.Sprintf("config error at line %d: %s (field: %s). Suggestion: %s", e.LineNumber, e.Description, e.Field, e.Suggestion)
}

// ConfigSchema defines the validation rules for configuration fields
type ConfigSchema struct {
	Fields map[string]FieldSchema
}

// FieldSchema defines validation rules for a single field
type FieldSchema struct {
	Type         string   // "bool", "string", "int", "enum"
	Required     bool
	AllowedValues []string // For enum types
	DefaultValue interface{}
}

// GetConfigSchema returns the configuration schema
func GetConfigSchema() ConfigSchema {
	return ConfigSchema{
		Fields: map[string]FieldSchema{
			"quiet": {
				Type:         "bool",
				Required:     false,
				DefaultValue: false,
			},
			"verbose": {
				Type:         "bool",
				Required:     false,
				DefaultValue: false,
			},
			"debug": {
				Type:         "bool",
				Required:     false,
				DefaultValue: false,
			},
			"color": {
				Type:         "enum",
				Required:     false,
				AllowedValues: []string{"auto", "always", "never"},
				DefaultValue: "auto",
			},
			"json": {
				Type:         "bool",
				Required:     false,
				DefaultValue: false,
			},
		},
	}
}

// ValidateConfig validates a configuration map against the schema
func ValidateConfig(config map[string]interface{}, configPath string) []ConfigValidationError {
	var errors []ConfigValidationError
	schema := GetConfigSchema()

	// Read config file to get line numbers
	content, err := os.ReadFile(configPath)
	if err != nil {
		// If we can't read the file, we can't provide line numbers
		// Still validate the values, just without line numbers
		for field, value := range config {
			if fieldSchema, ok := schema.Fields[field]; ok {
				if err := validateField(field, value, fieldSchema); err != nil {
					errors = append(errors, ConfigValidationError{
						Field:       field,
						LineNumber:  0,
						Description: err.Error(),
						Suggestion:  getErrorSuggestion(field, err),
					})
				}
			}
		}
		return errors
	}

	lines := strings.Split(string(content), "\n")

	// Validate each field
	for field, value := range config {
		if fieldSchema, ok := schema.Fields[field]; ok {
			lineNumber := findLineNumber(lines, field)
			if err := validateField(field, value, fieldSchema); err != nil {
				errors = append(errors, ConfigValidationError{
					Field:       field,
					LineNumber:  lineNumber,
					Description: err.Error(),
					Suggestion:  getErrorSuggestion(field, err),
				})
			}
		}
	}

	return errors
}

// validateField validates a single field against its schema
func validateField(field string, value interface{}, schema FieldSchema) error {
	switch schema.Type {
	case "bool":
		if _, ok := value.(bool); !ok {
			return fmt.Errorf("expected boolean, got %T", value)
		}
	case "string":
		if _, ok := value.(string); !ok {
			return fmt.Errorf("expected string, got %T", value)
		}
	case "int":
		if _, ok := value.(int); !ok {
			return fmt.Errorf("expected integer, got %T", value)
		}
	case "enum":
		strValue, ok := value.(string)
		if !ok {
			return fmt.Errorf("expected string for enum, got %T", value)
		}
		valid := false
		for _, allowed := range schema.AllowedValues {
			if strValue == allowed {
				valid = true
				break
			}
		}
		if !valid {
			return fmt.Errorf("invalid value '%s', allowed values: %v", strValue, schema.AllowedValues)
		}
	}
	return nil
}

// findLineNumber finds the line number where a field is defined
func findLineNumber(lines []string, field string) int {
	for i, line := range lines {
		if strings.Contains(line, field+":") {
			return i + 1 // Line numbers are 1-indexed
		}
	}
	return 0
}

// getErrorSuggestion provides a suggestion for fixing a validation error
func getErrorSuggestion(field string, err error) string {
	errMsg := err.Error()

	if strings.Contains(errMsg, "expected boolean") {
		return fmt.Sprintf("Set %s to true or false", field)
	}
	if strings.Contains(errMsg, "expected string") {
		return fmt.Sprintf("Set %s to a string value", field)
	}
	if strings.Contains(errMsg, "expected integer") {
		return fmt.Sprintf("Set %s to an integer value", field)
	}
	if strings.Contains(errMsg, "invalid value") {
		return fmt.Sprintf("Check the allowed values for %s in the config schema", field)
	}

	return fmt.Sprintf("Review the configuration for field %s", field)
}

