// printInstallInstructions displays post-installation instructions
func printInstallInstructions() {
	fmt.Println("\nInstallation complete!")
	fmt.Println("\nTo enable shell completions, add the following to your shell configuration:")
	fmt.Println("\nFor bash:")
	fmt.Println("  source ~/.local/share/bash-completion/completions/{{ project_slug }}")
	fmt.Println("\nFor zsh:")
	fmt.Println("  fpath=(~/.local/share/zsh/site-functions $fpath)")
	fmt.Println("  autoload -U compinit && compinit")
	fmt.Println("\nFor fish:")
	fmt.Println("  Completions are automatically loaded from ~/.local/share/fish/completions/")
	fmt.Println("\nMan page installed at: ~/.local/share/man/man1/{{ project_slug }}.1")
	fmt.Println("View with: man {{ project_slug }}")
	fmt.Println("\nConfig file initialized at: ~/.config/{{ project_slug }}/config.yaml")
}
