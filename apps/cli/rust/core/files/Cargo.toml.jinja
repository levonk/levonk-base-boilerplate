[package]
name = "{{ project_slug }}"
version = "0.1.0"
edition = "2021"
description = "{{ description }}"

[dependencies]
clap = { version = "4.4", features = ["derive", "env"] }
clap_complete = "4.4"
anyhow = "1.0"
thiserror = "1.0"
directories = "5.0"
ctrlc = "3.4"
signal-hook = "0.3"
signal-hook-tokio = { version = "0.3", features = ["futures-v0_3"] }
signal-hook-iterator = "0.3"
indicatif = "0.17"
glob = "0.3"
atty = "0.2"
urlencoding = "2.1"
walkdir = "2.4"
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
toml = "0.8"
serde_yaml = "0.9"
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter", "json", "ansi"] }
chrono = "0.4"
ansi_term = "0.12"
once_cell = "1.18"
uuid = { version = "1.0", features = ["v4"] }
tokio = { version = "1", features = ["rt-multi-thread", "macros", "signal", "process", "fs", "io-util", "time", "net"] }
{% if include_sqlite -%}
rusqlite = { version = "0.31", features = ["bundled"] }
{% endif %}
[target.'cfg(windows)'.dependencies]
windows-sys = { version = "0.52", features = ["Win32_System_Console"] }
ratatui = { version = "0.26", optional = true }
cursive = { version = "0.21", optional = true }

[features]
default = []
tui = ["dep:ratatui", "dep:cursive"]

[build-dependencies]
vergen = { version = "8.0", features = ["build", "git", "gitcl"] }

[dev-dependencies]
assert_cmd = "2.0"
predicates = "3.0"
tempfile = "3.8"
