#[test]
fn test_man_page_template_standard_format() {
    let man_template_path = "docs/man/{{ project_slug }}.1.jinja";
    let content = fs::read_to_string(man_template_path)
        .expect("Should be able to read man page template");
    
    // Check for standard Unix man page macros
    assert!(content.contains(".TP"), "Should use .TP for tagged paragraphs");
    assert!(content.contains(".B"), "Should use .B for bold text");
    assert!(content.contains(".I"), "Should use .I for italic text");
    assert!(content.contains(".P"), "Should use .P for paragraphs");
}

#[test]
fn test_man_page_template_exit_codes() {
    let man_template_path = "docs/man/{{ project_slug }}.1.jinja";
    let content = fs::read_to_string(man_template_path)
        .expect("Should be able to read man page template");
    
    // Check for exit codes section
    assert!(content.contains(".SH EXIT STATUS"), "Should have EXIT STATUS section");
    assert!(content.contains("0"), "Should document exit code 0 (success)");
    assert!(content.contains("1"), "Should document exit code 1 (error)");
}

