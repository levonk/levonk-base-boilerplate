#[test]
fn test_cli_show_progress_quiet() -> Result<()> {
    let cli = Cli {
        inputs: vec![],
        config: None,
        json: false,
        quiet: true,
        verbose: 0,
        debug: false,
        usage: false,
        color: None,
        nocolor: false,
        no_pager: false,
        install: false,
        uninstall: false,
        interactive: false,
        dry_run: false,
        force: false,
    };
    
    assert!(!cli.show_progress(), "Progress should not show in quiet mode");
    
    Ok(())
}
