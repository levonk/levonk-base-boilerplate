use {{ project_slug }}::cli::{Cli, Progress};
use anyhow::Result;

#[test]
fn test_progress_bar_creation() -> Result<()> {
    let progress = Progress::new(false);
    let bar = progress.bar(100, "Test progress");
    
    assert!(bar.is_some(), "Progress bar should be created when not quiet");
    
    if let Some(b) = bar {
        assert_eq!(b.length(), Some(100));
        b.finish();
    }
    
    Ok(())
}

#[test]
fn test_progress_bar_quiet_mode() -> Result<()> {
    let progress = Progress::new(true);
    let bar = progress.bar(100, "Test progress");
    
    assert!(bar.is_none(), "Progress bar should not be created in quiet mode");
    
    Ok(())
}

#[test]
fn test_spinner_creation() -> Result<()> {
    let progress = Progress::new(false);
    let spinner = progress.spinner("Test spinner");
    
    assert!(spinner.is_some(), "Spinner should be created when not quiet");
    
    if let Some(s) = spinner {
        s.finish();
    }
    
    Ok(())
}

#[test]
fn test_spinner_quiet_mode() -> Result<()> {
    let progress = Progress::new(true);
    let spinner = progress.spinner("Test spinner");
    
    assert!(spinner.is_none(), "Spinner should not be created in quiet mode");
    
    Ok(())
}

#[test]
fn test_progress_clear() -> Result<()> {
    let progress = Progress::new(false);
    let bar = progress.bar(10, "Clear test");
    
    if let Some(b) = bar {
        b.inc(5);
    }
    
    progress.clear();
    Ok(())
}

