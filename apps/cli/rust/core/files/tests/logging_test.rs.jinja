use assert_cmd::Command;
use predicates::prelude::*;

#[test]
fn test_logging_quiet_mode() {
    let mut cmd = Command::cargo_bin("{{ project_slug }}").unwrap();
    cmd.arg("--quiet")
        .arg("-")
        .write_stdin("test content")
        .assert()
        .success()
        .stderr(predicate::str::contains("INFO").not()); // Quiet mode should suppress INFO logs
}

#[test]
fn test_logging_verbose_mode() {
    let mut cmd = Command::cargo_bin("{{ project_slug }}").unwrap();
    cmd.arg("--verbose")
        .arg("-")
        .write_stdin("test content")
        .assert()
        .success()
        .stderr(predicate::str::contains("DEBUG")); // Verbose mode should show DEBUG logs
}

