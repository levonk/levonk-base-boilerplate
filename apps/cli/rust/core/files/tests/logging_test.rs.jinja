#[test]
fn test_logging_env_var_override() {
    let mut cmd = Command::cargo_bin("{{ project_slug }}").unwrap();
    cmd.env("{{ project_slug | upper | replace('-', '_') }}_LOG", "debug")
        .arg("-")
        .write_stdin("test content")
        .assert()
        .success()
        .stderr(predicate::str::contains("DEBUG")); // Env var should override
}

#[test]
fn test_logging_env_debug() {
    let mut cmd = Command::cargo_bin("{{ project_slug }}").unwrap();
    cmd.env("{{ project_slug | upper | replace('-', '_') }}_DEBUG", "1")
        .arg("-")
        .write_stdin("test content")
        .assert()
        .success()
        .stderr(predicate::str::contains("DEBUG")); // DEBUG env var should enable debug
}

