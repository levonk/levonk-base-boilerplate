#[tokio::test]
async fn test_list_jobs_with_filter() {
    let config = DaemonConfig::default();
    let manager = DaemonManager::new(config);
    
    let jobs_pending = manager.list_jobs(Some(JobStatus::Pending)).await;
    assert!(jobs_pending.is_empty());
    
    let jobs_running = manager.list_jobs(Some(JobStatus::Running)).await;
    assert!(jobs_running.is_empty());
}

