use anyhow::Result;
use {{ project_slug }}::daemon::{DaemonManager, DaemonConfig, Job, JobStatus};

#[test]
fn test_daemon_config_default() {
    let config = DaemonConfig::default();
    assert!(config.enabled);
    assert!(config.auto_spawn);
    assert_eq!(config.max_jobs, 10);
    assert_eq!(config.job_timeout, 300);
    assert!(config.socket_path.is_none());
}

#[test]
fn test_daemon_config_custom() {
    let config = DaemonConfig {
        enabled: false,
        auto_spawn: false,
        max_jobs: 5,
        job_timeout: 600,
        socket_path: Some("/tmp/test.sock".to_string()),
    };
    assert!(!config.enabled);
    assert!(!config.auto_spawn);
    assert_eq!(config.max_jobs, 5);
    assert_eq!(config.job_timeout, 600);
    assert_eq!(config.socket_path, Some("/tmp/test.sock".to_string()));
}

#[test]
fn test_job_creation() {
    let job = Job::new("test-id".to_string(), "echo hello".to_string());
    assert_eq!(job.id, "test-id");
    assert_eq!(job.command, "echo hello");
    assert_eq!(job.status, JobStatus::Pending);
    assert!(job.output.is_empty());
    assert!(job.error.is_none());
    assert!(!job.created_at.is_empty());
    assert!(job.started_at.is_none());
    assert!(job.completed_at.is_none());
}

#[test]
fn test_job_status_transitions() {
    let mut job = Job::new("test-id".to_string(), "echo hello".to_string());
    assert_eq!(job.status, JobStatus::Pending);
    
    job.status = JobStatus::Running;
    job.started_at = Some(chrono::Utc::now().to_rfc3339());
    assert_eq!(job.status, JobStatus::Running);
    assert!(job.started_at.is_some());
    
    job.status = JobStatus::Completed;
    job.output = "hello".to_string();
    job.completed_at = Some(chrono::Utc::now().to_rfc3339());
    assert_eq!(job.status, JobStatus::Completed);
    assert_eq!(job.output, "hello");
    assert!(job.completed_at.is_some());
}

#[test]
fn test_job_failed() {
    let mut job = Job::new("test-id".to_string(), "false".to_string());
    job.status = JobStatus::Failed;
    job.error = Some("Command failed".to_string());
    job.completed_at = Some(chrono::Utc::now().to_rfc3339());
    assert_eq!(job.status, JobStatus::Failed);
    assert_eq!(job.error, Some("Command failed".to_string()));
}

#[test]
fn test_job_cancelled() {
    let mut job = Job::new("test-id".to_string(), "sleep 100".to_string());
    job.status = JobStatus::Cancelled;
    job.completed_at = Some(chrono::Utc::now().to_rfc3339());
    assert_eq!(job.status, JobStatus::Cancelled);
}

#[tokio::test]
async fn test_daemon_manager_creation() {
    let config = DaemonConfig::default();
    let manager = DaemonManager::new(config);
    assert!(!manager.is_running().await);
}

#[tokio::test]
async fn test_daemon_manager_disabled() {
    let config = DaemonConfig {
        enabled: false,
        auto_spawn: false,
        ..Default::default()
    };
    let manager = DaemonManager::new(config);
    assert!(!manager.is_running().await);
    
    // Starting should fail when disabled
    let result = manager.start().await;
    assert!(result.is_err());
}

