use anyhow::Result;
use assert_cmd::Command;
use predicates::str::contains;

#[test]
fn test_completion_bash() -> Result<()> {
    let mut cmd = Command::cargo_bin("{{ project_slug }}")?;
    cmd.arg("completion").arg("bash");
    cmd.assert().success().stdout(contains("complete"));
    Ok(())
}

