#[test]
fn test_filter_operation() {
    let temp_dir = TempDir::new().unwrap();
    let input_path = temp_dir.path().join("input.json");
    
    // Create test data
    let export_config = ExportConfig {
        format: ExportFormat::Json,
        output_path: input_path.clone(),
        include_metadata: false,
        compress: false,
    };
    
    let exporter = DataExporter::new(export_config);
    let records = vec![
        DataRecord {
            id: "1".to_string(),
            timestamp: "2024-01-01T00:00:00Z".to_string(),
            record_type: "type_a".to_string(),
            data: serde_json::json!({}),
            metadata: None,
        },
        DataRecord {
            id: "2".to_string(),
            timestamp: "2024-01-02T00:00:00Z".to_string(),
            record_type: "type_b".to_string(),
            data: serde_json::json!({}),
            metadata: None,
        },
    ];
    
    exporter.export(records).unwrap();
    
    // Process with filter
    let filter_criteria = FilterCriteria {
        record_type: Some("type_a".to_string()),
        time_range: None,
        expression: None,
    };
    
    let processing_config = ProcessingConfig {
        input_path: input_path.clone(),
        output_path: None,
        operation: ProcessingOperation::Filter,
        operation_config: serde_json::to_value(filter_criteria).unwrap(),
    };
    
    let processor = DataProcessor::new(processing_config);
    let result = processor.process();
    
    assert!(result.is_ok());
    let analysis = result.unwrap();
    assert_eq!(analysis.analysis_type, "filter");
    
    let result_data = analysis.result.as_object().unwrap();
    assert_eq!(result_data.get("filtered_count").unwrap().as_i64().unwrap(), 1);
    assert_eq!(result_data.get("original_count").unwrap().as_i64().unwrap(), 2);
}

