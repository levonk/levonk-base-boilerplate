#[test]
fn test_cross_environment_workflow() {
    let temp_dir = TempDir::new().unwrap();
    
    // Step 1: Export data (collection environment)
    let export_path = temp_dir.path().join("collection_export.json");
    let export_config = ExportConfig {
        format: ExportFormat::Json,
        output_path: export_path.clone(),
        include_metadata: true,
        compress: false,
    };
    
    let exporter = DataExporter::new(export_config);
    let records = vec![
        DataRecord {
            id: "collected-1".to_string(),
            timestamp: chrono::Utc::now().to_rfc3339(),
            record_type: "collected".to_string(),
            data: serde_json::json!({"source": "collection"}),
            metadata: Some(serde_json::json!({"env": "collection"})),
        },
    ];
    
    let manifest = exporter.export(records).unwrap();
    assert_eq!(manifest.record_count, 1);
    
    // Step 2: Import data (processing environment)
    let import_config = ImportConfig {
        input_path: export_path.clone(),
        format: None,
    };
    
    let importer = DataImporter::new(import_config);
    let (imported_records, imported_manifest) = importer.import().unwrap();
    assert_eq!(imported_records.len(), 1);
    
    // Step 3: Process data (analysis environment)
    let processing_config = ProcessingConfig {
        input_path: export_path.clone(),
        output_path: None,
        operation: ProcessingOperation::Analyze,
        operation_config: serde_json::Value::Null,
    };
    
    let processor = DataProcessor::new(processing_config);
    let analysis_result = processor.process().unwrap();
    
    assert_eq!(analysis_result.analysis_type, "analyze");
    assert!(analysis_result.result.as_object().unwrap().contains_key("total_records"));
}

#[test]
fn test_export_with_metadata() {
    let temp_dir = TempDir::new().unwrap();
    let output_path = temp_dir.path().join("test_export.json");
    
    let config = ExportConfig {
        format: ExportFormat::Json,
        output_path: output_path.clone(),
        include_metadata: true,
        compress: false,
    };
    
    let exporter = DataExporter::new(config);
    let records = vec![
        DataRecord {
            id: "test-1".to_string(),
            timestamp: "2024-01-01T00:00:00Z".to_string(),
            record_type: "test".to_string(),
            data: serde_json::json!({"key": "value"}),
            metadata: None,
        },
    ];
    
    let result = exporter.export(records);
    assert!(result.is_ok());
    
    let manifest = result.unwrap();
    assert!(manifest.metadata.is_some());
    
    let metadata = manifest.metadata.unwrap();
    assert!(metadata.as_object().unwrap().contains_key("exported_by"));
    assert!(metadata.as_object().unwrap().contains_key("hostname"));
}
