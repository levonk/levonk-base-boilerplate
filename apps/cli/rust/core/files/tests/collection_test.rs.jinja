#[test]
fn test_export_config_defaults() {
    let config = ExportConfig::default();
    assert_eq!(config.format, ExportFormat::Json);
    assert_eq!(config.output_path, PathBuf::from("export.json"));
    assert!(config.include_metadata);
    assert!(!config.compress);
}

#[test]
fn test_export_json_format() {
    let temp_dir = TempDir::new().unwrap();
    let output_path = temp_dir.path().join("test_export.json");
    
    let config = ExportConfig {
        format: ExportFormat::Json,
        output_path: output_path.clone(),
        include_metadata: false,
        compress: false,
    };
    
    let exporter = DataExporter::new(config);
    let records = vec![
        DataRecord {
            id: "test-1".to_string(),
            timestamp: "2024-01-01T00:00:00Z".to_string(),
            record_type: "test".to_string(),
            data: serde_json::json!({"key": "value"}),
            metadata: None,
        },
        DataRecord {
            id: "test-2".to_string(),
            timestamp: "2024-01-02T00:00:00Z".to_string(),
            record_type: "test".to_string(),
            data: serde_json::json!({"key": "value2"}),
            metadata: Some(serde_json::json!({"meta": "data"})),
        },
    ];
    
    let result = exporter.export(records);
    assert!(result.is_ok());
    
    let manifest = result.unwrap();
    assert_eq!(manifest.record_count, 2);
    assert_eq!(manifest.format, ExportFormat::Json);
    assert!(output_path.exists());
    
    // Verify file content
    let content = std::fs::read_to_string(&output_path).unwrap();
    assert!(content.contains("\"manifest\""));
    assert!(content.contains("\"records\""));
}

