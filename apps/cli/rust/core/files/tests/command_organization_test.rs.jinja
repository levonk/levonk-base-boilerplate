use assert_cmd::Command;
use predicates::prelude::*;

#[test]
fn test_cli_help_shows_subcommands() {
    let mut cmd = Command::cargo_bin("{{ project_slug }}").unwrap();
    cmd.arg("--help");

    cmd.assert()
        .success()
        .stdout(predicate::str::contains("config"))
        .stdout(predicate::str::contains("daemon"))
        .stdout(predicate::str::contains("completion"))
        .stdout(predicate::str::contains("doctor"));
}

#[test]
fn test_config_subcommand_help() {
    let mut cmd = Command::cargo_bin("{{ project_slug }}").unwrap();
    cmd.args(["config", "--help"]);

    cmd.assert()
        .success()
        .stdout(predicate::str::contains("Manage configuration"))
        .stdout(predicate::str::contains("--show"))
        .stdout(predicate::str::contains("--reset"))
        .stdout(predicate::str::contains("--validate"));
}

#[test]
fn test_daemon_subcommand_help() {
    let mut cmd = Command::cargo_bin("{{ project_slug }}").unwrap();
    cmd.args(["daemon", "--help"]);

    cmd.assert()
        .success()
        .stdout(predicate::str::contains("Manage daemon processes"))
        .stdout(predicate::str::contains("--start"))
        .stdout(predicate::str::contains("--stop"))
        .stdout(predicate::str::contains("--restart"))
        .stdout(predicate::str::contains("--status"))
        .stdout(predicate::str::contains("--list-jobs"))
        .stdout(predicate::str::contains("--cancel-job"));
}

