#[test]
fn test_config_validation_numeric_fields() {
    let mut manager = ConfigManager::new();
    manager.load().expect("Failed to load config");

    // Test valid max_concurrent
    manager.config_mut().max_concurrent = 10;
    assert!(manager.validate().is_ok());

    // Test invalid max_concurrent (zero)
    manager.config_mut().max_concurrent = 0;
    assert!(manager.validate().is_err(), "max_concurrent=0 should fail validation");

    // Test valid timeout
    manager.config_mut().max_concurrent = 4; // Reset to valid
    manager.config_mut().timeout = 60;
    assert!(manager.validate().is_ok());

    // Test invalid timeout (zero)
    manager.config_mut().timeout = 0;
    assert!(manager.validate().is_err(), "timeout=0 should fail validation");
}
