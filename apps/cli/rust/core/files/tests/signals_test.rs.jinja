use std::sync::Arc;
use tokio::sync::Mutex;
use {{ project_slug }}::config::ConfigManager;
use {{ project_slug }}::signals::SignalHandler;

#[test]
fn test_signal_handler_creation() {
    let config_manager = Arc::new(Mutex::new(ConfigManager::new()));
    let handler = SignalHandler::new(config_manager);
    assert_eq!(handler.reload_count().await, 0);
}

#[test]
fn test_reload_count_initial() {
    let config_manager = Arc::new(Mutex::new(ConfigManager::new()));
    let handler = SignalHandler::new(config_manager);
    assert_eq!(handler.reload_count().await, 0);
}

#[test]
fn test_config_manager_reload() {
    let mut manager = ConfigManager::new();
    assert!(manager.load().is_ok());
    assert!(manager.validate().is_ok());

    // Test reload functionality
    assert!(manager.reload().is_ok());
    assert!(manager.validate().is_ok());
}

#[test]
fn test_config_manager_reload_with_invalid_config() {
    let mut manager = ConfigManager::new();
    assert!(manager.load().is_ok());

    // Manually set invalid config to test validation failure
    // Note: This is a simplified test - in practice, you'd need to
    // create a temporary invalid config file to test this properly
    let result = manager.validate();
    assert!(result.is_ok(), "Default config should be valid");
}

#[test]
fn test_signal_handler_with_valid_config() {
    let mut config_manager = ConfigManager::new();
    config_manager.load().expect("Failed to load config");
    config_manager.validate().expect("Failed to validate config");

    let config_manager_arc = Arc::new(Mutex::new(config_manager));
    let handler = SignalHandler::new(config_manager_arc);

    assert_eq!(handler.reload_count().await, 0);
}

#[test]
fn test_config_validation_color_modes() {
    let mut manager = ConfigManager::new();
    manager.load().expect("Failed to load config");

    // Test valid color modes
    for color_mode in &["auto", "always", "never"] {
        manager.config_mut().color = color_mode.to_string();
        assert!(manager.validate().is_ok(), "Color mode {} should be valid", color_mode);
    }

    // Test invalid color mode
    manager.config_mut().color = "invalid".to_string();
    assert!(manager.validate().is_err(), "Invalid color mode should fail validation");
}

