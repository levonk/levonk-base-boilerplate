//! Tests for session module

#[cfg(test)]
mod tests {
    use super::super::*;

    #[test]
    fn test_session_context_from_current_dir() {
        // This test will work if run in a git repository
        let context = SessionContext::from_current_dir();
        assert!(context.is_ok());
        
        let ctx = context.unwrap();
        assert!(!ctx.directory.is_empty());
    }

    #[test]
    fn test_generate_session_context() {
        let context = generate_session_context();
        assert!(context.is_ok());
    }

    #[test]
    fn test_capture_session_metadata() {
        let metadata = capture_session_metadata();
        assert!(metadata.is_ok());
        
        let meta = metadata.unwrap();
        assert!(!meta.directory.is_empty());
        assert!(meta.start_time > 0);
    }
}
