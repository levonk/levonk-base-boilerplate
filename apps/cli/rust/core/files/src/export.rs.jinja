use anyhow::{Context, Result};
use serde::{Deserialize, Serialize};
use std::fs;
use std::path::PathBuf;
use tracing::info;

/// Data export format
#[derive(Debug, Clone, Serialize, Deserialize, PartialEq)]
pub enum ExportFormat {
    /// JSON format
    Json,
    /// CSV format
    Csv,
    /// YAML format
    Yaml,
}

/// Data export configuration
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ExportConfig {
    /// Export format
    pub format: ExportFormat,
    /// Output file path
    pub output_path: PathBuf,
    /// Whether to include metadata
    pub include_metadata: bool,
    /// Whether to compress output
    pub compress: bool,
}

impl Default for ExportConfig {
    fn default() -> Self {
        Self {
            format: ExportFormat::Json,
            output_path: PathBuf::from("export.json"),
            include_metadata: true,
            compress: false,
        }
    }
}

/// Collected data record
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct DataRecord {
    /// Record ID
    pub id: String,
    /// Record timestamp
    pub timestamp: String,
    /// Record type
    pub record_type: String,
    /// Record data
    pub data: serde_json::Value,
    /// Optional metadata
    pub metadata: Option<serde_json::Value>,
}

/// Data export manifest
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ExportManifest {
    /// Export version
    pub version: String,
    /// Export timestamp
    pub timestamp: String,
    /// Source information
    pub source: String,
    /// Record count
    pub record_count: usize,
    /// Export format
    pub format: ExportFormat,
    /// Optional metadata
    pub metadata: Option<serde_json::Value>,
}

/// Data exporter
pub struct DataExporter {
    config: ExportConfig,
}

impl DataExporter {
    pub fn new(config: ExportConfig) -> Self {
        Self { config }
    }

    /// Export data records to file
    pub fn export(&self, records: Vec<DataRecord>) -> Result<ExportManifest> {
        info!("Exporting {} records to {:?}", records.len(), self.config.output_path);

        let manifest = ExportManifest {
            version: "1.0".to_string(),
            timestamp: chrono::Utc::now().to_rfc3339(),
            source: "{{ PROJECT_NAME }}".to_string(),
            record_count: records.len(),
            format: self.config.format.clone(),
            metadata: if self.config.include_metadata {
                Some(serde_json::json!({
                    "exported_by": std::env::var("USER").unwrap_or_else(|_| "unknown".to_string()),
                    "hostname": gethostname::gethostname().to_string_lossy().to_string(),
                }))
            } else {
                None
            },
        };

        let output = match self.config.format {
            ExportFormat::Json => self.export_json(&records, &manifest)?,
            ExportFormat::Csv => self.export_csv(&records)?,
            ExportFormat::Yaml => self.export_yaml(&records, &manifest)?,
        };

        // Ensure parent directory exists
        if let Some(parent) = self.config.output_path.parent() {
            fs::create_dir_all(parent).context("Failed to create output directory")?;
        }

        fs::write(&self.config.output_path, output).context("Failed to write export file")?;

        info!("Export completed successfully");
        Ok(manifest)
    }

    /// Export to JSON format
    fn export_json(&self, records: &[DataRecord], manifest: &ExportManifest) -> Result<String> {
        let export_data = serde_json::json!({
            "manifest": manifest,
            "records": records,
        });
        Ok(serde_json::to_string_pretty(&export_data)?)
    }

    /// Export to CSV format
    fn export_csv(&self, records: &[DataRecord]) -> Result<String> {
        let mut csv = String::new();
        
        // CSV header
        csv.push_str("id,timestamp,record_type,data,metadata\n");
        
        // CSV rows
        for record in records {
            let data_str = serde_json::to_string(&record.data)?;
            let metadata_str = record.metadata.as_ref()
                .map(|m| serde_json::to_string(m))
                .transpose()?
                .unwrap_or_else(|| "null".to_string());
            
            csv.push_str(&format!(
                "{},{},{},{},{}\n",
                record.id,
                record.timestamp,
                record.record_type,
                data_str,
                metadata_str
            ));
        }
        
        Ok(csv)
    }

    /// Export to YAML format
    fn export_yaml(&self, records: &[DataRecord], manifest: &ExportManifest) -> Result<String> {
        let export_data = serde_json::json!({
            "manifest": manifest,
            "records": records,
        });
        Ok(serde_yaml::to_string(&export_data)?)
    }
}

/// Data importer
pub struct DataImporter {
    config: ImportConfig,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ImportConfig {
    /// Input file path
    pub input_path: PathBuf,
    /// Expected format (auto-detect if None)
    pub format: Option<ExportFormat>,
}

impl Default for ImportConfig {
    fn default() -> Self {
        Self {
            input_path: PathBuf::from("export.json"),
            format: None,
        }
    }
}

impl DataImporter {
    pub fn new(config: ImportConfig) -> Self {
        Self { config }
    }

    /// Import data records from file
    pub fn import(&self) -> Result<(Vec<DataRecord>, ExportManifest)> {
        info!("Importing data from {:?}", self.config.input_path);

        let content = fs::read_to_string(&self.config.input_path)
            .context("Failed to read import file")?;

        let format = self.detect_format(&content)?;
        
        let (records, manifest) = match format {
            ExportFormat::Json => self.import_json(&content)?,
            ExportFormat::Csv => self.import_csv(&content)?,
            ExportFormat::Yaml => self.import_yaml(&content)?,
        };

        info!("Imported {} records successfully", records.len());
        Ok((records, manifest))
    }

    /// Detect format from content
    fn detect_format(&self, content: &str) -> Result<ExportFormat> {
        if let Some(format) = &self.config.format {
            return Ok(format.clone());
        }

        // Auto-detect based on content
        let trimmed = content.trim();
        if trimmed.starts_with('{') || trimmed.starts_with('[') {
            Ok(ExportFormat::Json)
        } else if trimmed.starts_with("id,timestamp") {
            Ok(ExportFormat::Csv)
        } else {
            Ok(ExportFormat::Yaml)
        }
    }

    /// Import from JSON format
    fn import_json(&self, content: &str) -> Result<(Vec<DataRecord>, ExportManifest)> {
        let data: serde_json::Value = serde_json::from_str(content)?;
        
        let manifest: ExportManifest = serde_json::from_value(data["manifest"].clone())
            .context("Failed to parse manifest")?;
        
        let records: Vec<DataRecord> = serde_json::from_value(data["records"].clone())
            .context("Failed to parse records")?;
        
        Ok((records, manifest))
    }

    /// Import from CSV format
    fn import_csv(&self, content: &str) -> Result<(Vec<DataRecord>, ExportManifest)> {
        let mut records = Vec::new();
        let mut lines = content.lines();
        
        // Skip header
        lines.next();
        
        for line in lines {
            let parts: Vec<&str> = line.split(',').collect();
            if parts.len() >= 4 {
                let data: serde_json::Value = serde_json::from_str(parts[3])
                    .unwrap_or_else(|_| serde_json::Value::Null);
                
                let metadata = if parts.len() > 4 {
                    Some(serde_json::from_str(parts[4])
                        .unwrap_or_else(|_| serde_json::Value::Null))
                } else {
                    None
                };
                
                records.push(DataRecord {
                    id: parts[0].to_string(),
                    timestamp: parts[1].to_string(),
                    record_type: parts[2].to_string(),
                    data,
                    metadata,
                });
            }
        }
        
        let manifest = ExportManifest {
            version: "1.0".to_string(),
            timestamp: chrono::Utc::now().to_rfc3339(),
            source: "{{ PROJECT_NAME }}".to_string(),
            record_count: records.len(),
            format: ExportFormat::Csv,
            metadata: None,
        };
        
        Ok((records, manifest))
    }

    /// Import from YAML format
    fn import_yaml(&self, content: &str) -> Result<(Vec<DataRecord>, ExportManifest)> {
        let data: serde_json::Value = serde_yaml::from_str(content)?;
        
        let manifest: ExportManifest = serde_json::from_value(data["manifest"].clone())
            .context("Failed to parse manifest")?;
        
        let records: Vec<DataRecord> = serde_json::from_value(data["records"].clone())
            .context("Failed to parse records")?;
        
        Ok((records, manifest))
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_export_config_default() {
        let config = ExportConfig::default();
        assert_eq!(config.format, ExportFormat::Json);
        assert_eq!(config.output_path, PathBuf::from("export.json"));
        assert!(config.include_metadata);
        assert!(!config.compress);
    }

    #[test]
    fn test_data_record_creation() {
        let record = DataRecord {
            id: "test-1".to_string(),
            timestamp: chrono::Utc::now().to_rfc3339(),
            record_type: "test".to_string(),
            data: serde_json::json!({"key": "value"}),
            metadata: None,
        };
        assert_eq!(record.id, "test-1");
    }

    #[test]
    fn test_export_json() {
        let config = ExportConfig {
            format: ExportFormat::Json,
            output_path: PathBuf::from("/tmp/test_export.json"),
            include_metadata: false,
            compress: false,
        };
        
        let exporter = DataExporter::new(config);
        let records = vec![
            DataRecord {
                id: "test-1".to_string(),
                timestamp: chrono::Utc::now().to_rfc3339(),
                record_type: "test".to_string(),
                data: serde_json::json!({"key": "value"}),
                metadata: None,
            },
        ];
        
        let result = exporter.export(records);
        assert!(result.is_ok());
        
        // Clean up
        let _ = fs::remove_file("/tmp/test_export.json");
    }

    #[test]
    fn test_import_config_default() {
        let config = ImportConfig::default();
        assert_eq!(config.input_path, PathBuf::from("export.json"));
        assert!(config.format.is_none());
    }
}
