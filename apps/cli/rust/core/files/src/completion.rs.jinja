use clap::Command;
use clap_complete::{generate_to, Generator, shells::Bash, shells::Elvish, shells::Fish, shells::PowerShell, shells::Zsh};
use std::io;

/// Generate shell completion scripts
///
/// This function generates completion scripts for various shells using clap's
/// auto-generation capabilities. The generated scripts can be written to stdout
/// or to files for installation.
///
/// # Supported Shells
///
/// - bash: Bourne Again SHell
/// - zsh: Z SHell
/// - fish: Friendly Interactive SHell
/// - elvish: Elvish shell
/// - powershell: PowerShell (pwsh)
///
/// # Examples
///
/// ```no_run
/// use {{ project_slug }}::completion::generate_completion;
/// use clap::Command;
///
/// let mut cmd = Command::new("myapp");
/// generate_completion(&mut cmd, "bash", &mut std::io::stdout());
/// ```
pub fn generate_completion(cmd: &mut Command, shell: &str, buf: &mut dyn io::Write) -> anyhow::Result<()> {
    match shell.to_lowercase().as_str() {
        "bash" => {
            Bash.generate(cmd, buf);
            Ok(())
        }
        "zsh" => {
            Zsh.generate(cmd, buf);
            Ok(())
        }
        "fish" => {
            Fish.generate(cmd, buf);
            Ok(())
        }
        "elvish" => {
            Elvish.generate(cmd, buf);
            Ok(())
        }
        "powershell" | "pwsh" => {
            PowerShell.generate(cmd, buf);
            Ok(())
        }
        _ => Err(anyhow::anyhow!(
            "Unsupported shell: {}. Supported shells: bash, zsh, fish, elvish, powershell",
            shell
        )),
    }
}

/// Get the installation path for a shell's completion script
///
/// Returns the standard path where completion scripts should be installed
/// for the given shell. These paths follow the XDG Base Directory specification
/// or platform-specific conventions.
///
/// # Arguments
///
/// * `shell` - The shell type (bash, zsh, fish, elvish, powershell)
///
/// # Returns
///
/// * `Option<String>` - The installation path, or None if the shell is not supported
pub fn get_completion_path(shell: &str) -> Option<String> {
    match shell.to_lowercase().as_str() {
        "bash" => {
            // XDG: ~/.local/share/bash-completion/completions/
            if let Ok(home) = std::env::var("HOME") {
                Some(format!("{}/.local/share/bash-completion/completions/{{ project_slug }}", home))
            } else {
                None
            }
        }
        "zsh" => {
            // Standard: ~/.local/share/zsh/site-functions/_<app>
            if let Ok(home) = std::env::var("HOME") {
                Some(format!("{}/.local/share/zsh/site-functions/_{{ project_slug }}", home))
            } else {
                None
            }
        }
        "fish" => {
            // Standard: ~/.local/share/fish/completions/<app>.fish
            if let Ok(home) = std::env::var("HOME") {
                Some(format!("{}/.local/share/fish/completions/{{ project_slug }}.fish", home))
            } else {
                None
            }
        }
        "elvish" => {
            // Standard: ~/.local/share/elvish/lib/<app>.elv
            if let Ok(home) = std::env::var("HOME") {
                Some(format!("{}/.local/share/elvish/lib/{{ project_slug }}.elv", home))
            } else {
                None
            }
        }
        "powershell" | "pwsh" => {
            // PowerShell: Use PowerShell profile directory
            if let Ok(home) = std::env::var("HOME") {
                // On Unix-like systems, PowerShell uses ~/.config/powershell/
                Some(format!("{}/.config/powershell/completions/{{ project_slug }}.ps1", home))
            } else if let Ok(localappdata) = std::env::var("LOCALAPPDATA") {
                // On Windows: %LOCALAPPDATA%\PowerShell\Scripts\
                Some(format!("{}/PowerShell/Scripts/{{ project_slug }}.ps1", localappdata))
            } else {
                None
            }
        }
        _ => None,
    }
}

/// Install completion script for a shell
///
/// Generates and installs the completion script to the appropriate location
/// for the given shell. Creates parent directories if they don't exist.
///
/// # Arguments
///
/// * `cmd` - The clap Command to generate completions for
/// * `shell` - The shell type (bash, zsh, fish, elvish, powershell)
///
/// # Returns
///
/// * `anyhow::Result<()>` - Ok if successful, error otherwise
pub fn install_completion(cmd: &mut Command, shell: &str) -> anyhow::Result<()> {
    let path = get_completion_path(shell)
        .ok_or_else(|| anyhow::anyhow!("Could not determine completion path for shell: {}", shell))?;

    // Create parent directories if they don't exist
    if let Some(parent) = std::path::Path::new(&path).parent() {
        std::fs::create_dir_all(parent)?;
    }

    // Generate completion to file
    let mut file = std::fs::File::create(&path)?;
    generate_completion(cmd, shell, &mut file)?;

    eprintln!("Completion script installed to: {}", path);
    eprintln!("You may need to restart your shell or run: source ~/.bashrc (or equivalent)");

    Ok(())
}

#[cfg(test)]
mod tests {
    use super::*;
    use clap::Parser;

    #[test]
    fn test_generate_bash_completion() {
        let mut cmd = Command::new("testapp");
        let mut buf = Vec::new();
        assert!(generate_completion(&mut cmd, "bash", &mut buf).is_ok());
        assert!(!buf.is_empty());
        let output = String::from_utf8(buf).unwrap();
        assert!(output.contains("complete"));
    }

    #[test]
    fn test_generate_zsh_completion() {
        let mut cmd = Command::new("testapp");
        let mut buf = Vec::new();
        assert!(generate_completion(&mut cmd, "zsh", &mut buf).is_ok());
        assert!(!buf.is_empty());
        let output = String::from_utf8(buf).unwrap();
        assert!(output.contains("#compdef"));
    }

    #[test]
    fn test_generate_fish_completion() {
        let mut cmd = Command::new("testapp");
        let mut buf = Vec::new();
        assert!(generate_completion(&mut cmd, "fish", &mut buf).is_ok());
        assert!(!buf.is_empty());
        let output = String::from_utf8(buf).unwrap();
        assert!(output.contains("complete"));
    }

    #[test]
    fn test_generate_elvish_completion() {
        let mut cmd = Command::new("testapp");
        let mut buf = Vec::new();
        assert!(generate_completion(&mut cmd, "elvish", &mut buf).is_ok());
        assert!(!buf.is_empty());
    }

    #[test]
    fn test_generate_powershell_completion() {
        let mut cmd = Command::new("testapp");
        let mut buf = Vec::new();
        assert!(generate_completion(&mut cmd, "powershell", &mut buf).is_ok());
        assert!(!buf.is_empty());
    }

    #[test]
    fn test_generate_powershell_pwsh_alias() {
        let mut cmd = Command::new("testapp");
        let mut buf = Vec::new();
        assert!(generate_completion(&mut cmd, "pwsh", &mut buf).is_ok());
        assert!(!buf.is_empty());
    }

    #[test]
    fn test_unsupported_shell() {
        let mut cmd = Command::new("testapp");
        let mut buf = Vec::new();
        assert!(generate_completion(&mut cmd, "unknown", &mut buf).is_err());
    }

    #[test]
    fn test_get_completion_path_bash() {
        std::env::set_var("HOME", "/test/home");
        let path = get_completion_path("bash");
        assert!(path.is_some());
        assert!(path.unwrap().contains("bash-completion"));
        std::env::remove_var("HOME");
    }

    #[test]
    fn test_get_completion_path_zsh() {
        std::env::set_var("HOME", "/test/home");
        let path = get_completion_path("zsh");
        assert!(path.is_some());
        assert!(path.unwrap().contains("site-functions"));
        std::env::remove_var("HOME");
    }

    #[test]
    fn test_get_completion_path_fish() {
        std::env::set_var("HOME", "/test/home");
        let path = get_completion_path("fish");
        assert!(path.is_some());
        assert!(path.unwrap().contains("fish/completions"));
        std::env::remove_var("HOME");
    }

    #[test]
    fn test_get_completion_path_unsupported() {
        let path = get_completion_path("unknown");
        assert!(path.is_none());
    }

    #[test]
    fn test_get_completion_path_no_home() {
        std::env::remove_var("HOME");
        let path = get_completion_path("bash");
        assert!(path.is_none());
    }
}
