# {{ project_name }} Configuration File
# This file is auto-generated with default values
# Modify as needed for your setup

version = 1

# CLI mode: agent, human
# Agent mode: Optimized for AI agent interaction with TOON format by default
# Human mode: Optimized for human interaction with human-readable output
mode = "agent"

# Default output format for agent mode: toon, json, human
# toon: Token-Oriented Object Notation (~40% token savings, AI-optimized)
# json: Standard JSON format
# human: Human-readable formatted output
default_format = "toon"

# Truncation limit for output content (default 1000)
# Limits the length of output fields to prevent excessive token usage
# Set to 0 for no truncation
truncation_limit = 1000

# Enable contextual help and suggestions
# When true, provides helpful suggestions and context-aware assistance
enable_contextual_help = true

# Enable session context integration
# When true, integrates with session context for enhanced AI interaction
# Requires session hook infrastructure to be configured
session_context_enabled = false

# Log level: error, warn, info, debug, trace
log_level = "info"

# Color mode: auto, always, never
color = "auto"

# Output format: text, json
output_format = "text"

# Quiet mode (suppress non-error output)
quiet = false

# Custom log file path (optional)
# log_file = "/path/to/log/file.log"

# Maximum number of concurrent operations
max_concurrent = 4

# Timeout in seconds for operations
timeout = 30

# Enable experimental features
experimental = false

# Daemon mode enabled
daemon_enabled = true

# Daemon auto-spawn on async operations
daemon_auto_spawn = true

# Maximum number of daemon jobs
daemon_max_jobs = 10

# Daemon job timeout in seconds
daemon_job_timeout = 300

# Maximum memory limit for daemon jobs (e.g., "512M", "2G")
# daemon_max_memory = "512M"

# Maximum CPU usage for daemon jobs (1-100)
# daemon_max_cpu = 80

# Daemon mode: execution, collection, processing
daemon_mode = "execution"

# Data storage path for collection mode
# daemon_data_storage_path = "/path/to/data"
