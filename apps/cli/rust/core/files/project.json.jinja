{
  "name": "{{ project_name | default('rust-cli') }}",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "src",
  "projectType": "application",
  "targets": {
    {% include "partials.bak/partials/nx-partials/nx-target-rust.jinja" %}
    "run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run",
        "cwd": "{projectRoot}"
      }
    }
    {%- if include_http_server -%},
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run -- serve",
        "cwd": "{projectRoot}"
      }
    }
    {%- endif -%}
  }
}
