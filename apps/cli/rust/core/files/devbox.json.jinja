{
  "name": "{{ project_name | default('rust-cli-app') }}",
  "version": "0.1.0",
  "description": "{{ description | default('A Rust CLI application') }}",
  "packages": {
    "rustc": "",
    "cargo": "",
    "rust-analyzer": "",
    "clippy": "",
    "rustfmt": "",
    "just": "",
    "cargo-watch": "",
    "cargo-tarpaulin": "",
    "cargo-audit": "",
    "pkg-config": ""
    {%- if include_openssl -%},
    "openssl": "",
    "openssl.dev": ""
    {%- endif -%}
    {%- if include_postgres -%},
    "postgresql": ""
    {%- endif -%}
    {%- if include_sqlite -%},
    "sqlite": ""
    {%- endif -%}
    {%- if include_redis -%},
    "redis": ""
    {%- endif -%}
  },
  "shell": {
    "init_hook": [
      "just bootstrap-internal"
    ]
  },
  "scripts": {
    "bootstrap": "just bootstrap-internal",
    "doctor": "just doctor-internal",
    "clean": "just clean-internal",
    "build": "just build-internal",
    "lint": "just lint-internal",
    "test": "just test-internal",
    "typecheck": "just typecheck-internal",
    "dev": "just dev-internal",
    "debug": "just debug-internal",
    "install": "just install-internal",
    "release": "just release-internal"
    {%- if include_http_server -%},
    "serve": "just serve-internal"
    {%- endif -%}
  },
  "env": {
    "RUST_LOG": "{{ rust_log_level | default('info') }}",
    "RUST_BACKTRACE": "{{ rust_backtrace | default('1') }}"
    {%- if include_postgres -%},
    "DATABASE_URL": "postgresql://localhost/{{ project_name | default('rust-cli-app') }}"
    {%- endif -%}
    {%- if include_sqlite -%},
    "DATABASE_URL": "sqlite:./{{ project_name | default('rust-cli-app') }}.db"
    {%- endif -%}
    {%- if include_redis -%},
    "REDIS_URL": "redis://localhost:6379"
    {%- endif -%}
    {%- if include_http_server -%},
    "HTTP_PORT": "{{ http_port | default('8080') }}",
    "HTTP_HOST": "0.0.0.0"
    {%- endif -%}
  },
  {% include "_shared/partials/devbox-partials/devbox-hooks-rust.jinja" %}
}
