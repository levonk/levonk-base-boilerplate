apiVersion: v1
kind: Service
metadata:
  name: {{ '{{ include "' }}{{ project_name }}{{ '.fullname" . }}' }}
spec:
  type: {{ '{{ .Values.service.type }}' }}
  ports:
    - port: {{ '{{ .Values.service.port }}' }}
      targetPort: 8080
  selector:
    app.kubernetes.io/name: {{ '{{ include "' }}{{ project_name }}{{ '.fullname" . }}' }}
