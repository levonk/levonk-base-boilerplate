# Environment configuration for {{ project_name }}
# This file is loaded by direnv when entering the directory

# Exit on any error
set -euo pipefail

# Project information
export PROJECT_NAME="{{ project_name }}"
export PROJECT_SLUG="{{ project_slug }}"
export PROJECT_DESCRIPTION="{{ project_description }}"
export APP_NAME="{{ app_name }}"
export APP_IMAGE="{{ app_image }}"
export APP_VERSION="{{ app_version }}"
export APP_PORT="{{ app_port }}"
export CHART_NAME="{{ chart_name }}"
export CHART_VERSION="{{ chart_version }}"
export INGRESS_DOMAIN="{{ ingress_domain }}"
export OCI_REGISTRY="{{ oci_registry }}"
export GITOPS_TOOL="{{ gitops_tool }}"
export AUTHOR_NAME="{{ author_name }}"
export AUTHOR_EMAIL="{{ author_email }}"
export REPO_URL="{{ repo_url }}"
export LICENSE="{{ license }}"

# Kubernetes configuration
export KUBECONFIG="${HOME}/.kube/config"
export KUBECONFIG_DIR="${HOME}/.kube"
export KUBECONFIG_CONTEXT="${KUBECONFIG_CONTEXT:-docker-desktop}"
export KUBECONFIG_NAMESPACE="${KUBECONFIG_NAMESPACE:-{{ project_name }}-dev}"

# Helm configuration
export HELM_CACHE_HOME="${HOME}/.cache/helm"
export HELM_CONFIG_HOME="${HOME}/.config/helm"
export HELM_DATA_HOME="${HOME}/.local/share/helm"
export HELM_REPOSITORY_CACHE="${HELM_CACHE_HOME}/repository"
export HELM_REPOSITORY_CONFIG="${HELM_CONFIG_HOME}/repositories.yaml"

# ArgoCD configuration
export ARGOCD_OPTS="--port-forward-namespace argocd"
export ARGOCD_SERVER="${ARGOCD_SERVER:-argocd-server.argocd.svc.cluster.local:443}"
export ARGOCD_INSECURE="${ARGOCD_INSECURE:-false}"

# Flux configuration
export FLUX_CONFIG="${FLUX_CONFIG:-${HOME}/.config/flux}"
export FLUX_SYSTEM_NAMESPACE="flux-system"

# Development tools
export YQ_CONFIG_YAML_INHERITANCE="override"
export JQ_COLORS="1;30:0;37:0;37:0;37:0;37"
export KUBECTL_DEFAULT_OUTPUT="json"

# Git configuration
export GIT_AUTHOR_NAME="${AUTHOR_NAME}"
export GIT_AUTHOR_EMAIL="${AUTHOR_EMAIL}"
export GIT_COMMITTER_NAME="${AUTHOR_NAME}"
export GIT_COMMITTER_EMAIL="${AUTHOR_EMAIL}"

# Build configuration
export BUILD_DATE="$(date -u +'%Y-%m-%dT%H:%M:%SZ')"
export VCS_REF="$(git rev-parse HEAD 2>/dev/null || echo 'unknown')"
export VCS_URL="${REPO_URL}"

# Security configuration
export SOPS_AGE_KEY_FILE="${HOME}/.config/sops/age/keys.txt"
export SOPS_GPG_EXECUTABLE="${SOPS_GPG_EXECUTABLE:-gpg}"

# Local development overrides
if [ -f ".env.local" ]; then
    source .env.local
fi

# Environment-specific configuration
case "${ENVIRONMENT:-dev}" in
    dev)
        export KUBECONFIG_NAMESPACE="{{ project_name }}-dev"
        export LOG_LEVEL="debug"
        export DEBUG_MODE="true"
        ;;
    staging)
        export KUBECONFIG_NAMESPACE="{{ project_name }}-staging"
        export LOG_LEVEL="info"
        export DEBUG_MODE="false"
        ;;
    prod)
        export KUBECONFIG_NAMESPACE="{{ project_name }}-prod"
        export LOG_LEVEL="warn"
        export DEBUG_MODE="false"
        ;;
    *)
        echo "Unknown environment: ${ENVIRONMENT:-dev}"
        echo "Valid environments: dev, staging, prod"
        exit 1
        ;;
esac

# Path configuration
export PATH="${PATH}:${HOME}/.local/bin:${PWD}/bin"

# Aliases for common commands
alias k="kubectl"
alias h="helm"
alias kx="kustomize"
alias kc="kubectl config"
alias kg="kubectl get"
alias kd="kubectl describe"
alias kdel="kubectl delete"
alias kapp="kubectl apply"
alias kdiff="kubectl diff"

# Kubernetes aliases with namespace
alias kgp="kubectl get pods -n ${KUBECONFIG_NAMESPACE}"
alias kgs="kubectl get services -n ${KUBECONFIG_NAMESPACE}"
alias kgi="kubectl get ingress -n ${KUBECONFIG_NAMESPACE}"
alias kgd="kubectl get deployments -n ${KUBECONFIG_NAMESPACE}"
alias kgsec="kubectl get secrets -n ${KUBECONFIG_NAMESPACE}"
alias kgcm="kubectl get configmaps -n ${KUBECONFIG_NAMESPACE}"

# Helm aliases
alias hi="helm install"
alias hu="helm upgrade"
alias hun="helm uninstall"
alias hl="helm lint"
alias ht="helm template"
alias hp="helm package"

# Kustomize aliases
alias kbd="kustomize build deploy/apps/{{ project_slug }}/overlays/dev"
alias kbs="kustomize build deploy/apps/{{ project_slug }}/overlays/staging"
alias kbp="kustomize build deploy/apps/{{ project_slug }}/overlays/prod"

# ArgoCD aliases
alias argo="argocd"
alias argoapp="argocd app"
alias argorepo="argocd repo"

# Functions
kns() {
    kubectl config set-context --current --namespace="$1"
}

kexec() {
    local pod="$1"
    shift
    kubectl exec -n ${KUBECONFIG_NAMESPACE} -it "$pod" -- "$@"
}

klogs() {
    local pod="$1"
    kubectl logs -n ${KUBECONFIG_NAMESPACE} -f "$pod"
}

kpf() {
    local service="$1"
    local local_port="${2:-{{ app_port }}"
    local remote_port="${3:-{{ app_port }}}"
    kubectl port-forward -n ${KUBECONFIG_NAMESPACE} "svc/$service" "${local_port}:${remote_port}"
}

# Validation functions
validate_k8s() {
    echo "Validating Kubernetes manifests..."
    kubeval --strict deploy/apps/{{ project_slug }}/base/kustomization.yaml
    kubeconform --strict deploy/apps/{{ project_slug }}/base/kustomization.yaml
    kube-score score deploy/apps/{{ project_slug }}/base/kustomization.yaml
}

validate_helm() {
    echo "Validating Helm chart..."
    helm lint deploy/charts/{{ project_slug }}/
    helm template {{ project_name }}-test deploy/charts/{{ project_slug }}/ --dry-run --validate
}

validate_all() {
    validate_k8s
    validate_helm
}

# Development functions
dev_setup() {
    echo "Setting up development environment..."
    kubectl config use-context "${KUBECONFIG_CONTEXT}"
    helm repo add stable https://charts.helm.sh/stable
    helm repo add jetstack https://charts.jetstack.io/stable
    helm repo update
    echo "Development environment setup complete!"
}

dev_deploy() {
    echo "Deploying to development environment..."
    kubectl apply -k deploy/apps/{{ project_slug }}/overlays/dev
    echo "Development deployment complete!"
}

dev_status() {
    echo "Checking development deployment status..."
    kubectl get pods -n ${KUBECONFIG_NAMESPACE}
    kubectl get services -n ${KUBECONFIG_NAMESPACE}
    kubectl get ingress -n ${KUBECONFIG_NAMESPACE}
}

# Welcome message
echo "🚀 {{ project_name }} environment loaded"
echo "📋 Project: {{ project_name }}"
echo "👤 Author: {{ author_name }} ({{ author_email }})"
echo "🔧 Environment: ${ENVIRONMENT:-dev}"
echo "🌐 Namespace: ${KUBECONFIG_NAMESPACE}"
echo "📊 Status: dev_status"
echo "🧪 Validate: validate_all"
echo "🚀 Deploy: dev_deploy"
echo ""
echo "Use 'help' to see available commands"
