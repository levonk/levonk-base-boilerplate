suite: secret test
templates:
  - secret.yaml
tests:
  - it: should create secret when database is enabled
    set:
      path: $[{{ .Values.database.enabled }}]
    asserts:
      - isKind:
          of: Secret
      - equal:
          path: metadata.name
          value: {{ chart_name }}-test-database
      - equal:
          path: metadata.labels.app.kubernetes.io/name
          value: {{ chart_name }}
      - equal:
          path: metadata.labels.app.kubernetes.io/instance
          value: {{ chart_name }}-test
      - equal:
          path: type
          value: Opaque
      - isNotEmpty:
          path: data
      - equal:
          path: data.username
          value: {{ .Values.database.user | b64enc }}
      - equal:
          path: data.password
          value: {{ .Values.database.password | b64enc }}
  - it: should have proper labels when database is enabled
    set:
      path: $[{{ .Values.database.enabled }}]
    asserts:
      - equal:
          path: metadata.labels.app.kubernetes.io/name
          value: {{ chart_name }}
      - equal:
          path: metadata.labels.app.kubernetes.io/instance
          value: {{ chart_name }}-test
  - it: should have proper annotations when specified
    set:
      path: $[{{ .Values.database.enabled }}]
      path: $[{{ if enable_secret_annotations }}].metadata.annotations
      value:
        secret.kubernetes.io/managed-by: "kustomize"
        secret.kubernetes.io/created-by: "platform-team"
    asserts:
      - equal:
          path: $[{{ .Values.database.enabled }}].metadata.annotations.secret.kubernetes.io/managed-by
          value: kustomize
      - equal:
          path: $[{{ .Values.database.enabled }}].metadata.annotations.secret.kubernetes.io/created-by
          value: platform-team
  - it: should have immutable annotation when specified
    set:
      path: $[{{ .Values.database.enabled }}]
      path: $[{{ if enable_immutable_secrets }}].metadata.annotations
      value:
        secret.kubernetes.io/immutable: "true"
    asserts:
      - equal:
          path: $[{{ .Values.database.enabled }}].metadata.annotations.secret.kubernetes.io/immutable
          value: "true"
  - it: should have custom type when specified
    set:
      path: $[{{ .Values.database.enabled }}]
      path: $[{{ if enable_custom_secret_type }}].type
      value: kubernetes.io/tls
    asserts:
      - equal:
          path: $[{{ .Values.database.enabled }}].type
          value: kubernetes.io/tls
  - it: should have custom namespace when specified
    set:
      path: $[{{ .Values.database.enabled }}]
      path: $[{{ if enable_custom_namespace }}].metadata.namespace
      value: custom-namespace
    asserts:
      - equal:
          path: $[{{ .Values.database.enabled }}].metadata.namespace
          value: custom-namespace
  - it: should have extra labels when specified
    set:
      path: $[{{ .Values.database.enabled }}]
      path: $[{{ if enable_extra_labels }}].metadata.labels
      value:
        extra-label: "extra-value"
        team: "platform"
    asserts:
      - equal:
          path: $[{{ .Values.database.enabled }}].metadata.labels.extra-label
          value: "extra-value"
      - equal:
          path: $[{{ .Values.database.enabled }}].metadata.labels.team
          value: "platform"
  - it: should have extra annotations when specified
    set:
      path: $[{{ .Values.database.enabled }}]
      path: $[{{ if enable_extra_annotations }}].metadata.annotations
      value:
        extra-annotation: "extra-value"
        secret.kubernetes.io/last-applied: "2023-01-01T00:00:00Z"
    asserts:
      - equal:
          path: $[{{ .Values.database.enabled }}].metadata.annotations.extra-annotation
          value: "extra-value"
      - equal:
          path: $[{{ .Values.database.enabled }}].metadata.annotations.secret.kubernetes.io/last-applied
          value: "2023-01-01T00:00:00Z"
  - it: should have owner references when specified
    set:
      path: $[{{ .Values.database.enabled }}]
      path: $[{{ if enable_owner_references }}].metadata.annotations
      value:
        secret.kubernetes.io/owner: "platform-team"
        secret.kubernetes.io/managed-by: "argocd"
    asserts:
      - equal:
          path: $[{{ .Values.database.enabled }}].metadata.annotations.secret.kubernetes.io/owner
          value: "platform-team"
      - equal:
          path: $[{{ .Values.database.enabled }}].metadata.annotations.secret.kubernetes.io/managed-by
          value: "argocd"
  - it: should have string data when specified
    set:
      path: $[{{ .Values.database.enabled }}]
      path: $[{{ if enable_string_data }}].data
      value:
        api-key: "base64-encoded-api-key"
        jwt-secret: "base64-encoded-jwt-secret"
        webhook-url: "base64-encoded-webhook-url"
    asserts:
      - equal:
          path: $[{{ .Values.database.enabled }}].data.api-key
          value: base64-encoded-api-key
      - equal:
          path: ${{ .Values.database.enabled }}.data.jwt-secret
          value: base64-encoded-jwt-secret
      - equal:
          path: $[{{ .Values.database.enabled }}.data.webhook-url
          value: base64-encoded-webhook-url
  - it: should have binary data when specified
    set:
      path: $[{{ .Values.database.enabled }}]
      path: $[{{ if enable_binary_data }}].data
      value:
        certificate.crt: |
          {{ "binary_certificate_placeholder" }}
        private.key: |
          {{ "binary_private_key_placeholder" }}
        ca-bundle.crt: |
          {{ "binary_ca_bundle_placeholder" }}
    asserts:
      - isNotEmpty:
          path: $[{{ .Values.database.enabled }}].data.certificate.crt
      - isNotEmpty:
          path: $[{{ .Values.database.enabled }}].data.private.key
      - isNotEmpty:
          path: ${{ .Values.database.enabled }}].data.ca-bundle.crt
  - it: should have TLS certificates when specified
    set:
      path: $[{{ .Values.database.enabled }}]
      path: $[{{ if enable_tls_certificates }}].data
      value:
        tls.crt: |
          {{ "tls_certificate_placeholder" }}
        tls.key: |
          {{ "tls_private_key_placeholder" }}
        ca.crt: |
          {{ "ca_certificate_placeholder" }}
    asserts:
      - isNotEmpty:
          path: $[{{ .Values.database.enabled }}].data.tls.crt
      - isNotEmpty:
          path: $[{{ .Values.database.enabled }}].data.tls.key
      - isNotEmpty:
          path: $[{{ .Values.database.enabled }}.data.ca.crt
  - it: should have SSH keys when specified
    set:
      path: $[{{ .Values.database.enabled }}]
      path: $[{{ if enable_ssh_keys }}].data
      value:
        id_rsa.pub: |
          {{ "ssh_public_key_placeholder" }}
        id_rsa: |
          {{ "ssh_private_key_placeholder" }}
        known_hosts: |
          {{ "known_hosts_placeholder" }}
    asserts:
      - isNotEmpty:
          path: $[{{ .Values.database.enabled }}].data.id_rsa.pub
      - isNotEmpty:
          path: ${{ .Values.database.enabled }}.data.id_rsa
      - isNotEmpty:
          path: $[{{ .Values.database.enabled }}.data.known_hosts
  - it: should have API keys when specified
    set:
      path: $[{{ .Values.database.enabled }}]
      path: $[{{ if enable_api_keys }}].data
      value:
        api-key: "base64-encoded-api-key"
        api-secret: "base64-encoded-api-secret"
        webhook-secret: "base64-encoded-webhook-secret"
    asserts:
      - equal:
          path: $[{{ .Values.database.enabled }}].data.api-key
          value: base64-encoded-api-key
      - equal:
          path: $[{{ .Values.database.enabled }}].data.api-secret
          value: base64-encoded-api-secret
      - equal:
          path: $[{{ .Values.database.enabled }}.data.webhook-secret
          value: base64-encoded-webhook-secret
  - it: should have OAuth tokens when specified
    set:
      path: $[{{ .Values.database.enabled }}]
      path: $[{{ if enable_oauth_tokens }}].data
      value:
        access-token: "base64-encoded-access-token"
        refresh-token: "base64-encoded-refresh-token"
        client-secret: "base64-encoded-client-secret"
    asserts:
      - equal:
          path: $[{{ .Values.database.enabled }}].data.access-token
          value: base64-encoded-access-token
      - equal:
          path: ${{ .Values.database.enabled }}].data.refresh-token
          value: base64-encoded-refresh-token
      - equal:
          path: $[{{ .Values.database.enabled }}].data.client-secret
          value: base64-encoded-client-secret
  - it: should have JWT secrets when specified
    set:
      path: $[{{ .Values.database.enabled }}]
      path: $[{{ if enable_jwt_secrets }}].data
      value:
        jwt-secret: "base64-encoded-jwt-secret"
        jwt-public-key: "base64-encoded-jwt-public-key"
        jwt-private-key: "base64-encoded-jwt-private-key"
    asserts:
      - equal:
          path: $[{{ .Values.database.enabled }}].data.jwt-secret
          value: base64-encoded-jwt-secret
      - equal:
          path: ${{ .Values.database.enabled }}.data.jwt-public-key
          value: base64-encoded-jwt-public-key
      - equal:
          path: $[{{ .Values.database.enabled }}].data.jwt-private-key
          value: base64-encoded-jwt-private-key
  - it: should have database connection string when specified
    set:
      path: $[{{ .Values.database.enabled }}]
      path: $[{{ if enable_connection_string }}].data
      value:
        database-url: "base64-encoded-database-url"
        redis-url: "base64-encoded-redis-url"
        mongodb-url: "base64-encoded-mongodb-url"
    asserts:
      - equal:
          path: $[{{ .Values.database.enabled }}].data.database-url
          value: base64-encoded-database-url
      - equal:
          path: $[{{ .Values.database.enabled }}].data.redis-url
          value: base64-encoded-redis-url
      - equal:
          path: ${{ .Values.database.enabled }}.data.mongodb-url
          value: base64-encoded-mongodb-url
  - it: should have configuration files when specified
    set:
      path: $[{{ .Values.database.enabled }}]
      path: $[{{ if enable_config_files }}].data
      value:
        database.conf: |
          {{ "database_configuration_placeholder" }}
        redis.conf: |
          {{ "redis_configuration_placeholder" }}
        app.properties: |
          {{ "application_properties_placeholder" }}
    asserts:
      - isNotEmpty:
          path: $[{{ .Values.database.enabled }}].data.database.conf
      - isNotEmpty:
          path: ${{ .Values.database.enabled }}].data.redis.conf
      - isNotEmpty:
          path: ${{ .Values.database.enabled }}].data.app.properties
  - it: should have environment variables when specified
    set:
      path: $[{{ .Values.database.enabled }}]
      path: $[{{ if enable_env_vars }}].data
      value:
        DATABASE_URL: "base64-encoded-database-url"
        REDIS_URL: "base64-encoded-redis-url"
        MONGODB_URL: "base64-encoded-mongodb-url"
        API_ENDPOINT: "base64-encoded-api-endpoint"
    asserts:
      - equal:
          path: $[{{ .Values.database.enabled }}].data.DATABASE_URL
          value: base64-encoded-database-url
      - equal:
          path: $[{{ .Values.database.enabled }}].data.REDIS_URL
          value: base64-encoded-redis-url
      - equal:
          path: $[{{ .Values.database.enabled }}].data.MONGODB_URL
          value: base64-encoded-mongodb-url
      - equal:
          path: $[{{ .Values.database.enabled }}].data.API_ENDPOINT
          value: base64-encoded-api-endpoint
  - it: should have custom secrets when specified
    set:
      path: $[{{ .Values.database.enabled }}]
      path: $[{{ if enable_custom_secrets }}].data
      value:
        custom-secret-1: "base64-encoded-custom-secret-1"
        custom-secret-2: "base64-encoded-custom-secret-2"
        custom-secret-3: "base64-encoded-custom-secret-3"
    asserts:
      - equal:
          path: $[{{ .Values.database.enabled }}].data.custom-secret-1
          value: base64-encoded-custom-secret-1
      - equal:
          path: $[{{ .Values.database.enabled }}].data.custom-secret-2
          value: base64-encoded-custom-secret-2
      - equal:
          path: $[{{ .Values.database.enabled }}].data.custom-secret-3
          value: base64-encoded-custom-secret-3
  - it: should have additional secrets when specified
    set:
      path: $[{{ .Values.database.enabled }}]
      path: $[{{ .Values.additional_secrets }}].data
      value:
        additional-secret-1: "base64-encoded-additional-secret-1"
        additional-secret-2: "base64-encoded-additional-secret-2"
    asserts:
      - isNotEmpty:
          path: $[{{ .Values.database.enabled }}].data.additional-secret-1
      - isNotEmpty:
          path: $[{{ .Values.database.enabled }}].data.additional-secret-2
  - it: should have proper encoding for all data
    set:
      path: $[{{ .Values.database.enabled }}]
      path: data.username
      value: {{ .Values.database.user | b64enc }}
    asserts:
      - matchRegex:
          path: data.username
          pattern: "^[A-Za-z0-9+/]+=*$"
  - it: should have proper encoding for password
    set:
      path: $[{{ .Values.database.enabled }}]
      path: data.password
      value: {{ .Values.database.password | b64enc }}
    asserts:
      - matchRegex:
          path: data.password
          pattern: "^[A-Za-z0-9+/]+=*$"
