{{- if .Values.secrets -}}
{{- range $name, $secret := .Values.secrets }}
---
apiVersion: v1
kind: Secret
metadata:
  name: {{ include "{{ chart_name }}.fullname" . }}-{{ $name }}
  labels:
    {{- include "{{ chart_name }}.labels" . | nindent 4 }}
type: Opaque
data:
  {{- toYaml $secret.data | nindent 2 }}
{{- end }}
{{- end }}

{{- if .Values.database.enabled }}
---
apiVersion: v1
kind: Secret
metadata:
  name: {{ include "{{ chart_name }}.fullname" . }}-database
  labels:
    {{- include "{{ chart_name }}.labels" . | nindent 4 }}
type: Opaque
data:
  username: {{ .Values.database.user | b64enc }}
  password: {{ .Values.database.password | b64enc }}
{{- end }}
