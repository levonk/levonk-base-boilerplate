# Paperclip Environment Configuration
# Copy this file to .env and customize for your environment

# Node.js environment
NODE_ENV=production

# Paperclip API server port
PORT={{ service_port }}

# Database configuration
{% if include_postgres %}
# PostgreSQL connection (docker-compose service)
DATABASE_URL=postgresql://paperclip:paperclip@postgres:{{ postgres_port }}/paperclip
{% else %}
# Embedded database (default)
# DATABASE_URL=
{% endif %}

# Server bind address
PAPERCLIP_BIND=0.0.0.0

# Optional: Additional Paperclip configuration
# PAPERCLIP_LOG_LEVEL=info
# PAPERCLIP_MAX_AGENTS=10
# PAPERCLIP_BUDGET_LIMIT=1000
