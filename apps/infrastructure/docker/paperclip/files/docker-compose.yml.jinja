version: '3.8'

services:
  paperclip:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: {{ service_name }}
    ports:
      - "{{ service_port }}:{{ service_port }}"
    environment:
      - NODE_ENV=production
      - PORT={{ service_port }}
{% if include_postgres %}
      - DATABASE_URL=postgresql://paperclip:paperclip@postgres:{{ postgres_port }}/paperclip
{% endif %}
      - PAPERCLIP_BIND=0.0.0.0
    restart: unless-stopped
{% if include_postgres %}
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - paperclip-network
{% endif %}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://127.0.0.1:{{ service_port }}/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s

{% if include_postgres %}
  postgres:
    image: postgres:{{ postgres_version }}-alpine
    container_name: {{ service_name }}-postgres
    environment:
      - POSTGRES_DB=paperclip
      - POSTGRES_USER=paperclip
      - POSTGRES_PASSWORD=paperclip
    ports:
      - "{{ postgres_port }}:{{ postgres_port }}"
    volumes:
      - postgres-data:/var/lib/postgresql/data
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U paperclip -d paperclip"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - paperclip-network
{% endif %}

{% if include_postgres %}
volumes:
  postgres-data:
    driver: local

networks:
  paperclip-network:
    driver: bridge
{% endif %}
