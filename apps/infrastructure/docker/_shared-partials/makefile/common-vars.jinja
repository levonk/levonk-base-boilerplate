# Colors for output
BLUE := \033[0;34m
GREEN := \033[0;32m
YELLOW := \033[0;33m
RED := \033[0;31m
NC := \033[0m # No Color

# Project configuration
SERVICE_NAME := {{ _service_name_slug }}
SERVICE_PORT := {{ _service_port }}
SERVICE_HEALTH_ENDPOINT := {{ _service_health_endpoint }}
COMPOSE_FILE ?= docker-compose.yml
COMPOSE_OVERRIDE_FILE ?= docker-compose.override.yml
ENV_FILE ?= .env
WORKDIR := $(CURDIR)
DOCKER_COMPOSE := docker compose -f $(COMPOSE_FILE) --env-file $(ENV_FILE)
