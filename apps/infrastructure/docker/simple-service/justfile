# Simple Docker Service Development Commands

# Detect NX binary
NX_BIN := `command -v nx || echo ""`
NX_AVAILABLE := if NX_BIN != "" { "true" } else { "false" }

# Default recipe
default:
    @just --list

# Standard development recipes (REQUIRED)
clean:
    devbox shell clean

dev:
    devbox shell dev

build:
    devbox shell build

test:
    devbox shell test

lint:
    devbox shell lint

typecheck:
    devbox shell typecheck

# Bootstrap recipes (REQUIRED)
bootstrap:
    devbox shell bootstrap

bootstrap-internal:
    @echo "📦 Installing pnpm and NX..."
    @npm install -g pnpm@latest
    @if [ "{{ NX_AVAILABLE }}" = "false" ]; then pnpm add -g nx@latest; fi
    @pnpm install
    @echo "✓ Bootstrap complete"

# NX Commands
nx-build:
    @if [ "{{ NX_AVAILABLE }}" = "true" ]; then nx docker:build; else docker build -t simple-service .; fi

nx-up:
    @if [ "{{ NX_AVAILABLE }}" = "true" ]; then nx docker:up; else docker run -p 8080:8080 simple-service; fi

nx-down:
    @if [ "{{ NX_AVAILABLE }}" = "true" ]; then nx docker:down; else docker stop $(docker ps -q --filter "name=simple-service"); fi

nx-affected:
    @if [ "{{ NX_AVAILABLE }}" = "true" ]; then nx affected; else echo "NX not available"; fi

nx-graph:
    @if [ "{{ NX_AVAILABLE }}" = "true" ]; then nx graph; else echo "NX not available"; fi

nx-clear-cache:
    @if [ "{{ NX_AVAILABLE }}" = "true" ]; then nx reset; else echo "NX not available"; fi

nx-install:
    @pnpm add -g nx@latest
    @echo "✓ NX installed globally"

# Health and diagnostics (REQUIRED)
doctor:
    # Check Simple Docker service environment
    @echo "🐳 Docker version:"
    @docker --version
    @echo ""
    @echo "🛠️  Development tools:"
    @command -v just || echo "just not found"
    @echo ""
    @echo "📦 Node environment:"
    @node --version
    @pnpm --version
    @echo "📊 NX: {{ if NX_AVAILABLE }}$(nx --version){{ else }}not installed{{ endif }}"
    @echo ""
    @echo "✅ Simple Docker service environment is ready!"

# Development mode
dev:
    @just build
    @just run

# Build Docker image
build:
    docker build -t simple-service .

# Run container
run:
    docker run -p 8080:8080 simple-service

# Run container in background
run-detached:
    docker run -d -p 8080:8080 simple-service

# Stop container
stop:
    docker stop $(docker ps -q --filter "name=simple-service")

# Remove container
rm:
    docker rm $(docker ps -aq --filter "name=simple-service")

# Clean up
clean:
    @just stop
    @just rm
    docker system prune -f

# Development setup
setup:
    @just bootstrap
    echo "✅ Simple Docker service development environment ready!"

# Health check
health:
    curl -f http://localhost:8080/health || echo "Service not running"

# Execute command in container
exec command="/bin/bash":
    docker exec -it $(docker ps -q --filter "name=simple-service") {{command}}

# Run tests
test:
    docker run --rm simple-service pytest

# Lint Docker files
lint:
    hadolint Dockerfile.jinja

# Type check
typecheck:
    echo "Type checking not applicable for Simple Docker service"

# Package for distribution
package:
    @just build
    @just clean
    mkdir -p dist
    docker save simple-service:latest > dist/simple-service.tar

# Quality checks
quality:
    @just lint
    @just test
    @just health

# View logs
logs:
    docker logs -f $(docker ps -q --filter "name=simple-service")
