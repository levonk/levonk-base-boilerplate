apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: {{ app_name }}
  namespace: flux-system
spec:
  interval: 10m
  path: ./apps/{{ app_name }}/overlays/prod
  prune: true
  sourceRef:
    kind: GitRepository
    name: {{ project_name }}
  targetNamespace: {{ app_name }}
