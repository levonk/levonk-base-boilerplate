{
    "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
    "packages": {
        "swift": "",
        "swiftlint": "",
        "swiftformat": "",
        "just": ""
        {% if include_docker %},
        "docker": "",
        "docker-compose": ""
        {% endif %}
        {% if include_ci %},
        "github-cli": ""
        {% endif %}
    },
    "shell": {
        "init_hook": [
            "echo '📦 {{ package_name | default('swift-package') }} environment initialized'",
            "echo '⚠️  Swift {{ swift_version | default('5.9') }} development environment ready'",
            "echo '🛠️  Use: just test && just lint'"
        ],
        "scripts": {
            "bootstrap": "just bootstrap-internal",
            "doctor": "just doctor-internal",
            "clean": "just clean-internal",
            "build": "just build-internal",
            "test": "just test-internal",
            "lint": "just lint-internal",
            "typecheck": "just typecheck-internal",
            "dev": "just dev-internal"
        }
    },
    "env": {
        "SWIFT_VERSION": "{{ swift_version | default('5.9') }}",
        "PACKAGE_NAME": "{{ package_slug | default('swift-package') }}",
        "MODULE_NAME": "{{ module_name | default('SwiftPackage') }}"
        {% if include_docker %},
        "DOCKER_BUILDKIT": "1",
        "COMPOSE_DOCKER_CLI_BUILD": "1"
        {% endif %}
    },
    {% include "partials.bak/partials/devbox-partials/devbox-hooks-swift.jinja" %}
}
