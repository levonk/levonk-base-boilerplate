{
  "name": "{{ project_name }}",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "{{ project_root }}",
  "projectType": "{% if is_library %}library{% else %}application{% endif %}",
  "targets": {
    "build": {
      {% if project_type == "nodejs" %}"executor": "@nx/js:build",
      "options": {
        "outputPath": "dist/{{ project_name }}",
        "main": "{projectRoot}/src/index.ts",
        "tsConfig": "{projectRoot}/tsconfig.json"
      }{% elif project_type == "docker" %}"executor": "@nx-tools/nx-container:build",
      "options": {
        "dockerfile": "{projectRoot}/Dockerfile",
        "context": "{projectRoot}",
        "tags": ["{{ project_name }}:latest"]
      }{% elif project_type == "python" %}"executor": "@nxlv/python:build",
      "options": {
        "outputPath": "dist/{{ project_name }}",
        "publish": false
      }{% else %}"executor": "nx:run-commands",
      "options": {
        "command": "echo 'Build not configured for {{ project_type }}'",
        "cwd": "{projectRoot}"
      }{% endif %}
    },
    "test": {
      {% if project_type == "nodejs" %}"executor": "@nx/js:test",
      "options": {
        "jestConfig": "{projectRoot}/jest.config.ts"
      }{% elif project_type == "python" %}"executor": "@nxlv/python:test",
      "options": {
        "testCommand": "pytest"
      }{% else %}"executor": "nx:run-commands",
      "options": {
        "command": "echo 'Tests not configured'",
        "cwd": "{projectRoot}"
      }{% endif %}
    },
    "lint": {
      {% if project_type == "nodejs" %}"executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["{projectRoot}/**/*.ts"]
      }{% elif project_type == "python" %}"executor": "@nxlv/python:lint",
      "options": {
        "linter": "ruff"
      }{% else %}"executor": "nx:run-commands",
      "options": {
        "command": "echo 'Lint not configured'",
        "cwd": "{projectRoot}"
      }{% endif %}
    },
    "dev": {
      {% if project_type == "nodejs" %}"executor": "@nx/js:node",
      "options": {
        "buildTarget": "{{ project_name }}:build",
        "watch": true
      }{% else %}"executor": "nx:run-commands",
      "options": {
        "command": "echo 'Dev mode not configured'",
        "cwd": "{projectRoot}"
      }{% endif %}
    }
  }
}
