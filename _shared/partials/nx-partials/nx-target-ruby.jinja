    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bundle install",
        "cwd": "{projectRoot}"
      },
      "cache": false
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bundle exec rspec",
        "cwd": "{projectRoot}"
      },
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bundle exec rubocop",
        "cwd": "{projectRoot}"
      },
      "cache": true
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bundle exec rubocop -A",
        "cwd": "{projectRoot}"
      },
      "cache": true
    },
