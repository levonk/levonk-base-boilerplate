# TypeScript/Node dependency synchronization
# Automatically syncs lock file when package.json is modified
# Supports pnpm (default), npm, and yarn

sync-deps:
    #!/usr/bin/env bash
    set -euo pipefail
    # Synchronize lock file with package.json
    # Called by pre-commit target when package.json is modified
    echo "🔄 Syncing lock file with package.json..."
    
    # Detect package manager and use appropriate command
    if [ -f "pnpm-lock.yaml" ]; then
        pnpm install
        git add pnpm-lock.yaml
    elif [ -f "package-lock.json" ]; then
        npm install
        git add package-lock.json
    elif [ -f "yarn.lock" ]; then
        yarn install
        git add yarn.lock
    else
        echo "⚠️  No lock file found, running pnpm install..."
        pnpm install
        git add pnpm-lock.yaml
    fi
    
    echo "✅ Lock file synchronized and staged"

pre-commit:
    #!/usr/bin/env bash
    set -euo pipefail
    # Pre-commit hook orchestration - called by git pre-commit hook
    # This target can call multiple validation targets
    echo "🔍 Running pre-commit checks..."
    
    # Check if package.json is modified and sync dependencies if needed
    if git diff --cached --name-only | grep -q "package.json"; then
        echo "package.json modified, syncing dependencies..."
        just sync-deps
    fi
    
    echo "✅ Pre-commit checks complete"
