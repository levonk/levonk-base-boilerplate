# Node/TypeScript: prettier for format. ESLint runs as a local hook against the
# project's own config (language: system) so it respects the local eslint version.
-   repo: https://github.com/pre-commit/mirrors-prettier
    rev: v3.3.3
    hooks:
    -   id: prettier
        types_or: [javascript, jsx, ts, tsx, json, css, yaml, markdown]
