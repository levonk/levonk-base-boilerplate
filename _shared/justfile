    @echo "📁 Shared partials location: $(pwd)"
    @echo "🛠️  Use: copier-wrapper.sh copy <template> <destination>"

doctor-internal:
    #!/usr/bin/env bash
    set -euo pipefail
    MISSING=0
    for tool in copier just git ctags uv desloppify roam qmd tkr; do
      if command -v $tool >/dev/null 2>&1; then
        printf "[doctor] %-8s OK\n" "$tool"
      else
        echo "[doctor] MISSING: $tool"
        MISSING=$((MISSING+1))
      fi
    done
    
    # Check for indexing artifacts
    echo "[doctor] Checking indexing artifacts..."
    if [ -f .tags ]; then
        echo "[doctor] .tags file found (ctags indexing)"
    else
        echo "[doctor] .tags file missing (run 'just prime' to generate)"
    fi
    
    if [ -d .roam ]; then
        echo "[doctor] .roam directory found (roam-code indexing)"
    else
        echo "[doctor] .roam directory missing (run 'just prime' to generate)"
    fi
    
    if [ -f .desloppify ]; then
        echo "[doctor] .desloppify file found (desloppify scanning)"
    else
        echo "[doctor] .desloppify file missing (run 'just prime' to generate)"
    fi
    
    # Check for memory management setup
    if [ -d memory ]; then
        echo "[doctor] memory/ directory found (Obsidian memory structure)"
    else
        echo "[doctor] memory/ directory missing (run 'just bootstrap' to create)"
    fi
    
    if [ -d .tickets ]; then
        echo "[doctor] .tickets directory found (tkr task management)"
    else
        echo "[doctor] .tickets directory missing (run 'just bootstrap' to create)"
    fi
    
    if [ "$MISSING" -ne 0 ]; then
        echo "[doctor] Missing $MISSING required tool(s). Run 'just bootstrap' to install."
        exit 1
    fi
    echo "[doctor] Shared partials environment looks good."

# Clean up (OPTIONAL)
clean-internal:
    @echo "🧹 Cleaning shared partials (internal)..."
    @find . -name "partials.bak" -type d -exec rm -rf {} + 2>/dev/null || true
    @echo "✅ Clean complete"

# Deep clean (OPTIONAL)
clean-all-internal:
    @echo "🧹 Deep cleaning shared partials..."
    @find . -name "partials.bak" -type d -exec rm -rf {} + 2>/dev/null || true
    @find . -name "*.tmp" -delete 2>/dev/null || true
    @find . -name ".DS_Store" -delete 2>/dev/null || true
    @echo "✅ Deep clean complete"

