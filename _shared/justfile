    @echo "🔍 Linting shared partials (internal)..."
    @find _shared -name "*.jinja" -exec echo "Checking {}" \;
    @echo "✅ Lint complete"

typecheck-internal:
    @echo "🔍 Type checking shared partials (internal)..."
    @echo "✅ Type check complete"

dev-internal:
