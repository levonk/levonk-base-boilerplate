{
  "name": "{{ project_name | default('ts-cli-app') }}",
  "version": "0.1.0",
  "description": "{{ project_description | default('A TypeScript CLI application') }}",
  "shell": {
    "init": [
      "echo '📘 Setting up {{ project_name | default('ts-cli-app') }} development environment...'"
    ],
  },
  {% include "partials.bak/partials/devbox-partials/devbox-hooks-typescript.jinja" %}
  "scripts": {
    "build": "tsc",
    "build-watch": "tsc --watch",
    "build-release": "tsc && npm pkg fix",
    "test": "vitest",
    "test-coverage": "vitest --coverage",
    "lint": "eslint . --ext .ts,.js",
    "format": "prettier --write .",
    "format-check": "prettier --check .",
    "run": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist/",
    "type-check": "tsc --noEmit",
    "check": "eslint . --ext .ts,.js && tsc --noEmit"
  },
  "packages": [
    "nixpkgs#nodejs",
    "nixpkgs#typescript",
    "nixpkgs#tsx",
    "nixpkgs#eslint",
    "nixpkgs#prettier",
    "nixpkgs#pnpm",
    "nixpkgs#just"
  ],
  "env": {
    "TS_NODE_PROJECT": "{{ ts_node_project | default('./tsconfig.json') }}"{% if include_development %},
    "LOG_LEVEL": "{{ log_level | default('info') }}",
    "DEBUG": "{{ debug | default('app:*') }}"{% endif %}{% if include_config %},
    "CONFIG_PATH": "{{ config_path | default('./config.json') }}"{% endif %},
    "NODE_ENV": "{{ node_env | default('development') }}"
  }
}
