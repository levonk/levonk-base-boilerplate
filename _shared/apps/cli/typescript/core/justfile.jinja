# Justfile for {{ project_name | default('ts-cli-app') }}
# NX-friendly configuration for monorepo integration

# Detect NX binary
NX_BIN := `command -v nx || echo ""`
NX_AVAILABLE := if NX_BIN != "" { "true" } else { "false" }

# Bootstrap - install pnpm and NX globally
bootstrap-internal:
    @echo "📦 Bootstrapping..."
    # Install dependencies in background if not present
    [ -d node_modules/ ] || pnpm install &

    @echo "📦 Installing pnpm and NX..."
    @npm install -g pnpm@latest
    @if [ "{{ NX_AVAILABLE }}" = "false" ]; then pnpm add -g nx@latest; fi
    @echo "✓ Bootstrap complete"

# NX Commands
nx-build:
    @if [ "{{ NX_AVAILABLE }}" = "true" ]; then nx build; else pnpm run build; fi

nx-test:
    @if [ "{{ NX_AVAILABLE }}" = "true" ]; then nx test; else pnpm run test; fi

nx-lint:
    @if [ "{{ NX_AVAILABLE }}" = "true" ]; then nx lint; else pnpm run lint; fi

nx-typecheck:
    @if [ "{{ NX_AVAILABLE }}" = "true" ]; then nx typecheck; else pnpm run typecheck; fi

nx-affected:
    @if [ "{{ NX_AVAILABLE }}" = "true" ]; then nx affected; else echo "NX not available"; fi

nx-graph:
    @if [ "{{ NX_AVAILABLE }}" = "true" ]; then nx graph; else echo "NX not available"; fi

nx-clear-cache:
    @if [ "{{ NX_AVAILABLE }}" = "true" ]; then nx reset; else echo "NX not available"; fi

# Legacy commands (for non-NX usage)
build:
    @pnpm run build

test:
    @pnpm run test

lint:
    @pnpm run lint

dev:
    @pnpm run dev

# Doctor - check environment
doctor:
    @echo "🔍 Environment check:"
    @echo "  Node: $(node --version)"
    @echo "  pnpm: $(pnpm --version)"
    @echo "  NX: {% if NX_AVAILABLE %}$(nx --version){% else %}not installed{% endif %}"

# Dependency synchronization
{% include '_shared/partials/justfile-partials/typescript-deps-sync.jinja' %}

# Help target
help:
    @echo "📦 TypeScript CLI Application"
    @echo ""
    @echo "Standard commands:"
    @echo "  just bootstrap    - Initialize the development environment"
    @echo "  just build        - Build the project"
    @echo "  just test         - Run tests"
    @echo "  just lint         - Run linting"
    @echo "  just typecheck    - Run type checking"
    @echo "  just dev          - Run in development mode"
    @echo "  just doctor       - Check environment health"
    @echo ""
    @echo "NX commands (if available):"
    @echo "  just nx-build     - Build with NX"
    @echo "  just nx-test      - Test with NX"
    @echo "  just nx-lint      - Lint with NX"
    @echo "  just nx-typecheck - Typecheck with NX"
    @echo ""
    @echo "TypeScript-specific commands:"
    @echo "  just sync-deps    - Sync lock file with package.json"
    @echo "  just pre-commit   - Run pre-commit checks"
